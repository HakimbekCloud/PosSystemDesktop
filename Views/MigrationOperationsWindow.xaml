                                      Content="I have captured an off-machine backup of %LocalAppData%\PosSystem."
                                      Grid.Row="2" Grid.Column="1" Margin="0,4,0,0" Foreground="#713F12"/>

                            <TextBlock Text="External backup note (optional)" Grid.Row="3" Grid.Column="0" Foreground="#713F12" Margin="0,4,0,0"/>
                            <TextBox  Text="{Binding RetentionCleanupExternalBackupNote, UpdateSourceTrigger=PropertyChanged}"
                                      IsEnabled="{Binding RetentionCleanupUiEnabled}"
                                      Grid.Row="3" Grid.Column="1" Margin="0,4,0,0" Padding="6,4"/>

                            <TextBlock Text="Categories to delete" Grid.Row="4" Grid.Column="0" Foreground="#713F12" FontWeight="SemiBold" Margin="0,8,0,2"/>
                            <CheckBox IsChecked="{Binding RetentionCleanupDeleteDiagnosticsLogs}"
                                      IsEnabled="{Binding RetentionCleanupUiEnabled}"
                                      Content="Old diagnostics logs (logs\diagnostics\)."
                                      Grid.Row="4" Grid.Column="1" Margin="0,8,0,2" Foreground="#713F12"/>

                            <TextBlock Grid.Row="5" Grid.Column="0"/>
                            <CheckBox IsChecked="{Binding RetentionCleanupDeletePreflightLogs}"
                                      IsEnabled="{Binding RetentionCleanupUiEnabled}"
                                      Content="Old preflight logs (logs\preflight\)."
                                      Grid.Row="5" Grid.Column="1" Margin="0,2,0,0" Foreground="#713F12"/>

                            <TextBlock Grid.Row="6" Grid.Column="0"/>
                            <CheckBox IsChecked="{Binding RetentionCleanupDeleteMigrationLogs}"
                                      IsEnabled="{Binding RetentionCleanupUiEnabled}"
                                      Content="Old migration logs (logs\migrations\)."
                                      Grid.Row="6" Grid.Column="1" Margin="0,2,0,0" Foreground="#713F12"/>

                            <TextBlock Grid.Row="7" Grid.Column="0"/>
                            <CheckBox IsChecked="{Binding RetentionCleanupDeleteRollbackLogs}"
                                      IsEnabled="{Binding RetentionCleanupUiEnabled}"
                                      Content="Old rollback logs (logs\rollbacks\)."
                                      Grid.Row="7" Grid.Column="1" Margin="0,2,0,0" Foreground="#713F12"/>

                            <TextBlock Grid.Row="8" Grid.Column="0"/>
                            <CheckBox IsChecked="{Binding RetentionCleanupDeleteOldBackups}"
                                      IsEnabled="{Binding RetentionCleanupUiEnabled}"
                                      Content="Old backups (backups\). Latest backup is always protected."
                                      Grid.Row="8" Grid.Column="1" Margin="0,2,0,0" Foreground="#713F12"/>

                            <TextBlock Grid.Row="9" Grid.Column="0"/>
                            <CheckBox IsChecked="{Binding RetentionCleanupDeleteArchivedTenantDirectories}"
                                      IsEnabled="{Binding RetentionCleanupUiEnabled}"
                                      Content="Archived tenant directories (tenants.before-rollback-*\)."
                                      Grid.Row="9" Grid.Column="1" Margin="0,2,0,0" Foreground="#713F12"/>

                            <TextBlock Grid.Row="10" Grid.Column="0"/>
                            <CheckBox IsChecked="{Binding RetentionCleanupDeleteBrokenLegacyDbFiles}"
                                      IsEnabled="{Binding RetentionCleanupUiEnabled}"
                                      Content="Broken legacy DB files (pos.db.broken-*)."
                                      Grid.Row="10" Grid.Column="1" Margin="0,2,0,0" Foreground="#713F12"/>
                        </Grid>

                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="260"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="Confirmation phrase" Grid.Row="0" Grid.Column="0" Foreground="#713F12"/>
                            <TextBox  Text="{Binding RetentionCleanupConfirmationPhraseInput, UpdateSourceTrigger=PropertyChanged}"
                                      IsEnabled="{Binding RetentionCleanupUiEnabled}"
                                      Grid.Row="0" Grid.Column="1" Padding="6,4" FontFamily="Consolas" FontSize="12"/>
                        </Grid>

                        <Button Command="{Binding ExecuteRetentionCleanupCommand}"
                                Content="Execute Retention Cleanup"
                                HorizontalAlignment="Left"
                                Padding="14,6" Margin="260,10,0,0"
                                Background="#7C2D12" Foreground="White" BorderThickness="0"
                                Cursor="Hand"
                                FontWeight="SemiBold"/>

                        <!-- Outcome -->
                        <Border Background="White" BorderBrush="#FDE68A" BorderThickness="1"
                                Padding="10" Margin="0,12,0,0" CornerRadius="4">
                            <StackPanel>
                                <TextBlock Text="Execution outcome" FontSize="12" FontWeight="SemiBold" Foreground="#713F12"/>
                                <Grid Margin="0,4,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="240"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="Outcome"               Grid.Row="0" Grid.Column="0" Foreground="#475569"/>
                                    <TextBlock Text="{Binding RetentionCleanupExecutionOutcome}" Grid.Row="0" Grid.Column="1"/>
                                    <TextBlock Text="Cleanup executed"      Grid.Row="1" Grid.Column="0" Foreground="#475569" Margin="0,2,0,0"/>
                                    <TextBlock Text="{Binding RetentionCleanupExecuted}" Grid.Row="1" Grid.Column="1" Margin="0,2,0,0"/>
                                    <TextBlock Text="Candidates before"     Grid.Row="2" Grid.Column="0" Foreground="#475569" Margin="0,2,0,0"/>
                                    <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Margin="0,2,0,0">
                                        <TextBlock Text="{Binding RetentionCleanupCandidateCountBefore}"/>
                                        <TextBlock Text=" items, "/>
                                        <TextBlock Text="{Binding RetentionCleanupCandidateSizeBefore}"/>
                                    </StackPanel>
                                    <TextBlock Text="Deleted"               Grid.Row="3" Grid.Column="0" Foreground="#475569" Margin="0,2,0,0"/>
                                    <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal" Margin="0,2,0,0">
                                        <TextBlock Text="{Binding RetentionCleanupDeletedItemCount}"/>
                                        <TextBlock Text=" items, "/>
                                        <TextBlock Text="{Binding RetentionCleanupDeletedSize}"/>
                                    </StackPanel>
                                    <TextBlock Text="Skipped items"         Grid.Row="4" Grid.Column="0" Foreground="#475569" Margin="0,2,0,0"/>
                                    <TextBlock Text="{Binding RetentionCleanupSkippedItemCount}" Grid.Row="4" Grid.Column="1" Margin="0,2,0,0"/>
                                    <TextBlock Text="Failed items"          Grid.Row="5" Grid.Column="0" Foreground="#475569" Margin="0,2,0,0"/>
                                    <TextBlock Text="{Binding RetentionCleanupFailedItemCount}" Grid.Row="5" Grid.Column="1" Margin="0,2,0,0"/>
                                    <TextBlock Text="Started / Completed (UTC)" Grid.Row="6" Grid.Column="0" Foreground="#475569" Margin="0,2,0,0"/>
                                    <StackPanel Grid.Row="6" Grid.Column="1" Orientation="Horizontal" Margin="0,2,0,0">
                                        <TextBlock Text="{Binding RetentionCleanupExecutionStartedAtUtc}"/>
                                        <TextBlock Text=" → "/>
                                        <TextBlock Text="{Binding RetentionCleanupExecutionCompletedAtUtc}"/>
                                    </StackPanel>
                                </Grid>

                                <TextBlock Text="{Binding RetentionCleanupExecutionStatusMessage}"
                                           Foreground="#0F172A" TextWrapping="Wrap" Margin="0,6,0,0"/>

                                <TextBlock Text="Steps:" Foreground="#475569"
                                           FontSize="11" FontWeight="SemiBold" Margin="0,8,0,2"/>
                                <ItemsControl ItemsSource="{Binding RetentionCleanupExecutionSteps}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}" Foreground="#475569" FontSize="11" TextWrapping="Wrap" Margin="0,2,0,0"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <TextBlock Text="Items:" Foreground="#475569"
                                           FontSize="11" FontWeight="SemiBold" Margin="0,8,0,2"/>
                                <ItemsControl ItemsSource="{Binding RetentionCleanupItemLines}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}" Foreground="#475569" FontSize="11" TextWrapping="Wrap" Margin="0,2,0,0"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <TextBlock Text="Blocking reasons:" Foreground="#991B1B"
                                           FontSize="11" FontWeight="SemiBold" Margin="0,8,0,2"/>
                                <ItemsControl ItemsSource="{Binding RetentionCleanupExecutionBlockingReasons}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}" Foreground="#991B1B" FontSize="11" TextWrapping="Wrap" Margin="0,2,0,0"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <TextBlock Text="Warnings:" Foreground="#92400E"
                                           FontSize="11" FontWeight="SemiBold" Margin="0,8,0,2"/>
                                <ItemsControl ItemsSource="{Binding RetentionCleanupExecutionWarnings}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}" Foreground="#92400E" FontSize="11" TextWrapping="Wrap" Margin="0,2,0,0"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <TextBlock Text="Errors:" Foreground="#991B1B"
                                           FontSize="11" FontWeight="SemiBold" Margin="0,8,0,2"/>
                                <ItemsControl ItemsSource="{Binding RetentionCleanupExecutionErrors}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}" Foreground="#991B1B" FontSize="11" TextWrapping="Wrap" Margin="0,2,0,0"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Preflight Export (Phase 10.10C) -->
                <Border Background="White" BorderBrush="#E2E8F0" BorderThickness="1"
                        Padding="12" Margin="0,0,0,10" CornerRadius="6">
                    <StackPanel>
                        <TextBlock Text="Preflight Export" FontSize="13" FontWeight="SemiBold" Foreground="#0F172A"/>
                        <TextBlock Text="Read-only preflight bundle. Does not perform migration or rollback. Click 'Export Preflight Report' to generate."
                                   FontSize="10" Foreground="#475569" Margin="0,2,0,6"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="240"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="Last preflight export path" Grid.Row="0" Grid.Column="0" Foreground="#475569"/>
                            <TextBlock Text="{Binding LastPreflightExportPath}" Grid.Row="0" Grid.Column="1" TextWrapping="Wrap"/>
                            <TextBlock Text="Preflight status"            Grid.Row="1" Grid.Column="0" Foreground="#475569" Margin="0,4,0,0"/>
                            <TextBlock Text="{Binding PreflightStatusMessage}" Grid.Row="1" Grid.Column="1" TextWrapping="Wrap" Margin="0,4,0,0"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Last Export Path -->
                <Border Background="White" BorderBrush="#E2E8F0" BorderThickness="1"
                        Padding="12" Margin="0,0,0,10" CornerRadius="6">
                    <StackPanel>
                        <TextBlock Text="Last Export Path" FontSize="13" FontWeight="SemiBold" Foreground="#0F172A"/>
                        <TextBlock Text="{Binding LastExportPath}" TextWrapping="Wrap" Margin="0,6,0,0" Foreground="#475569"/>
                    </StackPanel>
                </Border>

                <!-- ─────────────────────────────────────────────────────────
                     Operator Evidence Bundle Export — Local ZIP Only (Phase 10.22E)
                     Local-only ZIP + manifest generator.
                     • Default-OFF flag: operator_evidence_bundle_export_ui_enabled
                     • NO backend HTTP call in this phase.
                     • NO upload / finalize / review / download buttons.
                     • Forbidden: dangerous-execute / confirmation-phrase / raw SQL input.
                     ───────────────────────────────────────────────────────── -->
                <Border Background="White" BorderBrush="#E2E8F0" BorderThickness="1"
                        Padding="12" Margin="0,0,0,10" CornerRadius="6">
                    <StackPanel>
                        <TextBlock Text="Operator Evidence Bundle Export — Local ZIP Only (Phase 10.22E)"
                                   FontSize="13" FontWeight="SemiBold" Foreground="#0F172A"/>
                        <TextBlock Text="Local export only — no backend upload in this phase."
                                   FontSize="11" Foreground="#92400E" Margin="0,4,0,0" TextWrapping="Wrap"/>
                        <TextBlock Text="Generates a sanitized ZIP and manifest.json locally so it can be uploaded later when Phase 10.22F lands. Path safety, MIME/magic, and redaction scans mirror backend Phase 10.22D."
                                   FontSize="11" Foreground="#475569" Margin="0,4,0,0" TextWrapping="Wrap"/>

                        <!-- Flag status -->
                        <Border Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1"
                                Padding="8" Margin="0,8,0,0" CornerRadius="4">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="220"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Local flag" Foreground="#475569"/>
                                <TextBlock Grid.Column="1" Text="{Binding EvidenceExportFlagStatusText}"
                                           TextWrapping="Wrap"/>
                            </Grid>
                        </Border>

                        <!-- Inputs -->
                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="220"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Text="Evidence type"        Grid.Row="0" Grid.Column="0" Foreground="#475569" Margin="0,4,0,0"/>
                            <ComboBox  Grid.Row="0" Grid.Column="1" Margin="0,4,0,0"
                                       ItemsSource="{Binding EvidenceExportTypeChoices}"
                                       IsEditable="True"
                                       Text="{Binding EvidenceExportEvidenceType, UpdateSourceTrigger=PropertyChanged}"
                                       IsEnabled="{Binding EvidenceExportFlagEnabled}"/>

                            <TextBlock Text="Environment"          Grid.Row="1" Grid.Column="0" Foreground="#475569" Margin="0,4,0,0"/>
                            <ComboBox  Grid.Row="1" Grid.Column="1" Margin="0,4,0,0"
                                       ItemsSource="{Binding EvidenceExportEnvironmentChoices}"
                                       IsEditable="True"
                                       Text="{Binding EvidenceExportEnvironment, UpdateSourceTrigger=PropertyChanged}"
                                       IsEnabled="{Binding EvidenceExportFlagEnabled}"/>

                            <TextBlock Text="Phase (e.g. 10.21I)"  Grid.Row="2" Grid.Column="0" Foreground="#475569" Margin="0,4,0,0"/>
                            <TextBox   Grid.Row="2" Grid.Column="1" Margin="0,4,0,0"
                                       Text="{Binding EvidenceExportPhase, UpdateSourceTrigger=PropertyChanged}"
                                       IsEnabled="{Binding EvidenceExportFlagEnabled}"/>

                            <TextBlock Text="Tenant ID (optional)" Grid.Row="3" Grid.Column="0" Foreground="#475569" Margin="0,4,0,0"/>
                            <TextBox   Grid.Row="3" Grid.Column="1" Margin="0,4,0,0"
                                       Text="{Binding EvidenceExportTenantId, UpdateSourceTrigger=PropertyChanged}"
                                       IsEnabled="{Binding EvidenceExportFlagEnabled}"/>

                            <TextBlock Text="Store ID (optional)"  Grid.Row="4" Grid.Column="0" Foreground="#475569" Margin="0,4,0,0"/>
                            <TextBox   Grid.Row="4" Grid.Column="1" Margin="0,4,0,0"
                                       Text="{Binding EvidenceExportStoreId, UpdateSourceTrigger=PropertyChanged}"
                                       IsEnabled="{Binding EvidenceExportFlagEnabled}"/>

                            <TextBlock Text="Wave number (optional)" Grid.Row="5" Grid.Column="0" Foreground="#475569" Margin="0,4,0,0"/>
                            <TextBox   Grid.Row="5" Grid.Column="1" Margin="0,4,0,0"
                                       Text="{Binding EvidenceExportWaveNumber, TargetNullValue=''}"
                                       IsEnabled="{Binding EvidenceExportFlagEnabled}"/>

                            <CheckBox  Grid.Row="6" Grid.Column="1" Margin="0,8,0,0"
                                       Content="Overwrite existing ZIP if present"
                                       IsChecked="{Binding EvidenceExportAllowOverwrite}"
                                       IsEnabled="{Binding EvidenceExportFlagEnabled}"/>
                        </Grid>

                        <!-- Selected folders + outputs (read-only display) -->
                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="220"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Text="Selected evidence folder" Grid.Row="0" Grid.Column="0" Foreground="#475569"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" TextWrapping="Wrap"
                                       Text="{Binding EvidenceExportSourceFolderDisplay}"/>

                            <TextBlock Text="Output folder"            Grid.Row="1" Grid.Column="0" Foreground="#475569" Margin="0,4,0,0"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" TextWrapping="Wrap" Margin="0,4,0,0"
                                       Text="{Binding EvidenceExportOutputFolderDisplay}"/>

                            <TextBlock Text="Output ZIP (relative)"    Grid.Row="2" Grid.Column="0" Foreground="#475569" Margin="0,4,0,0"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" TextWrapping="Wrap" Margin="0,4,0,0"
                                       Text="{Binding EvidenceExportOutputZipDisplay}"/>

                            <TextBlock Text="Manifest"                 Grid.Row="3" Grid.Column="0" Foreground="#475569" Margin="0,4,0,0"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" TextWrapping="Wrap" Margin="0,4,0,0"
                                       Text="{Binding EvidenceExportManifestDisplay}"/>
                        </Grid>

                        <!-- Buttons -->
                        <WrapPanel Margin="0,10,0,0">
                            <Button Content="Select Evidence Folder"
                                    Command="{Binding SelectEvidenceBundleFolderCommand}"
                                    Margin="0,0,8,0" Padding="10,4"/>
                            <Button Content="Validate Folder"
                                    Command="{Binding ValidateEvidenceBundleFolderCommand}"
                                    Margin="0,0,8,0" Padding="10,4"/>
                            <Button Content="Generate Manifest + ZIP"
                                    Command="{Binding GenerateEvidenceBundleZipCommand}"
                                    Margin="0,0,8,0" Padding="10,4"/>
                            <Button Content="Open Output Folder"
                                    Command="{Binding OpenEvidenceBundleOutputFolderCommand}"
                                    Margin="0,0,8,0" Padding="10,4"/>
                            <Button Content="Clear"
                                    Command="{Binding ClearEvidenceBundleExportCommand}"
                                    Margin="0,0,0,0" Padding="10,4"/>
                        </WrapPanel>

                        <!-- Status summary -->
                        <Border Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1"
                                Padding="8" Margin="0,10,0,0" CornerRadius="4">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="220"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Text="Outcome"          Grid.Row="0" Grid.Column="0" Foreground="#475569"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding EvidenceExportOutcome}"/>

                                <TextBlock Text="Status"           Grid.Row="1" Grid.Column="0" Foreground="#475569" Margin="0,2,0,0"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding EvidenceExportStatusMessage}" Margin="0,2,0,0" TextWrapping="Wrap"/>

                                <TextBlock Text="Accepted file count" Grid.Row="2" Grid.Column="0" Foreground="#475569" Margin="0,2,0,0"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding EvidenceExportFileCount}" Margin="0,2,0,0"/>

                                <TextBlock Text="Total bytes"      Grid.Row="3" Grid.Column="0" Foreground="#475569" Margin="0,2,0,0"/>
                                <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding EvidenceExportTotalBytes}" Margin="0,2,0,0"/>

                                <TextBlock Text="Bundle SHA-256"   Grid.Row="4" Grid.Column="0" Foreground="#475569" Margin="0,2,0,0"/>
                                <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding EvidenceExportBundleSha256}" Margin="0,2,0,0" TextWrapping="Wrap"/>

                                <TextBlock Text="Last run (UTC)"   Grid.Row="5" Grid.Column="0" Foreground="#475569" Margin="0,2,0,0"/>
                                <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding EvidenceExportLastRunAtUtc, StringFormat='{}{0:yyyy-MM-dd HH:mm:ss} UTC'}"
                                           Margin="0,2,0,0"/>
                            </Grid>
                        </Border>

                        <!-- Files / issues / findings / artifacts (lists) -->
                        <TextBlock Text="Accepted files:" Foreground="#475569" Margin="0,8,0,0"/>
                        <ItemsControl ItemsSource="{Binding EvidenceExportFiles}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" Foreground="#0F172A" FontSize="11" TextWrapping="Wrap" Margin="0,2,0,0"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Text="Validation issues:" Foreground="#92400E" Margin="0,8,0,0"/>
                        <ItemsControl ItemsSource="{Binding EvidenceExportValidationIssues}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" Foreground="#92400E" FontSize="11" TextWrapping="Wrap" Margin="0,2,0,0"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Text="Redaction findings (preview is always [REDACTED] — raw matches never stored):"
                                   Foreground="#991B1B" Margin="0,8,0,0" TextWrapping="Wrap"/>
                        <ItemsControl ItemsSource="{Binding EvidenceExportRedactionFindings}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" Foreground="#991B1B" FontSize="11" TextWrapping="Wrap" Margin="0,2,0,0"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Text="Generated artifacts (inside output ZIP):" Foreground="#475569" Margin="0,8,0,0"/>
                        <ItemsControl ItemsSource="{Binding EvidenceExportGeneratedArtifacts}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" Foreground="#0F172A" FontSize="11" TextWrapping="Wrap" Margin="0,2,0,0"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- ─────────────────────────────────────────────────────────
                     Operator Evidence Bundle Upload — Backend Upload + Finalize (Phase 10.22F)
                     • Default-OFF flag: operator_evidence_bundle_upload_ui_enabled
                     • Uploads manifest.json + each manifest.files[] entry.
                     • NEVER uploads the local .zip.
                     • Forbidden: review / download / delete / retention /
                       execute / approve / confirmation-phrase / raw SQL.
                     ───────────────────────────────────────────────────────── -->
                <Border Background="White" BorderBrush="#E2E8F0" BorderThickness="1"
                        Padding="12" Margin="0,0,0,10" CornerRadius="6">
                    <StackPanel>
                        <TextBlock Text="Operator Evidence Bundle Upload — Backend Upload + Finalize (Phase 10.22F)"
                                   FontSize="13" FontWeight="SemiBold" Foreground="#0F172A"/>
                        <TextBlock Text="Uploads validated local evidence files to backend. Does not upload ZIP. Does not review/download/delete. Does not execute dangerous operations."
                                   FontSize="11" Foreground="#92400E" Margin="0,4,0,0" TextWrapping="Wrap"/>
                        <TextBlock Text="Reads manifest.json from the selected Phase 10.22E folder, validates locally, then POSTs manifest.json + every manifest.files[] entry to the backend Phase 10.22C/D API and finalizes the bundle."
                                   FontSize="11" Foreground="#475569" Margin="0,4,0,0" TextWrapping="Wrap"/>

                        <!-- Flag status -->
                        <Border Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1"
                                Padding="8" Margin="0,8,0,0" CornerRadius="4">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="220"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Local upload flag" Foreground="#475569"/>
                                <TextBlock Grid.Column="1" Text="{Binding EvidenceUploadFlagStatusText}" TextWrapping="Wrap"/>
                            </Grid>
                        </Border>

                        <!-- Folder + manifest + local ZIP (display only) -->
                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="220"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Text="Selected folder" Grid.Row="0" Grid.Column="0" Foreground="#475569"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" TextWrapping="Wrap"
                                       Text="{Binding EvidenceUploadSourceFolderDisplay}"/>

                            <TextBlock Text="Manifest path" Grid.Row="1" Grid.Column="0" Foreground="#475569" Margin="0,4,0,0"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" TextWrapping="Wrap" Margin="0,4,0,0"
                                       Text="{Binding EvidenceUploadManifestPathDisplay}"/>

                            <TextBlock Text="Local ZIP (display only)" Grid.Row="2" Grid.Column="0" Foreground="#475569" Margin="0,4,0,0"/>
                            <StackPanel Grid.Row="2" Grid.Column="1" Margin="0,4,0,0">
                                <TextBlock Text="{Binding EvidenceUploadLocalZipPathDisplay}" TextWrapping="Wrap"/>
                                <TextBlock Text="Local archive only — not uploaded."
                                           Foreground="#92400E" FontSize="11" TextWrapping="Wrap"/>
                            </StackPanel>

                            <TextBlock Text="Finalize notes (optional)" Grid.Row="3" Grid.Column="0" Foreground="#475569" Margin="0,4,0,0"/>
                            <TextBox   Grid.Row="3" Grid.Column="1" Margin="0,4,0,0"
                                       Text="{Binding EvidenceUploadFinalizeNotes, UpdateSourceTrigger=PropertyChanged}"
                                       IsEnabled="{Binding EvidenceUploadFlagEnabled}"/>
                        </Grid>

                        <!-- Buttons -->
                        <WrapPanel Margin="0,10,0,0">
                            <Button Content="Refresh Flag"
                                    Command="{Binding RefreshEvidenceBundleUploadFlagFromUiCommand}"
                                    Margin="0,0,8,0" Padding="10,4"/>
                            <Button Content="Select Folder"
                                    Command="{Binding SelectEvidenceBundleUploadFolderCommand}"
                                    Margin="0,0,8,0" Padding="10,4"/>
                            <Button Content="Validate Folder"
                                    Command="{Binding ValidateEvidenceBundleUploadFolderCommand}"
                                    Margin="0,0,8,0" Padding="10,4"/>
                            <Button Content="Upload + Finalize"
                                    Command="{Binding UploadEvidenceBundleToBackendCommand}"
                                    Margin="0,0,8,0" Padding="10,4"/>
                            <Button Content="Refresh Backend Status"
                                    Command="{Binding RefreshEvidenceBundleBackendStatusCommand}"
                                    Margin="0,0,8,0" Padding="10,4"/>
                            <Button Content="Clear"
                                    Command="{Binding ClearEvidenceBundleUploadCommand}"
                                    Margin="0,0,0,0" Padding="10,4"/>
                        </WrapPanel>

                        <!-- Status summary -->
                        <Border Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1"
                                Padding="8" Margin="0,10,0,0" CornerRadius="4">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="220"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Text="Outcome"             Grid.Row="0" Grid.Column="0" Foreground="#475569"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding EvidenceUploadOutcome}"/>

                                <TextBlock Text="Status"              Grid.Row="1" Grid.Column="0" Foreground="#475569" Margin="0,2,0,0"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding EvidenceUploadStatusMessage}" Margin="0,2,0,0" TextWrapping="Wrap"/>

                                <TextBlock Text="Backend bundle UUID" Grid.Row="2" Grid.Column="0" Foreground="#475569" Margin="0,2,0,0"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding EvidenceUploadBundleUuid}" Margin="0,2,0,0" TextWrapping="Wrap"/>

                                <TextBlock Text="Backend status"      Grid.Row="3" Grid.Column="0" Foreground="#475569" Margin="0,2,0,0"/>
                                <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding EvidenceUploadBackendStatus}" Margin="0,2,0,0"/>

                                <TextBlock Text="Backend bundle SHA-256" Grid.Row="4" Grid.Column="0" Foreground="#475569" Margin="0,2,0,0"/>
                                <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding EvidenceUploadBackendSha256}" Margin="0,2,0,0" TextWrapping="Wrap"/>

                                <TextBlock Text="Files uploaded / total" Grid.Row="5" Grid.Column="0" Foreground="#475569" Margin="0,2,0,0"/>
                                <StackPanel Grid.Row="5" Grid.Column="1" Orientation="Horizontal" Margin="0,2,0,0">
                                    <TextBlock Text="{Binding EvidenceUploadFilesUploaded}"/>
                                    <TextBlock Text=" / "/>
                                    <TextBlock Text="{Binding EvidenceUploadTotalFiles}"/>
                                </StackPanel>

                                <TextBlock Text="Bytes uploaded / total" Grid.Row="6" Grid.Column="0" Foreground="#475569" Margin="0,2,0,0"/>
                                <StackPanel Grid.Row="6" Grid.Column="1" Orientation="Horizontal" Margin="0,2,0,0">
                                    <TextBlock Text="{Binding EvidenceUploadBytesUploaded}"/>
                                    <TextBlock Text=" / "/>
                                    <TextBlock Text="{Binding EvidenceUploadTotalBytes}"/>
                                </StackPanel>

                                <TextBlock Text="Current file"        Grid.Row="7" Grid.Column="0" Foreground="#475569" Margin="0,2,0,0"/>
                                <TextBlock Grid.Row="7" Grid.Column="1" Text="{Binding EvidenceUploadCurrentFile}" Margin="0,2,0,0" TextWrapping="Wrap"/>

                                <TextBlock Text="Last backend error"  Grid.Row="8" Grid.Column="0" Foreground="#991B1B" Margin="0,2,0,0"/>
                                <StackPanel Grid.Row="8" Grid.Column="1" Margin="0,2,0,0">
                                    <TextBlock Text="{Binding EvidenceUploadLastBackendErrorCode}" Foreground="#991B1B"/>
                                    <TextBlock Text="{Binding EvidenceUploadLastBackendErrorMessage}" Foreground="#991B1B" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Lists -->
                        <TextBlock Text="Upload steps:" Foreground="#475569" Margin="0,8,0,0"/>
                        <ItemsControl ItemsSource="{Binding EvidenceUploadSteps}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" Foreground="#0F172A" FontSize="11" TextWrapping="Wrap" Margin="0,2,0,0"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Text="Uploaded files:" Foreground="#475569" Margin="0,8,0,0"/>
                        <ItemsControl ItemsSource="{Binding EvidenceUploadedFiles}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" Foreground="#0F172A" FontSize="11" TextWrapping="Wrap" Margin="0,2,0,0"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Text="Warnings:" Foreground="#92400E" Margin="0,8,0,0"/>
                        <ItemsControl ItemsSource="{Binding EvidenceUploadWarnings}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" Foreground="#92400E" FontSize="11" TextWrapping="Wrap" Margin="0,2,0,0"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Text="Errors:" Foreground="#991B1B" Margin="0,8,0,0"/>
                        <ItemsControl ItemsSource="{Binding EvidenceUploadErrors}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" Foreground="#991B1B" FontSize="11" TextWrapping="Wrap" Margin="0,2,0,0"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- ─────────────────────────────────────────────────────────
                     Operator Evidence Bundle Reviewer + Download (Phase 10.22G)
                     • Default-OFF flag: operator_evidence_bundle_review_ui_enabled
                     • Read-only review/download — NO upload / finalize /
                       delete / retention / hard-delete / dangerous-execute /
                       confirmation-phrase / raw-SQL controls.
                     ───────────────────────────────────────────────────────── -->
                <Border Background="White" BorderBrush="#E2E8F0" BorderThickness="1"
                        Padding="12" Margin="0,0,0,10" CornerRadius="6">
                    <StackPanel>
                        <TextBlock Text="Operator Evidence Bundle Reviewer + Download (Phase 10.22G)"
                                   FontSize="13" FontWeight="SemiBold" Foreground="#0F172A"/>
                        <TextBlock Text="Read-only review + download of FINALIZED / REVIEWED / REJECTED / NEEDS_CHANGES bundles. No upload, no delete, no retention, no dangerous execution."
                                   FontSize="11" Foreground="#92400E" Margin="0,4,0,0" TextWrapping="Wrap"/>
                        <TextBlock Text="Self-review is rejected by the backend. ADMIN reviews own-tenant bundles only; GLOBAL_ADMIN reviews cross-tenant."
                                   FontSize="11" Foreground="#475569" Margin="0,4,0,0" TextWrapping="Wrap"/>

                        <!-- Flag status -->
                        <Border Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1"
                                Padding="8" Margin="0,8,0,0" CornerRadius="4">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="220"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Local review flag" Foreground="#475569"/>
                                <TextBlock Grid.Column="1" Text="{Binding EvidenceReviewFlagStatusText}" TextWrapping="Wrap"/>
                            </Grid>
                        </Border>

                        <!-- Filters -->
                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="220"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Text="evidenceType filter"  Grid.Row="0" Grid.Column="0" Foreground="#475569" Margin="0,4,0,0"/>
                            <TextBox  Grid.Row="0" Grid.Column="1" Margin="0,4,0,0"
                                      Text="{Binding EvidenceReviewFilterEvidenceType, UpdateSourceTrigger=PropertyChanged}"
                                      IsEnabled="{Binding EvidenceReviewFlagEnabled}"/>

                            <TextBlock Text="phase filter"         Grid.Row="1" Grid.Column="0" Foreground="#475569" Margin="0,4,0,0"/>
                            <TextBox  Grid.Row="1" Grid.Column="1" Margin="0,4,0,0"
                                      Text="{Binding EvidenceReviewFilterPhase, UpdateSourceTrigger=PropertyChanged}"
                                      IsEnabled="{Binding EvidenceReviewFlagEnabled}"/>

                            <TextBlock Text="tenantId filter"      Grid.Row="2" Grid.Column="0" Foreground="#475569" Margin="0,4,0,0"/>
                            <TextBox  Grid.Row="2" Grid.Column="1" Margin="0,4,0,0"
                                      Text="{Binding EvidenceReviewFilterTenantId, UpdateSourceTrigger=PropertyChanged}"
                                      IsEnabled="{Binding EvidenceReviewFlagEnabled}"/>

                            <TextBlock Text="status filter"        Grid.Row="3" Grid.Column="0" Foreground="#475569" Margin="0,4,0,0"/>
                            <ComboBox Grid.Row="3" Grid.Column="1" Margin="0,4,0,0"
                                      ItemsSource="{Binding EvidenceReviewStatusChoices}"
                                      IsEditable="True"
                                      Text="{Binding EvidenceReviewFilterStatus, UpdateSourceTrigger=PropertyChanged}"
                                      IsEnabled="{Binding EvidenceReviewFlagEnabled}"/>

                            <TextBlock Text="page"                 Grid.Row="4" Grid.Column="0" Foreground="#475569" Margin="0,4,0,0"/>
                            <TextBox  Grid.Row="4" Grid.Column="1" Margin="0,4,0,0"
                                      Text="{Binding EvidenceReviewFilterPage}"
                                      IsEnabled="{Binding EvidenceReviewFlagEnabled}"/>

                            <TextBlock Text="size"                 Grid.Row="5" Grid.Column="0" Foreground="#475569" Margin="0,4,0,0"/>
                            <TextBox  Grid.Row="5" Grid.Column="1" Margin="0,4,0,0"
                                      Text="{Binding EvidenceReviewFilterSize}"
                                      IsEnabled="{Binding EvidenceReviewFlagEnabled}"/>
                        </Grid>

                        <WrapPanel Margin="0,8,0,0">
                            <Button Content="Refresh Flag"
                                    Command="{Binding RefreshEvidenceBundleReviewFlagFromUiCommand}"
                                    Margin="0,0,8,0" Padding="10,4"/>
                            <Button Content="List Bundles"
                                    Command="{Binding ListEvidenceReviewBundlesCommand}"
                                    Margin="0,0,8,0" Padding="10,4"/>
                            <Button Content="Clear"
                                    Command="{Binding ClearEvidenceReviewCommand}"
                                    Padding="10,4"/>
                        </WrapPanel>

                        <!-- Bundles list -->
                        <TextBlock Text="Bundles (set status filter to '' for all states):" Foreground="#475569" Margin="0,8,0,0"/>
                        <DataGrid ItemsSource="{Binding EvidenceReviewBundles}"
                                  AutoGenerateColumns="False" IsReadOnly="True"
                                  MaxHeight="200" Margin="0,4,0,0"
                                  CanUserAddRows="False" CanUserDeleteRows="False"
                                  GridLinesVisibility="Horizontal">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="UUID"          Binding="{Binding Uuid}"          Width="280"/>
                                <DataGridTextColumn Header="Type"          Binding="{Binding EvidenceType}"  Width="160"/>
                                <DataGridTextColumn Header="Phase"         Binding="{Binding Phase}"         Width="120"/>
                                <DataGridTextColumn Header="Status"        Binding="{Binding Status}"        Width="120"/>
                                <DataGridTextColumn Header="TenantId"      Binding="{Binding TenantId}"      Width="120"/>
                                <DataGridTextColumn Header="Files"         Binding="{Binding FileCount}"     Width="60"/>
                                <DataGridTextColumn Header="Bytes"         Binding="{Binding TotalBytes}"    Width="100"/>
                                <DataGridTextColumn Header="CreatedAt"     Binding="{Binding CreatedAt}"     Width="180"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <!-- Selected bundle UUID + load -->
                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="220"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Selected bundle UUID" Foreground="#475569"/>
                            <TextBox Grid.Column="1"
                                     Text="{Binding EvidenceReviewSelectedBundleUuid, UpdateSourceTrigger=PropertyChanged}"
                                     IsEnabled="{Binding EvidenceReviewFlagEnabled}"/>
                        </Grid>
                        <WrapPanel Margin="0,4,0,0">
                            <Button Content="Load Bundle Metadata"
                                    Command="{Binding LoadEvidenceReviewSelectedBundleCommand}"
                                    Margin="0,0,8,0" Padding="10,4"/>
                            <Button Content="Refresh Backend Status"
                                    Command="{Binding RefreshEvidenceReviewSelectedBundleCommand}"
                                    Padding="10,4"/>
                        </WrapPanel>

                        <!-- Selected bundle metadata display -->
                        <Border Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1"
                                Padding="8" Margin="0,8,0,0" CornerRadius="4">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="220"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Text="EvidenceType" Grid.Row="0" Grid.Column="0" Foreground="#475569"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding EvidenceReviewSelectedEvidenceType}"/>

                                <TextBlock Text="Phase" Grid.Row="1" Grid.Column="0" Foreground="#475569" Margin="0,2,0,0"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding EvidenceReviewSelectedPhase}" Margin="0,2,0,0"/>

                                <TextBlock Text="Environment" Grid.Row="2" Grid.Column="0" Foreground="#475569" Margin="0,2,0,0"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding EvidenceReviewSelectedEnvironment}" Margin="0,2,0,0"/>

                                <TextBlock Text="TenantId / StoreId" Grid.Row="3" Grid.Column="0" Foreground="#475569" Margin="0,2,0,0"/>
                                <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal" Margin="0,2,0,0">
                                    <TextBlock Text="{Binding EvidenceReviewSelectedTenantId}"/>
                                    <TextBlock Text=" / "/>
                                    <TextBlock Text="{Binding EvidenceReviewSelectedStoreId}"/>
                                </StackPanel>

                                <TextBlock Text="Status" Grid.Row="4" Grid.Column="0" Foreground="#475569" Margin="0,2,0,0"/>
                                <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding EvidenceReviewSelectedStatus}" Margin="0,2,0,0"/>

                                <TextBlock Text="File count / total bytes" Grid.Row="5" Grid.Column="0" Foreground="#475569" Margin="0,2,0,0"/>
                                <StackPanel Grid.Row="5" Grid.Column="1" Orientation="Horizontal" Margin="0,2,0,0">
                                    <TextBlock Text="{Binding EvidenceReviewSelectedFileCount}"/>
                                    <TextBlock Text=" / "/>
                                    <TextBlock Text="{Binding EvidenceReviewSelectedTotalBytes}"/>
                                </StackPanel>

                                <TextBlock Text="bundleSha256" Grid.Row="6" Grid.Column="0" Foreground="#475569" Margin="0,2,0,0"/>
                                <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding EvidenceReviewSelectedBundleSha256}" Margin="0,2,0,0" TextWrapping="Wrap"/>

                                <TextBlock Text="createdBy" Grid.Row="7" Grid.Column="0" Foreground="#475569" Margin="0,2,0,0"/>
                                <TextBlock Grid.Row="7" Grid.Column="1" Text="{Binding EvidenceReviewSelectedCreatedBy}" Margin="0,2,0,0"/>

                                <TextBlock Text="finalizedAt" Grid.Row="8" Grid.Column="0" Foreground="#475569" Margin="0,2,0,0"/>
                                <TextBlock Grid.Row="8" Grid.Column="1" Text="{Binding EvidenceReviewSelectedFinalizedAt}" Margin="0,2,0,0"/>

                                <TextBlock Text="reviewedAt" Grid.Row="9" Grid.Column="0" Foreground="#475569" Margin="0,2,0,0"/>
                                <TextBlock Grid.Row="9" Grid.Column="1" Text="{Binding EvidenceReviewSelectedReviewedAt}" Margin="0,2,0,0"/>
                            </Grid>
                        </Border>

                        <TextBlock Text="Files (relative paths + short sha):" Foreground="#475569" Margin="0,8,0,0"/>
                        <ItemsControl ItemsSource="{Binding EvidenceReviewSelectedFiles}" MaxHeight="180">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" Foreground="#0F172A" FontSize="11" TextWrapping="Wrap" Margin="0,2,0,0"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Review decision -->
                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="220"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="Review decision" Grid.Row="0" Grid.Column="0" Foreground="#475569"/>
                            <ComboBox Grid.Row="0" Grid.Column="1"
                                      ItemsSource="{Binding EvidenceReviewDecisionChoices}"
                                      SelectedItem="{Binding EvidenceReviewDecision, UpdateSourceTrigger=PropertyChanged}"
                                      IsEnabled="{Binding EvidenceReviewFlagEnabled}"/>
                            <TextBlock Text="Review notes (scrubbed)" Grid.Row="1" Grid.Column="0" Foreground="#475569" Margin="0,4,0,0"/>
                            <TextBox Grid.Row="1" Grid.Column="1" Margin="0,4,0,0"
                                     Text="{Binding EvidenceReviewNotes, UpdateSourceTrigger=PropertyChanged}"
                                     IsEnabled="{Binding EvidenceReviewFlagEnabled}"
                                     TextWrapping="Wrap" AcceptsReturn="True" MinHeight="48"/>
                        </Grid>
                        <WrapPanel Margin="0,4,0,0">
                            <Button Content="Submit Review"
                                    Command="{Binding SubmitEvidenceReviewCommand}"
                                    Padding="10,4"/>
                        </WrapPanel>

                        <!-- Download -->
                        <Grid Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="220"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="Download folder" Grid.Row="0" Grid.Column="0" Foreground="#475569"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding EvidenceReviewDownloadFolderDisplay}" TextWrapping="Wrap"/>

                            <CheckBox Grid.Row="1" Grid.Column="1" Margin="0,4,0,0"
                                      Content="Overwrite existing file if present"
                                      IsChecked="{Binding EvidenceReviewAllowOverwrite}"
                                      IsEnabled="{Binding EvidenceReviewFlagEnabled}"/>

                            <TextBlock Text="Downloaded filename" Grid.Row="2" Grid.Column="0" Foreground="#475569" Margin="0,4,0,0"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding EvidenceReviewDownloadedFilename}" Margin="0,4,0,0" TextWrapping="Wrap"/>

                            <TextBlock Text="Downloaded path"     Grid.Row="3" Grid.Column="0" Foreground="#475569" Margin="0,4,0,0"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding EvidenceReviewDownloadedPathDisplay}" Margin="0,4,0,0" TextWrapping="Wrap"/>

                            <TextBlock Text="Downloaded SHA-256"  Grid.Row="4" Grid.Column="0" Foreground="#475569" Margin="0,4,0,0"/>
                            <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding EvidenceReviewDownloadedSha256}" Margin="0,4,0,0" TextWrapping="Wrap"/>
                        </Grid>
                        <WrapPanel Margin="0,4,0,0">
                            <Button Content="Choose Download Folder"
                                    Command="{Binding SelectEvidenceReviewDownloadFolderCommand}"
                                    Margin="0,0,8,0" Padding="10,4"/>
                            <Button Content="Download Bundle (ZIP)"
                                    Command="{Binding DownloadEvidenceReviewBundleCommand}"
                                    Padding="10,4"/>
                        </WrapPanel>

                        <!-- Status summary -->
                        <Border Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1"
                                Padding="8" Margin="0,10,0,0" CornerRadius="4">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="220"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Text="Outcome" Grid.Row="0" Grid.Column="0" Foreground="#475569"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding EvidenceReviewOutcome}"/>
                                <TextBlock Text="Status"  Grid.Row="1" Grid.Column="0" Foreground="#475569" Margin="0,2,0,0"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding EvidenceReviewStatusMessage}" Margin="0,2,0,0" TextWrapping="Wrap"/>
                                <TextBlock Text="Last backend error" Grid.Row="2" Grid.Column="0" Foreground="#991B1B" Margin="0,2,0,0"/>
                                <StackPanel Grid.Row="2" Grid.Column="1" Margin="0,2,0,0">
                                    <TextBlock Text="{Binding EvidenceReviewLastErrorCode}"    Foreground="#991B1B"/>
                                    <TextBlock Text="{Binding EvidenceReviewLastErrorMessage}" Foreground="#991B1B" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <TextBlock Text="Warnings:" Foreground="#92400E" Margin="0,8,0,0"/>
                        <ItemsControl ItemsSource="{Binding EvidenceReviewWarnings}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" Foreground="#92400E" FontSize="11" TextWrapping="Wrap" Margin="0,2,0,0"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock Text="Errors:" Foreground="#991B1B" Margin="0,8,0,0"/>
                        <ItemsControl ItemsSource="{Binding EvidenceReviewErrors}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" Foreground="#991B1B" FontSize="11" TextWrapping="Wrap" Margin="0,2,0,0"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!--
                     ─────────────────────────────────────────────────────────
                     Operator Evidence Bundle Retention + Legal Hold (Phase 10.22H)
                     ─────────────────────────────────────────────────────────
                     Calls /retention, /legal-hold, /archive, /expire,
                     /retention-candidates. Gated by local default-OFF flag
                     `operator_evidence_bundle_retention_ui_enabled`. NO
                     upload / finalize / delete / hard-delete / dangerous-
                     execute / confirmation-phrase / raw-SQL / storage-path
                     control on this card. -->
                <Border Background="#FFFBEB" BorderBrush="#F59E0B" BorderThickness="1"
                        Padding="10" Margin="0,12,0,0" CornerRadius="6">
                    <StackPanel>
                        <TextBlock Text="Operator Evidence Bundle Retention + Legal Hold (Phase 10.22H)"
                                   FontSize="14" FontWeight="SemiBold" Foreground="#92400E"/>
                        <TextBlock Foreground="#92400E" FontSize="11" Margin="0,2,0,0" TextWrapping="Wrap"
                                   Text="Read-only listing of retention candidates and metadata + retention-admin mutations (retentionUntil / legal hold / archive / expire). No hard delete. No physical blob deletion. Archived/expired bundles keep their storage objects."/>
                        <TextBlock Margin="0,4,0,0" Foreground="#475569" FontSize="11"
                                   Text="{Binding EvidenceRetentionFlagStatusText}"/>

                        <!-- Filters -->
                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="220"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="EvidenceType filter" Grid.Row="0" Grid.Column="0" Foreground="#475569"/>
                            <TextBox  Grid.Row="0" Grid.Column="1"
                                      Text="{Binding EvidenceRetentionFilterEvidenceType, UpdateSourceTrigger=PropertyChanged}"
                                      IsEnabled="{Binding EvidenceRetentionFlagEnabled}"/>
                            <TextBlock Text="Status filter" Grid.Row="1" Grid.Column="0" Foreground="#475569" Margin="0,4,0,0"/>
                            <ComboBox Grid.Row="1" Grid.Column="1" Margin="0,4,0,0"
                                      ItemsSource="{Binding EvidenceRetentionStatusChoices}"
                                      SelectedItem="{Binding EvidenceRetentionFilterStatus, UpdateSourceTrigger=PropertyChanged}"
                                      IsEnabled="{Binding EvidenceRetentionFlagEnabled}"/>
                            <TextBlock Text="TenantId filter" Grid.Row="2" Grid.Column="0" Foreground="#475569" Margin="0,4,0,0"/>
                            <TextBox  Grid.Row="2" Grid.Column="1" Margin="0,4,0,0"
                                      Text="{Binding EvidenceRetentionFilterTenantId, UpdateSourceTrigger=PropertyChanged}"
                                      IsEnabled="{Binding EvidenceRetentionFlagEnabled}"/>
                            <TextBlock Text="before (ISO UTC)" Grid.Row="3" Grid.Column="0" Foreground="#475569" Margin="0,4,0,0"/>
                            <TextBox  Grid.Row="3" Grid.Column="1" Margin="0,4,0,0"
                                      Text="{Binding EvidenceRetentionFilterBeforeUtc, UpdateSourceTrigger=PropertyChanged}"
                                      IsEnabled="{Binding EvidenceRetentionFlagEnabled}"
                                      ToolTip="Optional. Defaults to now (server-side)."/>
                            <TextBlock Text="page" Grid.Row="4" Grid.Column="0" Foreground="#475569" Margin="0,4,0,0"/>
                            <TextBox  Grid.Row="4" Grid.Column="1" Margin="0,4,0,0"
                                      Text="{Binding EvidenceRetentionFilterPage, UpdateSourceTrigger=PropertyChanged}"
                                      IsEnabled="{Binding EvidenceRetentionFlagEnabled}"/>
                            <TextBlock Text="size" Grid.Row="5" Grid.Column="0" Foreground="#475569" Margin="0,4,0,0"/>
                            <TextBox  Grid.Row="5" Grid.Column="1" Margin="0,4,0,0"
                                      Text="{Binding EvidenceRetentionFilterSize, UpdateSourceTrigger=PropertyChanged}"
                                      IsEnabled="{Binding EvidenceRetentionFlagEnabled}"/>
                        </Grid>

                        <WrapPanel Margin="0,8,0,0">
                            <Button Content="Refresh Flag"
                                    Command="{Binding RefreshEvidenceBundleRetentionFlagFromUiCommand}"
                                    Margin="0,0,8,0" Padding="10,4"/>
                            <Button Content="List Retention Candidates"
                                    Command="{Binding ListEvidenceRetentionCandidatesCommand}"
                                    Margin="0,0,8,0" Padding="10,4"/>
                            <Button Content="Clear"
                                    Command="{Binding ClearEvidenceRetentionCommand}"
                                    Padding="10,4"/>
                        </WrapPanel>

                        <!-- Candidates DataGrid -->
                        <TextBlock Text="Retention candidates (legal-hold rows excluded by backend):"
                                   Foreground="#475569" Margin="0,8,0,0"/>
                        <DataGrid ItemsSource="{Binding EvidenceRetentionCandidates}"
                                  AutoGenerateColumns="False" IsReadOnly="True"
                                  MaxHeight="200" Margin="0,4,0,0"
                                  CanUserAddRows="False" CanUserDeleteRows="False"
                                  GridLinesVisibility="Horizontal">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="UUID"           Binding="{Binding Uuid}"           Width="260"/>
                                <DataGridTextColumn Header="Type"           Binding="{Binding EvidenceType}"   Width="140"/>
                                <DataGridTextColumn Header="Status"         Binding="{Binding Status}"         Width="120"/>
                                <DataGridTextColumn Header="TenantId"       Binding="{Binding TenantId}"       Width="100"/>
                                <DataGridTextColumn Header="RetentionUntil" Binding="{Binding RetentionUntil}" Width="180"/>
                                <DataGridCheckBoxColumn Header="LegalHold"  Binding="{Binding LegalHold}"      Width="80"/>
                                <DataGridTextColumn Header="Bytes"          Binding="{Binding TotalBytes}"     Width="100"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <!-- Selected bundle UUID + load -->
                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="220"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Selected bundle UUID" Foreground="#475569"/>
                            <TextBox Grid.Column="1"
                                     Text="{Binding EvidenceRetentionSelectedBundleUuid, UpdateSourceTrigger=PropertyChanged}"
                                     IsEnabled="{Binding EvidenceRetentionFlagEnabled}"/>
                        </Grid>
                        <WrapPanel Margin="0,4,0,0">
                            <Button Content="Load Bundle Metadata"
                                    Command="{Binding LoadEvidenceRetentionSelectedBundleCommand}"
                                    Padding="10,4"/>
                        </WrapPanel>

                        <!-- Selected metadata panel -->
                        <Border Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1"
                                Padding="8" Margin="0,8,0,0" CornerRadius="4">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="220"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Text="EvidenceType"   Grid.Row="0" Grid.Column="0" Foreground="#475569"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding EvidenceRetentionSelectedEvidenceType}"/>
                                <TextBlock Text="Phase"          Grid.Row="1" Grid.Column="0" Foreground="#475569" Margin="0,2,0,0"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding EvidenceRetentionSelectedPhase}" Margin="0,2,0,0"/>
                                <TextBlock Text="Status"         Grid.Row="2" Grid.Column="0" Foreground="#475569" Margin="0,2,0,0"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding EvidenceRetentionSelectedStatus}" Margin="0,2,0,0"/>
                                <TextBlock Text="TenantId"       Grid.Row="3" Grid.Column="0" Foreground="#475569" Margin="0,2,0,0"/>
                                <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding EvidenceRetentionSelectedTenantId}" Margin="0,2,0,0"/>
                                <TextBlock Text="RetentionClass" Grid.Row="4" Grid.Column="0" Foreground="#475569" Margin="0,2,0,0"/>
                                <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding EvidenceRetentionSelectedRetentionClass}" Margin="0,2,0,0"/>
                                <TextBlock Text="RetentionUntil" Grid.Row="5" Grid.Column="0" Foreground="#475569" Margin="0,2,0,0"/>
                                <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding EvidenceRetentionSelectedRetentionUntil}" Margin="0,2,0,0"/>
                                <TextBlock Text="LegalHold"      Grid.Row="6" Grid.Column="0" Foreground="#475569" Margin="0,2,0,0"/>
                                <CheckBox  Grid.Row="6" Grid.Column="1" IsChecked="{Binding EvidenceRetentionSelectedLegalHold, Mode=OneWay}" IsEnabled="False" Margin="0,2,0,0"/>
                                <TextBlock Text="ReviewedBy"     Grid.Row="7" Grid.Column="0" Foreground="#475569" Margin="0,2,0,0"/>
                                <TextBlock Grid.Row="7" Grid.Column="1" Text="{Binding EvidenceRetentionSelectedReviewedBy}" Margin="0,2,0,0"/>
                                <TextBlock Text="ReviewedAt"     Grid.Row="8" Grid.Column="0" Foreground="#475569" Margin="0,2,0,0"/>
                                <TextBlock Grid.Row="8" Grid.Column="1" Text="{Binding EvidenceRetentionSelectedReviewedAt}" Margin="0,2,0,0"/>
                            </Grid>
                        </Border>

                        <!-- Update retentionUntil -->
                        <TextBlock Text="Update retentionUntil" FontWeight="SemiBold" Margin="0,12,0,0"/>
                        <Grid Margin="0,4,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="220"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="New retentionUntil (ISO UTC)" Grid.Row="0" Grid.Column="0" Foreground="#475569"/>
                            <TextBox  Grid.Row="0" Grid.Column="1"
                                      Text="{Binding EvidenceRetentionNewRetentionUntilUtc, UpdateSourceTrigger=PropertyChanged}"
                                      IsEnabled="{Binding EvidenceRetentionFlagEnabled}"
                                      ToolTip="e.g. 2029-05-30T00:00:00"/>
                            <TextBlock Text="Reason (scrubbed)" Grid.Row="1" Grid.Column="0" Foreground="#475569" Margin="0,4,0,0"/>
                            <TextBox  Grid.Row="1" Grid.Column="1" Margin="0,4,0,0"
                                      Text="{Binding EvidenceRetentionUpdateReason, UpdateSourceTrigger=PropertyChanged}"
                                      IsEnabled="{Binding EvidenceRetentionFlagEnabled}"/>
                            <TextBlock Text="TicketId (scrubbed)" Grid.Row="2" Grid.Column="0" Foreground="#475569" Margin="0,4,0,0"/>
                            <TextBox  Grid.Row="2" Grid.Column="1" Margin="0,4,0,0"
                                      Text="{Binding EvidenceRetentionUpdateTicketId, UpdateSourceTrigger=PropertyChanged}"
                                      IsEnabled="{Binding EvidenceRetentionFlagEnabled}"/>
                        </Grid>
                        <WrapPanel Margin="0,4,0,0">
                            <Button Content="Submit Retention Update"
                                    Command="{Binding SubmitEvidenceRetentionUpdateCommand}"
                                    Padding="10,4"/>
                        </WrapPanel>

                        <!-- Legal hold -->
                        <TextBlock Text="Toggle legal hold" FontWeight="SemiBold" Margin="0,12,0,0"/>
                        <Grid Margin="0,4,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="220"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="New legalHold value" Grid.Row="0" Grid.Column="0" Foreground="#475569"/>
                            <CheckBox  Grid.Row="0" Grid.Column="1"
                                       Content="legalHold = true"
                                       IsChecked="{Binding EvidenceRetentionLegalHoldNewValue}"
                                       IsEnabled="{Binding EvidenceRetentionFlagEnabled}"/>
                            <TextBlock Text="Reason (scrubbed)" Grid.Row="1" Grid.Column="0" Foreground="#475569" Margin="0,4,0,0"/>
                            <TextBox  Grid.Row="1" Grid.Column="1" Margin="0,4,0,0"
                                      Text="{Binding EvidenceRetentionLegalHoldReason, UpdateSourceTrigger=PropertyChanged}"
                                      IsEnabled="{Binding EvidenceRetentionFlagEnabled}"/>
                            <TextBlock Text="TicketId (scrubbed)" Grid.Row="2" Grid.Column="0" Foreground="#475569" Margin="0,4,0,0"/>
                            <TextBox  Grid.Row="2" Grid.Column="1" Margin="0,4,0,0"
                                      Text="{Binding EvidenceRetentionLegalHoldTicketId, UpdateSourceTrigger=PropertyChanged}"
                                      IsEnabled="{Binding EvidenceRetentionFlagEnabled}"/>
                        </Grid>
                        <WrapPanel Margin="0,4,0,0">
                            <Button Content="Submit Legal Hold Toggle"
                                    Command="{Binding SubmitEvidenceRetentionLegalHoldCommand}"
                                    Padding="10,4"/>
                        </WrapPanel>

                        <!-- Archive -->
                        <TextBlock Text="Archive bundle (storage NOT deleted)" FontWeight="SemiBold" Margin="0,12,0,0"/>
                        <Grid Margin="0,4,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="220"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="Reason (scrubbed)" Grid.Row="0" Grid.Column="0" Foreground="#475569"/>
                            <TextBox  Grid.Row="0" Grid.Column="1"
                                      Text="{Binding EvidenceRetentionArchiveReason, UpdateSourceTrigger=PropertyChanged}"
                                      IsEnabled="{Binding EvidenceRetentionFlagEnabled}"/>
                            <TextBlock Text="TicketId (scrubbed)" Grid.Row="1" Grid.Column="0" Foreground="#475569" Margin="0,4,0,0"/>
                            <TextBox  Grid.Row="1" Grid.Column="1" Margin="0,4,0,0"
                                      Text="{Binding EvidenceRetentionArchiveTicketId, UpdateSourceTrigger=PropertyChanged}"
                                      IsEnabled="{Binding EvidenceRetentionFlagEnabled}"/>
                        </Grid>
                        <WrapPanel Margin="0,4,0,0">
                            <Button Content="Archive Bundle"
                                    Command="{Binding SubmitEvidenceRetentionArchiveCommand}"
                                    Padding="10,4"/>
                        </WrapPanel>

                        <!-- Expire -->
                        <TextBlock Text="Expire bundle (storage NOT deleted)" FontWeight="SemiBold" Margin="0,12,0,0"/>
                        <Grid Margin="0,4,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="220"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="Reason (scrubbed)" Grid.Row="0" Grid.Column="0" Foreground="#475569"/>
                            <TextBox  Grid.Row="0" Grid.Column="1"
                                      Text="{Binding EvidenceRetentionExpireReason, UpdateSourceTrigger=PropertyChanged}"
                                      IsEnabled="{Binding EvidenceRetentionFlagEnabled}"/>
                            <TextBlock Text="TicketId (scrubbed)" Grid.Row="1" Grid.Column="0" Foreground="#475569" Margin="0,4,0,0"/>
                            <TextBox  Grid.Row="1" Grid.Column="1" Margin="0,4,0,0"
                                      Text="{Binding EvidenceRetentionExpireTicketId, UpdateSourceTrigger=PropertyChanged}"
                                      IsEnabled="{Binding EvidenceRetentionFlagEnabled}"/>
                        </Grid>
                        <WrapPanel Margin="0,4,0,0">
                            <Button Content="Expire Bundle"
                                    Command="{Binding SubmitEvidenceRetentionExpireCommand}"
                                    Padding="10,4"/>
                        </WrapPanel>

                        <!-- Status -->
                        <Border Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1"
                                Padding="8" Margin="0,10,0,0" CornerRadius="4">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="220"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Text="Outcome" Grid.Row="0" Grid.Column="0" Foreground="#475569"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding EvidenceRetentionOutcome}"/>
                                <TextBlock Text="Status"  Grid.Row="1" Grid.Column="0" Foreground="#475569" Margin="0,2,0,0"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding EvidenceRetentionStatusMessage}" Margin="0,2,0,0" TextWrapping="Wrap"/>
                                <TextBlock Text="Last backend error" Grid.Row="2" Grid.Column="0" Foreground="#991B1B" Margin="0,2,0,0"/>
                                <StackPanel Grid.Row="2" Grid.Column="1" Margin="0,2,0,0">
                                    <TextBlock Text="{Binding EvidenceRetentionLastErrorCode}"    Foreground="#991B1B"/>
                                    <TextBlock Text="{Binding EvidenceRetentionLastErrorMessage}" Foreground="#991B1B" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <TextBlock Text="Warnings:" Foreground="#92400E" Margin="0,8,0,0"/>
                        <ItemsControl ItemsSource="{Binding EvidenceRetentionWarnings}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" Foreground="#92400E" FontSize="11" TextWrapping="Wrap" Margin="0,2,0,0"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock Text="Errors:" Foreground="#991B1B" Margin="0,8,0,0"/>
                        <ItemsControl ItemsSource="{Binding EvidenceRetentionErrors}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" Foreground="#991B1B" FontSize="11" TextWrapping="Wrap" Margin="0,2,0,0"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Phase 10.22P — Evidence Bundle Lifecycle Scheduler Status (read-only monitoring) -->
                <Border Background="White" BorderBrush="#93C5FD" BorderThickness="1"
                        Padding="8" Margin="0,8,0,0" CornerRadius="4">
                    <StackPanel>
                        <TextBlock Text="Evidence Bundle Lifecycle Scheduler Status (Phase 10.22P)"
                                   FontWeight="SemiBold" Foreground="#1E40AF" FontSize="13"/>
                        <TextBlock Foreground="#475569" FontSize="11" TextWrapping="Wrap" Margin="0,2,0,8"
                                   Text="Read-only scheduler monitoring. Does not hard-delete and does not delete storage objects."/>

                        <!-- Feature flags -->
                        <Border Background="#F1F5F9" BorderBrush="#CBD5E1" BorderThickness="1"
                                Padding="8" Margin="0,0,0,8" CornerRadius="4">
                            <StackPanel>
                                <TextBlock Text="Feature flags" FontWeight="SemiBold" Foreground="#1E3A5F" Margin="0,0,0,4"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="220"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="Status UI flag" Grid.Row="0" Grid.Column="0" Foreground="#475569"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding LifecycleSchedulerStatusText}" TextWrapping="Wrap"/>
                                    <TextBlock Text="Manual run flag" Grid.Row="1" Grid.Column="0" Foreground="#475569" Margin="0,2,0,0"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding LifecycleSchedulerManualRunStatusText}" TextWrapping="Wrap" Margin="0,2,0,0"/>
                                </Grid>
                                <Button Content="Refresh flag state"
                                        Command="{Binding RefreshLifecycleSchedulerStatusCommand}"
                                        Margin="0,8,0,0" Padding="8,4" HorizontalAlignment="Left"
                                        Background="#EFF6FF" Foreground="#1E40AF" BorderBrush="#BFDBFE"/>
                            </StackPanel>
                        </Border>

                        <!-- Shared outcome / error -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="220"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="Last status" Grid.Row="0" Grid.Column="0" Foreground="#475569"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding LifecycleSchedulerStatusMessage}" TextWrapping="Wrap"/>
                            <TextBlock Text="Last error code"    Grid.Row="1" Grid.Column="0" Foreground="#991B1B" Margin="0,2,0,0"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding LifecycleSchedulerErrorCode}" Foreground="#991B1B" Margin="0,2,0,0"/>
                            <TextBlock Text="Last error message" Grid.Row="2" Grid.Column="0" Foreground="#991B1B" Margin="0,2,0,0"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding LifecycleSchedulerErrorMessage}" Foreground="#991B1B" TextWrapping="Wrap" Margin="0,2,0,0"/>
                        </Grid>

                        <!-- ── Retention archive sweeper (Phase 10.22N) ── -->
                        <Border Background="#F0FDF4" BorderBrush="#86EFAC" BorderThickness="1"
                                Padding="8" Margin="0,0,0,8" CornerRadius="4">
                            <StackPanel>
                                <TextBlock Text="Retention archive sweeper (Phase 10.22N)"
                                           FontWeight="SemiBold" Foreground="#14532D" Margin="0,0,0,4"/>
                                <TextBlock Text="Transitions eligible ACTIVE → ARCHIVED bundles. Controlled by operator.evidence.bundle.retention.scheduler.*"
                                           Foreground="#166534" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,6"/>

                                <!-- Retention runs list -->
                                <DockPanel Margin="0,0,0,4">
                                    <Button DockPanel.Dock="Right"
                                            Content="Load runs"
                                            Command="{Binding ListRetentionSweepRunsCommand}"
                                            IsEnabled="{Binding LifecycleSchedulerEnabled}"
                                            Padding="8,4" Background="#DCFCE7" Foreground="#166534" BorderBrush="#86EFAC"/>
                                    <TextBlock Text="{Binding RetentionRunsTotalElements, StringFormat='Total: {0} runs'}"
                                               VerticalAlignment="Center" Foreground="#166534" FontSize="11"/>
                                </DockPanel>

                                <Border MaxHeight="160" BorderBrush="#86EFAC" BorderThickness="1" CornerRadius="2">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <ItemsControl ItemsSource="{Binding RetentionSweepRuns}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Padding="4,2" BorderBrush="#D1FAE5" BorderThickness="0,0,0,1">
                                                        <Button Command="{Binding DataContext.SelectRetentionSweepRunCommand,
                                                                    RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                CommandParameter="{Binding}"
                                                                Background="Transparent" BorderThickness="0" Padding="0"
                                                                HorizontalContentAlignment="Stretch">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="90"/>
                                                                    <ColumnDefinition Width="80"/>
                                                                    <ColumnDefinition Width="60"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                </Grid.ColumnDefinitions>
                                                                <TextBlock Grid.Column="0" Text="{Binding Status}"       FontSize="11" Foreground="#14532D"/>
                                                                <TextBlock Grid.Column="1" Text="{Binding TriggerType}"  FontSize="11" Foreground="#475569"/>
                                                                <TextBlock Grid.Column="2" Text="{Binding DryRun, StringFormat='dry={0}'}" FontSize="11" Foreground="#475569"/>
                                                                <TextBlock Grid.Column="3" Text="{Binding RunUuid}"      FontSize="10" Foreground="#94A3B8" TextTrimming="CharacterEllipsis"/>
                                                            </Grid>
                                                        </Button>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </Border>

                                <!-- Retention selected run detail -->
                                <Border Background="White" BorderBrush="#86EFAC" BorderThickness="1"
                                        Padding="6" Margin="0,6,0,0" CornerRadius="2">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="160"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Text="UUID"           Grid.Row="0" Grid.Column="0" Foreground="#475569" FontSize="11"/>
                                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding RetentionRunLastUuid}" FontSize="11" TextWrapping="Wrap"/>
                                        <TextBlock Text="Status"         Grid.Row="1" Grid.Column="0" Foreground="#475569" FontSize="11" Margin="0,2,0,0"/>
                                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding RetentionRunLastStatus}" FontSize="11" Margin="0,2,0,0"/>
                                        <TextBlock Text="Trigger"        Grid.Row="2" Grid.Column="0" Foreground="#475569" FontSize="11" Margin="0,2,0,0"/>
                                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding RetentionRunLastTriggerType}" FontSize="11" Margin="0,2,0,0"/>
                                        <TextBlock Text="Dry run"        Grid.Row="3" Grid.Column="0" Foreground="#475569" FontSize="11" Margin="0,2,0,0"/>
                                        <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding RetentionRunLastDryRun}" FontSize="11" Margin="0,2,0,0"/>
                                        <TextBlock Text="Candidates"     Grid.Row="4" Grid.Column="0" Foreground="#475569" FontSize="11" Margin="0,2,0,0"/>
                                        <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding RetentionRunLastCandidateCount}" FontSize="11" Margin="0,2,0,0"/>
                                        <TextBlock Text="Archived"       Grid.Row="5" Grid.Column="0" Foreground="#475569" FontSize="11" Margin="0,2,0,0"/>
                                        <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding RetentionRunLastArchivedCount}" FontSize="11" Margin="0,2,0,0"/>
                                        <TextBlock Text="Skipped/Failed" Grid.Row="6" Grid.Column="0" Foreground="#475569" FontSize="11" Margin="0,2,0,0"/>
                                        <StackPanel Grid.Row="6" Grid.Column="1" Orientation="Horizontal" Margin="0,2,0,0">
                                            <TextBlock Text="{Binding RetentionRunLastSkippedCount}" FontSize="11"/>
                                            <TextBlock Text=" / " FontSize="11" Foreground="#475569"/>
                                            <TextBlock Text="{Binding RetentionRunLastFailedCount}" FontSize="11"/>
                                        </StackPanel>
                                        <TextBlock Text="Error code"     Grid.Row="7" Grid.Column="0" Foreground="#991B1B" FontSize="11" Margin="0,2,0,0"/>
                                        <TextBlock Grid.Row="7" Grid.Column="1" Text="{Binding RetentionRunLastErrorCode}" Foreground="#991B1B" FontSize="11" Margin="0,2,0,0"/>
                                        <TextBlock Text="Error message"  Grid.Row="8" Grid.Column="0" Foreground="#991B1B" FontSize="11" Margin="0,2,0,0"/>
                                        <TextBlock Grid.Row="8" Grid.Column="1" Text="{Binding RetentionRunLastErrorMessage}" Foreground="#991B1B" FontSize="11" TextWrapping="Wrap" Margin="0,2,0,0"/>
                                    </Grid>
                                </Border>

                                <!-- Retention manual run (visible only when manual run flag is ON) -->
                                <Border Visibility="{Binding LifecycleSchedulerManualRunEnabled,
                                            Converter={StaticResource BoolToVisibilityConverter}}"
                                        Background="#ECFDF5" BorderBrush="#6EE7B7" BorderThickness="1"
                                        Padding="6" Margin="0,8,0,0" CornerRadius="2">
                                    <StackPanel>
                                        <TextBlock Text="Manual run — retention sweeper"
                                                   FontWeight="SemiBold" Foreground="#065F46" Margin="0,0,0,4" FontSize="12"/>
                                        <CheckBox IsChecked="{Binding RetentionManualRunDryRun}"
                                                  Content="Dry run (count only, no archiving)" Margin="0,0,0,4"/>
                                        <Grid Margin="0,0,0,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="80"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <TextBlock Text="Reason" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" FontSize="11"/>
                                            <TextBox   Text="{Binding RetentionManualRunReason, UpdateSourceTrigger=PropertyChanged}"
                                                       Grid.Row="0" Grid.Column="1" Padding="4,2" FontSize="11"/>
                                            <TextBlock Text="Ticket ID" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" FontSize="11" Margin="0,4,0,0"/>
                                            <TextBox   Text="{Binding RetentionManualRunTicketId, UpdateSourceTrigger=PropertyChanged}"
                                                       Grid.Row="1" Grid.Column="1" Padding="4,2" FontSize="11" Margin="0,4,0,0"/>
                                        </Grid>
                                        <DockPanel>
                                            <Button DockPanel.Dock="Right"
                                                    Content="Submit run"
                                                    Command="{Binding RunRetentionSweepOnceCommand}"
                                                    Padding="8,4" Background="#D1FAE5" Foreground="#065F46" BorderBrush="#6EE7B7"/>
                                            <TextBlock Text="{Binding RetentionManualRunOutcome}" VerticalAlignment="Center"
                                                       FontSize="11" Foreground="#065F46" TextWrapping="Wrap" Margin="0,0,8,0"/>
                                        </DockPanel>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- ── Expiration sweeper (Phase 10.22O) ── -->
                        <Border Background="#FFF7ED" BorderBrush="#FCD34D" BorderThickness="1"
                                Padding="8" Margin="0,0,0,0" CornerRadius="4">
                            <StackPanel>
                                <TextBlock Text="Expiration sweeper (Phase 10.22O)"
                                           FontWeight="SemiBold" Foreground="#78350F" Margin="0,0,0,4"/>
                                <TextBlock Text="Transitions eligible ARCHIVED → EXPIRED bundles. Controlled by operator.evidence.bundle.expiration.scheduler.*"
                                           Foreground="#92400E" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,6"/>

                                <!-- Expiration runs list -->
                                <DockPanel Margin="0,0,0,4">
                                    <Button DockPanel.Dock="Right"
                                            Content="Load runs"
                                            Command="{Binding ListExpirationSweepRunsCommand}"
                                            IsEnabled="{Binding LifecycleSchedulerEnabled}"
                                            Padding="8,4" Background="#FEF3C7" Foreground="#92400E" BorderBrush="#FCD34D"/>
                                    <TextBlock Text="{Binding ExpirationRunsTotalElements, StringFormat='Total: {0} runs'}"
                                               VerticalAlignment="Center" Foreground="#92400E" FontSize="11"/>
                                </DockPanel>

                                <Border MaxHeight="160" BorderBrush="#FCD34D" BorderThickness="1" CornerRadius="2">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <ItemsControl ItemsSource="{Binding ExpirationSweepRuns}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Padding="4,2" BorderBrush="#FDE68A" BorderThickness="0,0,0,1">
                                                        <Button Command="{Binding DataContext.SelectExpirationSweepRunCommand,
                                                                    RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                CommandParameter="{Binding}"
                                                                Background="Transparent" BorderThickness="0" Padding="0"
                                                                HorizontalContentAlignment="Stretch">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="90"/>
                                                                    <ColumnDefinition Width="80"/>
                                                                    <ColumnDefinition Width="60"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                </Grid.ColumnDefinitions>
                                                                <TextBlock Grid.Column="0" Text="{Binding Status}"      FontSize="11" Foreground="#78350F"/>
                                                                <TextBlock Grid.Column="1" Text="{Binding TriggerType}" FontSize="11" Foreground="#475569"/>
                                                                <TextBlock Grid.Column="2" Text="{Binding DryRun, StringFormat='dry={0}'}" FontSize="11" Foreground="#475569"/>
                                                                <TextBlock Grid.Column="3" Text="{Binding RunUuid}"     FontSize="10" Foreground="#94A3B8" TextTrimming="CharacterEllipsis"/>
                                                            </Grid>
                                                        </Button>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </Border>

                                <!-- Expiration selected run detail -->
                                <Border Background="White" BorderBrush="#FCD34D" BorderThickness="1"
                                        Padding="6" Margin="0,6,0,0" CornerRadius="2">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="160"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Text="UUID"           Grid.Row="0" Grid.Column="0" Foreground="#475569" FontSize="11"/>
                                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding ExpirationRunLastUuid}" FontSize="11" TextWrapping="Wrap"/>
                                        <TextBlock Text="Status"         Grid.Row="1" Grid.Column="0" Foreground="#475569" FontSize="11" Margin="0,2,0,0"/>
                                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding ExpirationRunLastStatus}" FontSize="11" Margin="0,2,0,0"/>
                                        <TextBlock Text="Trigger"        Grid.Row="2" Grid.Column="0" Foreground="#475569" FontSize="11" Margin="0,2,0,0"/>
                                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding ExpirationRunLastTriggerType}" FontSize="11" Margin="0,2,0,0"/>
                                        <TextBlock Text="Dry run"        Grid.Row="3" Grid.Column="0" Foreground="#475569" FontSize="11" Margin="0,2,0,0"/>
                                        <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding ExpirationRunLastDryRun}" FontSize="11" Margin="0,2,0,0"/>
                                        <TextBlock Text="Candidates"     Grid.Row="4" Grid.Column="0" Foreground="#475569" FontSize="11" Margin="0,2,0,0"/>
                                        <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding ExpirationRunLastCandidateCount}" FontSize="11" Margin="0,2,0,0"/>
                                        <TextBlock Text="Expired"        Grid.Row="5" Grid.Column="0" Foreground="#475569" FontSize="11" Margin="0,2,0,0"/>
                                        <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding ExpirationRunLastExpiredCount}" FontSize="11" Margin="0,2,0,0"/>
                                        <TextBlock Text="Skipped/Failed" Grid.Row="6" Grid.Column="0" Foreground="#475569" FontSize="11" Margin="0,2,0,0"/>
                                        <StackPanel Grid.Row="6" Grid.Column="1" Orientation="Horizontal" Margin="0,2,0,0">
                                            <TextBlock Text="{Binding ExpirationRunLastSkippedCount}" FontSize="11"/>
                                            <TextBlock Text=" / " FontSize="11" Foreground="#475569"/>
                                            <TextBlock Text="{Binding ExpirationRunLastFailedCount}" FontSize="11"/>
                                        </StackPanel>
                                        <TextBlock Text="Error code"     Grid.Row="7" Grid.Column="0" Foreground="#991B1B" FontSize="11" Margin="0,2,0,0"/>
                                        <TextBlock Grid.Row="7" Grid.Column="1" Text="{Binding ExpirationRunLastErrorCode}" Foreground="#991B1B" FontSize="11" Margin="0,2,0,0"/>
                                        <TextBlock Text="Error message"  Grid.Row="8" Grid.Column="0" Foreground="#991B1B" FontSize="11" Margin="0,2,0,0"/>
                                        <TextBlock Grid.Row="8" Grid.Column="1" Text="{Binding ExpirationRunLastErrorMessage}" Foreground="#991B1B" FontSize="11" TextWrapping="Wrap" Margin="0,2,0,0"/>
                                    </Grid>
                                </Border>

                                <!-- Expiration manual run (visible only when manual run flag is ON) -->
                                <Border Visibility="{Binding LifecycleSchedulerManualRunEnabled,
                                            Converter={StaticResource BoolToVisibilityConverter}}"
                                        Background="#FFFBEB" BorderBrush="#FCD34D" BorderThickness="1"
                                        Padding="6" Margin="0,8,0,0" CornerRadius="2">
                                    <StackPanel>
                                        <TextBlock Text="Manual run — expiration sweeper"
                                                   FontWeight="SemiBold" Foreground="#78350F" Margin="0,0,0,4" FontSize="12"/>
                                        <CheckBox IsChecked="{Binding ExpirationManualRunDryRun}"
                                                  Content="Dry run (count only, no expiration)" Margin="0,0,0,4"/>
                                        <Grid Margin="0,0,0,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="80"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <TextBlock Text="Reason" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" FontSize="11"/>
                                            <TextBox   Text="{Binding ExpirationManualRunReason, UpdateSourceTrigger=PropertyChanged}"
                                                       Grid.Row="0" Grid.Column="1" Padding="4,2" FontSize="11"/>
                                            <TextBlock Text="Ticket ID" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" FontSize="11" Margin="0,4,0,0"/>
                                            <TextBox   Text="{Binding ExpirationManualRunTicketId, UpdateSourceTrigger=PropertyChanged}"
                                                       Grid.Row="1" Grid.Column="1" Padding="4,2" FontSize="11" Margin="0,4,0,0"/>
                                        </Grid>
                                        <DockPanel>
                                            <Button DockPanel.Dock="Right"
                                                    Content="Submit run"
                                                    Command="{Binding RunExpirationSweepOnceCommand}"
                                                    Padding="8,4" Background="#FEF3C7" Foreground="#78350F" BorderBrush="#FCD34D"/>
                                            <TextBlock Text="{Binding ExpirationManualRunOutcome}" VerticalAlignment="Center"
                                                       FontSize="11" Foreground="#78350F" TextWrapping="Wrap" Margin="0,0,8,0"/>
                                        </DockPanel>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Status bar -->
        <Border Grid.Row="3" Background="White" BorderBrush="#E2E8F0" BorderThickness="1"
                Padding="10" Margin="0,10,0,0" CornerRadius="6">
            <DockPanel>
                <TextBlock DockPanel.Dock="Right"
                           Foreground="#475569" FontSize="11"
                           Text="{Binding LastUpdatedAt, StringFormat='Last updated: {0:HH:mm:ss}'}"/>
                <TextBlock Text="{Binding StatusMessage}" FontSize="12" Foreground="#0F172A"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
