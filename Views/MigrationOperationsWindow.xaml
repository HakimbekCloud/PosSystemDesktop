                            <TextBlock Text="Backup count"                 Grid.Row="5"  Grid.Column="0" Foreground="#475569" Margin="0,4,0,0"/>
                            <TextBlock Text="{Binding InventoryBackupCount}" Grid.Row="5" Grid.Column="1" Margin="0,4,0,0"/>
