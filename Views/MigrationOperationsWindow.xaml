                            <TextBlock Text="Legacy DB exists"                 Grid.Row="6"  Grid.Column="0" Foreground="#475569" Margin="0,4,0,0"/>
                            <TextBlock Text="{Binding RollbackDryRunLegacyDbExists}" Grid.Row="6" Grid.Column="1" Margin="0,4,0,0"/>
                            <TextBlock Text="Legacy DB readable"               Grid.Row="7"  Grid.Column="0" Foreground="#475569" Margin="0,4,0,0"/>
