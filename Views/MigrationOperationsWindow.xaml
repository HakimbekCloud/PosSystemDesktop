                <!-- Guarded Retention Cleanup Execution (Phase 10.16B) -->
                <Border Background="#FEF3C7" BorderBrush="#A16207" BorderThickness="2"
                        Padding="12" Margin="0,0,0,10" CornerRadius="6">
                    <StackPanel>
                        <TextBlock Text="Guarded Retention Cleanup Execution" FontSize="13" FontWeight="Bold" Foreground="#713F12"/>
