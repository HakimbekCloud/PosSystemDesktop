                            <TextBlock Text="{Binding InventoryArchivedTenantDirCount}" Grid.Row="6" Grid.Column="1" Margin="0,4,0,0"/>
                            <TextBlock Text="Broken legacy DB count"       Grid.Row="7"  Grid.Column="0" Foreground="#475569" Margin="0,4,0,0"/>
                            <TextBlock Text="{Binding InventoryBrokenLegacyDbCount}" Grid.Row="7" Grid.Column="1" Margin="0,4,0,0"/>
                            <TextBlock Text="Migration log count"          Grid.Row="8"  Grid.Column="0" Foreground="#475569" Margin="0,4,0,0"/>
                            <TextBlock Text="{Binding InventoryMigrationLogCount}" Grid.Row="8" Grid.Column="1" Margin="0,4,0,0"/>
                            <TextBlock Text="Rollback log count"           Grid.Row="9"  Grid.Column="0" Foreground="#475569" Margin="0,4,0,0"/>
                            <TextBlock Text="{Binding InventoryRollbackLogCount}" Grid.Row="9" Grid.Column="1" Margin="0,4,0,0"/>
                            <TextBlock Text="Diagnostics log count"        Grid.Row="10" Grid.Column="0" Foreground="#475569" Margin="0,4,0,0"/>
                            <TextBlock Text="{Binding InventoryDiagnosticsLogCount}" Grid.Row="10" Grid.Column="1" Margin="0,4,0,0"/>
                            <TextBlock Text="Preflight log count"          Grid.Row="11" Grid.Column="0" Foreground="#475569" Margin="0,4,0,0"/>
                            <TextBlock Text="{Binding InventoryPreflightLogCount}" Grid.Row="11" Grid.Column="1" Margin="0,4,0,0"/>
                        </Grid>

                        <TextBlock Text="{Binding InventorySummary}"
                                   Foreground="#0F172A" TextWrapping="Wrap" Margin="0,8,0,0"/>

                        <TextBlock Text="Tenant databases:" Foreground="#475569"
                                   FontSize="11" FontWeight="SemiBold" Margin="0,8,0,2"/>
                        <ItemsControl ItemsSource="{Binding InventoryTenantDbLines}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" Foreground="#475569" FontSize="11" TextWrapping="Wrap" Margin="0,2,0,0"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Text="Backup files:" Foreground="#475569"
                                   FontSize="11" FontWeight="SemiBold" Margin="0,8,0,2"/>
                        <ItemsControl ItemsSource="{Binding InventoryBackupLines}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" Foreground="#475569" FontSize="11" TextWrapping="Wrap" Margin="0,2,0,0"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Text="Archived tenant directories:" Foreground="#475569"
                                   FontSize="11" FontWeight="SemiBold" Margin="0,8,0,2"/>
                        <ItemsControl ItemsSource="{Binding InventoryArchiveLines}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" Foreground="#475569" FontSize="11" TextWrapping="Wrap" Margin="0,2,0,0"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Text="Log directories:" Foreground="#475569"
                                   FontSize="11" FontWeight="SemiBold" Margin="0,8,0,2"/>
                        <ItemsControl ItemsSource="{Binding InventoryLogLines}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" Foreground="#475569" FontSize="11" TextWrapping="Wrap" Margin="0,2,0,0"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Retention Preview (Phase 10.11B) -->
                <Border Background="White" BorderBrush="#E2E8F0" BorderThickness="1"
                        Padding="12" Margin="0,0,0,10" CornerRadius="6">
                    <StackPanel>
                        <TextBlock Text="Retention Preview" FontSize="13" FontWeight="SemiBold" Foreground="#0F172A"/>
                        <TextBlock Text="Preview only — no files are deleted or moved. Click 'Preview Retention Plan' to classify storage into 'candidate for future cleanup' vs 'protected'."
                                   FontSize="10" Foreground="#475569" Margin="0,2,0,6"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="240"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="Candidate count"     Grid.Row="0" Grid.Column="0" Foreground="#475569"/>
                            <TextBlock Text="{Binding RetentionPreviewCandidateCount}" Grid.Row="0" Grid.Column="1"/>
                            <TextBlock Text="Candidate size"      Grid.Row="1" Grid.Column="0" Foreground="#475569" Margin="0,4,0,0"/>
                            <TextBlock Text="{Binding RetentionPreviewCandidateSize}" Grid.Row="1" Grid.Column="1" Margin="0,4,0,0"/>
                            <TextBlock Text="Protected item count" Grid.Row="2" Grid.Column="0" Foreground="#475569" Margin="0,4,0,0"/>
                            <TextBlock Text="{Binding RetentionPreviewProtectedItemCount}" Grid.Row="2" Grid.Column="1" Margin="0,4,0,0"/>
                            <TextBlock Text="Protected size"      Grid.Row="3" Grid.Column="0" Foreground="#475569" Margin="0,4,0,0"/>
                            <TextBlock Text="{Binding RetentionPreviewProtectedSize}" Grid.Row="3" Grid.Column="1" Margin="0,4,0,0"/>
                        </Grid>

                        <TextBlock Text="{Binding RetentionPreviewSummary}"
                                   Foreground="#0F172A" TextWrapping="Wrap" Margin="0,8,0,0"/>

                        <TextBlock Text="Cleanup candidates (future cleanup tool — not executed now):"
                                   Foreground="#475569" FontSize="11" FontWeight="SemiBold" Margin="0,8,0,2"/>
                        <ItemsControl ItemsSource="{Binding RetentionPreviewCandidateLines}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" Foreground="#475569" FontSize="11" TextWrapping="Wrap" Margin="0,2,0,0"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Text="Protected items (never candidates for cleanup):"
                                   Foreground="#475569" FontSize="11" FontWeight="SemiBold" Margin="0,8,0,2"/>
                        <ItemsControl ItemsSource="{Binding RetentionPreviewProtectedLines}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" Foreground="#475569" FontSize="11" TextWrapping="Wrap" Margin="0,2,0,0"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Inventory Export (Phase 10.11C) -->
                <Border Background="White" BorderBrush="#E2E8F0" BorderThickness="1"
                        Padding="12" Margin="0,0,0,10" CornerRadius="6">
                    <StackPanel>
                        <TextBlock Text="Inventory Export" FontSize="13" FontWeight="SemiBold" Foreground="#0F172A"/>
                        <TextBlock Text="Read-only inventory + retention bundle. Writes one redacted JSON file. Does not delete, move, or modify anything else."
                                   FontSize="10" Foreground="#475569" Margin="0,2,0,6"/>
                        <Grid Margin="0,6,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="240"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="Last inventory export path" Grid.Row="0" Grid.Column="0" Foreground="#475569"/>
                            <TextBlock Text="{Binding LastInventoryExportPath}" Grid.Row="0" Grid.Column="1" TextWrapping="Wrap"/>
                            <TextBlock Text="Inventory export status"     Grid.Row="1" Grid.Column="0" Foreground="#475569" Margin="0,4,0,0"/>
                            <TextBlock Text="{Binding InventoryExportStatusMessage}" Grid.Row="1" Grid.Column="1" TextWrapping="Wrap" Margin="0,4,0,0"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Real Migration Gate (Phase 10.12A) -->
                <Border Background="White" BorderBrush="#E2E8F0" BorderThickness="1"
                        Padding="12" Margin="0,0,0,10" CornerRadius="6">
                    <StackPanel>
                        <TextBlock Text="Real Migration Gate" FontSize="13" FontWeight="SemiBold" Foreground="#0F172A"/>
                        <TextBlock Text="This section does not execute migration. It only reports whether real migration would be allowed right now."
                                   FontSize="10" Foreground="#475569" Margin="0,2,0,6"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="240"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="Gate status"                 Grid.Row="0" Grid.Column="0" Foreground="#475569"/>
                            <TextBlock Text="{Binding RealMigrationGateStatus}" Grid.Row="0" Grid.Column="1"/>
                            <TextBlock Text="Can execute real migration"  Grid.Row="1" Grid.Column="0" Foreground="#475569" Margin="0,4,0,0"/>
                            <TextBlock Text="{Binding RealMigrationCanExecute}" Grid.Row="1" Grid.Column="1" Margin="0,4,0,0"/>
                        </Grid>

                        <TextBlock Text="{Binding RealMigrationGateSummary}"
                                   Foreground="#0F172A" TextWrapping="Wrap" Margin="0,8,0,0"/>

                        <TextBlock Text="Blocking reasons:" Foreground="#991B1B"
                                   FontSize="11" FontWeight="SemiBold" Margin="0,8,0,2"/>
                        <ItemsControl ItemsSource="{Binding RealMigrationBlockingReasons}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" Foreground="#991B1B" FontSize="11" TextWrapping="Wrap" Margin="0,2,0,0"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Text="Warnings:" Foreground="#92400E"
                                   FontSize="11" FontWeight="SemiBold" Margin="0,8,0,2"/>
                        <ItemsControl ItemsSource="{Binding RealMigrationWarnings}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" Foreground="#92400E" FontSize="11" TextWrapping="Wrap" Margin="0,2,0,0"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Text="Recommended steps:" Foreground="#475569"
                                   FontSize="11" FontWeight="SemiBold" Margin="0,8,0,2"/>
                        <ItemsControl ItemsSource="{Binding RealMigrationRecommendedSteps}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" Foreground="#475569" FontSize="11" TextWrapping="Wrap" Margin="0,2,0,0"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Guarded Real Migration Execution (Phase 10.12C) -->
                <Border Background="#FEF2F2" BorderBrush="#DC2626" BorderThickness="2"
                        Padding="12" Margin="0,0,0,10" CornerRadius="6">
                    <StackPanel>
                        <TextBlock Text="Guarded Real Migration Execution" FontSize="13" FontWeight="Bold" Foreground="#7F1D1D"/>
                        <TextBlock Text="This action performs real migration. It does NOT enable tenant runtime mode and does NOT switch database."
                                   FontSize="11" FontWeight="SemiBold" Foreground="#991B1B" TextWrapping="Wrap" Margin="0,4,0,0"/>
                        <TextBlock Text="Required confirmation phrase is not displayed. Type the phrase provided by your internal runbook."
                                   FontSize="11" Foreground="#7F1D1D" TextWrapping="Wrap" Margin="0,2,0,6"/>

                        <Grid Margin="0,4,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="240"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Text="Section status"             Grid.Row="0" Grid.Column="0" Foreground="#7F1D1D"/>
                            <TextBlock Text="{Binding RealMigrationUiEnabledStatusText}" Grid.Row="0" Grid.Column="1" TextWrapping="Wrap"/>

                            <TextBlock Text="Reviewed preflight export path" Grid.Row="1" Grid.Column="0" Foreground="#7F1D1D" Margin="0,4,0,0"/>
                            <TextBox  Text="{Binding RealMigrationReviewedPreflightExportPath, UpdateSourceTrigger=PropertyChanged}"
                                      IsEnabled="{Binding RealMigrationUiEnabled}"
                                      Grid.Row="1" Grid.Column="1" Margin="0,4,0,0" Padding="6,4" FontFamily="Consolas" FontSize="12"/>

                            <TextBlock Text="Reviewed inventory export path" Grid.Row="2" Grid.Column="0" Foreground="#7F1D1D" Margin="0,4,0,0"/>
                            <TextBox  Text="{Binding RealMigrationReviewedInventoryExportPath, UpdateSourceTrigger=PropertyChanged}"
                                      IsEnabled="{Binding RealMigrationUiEnabled}"
                                      Grid.Row="2" Grid.Column="1" Margin="0,4,0,0" Padding="6,4" FontFamily="Consolas" FontSize="12"/>

                            <TextBlock Text="External backup acknowledged" Grid.Row="3" Grid.Column="0" Foreground="#7F1D1D" Margin="0,4,0,0"/>
                            <CheckBox IsChecked="{Binding RealMigrationExternalBackupAcknowledged}"
                                      IsEnabled="{Binding RealMigrationUiEnabled}"
                                      Content="I have captured an off-machine backup of %LocalAppData%\PosSystem."
                                      Grid.Row="3" Grid.Column="1" Margin="0,4,0,0" Foreground="#7F1D1D"/>

                            <TextBlock Text="External backup note (optional)" Grid.Row="4" Grid.Column="0" Foreground="#7F1D1D" Margin="0,4,0,0"/>
                            <TextBox  Text="{Binding RealMigrationExternalBackupNote, UpdateSourceTrigger=PropertyChanged}"
                                      IsEnabled="{Binding RealMigrationUiEnabled}"
                                      Grid.Row="4" Grid.Column="1" Margin="0,4,0,0" Padding="6,4"/>

                            <TextBlock Text="Allow gate warnings" Grid.Row="5" Grid.Column="0" Foreground="#7F1D1D" Margin="0,4,0,0"/>
                            <CheckBox IsChecked="{Binding RealMigrationAllowWarnings}"
                                      IsEnabled="{Binding RealMigrationUiEnabled}"
                                      Content="Proceed if gate status is AllowedWithWarnings."
                                      Grid.Row="5" Grid.Column="1" Margin="0,4,0,0" Foreground="#7F1D1D"/>

                            <TextBlock Text="Confirmation phrase" Grid.Row="6" Grid.Column="0" Foreground="#7F1D1D" Margin="0,4,0,0"/>
                            <TextBox  Text="{Binding RealMigrationConfirmationPhraseInput, UpdateSourceTrigger=PropertyChanged}"
                                      IsEnabled="{Binding RealMigrationUiEnabled}"
                                      Grid.Row="6" Grid.Column="1" Margin="0,4,0,0" Padding="6,4" FontFamily="Consolas" FontSize="12"/>

                            <TextBlock Text=""                           Grid.Row="7" Grid.Column="0"/>
                            <Button   Grid.Row="7" Grid.Column="1"
                                      Command="{Binding ExecuteRealMigrationCommand}"
                                      Content="Execute Real Migration"
                                      HorizontalAlignment="Left"
                                      Padding="14,6" Margin="0,10,0,0"
                                      Background="#B91C1C" Foreground="White" BorderThickness="0"
                                      Cursor="Hand"
                                      FontWeight="SemiBold"/>
                        </Grid>

                        <!-- Outcome -->
                        <Border Background="White" BorderBrush="#FCA5A5" BorderThickness="1"
                                Padding="10" Margin="0,12,0,0" CornerRadius="4">
                            <StackPanel>
                                <TextBlock Text="Execution outcome" FontSize="12" FontWeight="SemiBold" Foreground="#7F1D1D"/>
                                <Grid Margin="0,4,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="220"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="Outcome"           Grid.Row="0" Grid.Column="0" Foreground="#475569"/>
                                    <TextBlock Text="{Binding RealMigrationExecutionOutcome}" Grid.Row="0" Grid.Column="1"/>
                                    <TextBlock Text="Migration executed" Grid.Row="1" Grid.Column="0" Foreground="#475569" Margin="0,2,0,0"/>
                                    <TextBlock Text="{Binding RealMigrationExecuted}" Grid.Row="1" Grid.Column="1" Margin="0,2,0,0"/>
                                    <TextBlock Text="Started (UTC)"     Grid.Row="2" Grid.Column="0" Foreground="#475569" Margin="0,2,0,0"/>
                                    <TextBlock Text="{Binding RealMigrationExecutionStartedAtUtc}" Grid.Row="2" Grid.Column="1" Margin="0,2,0,0"/>
                                    <TextBlock Text="Completed (UTC)"   Grid.Row="3" Grid.Column="0" Foreground="#475569" Margin="0,2,0,0"/>
                                    <TextBlock Text="{Binding RealMigrationExecutionCompletedAtUtc}" Grid.Row="3" Grid.Column="1" Margin="0,2,0,0"/>
                                </Grid>

                                <TextBlock Text="{Binding RealMigrationExecutionStatusMessage}"
                                           Foreground="#0F172A" TextWrapping="Wrap" Margin="0,6,0,0"/>

                                <TextBlock Text="Steps:" Foreground="#475569"
                                           FontSize="11" FontWeight="SemiBold" Margin="0,8,0,2"/>
                                <ItemsControl ItemsSource="{Binding RealMigrationExecutionSteps}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}" Foreground="#475569" FontSize="11" TextWrapping="Wrap" Margin="0,2,0,0"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <TextBlock Text="Blocking reasons:" Foreground="#991B1B"
                                           FontSize="11" FontWeight="SemiBold" Margin="0,8,0,2"/>
                                <ItemsControl ItemsSource="{Binding RealMigrationExecutionBlockingReasons}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}" Foreground="#991B1B" FontSize="11" TextWrapping="Wrap" Margin="0,2,0,0"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <TextBlock Text="Warnings:" Foreground="#92400E"
                                           FontSize="11" FontWeight="SemiBold" Margin="0,8,0,2"/>
                                <ItemsControl ItemsSource="{Binding RealMigrationExecutionWarnings}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}" Foreground="#92400E" FontSize="11" TextWrapping="Wrap" Margin="0,2,0,0"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <TextBlock Text="Errors:" Foreground="#991B1B"
                                           FontSize="11" FontWeight="SemiBold" Margin="0,8,0,2"/>
                                <ItemsControl ItemsSource="{Binding RealMigrationExecutionErrors}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}" Foreground="#991B1B" FontSize="11" TextWrapping="Wrap" Margin="0,2,0,0"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Operator Permission Authoritative Status — Read Only (Phase 10.21G) -->
                <Border Background="White" BorderBrush="#0EA5E9" BorderThickness="1"
                        Padding="12" Margin="0,0,0,10" CornerRadius="6">
                    <StackPanel>
                        <TextBlock Text="Operator Permission Authoritative Status — Read Only (Phase 10.21G)"
                                   FontSize="13" FontWeight="SemiBold" Foreground="#075985"/>
                        <TextBlock Text="This section is read-only. It shows DB-authoritative permission mode, parity/preflight readiness, and risk status. It does not grant, revoke, approve, or execute maintenance operations."
                                   FontSize="10" Foreground="#075985" TextWrapping="Wrap" Margin="0,2,0,6"/>

                        <!-- Local flag + refresh -->
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="240"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="Local flag state"   Grid.Row="0" Grid.Column="0" Foreground="#475569"/>
                            <TextBlock Text="{Binding PermissionAuthoritativeStatusUiStatusText}" Grid.Row="0" Grid.Column="1" TextWrapping="Wrap"/>
                            <Button Content="Refresh"            Grid.Row="0" Grid.Column="2" Margin="6,0,0,0"
                                    Command="{Binding RefreshPermissionAuthoritativeStatusCommand}"
                                    IsEnabled="{Binding PermissionAuthoritativeStatusUiEnabled}"/>
                            <TextBlock Text="Status message"     Grid.Row="1" Grid.Column="0" Foreground="#475569" Margin="0,4,0,0"/>
                            <TextBlock Text="{Binding PermissionAuthoritativeStatusMessage}" Grid.Row="1" Grid.Column="1" TextWrapping="Wrap" Margin="0,4,0,0"/>
                            <Button Content="Clear"              Grid.Row="1" Grid.Column="2" Margin="6,4,0,0"
                                    Command="{Binding ClearPermissionAuthoritativeStatusCommand}"/>
                        </Grid>

                        <!-- Summary line -->
                        <Grid Margin="0,4,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="240"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="Generated at"                            Grid.Row="0"  Grid.Column="0" Foreground="#475569"/>
                            <TextBlock Text="{Binding PermissionAuthoritativeGeneratedAt}"             Grid.Row="0"  Grid.Column="1" TextWrapping="Wrap"/>
                            <TextBlock Text="permissionsSource"                       Grid.Row="1"  Grid.Column="0" Foreground="#475569" Margin="0,4,0,0"/>
                            <TextBlock Text="{Binding PermissionAuthoritativePermissionsSource}"      Grid.Row="1"  Grid.Column="1" TextWrapping="Wrap" Margin="0,4,0,0"/>
                            <TextBlock Text="Read-only authoritative"                 Grid.Row="2"  Grid.Column="0" Foreground="#475569" Margin="0,4,0,0"/>
                            <TextBlock Text="{Binding PermissionAuthoritativeReadOnlyEnabled}"        Grid.Row="2"  Grid.Column="1" Margin="0,4,0,0"/>
                            <TextBlock Text="Dangerous preflight"                     Grid.Row="3"  Grid.Column="0" Foreground="#475569" Margin="0,4,0,0"/>
                            <TextBlock Text="{Binding PermissionAuthoritativeDangerousPreflightEnabled}" Grid.Row="3" Grid.Column="1" Margin="0,4,0,0"/>
                            <TextBlock Text="Dangerous authoritative"                 Grid.Row="4"  Grid.Column="0" Foreground="#475569" Margin="0,4,0,0"/>
                            <TextBlock Text="{Binding PermissionAuthoritativeDangerousEnabled}"       Grid.Row="4"  Grid.Column="1" Margin="0,4,0,0"/>
                            <TextBlock Text="fail_on_mismatch"                        Grid.Row="5"  Grid.Column="0" Foreground="#475569" Margin="0,4,0,0"/>
                            <TextBlock Text="{Binding PermissionAuthoritativeFailOnMismatch}"         Grid.Row="5"  Grid.Column="1" Margin="0,4,0,0"/>
                            <TextBlock Text="allow_code_fallback_readonly"            Grid.Row="6"  Grid.Column="0" Foreground="#475569" Margin="0,4,0,0"/>
                            <TextBlock Text="{Binding PermissionAuthoritativeAllowCodeFallbackReadOnly}" Grid.Row="6" Grid.Column="1" Margin="0,4,0,0"/>
                            <TextBlock Text="Parity healthy"                          Grid.Row="7"  Grid.Column="0" Foreground="#475569" Margin="0,4,0,0"/>
                            <TextBlock Text="{Binding PermissionAuthoritativeParityHealthy}"          Grid.Row="7"  Grid.Column="1" Margin="0,4,0,0"/>
                            <TextBlock Text="Dangerous preflight healthy"             Grid.Row="8"  Grid.Column="0" Foreground="#475569" Margin="0,4,0,0"/>
                            <TextBlock Text="{Binding PermissionAuthoritativeDangerousPreflightHealthy}" Grid.Row="8" Grid.Column="1" Margin="0,4,0,0"/>
                            <TextBlock Text="Ready for read-only authoritative"       Grid.Row="9"  Grid.Column="0" Foreground="#475569" Margin="0,4,0,0"/>
                            <TextBlock Text="{Binding PermissionAuthoritativeReadyForReadOnly}"       Grid.Row="9"  Grid.Column="1" Margin="0,4,0,0"/>
                            <TextBlock Text="Ready for dangerous authoritative"       Grid.Row="10" Grid.Column="0" Foreground="#475569" Margin="0,4,0,0"/>
                            <TextBlock Text="{Binding PermissionAuthoritativeReadyForDangerous}"      Grid.Row="10" Grid.Column="1" Margin="0,4,0,0"/>
                            <TextBlock Text="Blocker count"                           Grid.Row="11" Grid.Column="0" Foreground="#475569" Margin="0,4,0,0"/>
                            <TextBlock Text="{Binding PermissionAuthoritativeBlockerCount}"           Grid.Row="11" Grid.Column="1" Foreground="#B91C1C" FontWeight="SemiBold" Margin="0,4,0,0"/>
                            <TextBlock Text="Warning count"                           Grid.Row="12" Grid.Column="0" Foreground="#475569" Margin="0,4,0,0"/>
                            <TextBlock Text="{Binding PermissionAuthoritativeWarningCount}"           Grid.Row="12" Grid.Column="1" Foreground="#D97706" Margin="0,4,0,0"/>
                            <TextBlock Text="Info count"                              Grid.Row="13" Grid.Column="0" Foreground="#475569" Margin="0,4,0,0"/>
