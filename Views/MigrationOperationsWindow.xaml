<Window x:Class="PosSystem.Views.MigrationOperationsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Migration Operations"
        Height="820" Width="980"
        WindowStartupLocation="CenterOwner"
        Background="#F8FAFC">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="Migration Operations" FontSize="20" FontWeight="Bold" Foreground="#0F172A"/>
            <TextBlock Text="Read-only dashboard — no migration or rollback can be executed here."
                       FontSize="11" Foreground="#475569" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Tenant + actions -->
        <Border Grid.Row="1" Background="White" BorderBrush="#E2E8F0" BorderThickness="1"
                Padding="12" Margin="0,0,0,12" CornerRadius="6">
            <DockPanel>
                <StackPanel DockPanel.Dock="Left" MinWidth="220" Margin="0,0,12,0">
                    <TextBlock Text="Tenant subdomain (optional)" FontSize="11" Foreground="#475569"/>
                    <TextBox Text="{Binding TenantSubdomainInput, UpdateSourceTrigger=PropertyChanged}"
                             FontSize="13" Padding="6,4"/>
                </StackPanel>

                <WrapPanel HorizontalAlignment="Right" VerticalAlignment="Bottom">
                    <Button Command="{Binding RefreshCommand}"
                            Content="Refresh"
                            Padding="12,6" Margin="0,4,8,0"
                            Background="#1E40AF" Foreground="White" BorderThickness="0"
                            Cursor="Hand"/>

                    <Button Command="{Binding ExportDiagnosticsCommand}"
                            Content="Export Diagnostics JSON"
                            Padding="12,6" Margin="0,4,8,0"
                            Background="#0F766E" Foreground="White" BorderThickness="0"
                            Cursor="Hand"/>

                    <Button Command="{Binding PreviewMigrationDryRunCommand}"
                            Content="Preview Migration Dry-Run"
                            Padding="12,6" Margin="0,4,8,0"
                            Background="#6B7280" Foreground="White" BorderThickness="0"
                            Cursor="Hand"
                            ToolTip="Read-only preview. Does not perform migration."/>

                    <Button Command="{Binding PreviewRollbackDryRunCommand}"
                            Content="Preview Rollback Dry-Run"
                            Padding="12,6" Margin="0,4,8,0"
                            Background="#475569" Foreground="White" BorderThickness="0"
                            Cursor="Hand"
                            ToolTip="Read-only preview. Does not perform rollback."/>

                    <Button Command="{Binding ExportPreflightReportCommand}"
                            Content="Export Preflight Report"
                            Padding="12,6" Margin="0,4,8,0"
                            Background="#1D4ED8" Foreground="White" BorderThickness="0"
                            Cursor="Hand"
                            ToolTip="Read-only preflight bundle. Does not perform migration or rollback."/>

                    <Button Command="{Binding RefreshInventoryCommand}"
                            Content="Refresh Inventory"
                            Padding="12,6" Margin="0,4,8,0"
                            Background="#0E7490" Foreground="White" BorderThickness="0"
                            Cursor="Hand"
                            ToolTip="Read-only filesystem inventory. Does not delete, archive, rename, restore, or copy anything."/>

                    <Button Command="{Binding PreviewRetentionPlanCommand}"
                            Content="Preview Retention Plan"
                            Padding="12,6" Margin="0,4,8,0"
                            Background="#7C3AED" Foreground="White" BorderThickness="0"
                            Cursor="Hand"
                            ToolTip="Read-only retention classification. Does not delete, move, or modify anything."/>

                    <Button Command="{Binding ExportInventoryReportCommand}"
                            Content="Export Inventory Report"
                            Padding="12,6" Margin="0,4,8,0"
                            Background="#0369A1" Foreground="White" BorderThickness="0"
                            Cursor="Hand"
                            ToolTip="Read-only inventory + retention bundle. Writes one redacted JSON file. Does not delete, move, or modify anything else."/>

                    <Button Command="{Binding CheckRealMigrationGateCommand}"
                            Content="Check Real Migration Gate"
                            Padding="12,6" Margin="0,4,8,0"
                            Background="#B45309" Foreground="White" BorderThickness="0"
                            Cursor="Hand"
                            ToolTip="Read-only readiness verdict. Does not execute migration."/>

                    <Button Command="{Binding ExecuteRealMigrationCommand}"
                            Content="Execute Real Migration"
                            Padding="12,6" Margin="0,4,8,0"
                            Background="#B91C1C" Foreground="White" BorderThickness="0"
                            Cursor="Hand"
                            ToolTip="DESTRUCTIVE. Routed exclusively through GuardedRealMigrationExecutorService. Does not enable tenant runtime mode and does not switch database."/>

                    <Button Command="{Binding ExecuteRuntimeCutoverCommand}"
                            Content="Execute Runtime Cutover"
                            Padding="12,6" Margin="0,4,8,0"
                            Background="#C2410C" Foreground="White" BorderThickness="0"
                            Cursor="Hand"
                            ToolTip="Routed exclusively through GuardedRuntimeCutoverExecutorService. Enables tenant DB runtime mode for next startup/login. Does NOT switch the current database session and does NOT restart/logout."/>

                    <Button Command="{Binding ExecuteRollbackCommand}"
                            Content="Execute Rollback"
                            Padding="12,6" Margin="0,4,8,0"
                            Background="#7F1D1D" Foreground="White" BorderThickness="0"
                            Cursor="Hand"
                            ToolTip="DESTRUCTIVE. Routed exclusively through GuardedRollbackExecutorService. May archive tenants directory and disable runtime flag. Does NOT switch the current database session and does NOT restart/logout."/>

                    <Button Command="{Binding ExecuteRetentionCleanupCommand}"
                            Content="Execute Retention Cleanup"
                            Padding="12,6" Margin="0,4,0,0"
                            Background="#7C2D12" Foreground="White" BorderThickness="0"
                            Cursor="Hand"
                            ToolTip="Routed exclusively through GuardedRetentionCleanupExecutorService. Deletes only retention preview candidates. Never accepts arbitrary paths. Does NOT switch DB, restart, or logout."/>
                </WrapPanel>
            </DockPanel>
        </Border>

        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- Dangerous Operation Lock (Phase 10.15A) -->
                <Border Background="White" BorderBrush="#E2E8F0" BorderThickness="1"
                        Padding="12" Margin="0,0,0,10" CornerRadius="6">
                    <StackPanel>
                        <TextBlock Text="Dangerous Operation Lock" FontSize="13" FontWeight="SemiBold" Foreground="#0F172A"/>
                        <Grid Margin="0,6,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="240"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="Dangerous operation running" Grid.Row="0" Grid.Column="0" Foreground="#475569"/>
                            <TextBlock Text="{Binding IsDangerousOperationRunning}" Grid.Row="0" Grid.Column="1"/>
                            <TextBlock Text="Operation name"             Grid.Row="1" Grid.Column="0" Foreground="#475569" Margin="0,4,0,0"/>
                            <TextBlock Text="{Binding DangerousOperationName}" Grid.Row="1" Grid.Column="1" Margin="0,4,0,0"/>
                            <TextBlock Text="Status message"             Grid.Row="2" Grid.Column="0" Foreground="#475569" Margin="0,4,0,0"/>
                            <TextBlock Text="{Binding DangerousOperationStatusMessage}" Grid.Row="2" Grid.Column="1" TextWrapping="Wrap" Margin="0,4,0,0"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Production Pilot Readiness (Phase 10.17A) -->
                <Border Background="#F0FDF4" BorderBrush="#10B981" BorderThickness="1"
                        Padding="12" Margin="0,0,0,10" CornerRadius="6">
                    <StackPanel>
                        <TextBlock Text="Production Pilot Readiness" FontSize="13" FontWeight="SemiBold" Foreground="#064E3B"/>
                        <TextBlock Text="This is a read-only readiness report. It does not execute migration, cutover, rollback, cleanup, DB switch, logout, or restart."
                                   FontSize="11" Foreground="#065F46" TextWrapping="Wrap" Margin="0,4,0,6"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="240"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="Overall status"           Grid.Row="0" Grid.Column="0" Foreground="#475569"/>
                            <TextBlock Text="{Binding PilotReadinessOverallStatus}" Grid.Row="0" Grid.Column="1"/>
                            <TextBlock Text="Generated (UTC)"          Grid.Row="1" Grid.Column="0" Foreground="#475569" Margin="0,4,0,0"/>
                            <TextBlock Text="{Binding PilotReadinessGeneratedAtUtc}" Grid.Row="1" Grid.Column="1" Margin="0,4,0,0"/>
                            <TextBlock Text="Export path"              Grid.Row="2" Grid.Column="0" Foreground="#475569" Margin="0,4,0,0"/>
                            <TextBlock Text="{Binding PilotReadinessExportPath}" Grid.Row="2" Grid.Column="1" TextWrapping="Wrap" Margin="0,4,0,0"/>
                        </Grid>

                        <TextBlock Text="{Binding PilotReadinessStatusMessage}"
                                   Foreground="#0F172A" TextWrapping="Wrap" Margin="0,8,0,0"/>

                        <Button Command="{Binding GeneratePilotReadinessReportCommand}"
                                Content="Generate Pilot Readiness Report"
                                HorizontalAlignment="Left"
                                Padding="14,6" Margin="0,10,0,0"
                                Background="#0EA5E9" Foreground="White" BorderThickness="0"
                                Cursor="Hand"
                                FontWeight="SemiBold"
                                ToolTip="Read-only readiness check. Does not execute migration, cutover, rollback, cleanup, DB switch, logout, or restart."/>

                        <TextBlock Text="Checks:" Foreground="#475569"
                                   FontSize="11" FontWeight="SemiBold" Margin="0,10,0,2"/>
                        <ItemsControl ItemsSource="{Binding PilotReadinessChecks}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" Foreground="#475569" FontSize="11" TextWrapping="Wrap" Margin="0,2,0,0"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Text="Blocking reasons:" Foreground="#991B1B"
                                   FontSize="11" FontWeight="SemiBold" Margin="0,8,0,2"/>
                        <ItemsControl ItemsSource="{Binding PilotReadinessBlockingReasons}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" Foreground="#991B1B" FontSize="11" TextWrapping="Wrap" Margin="0,2,0,0"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Text="Warnings:" Foreground="#92400E"
                                   FontSize="11" FontWeight="SemiBold" Margin="0,8,0,2"/>
                        <ItemsControl ItemsSource="{Binding PilotReadinessWarnings}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" Foreground="#92400E" FontSize="11" TextWrapping="Wrap" Margin="0,2,0,0"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Text="Recommended next steps:" Foreground="#475569"
                                   FontSize="11" FontWeight="SemiBold" Margin="0,8,0,2"/>
                        <ItemsControl ItemsSource="{Binding PilotReadinessRecommendedNextSteps}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" Foreground="#475569" FontSize="11" TextWrapping="Wrap" Margin="0,2,0,0"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Production Pilot Evidence Bundle (Phase 10.17B) -->
                <Border Background="#ECFDF5" BorderBrush="#059669" BorderThickness="1"
                        Padding="12" Margin="0,0,0,10" CornerRadius="6">
                    <StackPanel>
                        <TextBlock Text="Production Pilot Evidence Bundle" FontSize="13" FontWeight="SemiBold" Foreground="#064E3B"/>
                        <TextBlock Text="This export is read-only. It writes sanitized JSON summaries only and does not include DB files, backups, tokens, or raw confirmation phrases."
                                   FontSize="11" Foreground="#065F46" TextWrapping="Wrap" Margin="0,4,0,6"/>

                        <Button Command="{Binding ExportPilotEvidenceBundleCommand}"
                                Content="Export Pilot Evidence Bundle"
                                HorizontalAlignment="Left"
                                Padding="14,6" Margin="0,4,0,8"
                                Background="#0891B2" Foreground="White" BorderThickness="0"
                                Cursor="Hand"
                                FontWeight="SemiBold"
                                ToolTip="Read-only. Writes sanitized JSON summaries only. No DB files, backups, tokens, or raw confirmation phrases."/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="240"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="Outcome"            Grid.Row="0" Grid.Column="0" Foreground="#475569"/>
                            <TextBlock Text="{Binding PilotEvidenceOutcome}" Grid.Row="0" Grid.Column="1"/>
                            <TextBlock Text="Bundle directory"   Grid.Row="1" Grid.Column="0" Foreground="#475569" Margin="0,2,0,0"/>
                            <TextBlock Text="{Binding PilotEvidenceBundleDirectory}" Grid.Row="1" Grid.Column="1" TextWrapping="Wrap" Margin="0,2,0,0"/>
                            <TextBlock Text="ZIP path"           Grid.Row="2" Grid.Column="0" Foreground="#475569" Margin="0,2,0,0"/>
                            <TextBlock Text="{Binding PilotEvidenceBundleZipPath}" Grid.Row="2" Grid.Column="1" TextWrapping="Wrap" Margin="0,2,0,0"/>
                            <TextBlock Text="Manifest path"      Grid.Row="3" Grid.Column="0" Foreground="#475569" Margin="0,2,0,0"/>
                            <TextBlock Text="{Binding PilotEvidenceManifestPath}" Grid.Row="3" Grid.Column="1" TextWrapping="Wrap" Margin="0,2,0,0"/>
                            <TextBlock Text="Started / Completed (UTC)" Grid.Row="4" Grid.Column="0" Foreground="#475569" Margin="0,2,0,0"/>
                            <StackPanel Grid.Row="4" Grid.Column="1" Orientation="Horizontal" Margin="0,2,0,0">
                                <TextBlock Text="{Binding PilotEvidenceStartedAtUtc}"/>
                                <TextBlock Text=" → "/>
                                <TextBlock Text="{Binding PilotEvidenceCompletedAtUtc}"/>
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="{Binding PilotEvidenceStatusMessage}"
                                   Foreground="#0F172A" TextWrapping="Wrap" Margin="0,6,0,0"/>

                        <TextBlock Text="Included files:" Foreground="#475569"
                                   FontSize="11" FontWeight="SemiBold" Margin="0,8,0,2"/>
                        <ItemsControl ItemsSource="{Binding PilotEvidenceIncludedFiles}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" Foreground="#475569" FontSize="11" TextWrapping="Wrap" Margin="0,2,0,0"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Text="Steps:" Foreground="#475569"
                                   FontSize="11" FontWeight="SemiBold" Margin="0,8,0,2"/>
                        <ItemsControl ItemsSource="{Binding PilotEvidenceSteps}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" Foreground="#475569" FontSize="11" TextWrapping="Wrap" Margin="0,2,0,0"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Text="Warnings:" Foreground="#92400E"
                                   FontSize="11" FontWeight="SemiBold" Margin="0,8,0,2"/>
                        <ItemsControl ItemsSource="{Binding PilotEvidenceWarnings}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" Foreground="#92400E" FontSize="11" TextWrapping="Wrap" Margin="0,2,0,0"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Text="Errors:" Foreground="#991B1B"
                                   FontSize="11" FontWeight="SemiBold" Margin="0,8,0,2"/>
                        <ItemsControl ItemsSource="{Binding PilotEvidenceErrors}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" Foreground="#991B1B" FontSize="11" TextWrapping="Wrap" Margin="0,2,0,0"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Backend Operator Permissions (Phase 10.19C — display-only) -->
                <Border Background="#EFF6FF" BorderBrush="#1D4ED8" BorderThickness="1"
                        Padding="12" Margin="0,0,0,10" CornerRadius="6">
                    <StackPanel>
                        <TextBlock Text="Backend Operator Permissions" FontSize="13" FontWeight="SemiBold" Foreground="#1E3A8A"/>
                        <TextBlock Text="This section is read-only. Backend permissions are displayed for visibility only and do not yet change desktop button gating."
                                   FontSize="11" FontWeight="SemiBold" Foreground="#1E40AF" TextWrapping="Wrap" Margin="0,4,0,2"/>
                        <TextBlock Text="Local flags and guarded wrapper services remain the authoritative gates for every dangerous operation. Phase 10.19C does not enforce backend permissions."
                                   FontSize="11" Foreground="#1E3A8A" TextWrapping="Wrap" Margin="0,0,0,6"/>

                        <Button Command="{Binding RefreshBackendOperatorPermissionsCommand}"
                                Content="Refresh Backend Operator Permissions"
                                HorizontalAlignment="Left"
                                Padding="14,6" Margin="0,4,0,8"
                                Background="#1D4ED8" Foreground="White" BorderThickness="0"
                                Cursor="Hand"
                                FontWeight="SemiBold"
                                ToolTip="Read-only fetch from the Phase 10.19B backend. Does not gate any desktop button."/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="240"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="Status"                Grid.Row="0"  Grid.Column="0" Foreground="#475569"/>
                            <TextBlock Text="{Binding BackendOperatorPermissionsStatus}" Grid.Row="0" Grid.Column="1" TextWrapping="Wrap"/>

                            <TextBlock Text="User id"               Grid.Row="1"  Grid.Column="0" Foreground="#475569" Margin="0,2,0,0"/>
                            <TextBlock Text="{Binding BackendOperatorUserId}" Grid.Row="1" Grid.Column="1" Margin="0,2,0,0"/>
                            <TextBlock Text="Username"              Grid.Row="2"  Grid.Column="0" Foreground="#475569" Margin="0,2,0,0"/>
                            <TextBlock Text="{Binding BackendOperatorUsername}" Grid.Row="2" Grid.Column="1" Margin="0,2,0,0"/>
                            <TextBlock Text="Backend role"          Grid.Row="3"  Grid.Column="0" Foreground="#475569" Margin="0,2,0,0"/>
                            <TextBlock Text="{Binding BackendOperatorRole}" Grid.Row="3" Grid.Column="1" Margin="0,2,0,0"/>
                            <TextBlock Text="Tenant id"             Grid.Row="4"  Grid.Column="0" Foreground="#475569" Margin="0,2,0,0"/>
                            <TextBlock Text="{Binding BackendOperatorTenantId}" Grid.Row="4" Grid.Column="1" Margin="0,2,0,0"/>
                            <TextBlock Text="Store id"              Grid.Row="5"  Grid.Column="0" Foreground="#475569" Margin="0,2,0,0"/>
                            <TextBlock Text="{Binding BackendOperatorStoreId}" Grid.Row="5" Grid.Column="1" Margin="0,2,0,0"/>
                            <TextBlock Text="Authenticated"         Grid.Row="6"  Grid.Column="0" Foreground="#475569" Margin="0,2,0,0"/>
                            <TextBlock Text="{Binding BackendOperatorAuthenticated}" Grid.Row="6" Grid.Column="1" Margin="0,2,0,0"/>
                            <TextBlock Text="Permissions source"    Grid.Row="7"  Grid.Column="0" Foreground="#475569" Margin="0,2,0,0"/>
                            <TextBlock Text="{Binding BackendOperatorPermissionsSource}" Grid.Row="7" Grid.Column="1" Margin="0,2,0,0"/>
                            <TextBlock Text="Generated (UTC)"       Grid.Row="8"  Grid.Column="0" Foreground="#475569" Margin="0,2,0,0"/>
                            <TextBlock Text="{Binding BackendOperatorPermissionsGeneratedAt}" Grid.Row="8" Grid.Column="1" Margin="0,2,0,0"/>
                            <TextBlock Text="Expires (UTC)"         Grid.Row="9"  Grid.Column="0" Foreground="#475569" Margin="0,2,0,0"/>
                            <TextBlock Text="{Binding BackendOperatorPermissionsExpiresAt}" Grid.Row="9" Grid.Column="1" Margin="0,2,0,0"/>
                            <TextBlock Text="Permission count"      Grid.Row="10" Grid.Column="0" Foreground="#475569" Margin="0,2,0,0"/>
                            <StackPanel Grid.Row="10" Grid.Column="1" Orientation="Horizontal" Margin="0,2,0,0">
                                <TextBlock Text="{Binding BackendOperatorPermissionCount}"/>
                                <TextBlock Text="  (dangerous: "/>
                                <TextBlock Text="{Binding BackendOperatorDangerousPermissionCount}"/>
                                <TextBlock Text=", read-only: "/>
                                <TextBlock Text="{Binding BackendOperatorReadOnlyPermissionCount}"/>
                                <TextBlock Text=")"/>
                            </StackPanel>
                            <TextBlock Text=""                      Grid.Row="11" Grid.Column="0"/>
                            <TextBlock Grid.Row="11" Grid.Column="1" Margin="0,2,0,0"/>
                        </Grid>

                        <!-- Phase 10.19D — backend permission enforcement state + last preflight. -->
                        <Border Background="White" BorderBrush="#93C5FD" BorderThickness="1"
                                Padding="8" Margin="0,8,0,0" CornerRadius="4">
                            <StackPanel>
                                <TextBlock Text="Backend permission enforcement" FontSize="11" FontWeight="SemiBold" Foreground="#1E3A8A"/>
                                <Grid Margin="0,4,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="220"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="Enforcement state"     Grid.Row="0" Grid.Column="0" Foreground="#475569"/>
                                    <TextBlock Text="{Binding BackendPermissionEnforcementStatusText}" Grid.Row="0" Grid.Column="1" TextWrapping="Wrap"/>
                                    <TextBlock Text="Last preflight op"     Grid.Row="1" Grid.Column="0" Foreground="#475569" Margin="0,2,0,0"/>
                                    <TextBlock Text="{Binding BackendPermissionLastPreflightOperation}" Grid.Row="1" Grid.Column="1" Margin="0,2,0,0"/>
                                    <TextBlock Text="Last preflight key"    Grid.Row="2" Grid.Column="0" Foreground="#475569" Margin="0,2,0,0"/>
                                    <TextBlock Text="{Binding BackendPermissionLastPreflightKey}" Grid.Row="2" Grid.Column="1" Margin="0,2,0,0"/>
                                    <TextBlock Text="Last preflight status" Grid.Row="3" Grid.Column="0" Foreground="#475569" Margin="0,2,0,0"/>
                                    <TextBlock Text="{Binding BackendPermissionLastPreflightStatus}" Grid.Row="3" Grid.Column="1" Margin="0,2,0,0"/>
                                    <TextBlock Text="Last preflight reason" Grid.Row="4" Grid.Column="0" Foreground="#475569" Margin="0,2,0,0"/>
                                    <TextBlock Text="{Binding BackendPermissionLastPreflightReason}" Grid.Row="4" Grid.Column="1" TextWrapping="Wrap" Margin="0,2,0,0"/>
                                    <TextBlock Text="Last preflight (UTC)"  Grid.Row="5" Grid.Column="0" Foreground="#475569" Margin="0,2,0,0"/>
                                    <TextBlock Text="{Binding BackendPermissionLastPreflightAtUtc}" Grid.Row="5" Grid.Column="1" Margin="0,2,0,0"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Phase 10.19G — backend audit-intent + evidence-registration display-only sub-card. -->
                        <Border Background="White" BorderBrush="#93C5FD" BorderThickness="1"
                                Padding="8" Margin="0,8,0,0" CornerRadius="4">
                            <StackPanel>
                                <TextBlock Text="Backend audit / evidence integration (Phase 10.19G)"
                                           FontSize="11" FontWeight="SemiBold" Foreground="#1E3A8A"/>
                                <TextBlock Text="These backend calls are metadata-only. They do not approve or execute desktop maintenance operations."
                                           FontSize="10" Foreground="#475569" TextWrapping="Wrap" Margin="0,2,0,0"/>

                                <TextBlock Text="Audit intent" FontSize="11" FontWeight="SemiBold"
                                           Foreground="#1E3A8A" Margin="0,8,0,0"/>
                                <Grid Margin="0,4,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="220"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="Flag state"          Grid.Row="0" Grid.Column="0" Foreground="#475569"/>
                                    <TextBlock Text="{Binding BackendAuditIntentFlagStatusText}" Grid.Row="0" Grid.Column="1" TextWrapping="Wrap"/>
                                    <TextBlock Text="Last operation"      Grid.Row="1" Grid.Column="0" Foreground="#475569" Margin="0,2,0,0"/>
                                    <TextBlock Text="{Binding BackendAuditIntentLastOperation}"      Grid.Row="1" Grid.Column="1" Margin="0,2,0,0"/>
                                    <TextBlock Text="Last permission key" Grid.Row="2" Grid.Column="0" Foreground="#475569" Margin="0,2,0,0"/>
                                    <TextBlock Text="{Binding BackendAuditIntentLastPermissionKey}"  Grid.Row="2" Grid.Column="1" Margin="0,2,0,0"/>
                                    <TextBlock Text="Last status"         Grid.Row="3" Grid.Column="0" Foreground="#475569" Margin="0,2,0,0"/>
                                    <TextBlock Text="{Binding BackendAuditIntentLastStatus}"         Grid.Row="3" Grid.Column="1" Margin="0,2,0,0"/>
                                    <TextBlock Text="Last intent id"      Grid.Row="4" Grid.Column="0" Foreground="#475569" Margin="0,2,0,0"/>
                                    <TextBlock Text="{Binding BackendAuditIntentLastIntentId}"       Grid.Row="4" Grid.Column="1" TextWrapping="Wrap" Margin="0,2,0,0"/>
                                    <TextBlock Text="Last reason"         Grid.Row="5" Grid.Column="0" Foreground="#475569" Margin="0,2,0,0"/>
                                    <TextBlock Text="{Binding BackendAuditIntentLastReason}"         Grid.Row="5" Grid.Column="1" TextWrapping="Wrap" Margin="0,2,0,0"/>
                                    <TextBlock Text="Last call (UTC)"     Grid.Row="6" Grid.Column="0" Foreground="#475569" Margin="0,2,0,0"/>
                                    <TextBlock Text="{Binding BackendAuditIntentLastAtUtc}"          Grid.Row="6" Grid.Column="1" Margin="0,2,0,0"/>
                                </Grid>

                                <TextBlock Text="Evidence registration" FontSize="11" FontWeight="SemiBold"
                                           Foreground="#1E3A8A" Margin="0,8,0,0"/>
                                <Grid Margin="0,4,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="220"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="Flag state"            Grid.Row="0" Grid.Column="0" Foreground="#475569"/>
                                    <TextBlock Text="{Binding BackendEvidenceRegistrationFlagStatusText}" Grid.Row="0" Grid.Column="1" TextWrapping="Wrap"/>
                                    <TextBlock Text="Last status"           Grid.Row="1" Grid.Column="0" Foreground="#475569" Margin="0,2,0,0"/>
                                    <TextBlock Text="{Binding BackendEvidenceRegistrationLastStatus}"        Grid.Row="1" Grid.Column="1" Margin="0,2,0,0"/>
                                    <TextBlock Text="Last bundle id"        Grid.Row="2" Grid.Column="0" Foreground="#475569" Margin="0,2,0,0"/>
                                    <TextBlock Text="{Binding BackendEvidenceRegistrationLastBundleId}"      Grid.Row="2" Grid.Column="1" TextWrapping="Wrap" Margin="0,2,0,0"/>
                                    <TextBlock Text="Last registration id"  Grid.Row="3" Grid.Column="0" Foreground="#475569" Margin="0,2,0,0"/>
                                    <TextBlock Text="{Binding BackendEvidenceRegistrationLastRegistrationId}" Grid.Row="3" Grid.Column="1" TextWrapping="Wrap" Margin="0,2,0,0"/>
                                    <TextBlock Text="Last reason"           Grid.Row="4" Grid.Column="0" Foreground="#475569" Margin="0,2,0,0"/>
                                    <TextBlock Text="{Binding BackendEvidenceRegistrationLastReason}"        Grid.Row="4" Grid.Column="1" TextWrapping="Wrap" Margin="0,2,0,0"/>
                                    <TextBlock Text="Last call (UTC)"       Grid.Row="5" Grid.Column="0" Foreground="#475569" Margin="0,2,0,0"/>
                                    <TextBlock Text="{Binding BackendEvidenceRegistrationLastAtUtc}"         Grid.Row="5" Grid.Column="1" Margin="0,2,0,0"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="All permissions:" Foreground="#475569"
                                   FontSize="11" FontWeight="SemiBold" Margin="0,8,0,2"/>
                        <ItemsControl ItemsSource="{Binding BackendOperatorPermissions}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" Foreground="#475569" FontSize="11" TextWrapping="Wrap" Margin="0,2,0,0"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Text="Dangerous permissions:" Foreground="#991B1B"
                                   FontSize="11" FontWeight="SemiBold" Margin="0,8,0,2"/>
                        <ItemsControl ItemsSource="{Binding BackendOperatorDangerousPermissions}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" Foreground="#991B1B" FontSize="11" TextWrapping="Wrap" Margin="0,2,0,0"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Text="Read-only permissions:" Foreground="#475569"
                                   FontSize="11" FontWeight="SemiBold" Margin="0,8,0,2"/>
                        <ItemsControl ItemsSource="{Binding BackendOperatorReadOnlyPermissions}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" Foreground="#475569" FontSize="11" TextWrapping="Wrap" Margin="0,2,0,0"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Text="Warnings:" Foreground="#92400E"
                                   FontSize="11" FontWeight="SemiBold" Margin="0,8,0,2"/>
                        <ItemsControl ItemsSource="{Binding BackendOperatorPermissionWarnings}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" Foreground="#92400E" FontSize="11" TextWrapping="Wrap" Margin="0,2,0,0"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Text="Errors:" Foreground="#991B1B"
                                   FontSize="11" FontWeight="SemiBold" Margin="0,8,0,2"/>
                        <ItemsControl ItemsSource="{Binding BackendOperatorPermissionErrors}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" Foreground="#991B1B" FontSize="11" TextWrapping="Wrap" Margin="0,2,0,0"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Backend Operator Audit / Evidence Review (Phase 10.19J — read-only) -->
                <Border Background="White" BorderBrush="#93C5FD" BorderThickness="1"
                        Padding="12" Margin="0,0,0,10" CornerRadius="6">
                    <StackPanel>
                        <TextBlock Text="Backend Operator Audit / Evidence Review (Phase 10.19J)"
                                   FontSize="13" FontWeight="SemiBold" Foreground="#1E3A8A"/>
                        <TextBlock Text="This section is read-only. It reviews sanitized backend audit/evidence metadata only. It does not approve, execute, delete, or modify maintenance operations."
                                   FontSize="10" Foreground="#475569" TextWrapping="Wrap" Margin="0,2,0,6"/>

                        <!-- Flag state + status -->
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="220"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="Feature flag state" Grid.Row="0" Grid.Column="0" Foreground="#475569"/>
                            <TextBlock Text="{Binding BackendAuditReviewUiStatusText}" Grid.Row="0" Grid.Column="1" TextWrapping="Wrap"/>
                            <TextBlock Text="Status message"     Grid.Row="1" Grid.Column="0" Foreground="#475569" Margin="0,4,0,0"/>
                            <TextBlock Text="{Binding BackendAuditReviewStatusMessage}" Grid.Row="1" Grid.Column="1" TextWrapping="Wrap" Margin="0,4,0,0"/>
                        </Grid>

                        <!-- Filters -->
                        <Border Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1"
                                Padding="8" Margin="0,4,0,0" CornerRadius="4">
                            <StackPanel>
                                <TextBlock Text="Filters" FontSize="11" FontWeight="SemiBold" Foreground="#1E3A8A"/>
                                <Grid Margin="0,4,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="160"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="tenantId"        Grid.Row="0" Grid.Column="0" Foreground="#475569"/>
                                    <TextBox   Text="{Binding BackendAuditReviewFilterTenantId, UpdateSourceTrigger=PropertyChanged}"
                                               Grid.Row="0" Grid.Column="1"/>
                                    <TextBlock Text="entityType"      Grid.Row="1" Grid.Column="0" Foreground="#475569" Margin="0,4,0,0"/>
                                    <TextBox   Text="{Binding BackendAuditReviewFilterEntityType, UpdateSourceTrigger=PropertyChanged}"
                                               Grid.Row="1" Grid.Column="1" Margin="0,4,0,0"
                                               ToolTip="OPERATOR_MAINTENANCE | OPERATOR_EVIDENCE"/>
                                    <TextBlock Text="action"          Grid.Row="2" Grid.Column="0" Foreground="#475569" Margin="0,4,0,0"/>
                                    <TextBox   Text="{Binding BackendAuditReviewFilterAction, UpdateSourceTrigger=PropertyChanged}"
                                               Grid.Row="2" Grid.Column="1" Margin="0,4,0,0"
                                               ToolTip="OPERATOR_AUDIT_INTENT_ACCEPTED | OPERATOR_AUDIT_INTENT_DENIED | OPERATOR_EVIDENCE_REGISTERED | OPERATOR_EVIDENCE_REGISTRATION_DENIED"/>
                                    <TextBlock Text="operationName"   Grid.Row="3" Grid.Column="0" Foreground="#475569" Margin="0,4,0,0"/>
                                    <TextBox   Text="{Binding BackendAuditReviewFilterOperationName, UpdateSourceTrigger=PropertyChanged}"
                                               Grid.Row="3" Grid.Column="1" Margin="0,4,0,0"/>
                                    <TextBlock Text="permissionKey"   Grid.Row="4" Grid.Column="0" Foreground="#475569" Margin="0,4,0,0"/>
                                    <TextBox   Text="{Binding BackendAuditReviewFilterPermissionKey, UpdateSourceTrigger=PropertyChanged}"
                                               Grid.Row="4" Grid.Column="1" Margin="0,4,0,0"/>
                                    <TextBlock Text="accepted (true|false|blank)" Grid.Row="5" Grid.Column="0" Foreground="#475569" Margin="0,4,0,0"/>
                                    <TextBox   Text="{Binding BackendAuditReviewFilterAccepted, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}"
                                               Grid.Row="5" Grid.Column="1" Margin="0,4,0,0"/>
                                    <TextBlock Text="page"            Grid.Row="6" Grid.Column="0" Foreground="#475569" Margin="0,4,0,0"/>
                                    <TextBox   Text="{Binding BackendAuditReviewPage, UpdateSourceTrigger=PropertyChanged}"
                                               Grid.Row="6" Grid.Column="1" Margin="0,4,0,0"/>
                                    <TextBlock Text="size (1..200)"   Grid.Row="7" Grid.Column="0" Foreground="#475569" Margin="0,4,0,0"/>
                                    <TextBox   Text="{Binding BackendAuditReviewSize, UpdateSourceTrigger=PropertyChanged}"
                                               Grid.Row="7" Grid.Column="1" Margin="0,4,0,0"/>
                                </Grid>
                                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                    <Button Command="{Binding RefreshBackendAuditReviewEventsCommand}"
                                            Content="Refresh Events" Margin="0,0,6,0"
                                            IsEnabled="{Binding BackendAuditReviewUiEnabled}"/>
                                    <Button Command="{Binding BackendAuditReviewPreviousPageCommand}"
                                            Content="Previous Page" Margin="0,0,6,0"
                                            IsEnabled="{Binding BackendAuditReviewUiEnabled}"/>
                                    <Button Command="{Binding BackendAuditReviewNextPageCommand}"
                                            Content="Next Page" Margin="0,0,6,0"
                                            IsEnabled="{Binding BackendAuditReviewUiEnabled}"/>
                                    <Button Command="{Binding ClearBackendAuditReviewFiltersCommand}"
                                            Content="Clear Filters"/>
                                </StackPanel>
                                <TextBlock Text="{Binding BackendAuditReviewTotalElements, StringFormat={}Total events: {0}}"
                                           Foreground="#475569" FontSize="11" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Lookup -->
                        <Border Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1"
                                Padding="8" Margin="0,8,0,0" CornerRadius="4">
                            <StackPanel>
                                <TextBlock Text="Single-row lookup" FontSize="11" FontWeight="SemiBold" Foreground="#1E3A8A"/>
                                <Grid Margin="0,4,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="160"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="eventId"        Grid.Row="0" Grid.Column="0" Foreground="#475569"/>
                                    <TextBox   Text="{Binding BackendAuditReviewLookupEventId, UpdateSourceTrigger=PropertyChanged}"
                                               Grid.Row="0" Grid.Column="1"/>
                                    <Button    Command="{Binding LookupBackendAuditEventCommand}"
                                               Content="Lookup Event" Grid.Row="0" Grid.Column="2" Margin="6,0,0,0"
                                               IsEnabled="{Binding BackendAuditReviewUiEnabled}"/>
                                    <TextBlock Text="intentId"       Grid.Row="1" Grid.Column="0" Foreground="#475569" Margin="0,4,0,0"/>
                                    <TextBox   Text="{Binding BackendAuditReviewLookupIntentId, UpdateSourceTrigger=PropertyChanged}"
                                               Grid.Row="1" Grid.Column="1" Margin="0,4,0,0"/>
                                    <Button    Command="{Binding LookupBackendAuditIntentCommand}"
                                               Content="Lookup Intent" Grid.Row="1" Grid.Column="2" Margin="6,4,0,0"
                                               IsEnabled="{Binding BackendAuditReviewUiEnabled}"/>
                                    <TextBlock Text="registrationId" Grid.Row="2" Grid.Column="0" Foreground="#475569" Margin="0,4,0,0"/>
                                    <TextBox   Text="{Binding BackendAuditReviewLookupRegistrationId, UpdateSourceTrigger=PropertyChanged}"
                                               Grid.Row="2" Grid.Column="1" Margin="0,4,0,0"/>
                                    <Button    Command="{Binding LookupBackendAuditEvidenceCommand}"
                                               Content="Lookup Evidence" Grid.Row="2" Grid.Column="2" Margin="6,4,0,0"
                                               IsEnabled="{Binding BackendAuditReviewUiEnabled}"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Event list -->
                        <TextBlock Text="Audit events (most recent first):" Foreground="#475569"
                                   FontSize="11" FontWeight="SemiBold" Margin="0,8,0,2"/>
                        <ItemsControl ItemsSource="{Binding BackendAuditReviewEvents}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" Foreground="#1E293B" FontFamily="Consolas"
                                               FontSize="11" TextWrapping="Wrap" Margin="0,1,0,0"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Selected event header -->
                        <Border Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1"
                                Padding="8" Margin="0,8,0,0" CornerRadius="4">
                            <StackPanel>
                                <TextBlock Text="Selected event" FontSize="11" FontWeight="SemiBold" Foreground="#1E3A8A"/>
                                <Grid Margin="0,4,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="180"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="eventId"        Grid.Row="0"  Grid.Column="0" Foreground="#475569"/>
                                    <TextBlock Text="{Binding BackendAuditReviewSelectedEventId}"       Grid.Row="0"  Grid.Column="1" TextWrapping="Wrap"/>
                                    <TextBlock Text="action"         Grid.Row="1"  Grid.Column="0" Foreground="#475569" Margin="0,2,0,0"/>
                                    <TextBlock Text="{Binding BackendAuditReviewSelectedAction}"        Grid.Row="1"  Grid.Column="1" Margin="0,2,0,0"/>
                                    <TextBlock Text="entityType"     Grid.Row="2"  Grid.Column="0" Foreground="#475569" Margin="0,2,0,0"/>
                                    <TextBlock Text="{Binding BackendAuditReviewSelectedEntityType}"    Grid.Row="2"  Grid.Column="1" Margin="0,2,0,0"/>
                                    <TextBlock Text="entityId"       Grid.Row="3"  Grid.Column="0" Foreground="#475569" Margin="0,2,0,0"/>
                                    <TextBlock Text="{Binding BackendAuditReviewSelectedEntityId}"      Grid.Row="3"  Grid.Column="1" TextWrapping="Wrap" Margin="0,2,0,0"/>
                                    <TextBlock Text="tenantId"       Grid.Row="4"  Grid.Column="0" Foreground="#475569" Margin="0,2,0,0"/>
                                    <TextBlock Text="{Binding BackendAuditReviewSelectedTenantId}"      Grid.Row="4"  Grid.Column="1" Margin="0,2,0,0"/>
                                    <TextBlock Text="username"       Grid.Row="5"  Grid.Column="0" Foreground="#475569" Margin="0,2,0,0"/>
                                    <TextBlock Text="{Binding BackendAuditReviewSelectedUsername}"      Grid.Row="5"  Grid.Column="1" Margin="0,2,0,0"/>
                                    <TextBlock Text="role"           Grid.Row="6"  Grid.Column="0" Foreground="#475569" Margin="0,2,0,0"/>
                                    <TextBlock Text="{Binding BackendAuditReviewSelectedRole}"          Grid.Row="6"  Grid.Column="1" Margin="0,2,0,0"/>
                                    <TextBlock Text="operationName"  Grid.Row="7"  Grid.Column="0" Foreground="#475569" Margin="0,2,0,0"/>
                                    <TextBlock Text="{Binding BackendAuditReviewSelectedOperationName}" Grid.Row="7"  Grid.Column="1" Margin="0,2,0,0"/>
                                    <TextBlock Text="permissionKey"  Grid.Row="8"  Grid.Column="0" Foreground="#475569" Margin="0,2,0,0"/>
                                    <TextBlock Text="{Binding BackendAuditReviewSelectedPermissionKey}" Grid.Row="8"  Grid.Column="1" Margin="0,2,0,0"/>
                                    <TextBlock Text="accepted"       Grid.Row="9"  Grid.Column="0" Foreground="#475569" Margin="0,2,0,0"/>
                                    <TextBlock Text="{Binding BackendAuditReviewSelectedAccepted}"      Grid.Row="9"  Grid.Column="1" Margin="0,2,0,0"/>
                                    <TextBlock Text="auditSource"    Grid.Row="10" Grid.Column="0" Foreground="#475569" Margin="0,2,0,0"/>
                                    <TextBlock Text="{Binding BackendAuditReviewSelectedAuditSource}"   Grid.Row="10" Grid.Column="1" Margin="0,2,0,0"/>
                                    <TextBlock Text="redacted"       Grid.Row="11" Grid.Column="0" Foreground="#475569" Margin="0,2,0,0"/>
                                    <TextBlock Text="{Binding BackendAuditReviewSelectedRedacted}"      Grid.Row="11" Grid.Column="1" Margin="0,2,0,0"/>
                                    <TextBlock Text="reviewSource"   Grid.Row="12" Grid.Column="0" Foreground="#475569" Margin="0,2,0,0"/>
                                    <TextBlock Text="{Binding BackendAuditReviewSelectedReviewSource}"  Grid.Row="12" Grid.Column="1" Margin="0,2,0,0"/>
                                    <TextBlock Text="createdAt (UTC)" Grid.Row="13" Grid.Column="0" Foreground="#475569" Margin="0,2,0,0"/>
                                    <TextBlock Text="{Binding BackendAuditReviewSelectedCreatedAt}"     Grid.Row="13" Grid.Column="1" Margin="0,2,0,0"/>
                                </Grid>
                                <TextBlock Text="Sanitized metadata:" Foreground="#475569"
                                           FontSize="11" FontWeight="SemiBold" Margin="0,6,0,2"/>
                                <ItemsControl ItemsSource="{Binding BackendAuditReviewSelectedMetadata}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}" Foreground="#1E293B" FontFamily="Consolas"
                                                       FontSize="11" TextWrapping="Wrap" Margin="0,1,0,0"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <!-- Warnings + Errors -->
                        <TextBlock Text="Warnings:" Foreground="#92400E"
                                   FontSize="11" FontWeight="SemiBold" Margin="0,6,0,2"/>
                        <ItemsControl ItemsSource="{Binding BackendAuditReviewWarnings}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" Foreground="#92400E" FontSize="11" TextWrapping="Wrap" Margin="0,2,0,0"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock Text="Errors:" Foreground="#991B1B"
                                   FontSize="11" FontWeight="SemiBold" Margin="0,6,0,2"/>
                        <ItemsControl ItemsSource="{Binding BackendAuditReviewErrors}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" Foreground="#991B1B" FontSize="11" TextWrapping="Wrap" Margin="0,2,0,0"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Operator Permission Admin — Read Only (Phase 10.20G) -->
                <Border Background="White" BorderBrush="#93C5FD" BorderThickness="1"
                        Padding="12" Margin="0,0,0,10" CornerRadius="6">
                    <StackPanel>
                        <TextBlock Text="Operator Permission Admin — Read Only (Phase 10.20G)"
                                   FontSize="13" FontWeight="SemiBold" Foreground="#1E3A8A"/>
                        <TextBlock Text="This section is read-only. It shows backend permission definitions, grants, overrides, and DB-shadow effective permissions. It does not grant, revoke, approve, or execute maintenance operations."
                                   FontSize="10" Foreground="#475569" TextWrapping="Wrap" Margin="0,2,0,6"/>

                        <!-- Flag + status -->
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="220"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="Feature flag state" Grid.Row="0" Grid.Column="0" Foreground="#475569"/>
                            <TextBlock Text="{Binding PermissionAdminReadOnlyUiStatusText}" Grid.Row="0" Grid.Column="1" TextWrapping="Wrap"/>
                            <TextBlock Text="Status message"     Grid.Row="1" Grid.Column="0" Foreground="#475569" Margin="0,4,0,0"/>
                            <TextBlock Text="{Binding PermissionAdminStatusMessage}" Grid.Row="1" Grid.Column="1" TextWrapping="Wrap" Margin="0,4,0,0"/>
                        </Grid>

                        <!-- Definitions -->
                        <Border Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1"
                                Padding="8" Margin="0,4,0,0" CornerRadius="4">
                            <StackPanel>
                                <TextBlock Text="Definitions" FontSize="11" FontWeight="SemiBold" Foreground="#1E3A8A"/>
                                <Grid Margin="0,4,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="180"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="permissionKey" Grid.Row="0" Grid.Column="0" Foreground="#475569"/>
                                    <TextBox   Text="{Binding PermissionDefinitionFilterKey, UpdateSourceTrigger=PropertyChanged}" Grid.Row="0" Grid.Column="1"/>
                                    <TextBlock Text="category"      Grid.Row="1" Grid.Column="0" Foreground="#475569" Margin="0,4,0,0"
                                               ToolTip="READ_ONLY | DANGEROUS_TENANT_SCOPED | FUTURE_ONLY"/>
                                    <TextBox   Text="{Binding PermissionDefinitionFilterCategory, UpdateSourceTrigger=PropertyChanged}" Grid.Row="1" Grid.Column="1" Margin="0,4,0,0"/>
                                    <TextBlock Text="active (true|false|blank)"   Grid.Row="2" Grid.Column="0" Foreground="#475569" Margin="0,4,0,0"/>
                                    <TextBox   Text="{Binding PermissionDefinitionFilterActive, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}" Grid.Row="2" Grid.Column="1" Margin="0,4,0,0"/>
                                    <TextBlock Text="dangerous (true|false|blank)" Grid.Row="3" Grid.Column="0" Foreground="#475569" Margin="0,4,0,0"/>
                                    <TextBox   Text="{Binding PermissionDefinitionFilterDangerous, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}" Grid.Row="3" Grid.Column="1" Margin="0,4,0,0"/>
                                    <TextBlock Text="page"          Grid.Row="4" Grid.Column="0" Foreground="#475569" Margin="0,4,0,0"/>
                                    <TextBox   Text="{Binding PermissionDefinitionPage, UpdateSourceTrigger=PropertyChanged}" Grid.Row="4" Grid.Column="1" Margin="0,4,0,0"/>
                                    <TextBlock Text="size (1..200)" Grid.Row="5" Grid.Column="0" Foreground="#475569" Margin="0,4,0,0"/>
                                    <TextBox   Text="{Binding PermissionDefinitionSize, UpdateSourceTrigger=PropertyChanged}" Grid.Row="5" Grid.Column="1" Margin="0,4,0,0"/>
                                </Grid>
                                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                    <Button Command="{Binding RefreshPermissionDefinitionsCommand}"        Content="Refresh Definitions"   Margin="0,0,6,0" IsEnabled="{Binding PermissionAdminReadOnlyUiEnabled}"/>
                                    <Button Command="{Binding PermissionDefinitionsPreviousPageCommand}"   Content="Previous"              Margin="0,0,6,0" IsEnabled="{Binding PermissionAdminReadOnlyUiEnabled}"/>
                                    <Button Command="{Binding PermissionDefinitionsNextPageCommand}"       Content="Next"                  Margin="0,0,6,0" IsEnabled="{Binding PermissionAdminReadOnlyUiEnabled}"/>
                                    <Button Command="{Binding ClearPermissionDefinitionFiltersCommand}"    Content="Clear"/>
                                </StackPanel>
                                <TextBlock Text="{Binding PermissionDefinitionTotalElements, StringFormat={}Total definitions: {0}}"
                                           Foreground="#475569" FontSize="11" Margin="0,4,0,0"/>
                                <ItemsControl ItemsSource="{Binding PermissionDefinitions}" Margin="0,4,0,0">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}" FontFamily="Consolas" FontSize="11" Foreground="#1E293B"
                                                       TextWrapping="Wrap" Margin="0,1,0,0"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <!-- Role grants -->
                        <Border Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1"
                                Padding="8" Margin="0,8,0,0" CornerRadius="4">
                            <StackPanel>
                                <TextBlock Text="Role grants" FontSize="11" FontWeight="SemiBold" Foreground="#1E3A8A"/>
                                <Grid Margin="0,4,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="180"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="role"              Grid.Row="0" Grid.Column="0" Foreground="#475569"/>
                                    <TextBox   Text="{Binding RoleGrantFilterRole, UpdateSourceTrigger=PropertyChanged}" Grid.Row="0" Grid.Column="1"/>
                                    <TextBlock Text="permissionKey"     Grid.Row="1" Grid.Column="0" Foreground="#475569" Margin="0,4,0,0"/>
                                    <TextBox   Text="{Binding RoleGrantFilterPermissionKey, UpdateSourceTrigger=PropertyChanged}" Grid.Row="1" Grid.Column="1" Margin="0,4,0,0"/>
                                    <TextBlock Text="tenantScopePolicy" Grid.Row="2" Grid.Column="0" Foreground="#475569" Margin="0,4,0,0"
                                               ToolTip="TENANT_ONLY | CROSS_TENANT | STORE_SCOPED"/>
                                    <TextBox   Text="{Binding RoleGrantFilterTenantScopePolicy, UpdateSourceTrigger=PropertyChanged}" Grid.Row="2" Grid.Column="1" Margin="0,4,0,0"/>
                                    <TextBlock Text="active (true|false|blank)" Grid.Row="3" Grid.Column="0" Foreground="#475569" Margin="0,4,0,0"/>
                                    <TextBox   Text="{Binding RoleGrantFilterActive, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}" Grid.Row="3" Grid.Column="1" Margin="0,4,0,0"/>
                                    <TextBlock Text="page"              Grid.Row="4" Grid.Column="0" Foreground="#475569" Margin="0,4,0,0"/>
                                    <TextBox   Text="{Binding RoleGrantPage, UpdateSourceTrigger=PropertyChanged}" Grid.Row="4" Grid.Column="1" Margin="0,4,0,0"/>
                                    <TextBlock Text="size (1..200)"     Grid.Row="5" Grid.Column="0" Foreground="#475569" Margin="0,4,0,0"/>
                                    <TextBox   Text="{Binding RoleGrantSize, UpdateSourceTrigger=PropertyChanged}" Grid.Row="5" Grid.Column="1" Margin="0,4,0,0"/>
                                </Grid>
                                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                    <Button Command="{Binding RefreshRoleGrantsCommand}"      Content="Refresh Role Grants" Margin="0,0,6,0" IsEnabled="{Binding PermissionAdminReadOnlyUiEnabled}"/>
                                    <Button Command="{Binding RoleGrantsPreviousPageCommand}" Content="Previous"            Margin="0,0,6,0" IsEnabled="{Binding PermissionAdminReadOnlyUiEnabled}"/>
                                    <Button Command="{Binding RoleGrantsNextPageCommand}"     Content="Next"                Margin="0,0,6,0" IsEnabled="{Binding PermissionAdminReadOnlyUiEnabled}"/>
                                    <Button Command="{Binding ClearRoleGrantFiltersCommand}"  Content="Clear"/>
                                </StackPanel>
                                <TextBlock Text="{Binding RoleGrantTotalElements, StringFormat={}Total role grants: {0}}"
                                           Foreground="#475569" FontSize="11" Margin="0,4,0,0"/>
                                <ItemsControl ItemsSource="{Binding RoleGrants}" Margin="0,4,0,0">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}" FontFamily="Consolas" FontSize="11" Foreground="#1E293B"
                                                       TextWrapping="Wrap" Margin="0,1,0,0"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <!-- User overrides -->
                        <Border Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1"
                                Padding="8" Margin="0,8,0,0" CornerRadius="4">
                            <StackPanel>
                                <TextBlock Text="User overrides" FontSize="11" FontWeight="SemiBold" Foreground="#1E3A8A"/>
                                <Grid Margin="0,4,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="180"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="userId"        Grid.Row="0" Grid.Column="0" Foreground="#475569"/>
                                    <TextBox   Text="{Binding UserOverrideFilterUserId, UpdateSourceTrigger=PropertyChanged}" Grid.Row="0" Grid.Column="1"/>
                                    <TextBlock Text="tenantId"      Grid.Row="1" Grid.Column="0" Foreground="#475569" Margin="0,4,0,0"/>
                                    <TextBox   Text="{Binding UserOverrideFilterTenantId, UpdateSourceTrigger=PropertyChanged}" Grid.Row="1" Grid.Column="1" Margin="0,4,0,0"/>
                                    <TextBlock Text="storeId"       Grid.Row="2" Grid.Column="0" Foreground="#475569" Margin="0,4,0,0"/>
                                    <TextBox   Text="{Binding UserOverrideFilterStoreId, UpdateSourceTrigger=PropertyChanged}" Grid.Row="2" Grid.Column="1" Margin="0,4,0,0"/>
                                    <TextBlock Text="permissionKey" Grid.Row="3" Grid.Column="0" Foreground="#475569" Margin="0,4,0,0"/>
                                    <TextBox   Text="{Binding UserOverrideFilterPermissionKey, UpdateSourceTrigger=PropertyChanged}" Grid.Row="3" Grid.Column="1" Margin="0,4,0,0"/>
                                    <TextBlock Text="grantType"     Grid.Row="4" Grid.Column="0" Foreground="#475569" Margin="0,4,0,0"
                                               ToolTip="ALLOW | DENY"/>
                                    <TextBox   Text="{Binding UserOverrideFilterGrantType, UpdateSourceTrigger=PropertyChanged}" Grid.Row="4" Grid.Column="1" Margin="0,4,0,0"/>
                                    <TextBlock Text="active (true|false|blank)"  Grid.Row="5" Grid.Column="0" Foreground="#475569" Margin="0,4,0,0"/>
                                    <TextBox   Text="{Binding UserOverrideFilterActive, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}" Grid.Row="5" Grid.Column="1" Margin="0,4,0,0"/>
                                    <TextBlock Text="expired (true|false|blank)" Grid.Row="6" Grid.Column="0" Foreground="#475569" Margin="0,4,0,0"/>
                                    <TextBox   Text="{Binding UserOverrideFilterExpired, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}" Grid.Row="6" Grid.Column="1" Margin="0,4,0,0"/>
                                    <TextBlock Text="page"          Grid.Row="7" Grid.Column="0" Foreground="#475569" Margin="0,4,0,0"/>
                                    <TextBox   Text="{Binding UserOverridePage, UpdateSourceTrigger=PropertyChanged}" Grid.Row="7" Grid.Column="1" Margin="0,4,0,0"/>
                                    <TextBlock Text="size (1..200)" Grid.Row="8" Grid.Column="0" Foreground="#475569" Margin="0,4,0,0"/>
                                    <TextBox   Text="{Binding UserOverrideSize, UpdateSourceTrigger=PropertyChanged}" Grid.Row="8" Grid.Column="1" Margin="0,4,0,0"/>
                                </Grid>
                                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                    <Button Command="{Binding RefreshUserOverridesCommand}"      Content="Refresh User Overrides" Margin="0,0,6,0" IsEnabled="{Binding PermissionAdminReadOnlyUiEnabled}"/>
                                    <Button Command="{Binding UserOverridesPreviousPageCommand}" Content="Previous"               Margin="0,0,6,0" IsEnabled="{Binding PermissionAdminReadOnlyUiEnabled}"/>
                                    <Button Command="{Binding UserOverridesNextPageCommand}"     Content="Next"                   Margin="0,0,6,0" IsEnabled="{Binding PermissionAdminReadOnlyUiEnabled}"/>
                                    <Button Command="{Binding ClearUserOverrideFiltersCommand}"  Content="Clear"/>
                                </StackPanel>
                                <TextBlock Text="{Binding UserOverrideTotalElements, StringFormat={}Total user overrides: {0}}"
                                           Foreground="#475569" FontSize="11" Margin="0,4,0,0"/>
                                <ItemsControl ItemsSource="{Binding UserOverrides}" Margin="0,4,0,0">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}" FontFamily="Consolas" FontSize="11" Foreground="#1E293B"
                                                       TextWrapping="Wrap" Margin="0,1,0,0"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <!-- Effective view -->
                        <Border Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1"
                                Padding="8" Margin="0,8,0,0" CornerRadius="4">
                            <StackPanel>
                                <TextBlock Text="Effective view (DB shadow)" FontSize="11" FontWeight="SemiBold" Foreground="#1E3A8A"/>
                                <Grid Margin="0,4,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="180"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="userId"   Grid.Row="0" Grid.Column="0" Foreground="#475569"/>
                                    <TextBox   Text="{Binding EffectiveQueryUserId, UpdateSourceTrigger=PropertyChanged}" Grid.Row="0" Grid.Column="1"/>
                                    <TextBlock Text="tenantId" Grid.Row="1" Grid.Column="0" Foreground="#475569" Margin="0,4,0,0"/>
                                    <TextBox   Text="{Binding EffectiveQueryTenantId, UpdateSourceTrigger=PropertyChanged}" Grid.Row="1" Grid.Column="1" Margin="0,4,0,0"/>
                                    <TextBlock Text="storeId"  Grid.Row="2" Grid.Column="0" Foreground="#475569" Margin="0,4,0,0"/>
                                    <TextBox   Text="{Binding EffectiveQueryStoreId, UpdateSourceTrigger=PropertyChanged}" Grid.Row="2" Grid.Column="1" Margin="0,4,0,0"/>
                                </Grid>
                                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                    <Button Command="{Binding ResolveEffectivePermissionsCommand}" Content="Resolve" Margin="0,0,6,0" IsEnabled="{Binding PermissionAdminReadOnlyUiEnabled}"/>
                                    <Button Command="{Binding ClearEffectivePermissionQueryCommand}" Content="Clear"/>
                                </StackPanel>
                                <Grid Margin="0,6,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="220"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="auditSource"              Grid.Row="0" Grid.Column="0" Foreground="#475569"/>
                                    <TextBlock Text="{Binding EffectiveAuditSource}"           Grid.Row="0" Grid.Column="1" TextWrapping="Wrap"/>
                                    <TextBlock Text="enabled"                  Grid.Row="1" Grid.Column="0" Foreground="#475569" Margin="0,2,0,0"/>
                                    <TextBlock Text="{Binding EffectiveEnabled}"               Grid.Row="1" Grid.Column="1" Margin="0,2,0,0"/>
                                    <TextBlock Text="healthy"                  Grid.Row="2" Grid.Column="0" Foreground="#475569" Margin="0,2,0,0"/>
                                    <TextBlock Text="{Binding EffectiveHealthy}"               Grid.Row="2" Grid.Column="1" Margin="0,2,0,0"/>
                                    <TextBlock Text="permissionsSource"        Grid.Row="3" Grid.Column="0" Foreground="#475569" Margin="0,2,0,0"/>
                                    <TextBlock Text="{Binding EffectivePermissionsSource}"     Grid.Row="3" Grid.Column="1" Margin="0,2,0,0"/>
                                    <TextBlock Text="comparison.matchesCode"   Grid.Row="4" Grid.Column="0" Foreground="#475569" Margin="0,2,0,0"/>
                                    <TextBlock Text="{Binding EffectiveComparisonMatchesCode}" Grid.Row="4" Grid.Column="1" Margin="0,2,0,0"/>
                                </Grid>
                                <TextBlock Text="Effective permissions:" Foreground="#475569" FontSize="11" FontWeight="SemiBold" Margin="0,6,0,2"/>
                                <ItemsControl ItemsSource="{Binding EffectivePermissions}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}" FontFamily="Consolas" FontSize="11" Foreground="#1E293B"
                                                       TextWrapping="Wrap" Margin="0,1,0,0"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <TextBlock Text="Decisions:" Foreground="#475569" FontSize="11" FontWeight="SemiBold" Margin="0,6,0,2"/>
                                <ItemsControl ItemsSource="{Binding EffectiveDecisions}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}" FontFamily="Consolas" FontSize="11" Foreground="#1E293B"
                                                       TextWrapping="Wrap" Margin="0,1,0,0"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <!-- Warnings + errors -->
                        <TextBlock Text="Warnings:" Foreground="#92400E"
                                   FontSize="11" FontWeight="SemiBold" Margin="0,6,0,2"/>
                        <ItemsControl ItemsSource="{Binding PermissionAdminWarnings}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" Foreground="#92400E" FontSize="11" TextWrapping="Wrap" Margin="0,2,0,0"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock Text="Errors:" Foreground="#991B1B"
                                   FontSize="11" FontWeight="SemiBold" Margin="0,6,0,2"/>
                        <ItemsControl ItemsSource="{Binding PermissionAdminErrors}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" Foreground="#991B1B" FontSize="11" TextWrapping="Wrap" Margin="0,2,0,0"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Operator Permission Admin — Mutations (Phase 10.20I) -->
                <Border Background="White" BorderBrush="#F59E0B" BorderThickness="1"
                        Padding="12" Margin="0,0,0,10" CornerRadius="6">
                    <StackPanel>
                        <TextBlock Text="Operator Permission Admin — Mutations (Phase 10.20I)"
                                   FontSize="13" FontWeight="SemiBold" Foreground="#7C2D12"/>
                        <TextBlock Text="This section can create or revoke DB permission grants/overrides only when both local and backend mutation flags are enabled. DB permissions are still not authoritative and this does not execute maintenance operations."
                                   FontSize="10" Foreground="#7C2D12" TextWrapping="Wrap" Margin="0,2,0,2"/>
                        <TextBlock Text="Backend mutation API is controlled by a server-side feature flag. If disabled, requests will be rejected and no DB rows will be changed."
                                   FontSize="10" Foreground="#7C2D12" TextWrapping="Wrap" Margin="0,2,0,6" FontStyle="Italic"/>

                        <!-- Flag + status -->
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="240"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="Local flag state"   Grid.Row="0" Grid.Column="0" Foreground="#475569"/>
                            <TextBlock Text="{Binding PermissionAdminMutationUiStatusText}" Grid.Row="0" Grid.Column="1" TextWrapping="Wrap"/>
                            <TextBlock Text="Status message"     Grid.Row="1" Grid.Column="0" Foreground="#475569" Margin="0,4,0,0"/>
                            <TextBlock Text="{Binding PermissionAdminMutationStatusMessage}" Grid.Row="1" Grid.Column="1" TextWrapping="Wrap" Margin="0,4,0,0"/>
                        </Grid>

                        <!-- Create user override -->
                        <Border Background="#FFFBEB" BorderBrush="#FCD34D" BorderThickness="1"
                                Padding="8" Margin="0,4,0,0" CornerRadius="4">
                            <StackPanel>
                                <TextBlock Text="Create user override" FontSize="11" FontWeight="SemiBold" Foreground="#7C2D12"/>
                                <Grid Margin="0,4,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="180"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="userId"           Grid.Row="0" Grid.Column="0" Foreground="#475569"/>
                                    <TextBox   Text="{Binding CreateOverrideUserId, UpdateSourceTrigger=PropertyChanged}" Grid.Row="0" Grid.Column="1"/>
                                    <TextBlock Text="tenantId"         Grid.Row="1" Grid.Column="0" Foreground="#475569" Margin="0,4,0,0"/>
                                    <TextBox   Text="{Binding CreateOverrideTenantId, UpdateSourceTrigger=PropertyChanged}" Grid.Row="1" Grid.Column="1" Margin="0,4,0,0"/>
                                    <TextBlock Text="storeId"          Grid.Row="2" Grid.Column="0" Foreground="#475569" Margin="0,4,0,0"/>
                                    <TextBox   Text="{Binding CreateOverrideStoreId, UpdateSourceTrigger=PropertyChanged}" Grid.Row="2" Grid.Column="1" Margin="0,4,0,0"/>
                                    <TextBlock Text="permissionKey"    Grid.Row="3" Grid.Column="0" Foreground="#475569" Margin="0,4,0,0"/>
                                    <TextBox   Text="{Binding CreateOverridePermissionKey, UpdateSourceTrigger=PropertyChanged}" Grid.Row="3" Grid.Column="1" Margin="0,4,0,0"/>
                                    <TextBlock Text="grantType (ALLOW|DENY)" Grid.Row="4" Grid.Column="0" Foreground="#475569" Margin="0,4,0,0"/>
                                    <TextBox   Text="{Binding CreateOverrideGrantType, UpdateSourceTrigger=PropertyChanged}" Grid.Row="4" Grid.Column="1" Margin="0,4,0,0"/>
                                    <TextBlock Text="expiresAt (ISO-8601)" Grid.Row="5" Grid.Column="0" Foreground="#475569" Margin="0,4,0,0"
                                               ToolTip="Required for dangerous ALLOW. Backend caps at 24h from now."/>
                                    <TextBox   Text="{Binding CreateOverrideExpiresAt, UpdateSourceTrigger=PropertyChanged}" Grid.Row="5" Grid.Column="1" Margin="0,4,0,0"/>
                                    <TextBlock Text="reason"           Grid.Row="6" Grid.Column="0" Foreground="#475569" Margin="0,4,0,0"/>
                                    <TextBox   Text="{Binding CreateOverrideReason, UpdateSourceTrigger=PropertyChanged}" Grid.Row="6" Grid.Column="1" Margin="0,4,0,0"/>
                                    <TextBlock Text="approvalTicketId" Grid.Row="7" Grid.Column="0" Foreground="#475569" Margin="0,4,0,0"/>
                                    <TextBox   Text="{Binding CreateOverrideApprovalTicketId, UpdateSourceTrigger=PropertyChanged}" Grid.Row="7" Grid.Column="1" Margin="0,4,0,0"/>
                                </Grid>
                                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                    <Button Command="{Binding CreateUserOverrideCommand}"       Content="Create Override" Margin="0,0,6,0" IsEnabled="{Binding PermissionAdminMutationUiEnabled}"/>
                                    <Button Command="{Binding ClearUserOverrideCreateFormCommand}" Content="Clear"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Revoke user override -->
                        <Border Background="#FFFBEB" BorderBrush="#FCD34D" BorderThickness="1"
                                Padding="8" Margin="0,6,0,0" CornerRadius="4">
                            <StackPanel>
                                <TextBlock Text="Revoke user override" FontSize="11" FontWeight="SemiBold" Foreground="#7C2D12"/>
                                <Grid Margin="0,4,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="180"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="overrideId"      Grid.Row="0" Grid.Column="0" Foreground="#475569"/>
                                    <TextBox   Text="{Binding RevokeOverrideId, UpdateSourceTrigger=PropertyChanged}" Grid.Row="0" Grid.Column="1"/>
                                    <TextBlock Text="reason"          Grid.Row="1" Grid.Column="0" Foreground="#475569" Margin="0,4,0,0"/>
                                    <TextBox   Text="{Binding RevokeOverrideReason, UpdateSourceTrigger=PropertyChanged}" Grid.Row="1" Grid.Column="1" Margin="0,4,0,0"/>
                                    <TextBlock Text="approvalTicketId" Grid.Row="2" Grid.Column="0" Foreground="#475569" Margin="0,4,0,0"/>
                                    <TextBox   Text="{Binding RevokeOverrideApprovalTicketId, UpdateSourceTrigger=PropertyChanged}" Grid.Row="2" Grid.Column="1" Margin="0,4,0,0"/>
                                </Grid>
                                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                    <Button Command="{Binding RevokeUserOverrideCommand}"       Content="Revoke Override" Margin="0,0,6,0" IsEnabled="{Binding PermissionAdminMutationUiEnabled}"/>
                                    <Button Command="{Binding ClearUserOverrideRevokeFormCommand}" Content="Clear"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Create role grant -->
                        <Border Background="#FFFBEB" BorderBrush="#FCD34D" BorderThickness="1"
                                Padding="8" Margin="0,6,0,0" CornerRadius="4">
                            <StackPanel>
                                <TextBlock Text="Create role grant (GLOBAL_ADMIN only)" FontSize="11" FontWeight="SemiBold" Foreground="#7C2D12"/>
                                <Grid Margin="0,4,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="180"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="role"               Grid.Row="0" Grid.Column="0" Foreground="#475569"/>
                                    <TextBox   Text="{Binding CreateRoleGrantRole, UpdateSourceTrigger=PropertyChanged}" Grid.Row="0" Grid.Column="1"/>
                                    <TextBlock Text="permissionKey"      Grid.Row="1" Grid.Column="0" Foreground="#475569" Margin="0,4,0,0"/>
                                    <TextBox   Text="{Binding CreateRoleGrantPermissionKey, UpdateSourceTrigger=PropertyChanged}" Grid.Row="1" Grid.Column="1" Margin="0,4,0,0"/>
                                    <TextBlock Text="tenantScopePolicy"  Grid.Row="2" Grid.Column="0" Foreground="#475569" Margin="0,4,0,0"
                                               ToolTip="TENANT_ONLY | CROSS_TENANT | STORE_SCOPED"/>
                                    <TextBox   Text="{Binding CreateRoleGrantTenantScopePolicy, UpdateSourceTrigger=PropertyChanged}" Grid.Row="2" Grid.Column="1" Margin="0,4,0,0"/>
                                    <TextBlock Text="reason"             Grid.Row="3" Grid.Column="0" Foreground="#475569" Margin="0,4,0,0"/>
                                    <TextBox   Text="{Binding CreateRoleGrantReason, UpdateSourceTrigger=PropertyChanged}" Grid.Row="3" Grid.Column="1" Margin="0,4,0,0"/>
                                    <TextBlock Text="approvalTicketId"   Grid.Row="4" Grid.Column="0" Foreground="#475569" Margin="0,4,0,0"/>
                                    <TextBox   Text="{Binding CreateRoleGrantApprovalTicketId, UpdateSourceTrigger=PropertyChanged}" Grid.Row="4" Grid.Column="1" Margin="0,4,0,0"/>
                                </Grid>
                                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                    <Button Command="{Binding CreateRoleGrantCommand}"       Content="Create Role Grant" Margin="0,0,6,0" IsEnabled="{Binding PermissionAdminMutationUiEnabled}"/>
                                    <Button Command="{Binding ClearRoleGrantCreateFormCommand}" Content="Clear"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Revoke role grant -->
                        <Border Background="#FFFBEB" BorderBrush="#FCD34D" BorderThickness="1"
                                Padding="8" Margin="0,6,0,0" CornerRadius="4">
                            <StackPanel>
                                <TextBlock Text="Revoke role grant (GLOBAL_ADMIN only)" FontSize="11" FontWeight="SemiBold" Foreground="#7C2D12"/>
                                <Grid Margin="0,4,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="180"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
