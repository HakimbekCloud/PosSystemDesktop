<UserControl x:Class="PosSystem.Views.Admin.AdminShellView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:PosSystem.ViewModels.Admin"
             xmlns:modulesVm="clr-namespace:PosSystem.ViewModels.Admin.Modules"
             xmlns:modules="clr-namespace:PosSystem.Views.Admin.Modules"
             d:DataContext="{d:DesignInstance Type=vm:AdminShellViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="{StaticResource SurfaceApp}">

    <UserControl.Resources>
        <!-- DataTemplates map each module's ViewModel to its View. The ContentControl
             swaps these by setting Content to the relevant VM. -->
        <DataTemplate DataType="{x:Type modulesVm:DashboardViewModel}">
            <modules:DashboardView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type modulesVm:SalesEntryViewModel}">
            <modules:SalesEntryView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type modulesVm:ReturnsViewModel}">
            <modules:ReturnsView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type modulesVm:ProductsAdminViewModel}">
            <modules:ProductsAdminView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type modulesVm:InventoryViewModel}">
            <modules:InventoryView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type modulesVm:CustomersViewModel}">
            <modules:CustomersView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type modulesVm:EmployeesViewModel}">
            <modules:EmployeesView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type modulesVm:StatisticsViewModel}">
            <modules:StatisticsView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type modulesVm:SettingsViewModel}">
            <modules:SettingsView/>
        </DataTemplate>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="48"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ════════════════════════════════════════════════════════
             TOPBAR
             ════════════════════════════════════════════════════════ -->
        <Border Grid.Row="0"
                Background="{StaticResource TopbarGradient}"
                BorderBrush="{StaticResource TopbarBorder}"
                BorderThickness="0,0,0,1">
            <Grid Margin="16,0,12,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>   <!-- brand + status -->
                    <ColumnDefinition Width="*"/>      <!-- search -->
                    <ColumnDefinition Width="Auto"/>   <!-- icons + user -->
                </Grid.ColumnDefinitions>

                <!-- ── Left: brand + status pills ── -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- Brand -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,16,0">
                        <Border Width="26" Height="26"
                                Background="{StaticResource TopbarPanel}"
                                CornerRadius="5">
                            <TextBlock Text="S"
                                       FontFamily="{StaticResource UiFontDisplay}"
                                       FontWeight="Bold"
                                       FontSize="14"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="ShefPos Admin"
                                       FontFamily="{StaticResource UiFontDisplay}"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="White"/>
                            <TextBlock Text="{Binding BranchName}"
                                       FontFamily="{StaticResource UiFont}"
                                       FontSize="10"
                                       Foreground="{StaticResource TopbarTextMuted}"
                                       Margin="0,1,0,0"/>
                        </StackPanel>
                    </StackPanel>

                    <Border Width="1" Background="{StaticResource TopbarBorderInner}" Margin="0,8,12,8"/>

                    <!-- Status pills -->
                    <Border Style="{StaticResource TopbarPill}" Padding="0,0,0,0">
                        <StackPanel Orientation="Horizontal">
                            <StackPanel Orientation="Horizontal" Margin="10,0">
                                <Ellipse Width="7" Height="7" Fill="{StaticResource Success500}" Margin="0,0,6,0"/>
                                <TextBlock Text="Onlayn" Foreground="White" FontSize="11" VerticalAlignment="Center"/>
                            </StackPanel>
                            <Border Width="1" Background="{StaticResource TopbarBorderInner}"/>
                            <TextBlock Margin="10,0"
                                       Foreground="White"
                                       FontSize="11"
                                       VerticalAlignment="Center"
                                       FontFamily="{StaticResource UiFontMono}">
                                <Run Text="{Binding ShiftLabel}"/>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- ── Center: global search ── -->
                <Grid Grid.Column="1" Margin="20,0" MaxWidth="440">
                    <TextBox Style="{StaticResource TopbarSearchTextBox}"
                             Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                             Tag="Mahsulot, chek yoki mijoz qidirish…"/>
                    <TextBlock Text="&#xE721;"
                               FontFamily="{StaticResource FluentIcons}"
                               FontSize="13"
                               Foreground="{StaticResource TopbarTextDim}"
                               HorizontalAlignment="Left"
                               VerticalAlignment="Center"
                               Margin="10,0,0,0"
                               IsHitTestVisible="False"/>
                    <TextBlock Text="Mahsulot, chek yoki mijoz qidirish…"
                               FontFamily="{StaticResource UiFont}"
                               FontSize="12"
                               Foreground="{StaticResource TopbarTextDim}"
                               HorizontalAlignment="Left"
                               VerticalAlignment="Center"
                               Margin="32,0,0,0"
                               IsHitTestVisible="False"
                               Visibility="{Binding SearchQuery, Converter={StaticResource EmptyStringToVisibilityConverter}}"/>
                    <Border HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Margin="0,0,6,0"
                            Background="{StaticResource TopbarPanelHover}"
                            BorderBrush="{StaticResource TopbarBorderInner}"
                            BorderThickness="1"
                            CornerRadius="3"
                            Padding="6,1">
                        <TextBlock Text="Ctrl+K"
                                   FontFamily="{StaticResource UiFontMono}"
                                   FontSize="10"
                                   Foreground="{StaticResource TopbarTextMuted}"/>
                    </Border>
                </Grid>

                <!-- ── Right: icons + clock + user ── -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Style="{StaticResource TopbarIconButton}" Content="&#xE713;" ToolTip="Sozlamalar"/>
                    <Button Style="{StaticResource TopbarIconButton}" Content="&#xE895;" ToolTip="Sinxron"/>
                    <Button Style="{StaticResource TopbarIconButton}" Content="&#xEA8F;" ToolTip="Bildirishnomalar"/>

                    <Border Width="1" Background="{StaticResource TopbarBorderInner}" Margin="6,8,6,8"/>

                    <Border Style="{StaticResource TopbarPill}">
                        <TextBlock Text="{Binding ClockText}"
                                   FontFamily="{StaticResource UiFontMono}"
                                   FontSize="12"
                                   Foreground="White"
                                   VerticalAlignment="Center"/>
                    </Border>

                    <Border Style="{StaticResource TopbarPill}"
                            Margin="6,0,0,0"
                            Padding="4,0,10,0"
                            Height="30">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Width="22" Height="22"
                                    Background="{StaticResource TopbarPanelHover}"
                                    CornerRadius="4">
                                <TextBlock Text="{Binding UserInitials}"
                                           Foreground="White"
                                           FontSize="10"
                                           FontWeight="Bold"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="{Binding UserName}"
                                       Foreground="White"
                                       FontSize="12"
                                       FontWeight="Medium"
                                       VerticalAlignment="Center"
                                       Margin="8,0,0,0"/>
                            <TextBlock Text="&#xE70D;"
                                       FontFamily="{StaticResource FluentIcons}"
                                       FontSize="9"
                                       Foreground="{StaticResource TopbarTextMuted}"
                                       VerticalAlignment="Center"
                                       Margin="6,0,0,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ════════════════════════════════════════════════════════
             MAIN: sidebar + workspace
             ════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="232"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ─── SIDEBAR ─── -->
            <Border Grid.Column="0"
                    Background="{StaticResource SurfaceRail}"
                    BorderBrush="{StaticResource BorderSubtle}"
                    BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" Padding="8,8,8,12">
                        <StackPanel>
                            <!-- TOP group (Dashboard + POS) -->
                            <TextBlock Text="ASOSIY" Style="{StaticResource SidebarGroupLabel}"/>
                            <ListBox Style="{StaticResource SidebarListBox}"
                                     ItemsSource="{Binding NavTopGroup}"
                                     SelectedItem="{Binding SelectedItem, Mode=TwoWay}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="18"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding Glyph}" Style="{StaticResource FluentIconText}" FontSize="14"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Title}" Margin="10,0,0,0" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="2" Text="{Binding Shortcut}"
                                                       FontFamily="{StaticResource UiFontMono}"
                                                       FontSize="10"
                                                       Foreground="{StaticResource N400}"
                                                       VerticalAlignment="Center"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <!-- MAIN group -->
                            <TextBlock Text="BOSHQARUV" Style="{StaticResource SidebarGroupLabel}" Margin="12,16,12,4"/>
                            <ListBox Style="{StaticResource SidebarListBox}"
                                     ItemsSource="{Binding NavMainGroup}"
                                     SelectedItem="{Binding SelectedItem, Mode=TwoWay}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="18"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding Glyph}" Style="{StaticResource FluentIconText}" FontSize="14"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Title}" Margin="10,0,0,0" VerticalAlignment="Center"/>
                                            <Border Grid.Column="2"
                                                    Background="{StaticResource N200}"
                                                    CornerRadius="99"
                                                    Padding="6,1"
                                                    VerticalAlignment="Center"
                                                    Visibility="{Binding BadgeText, Converter={StaticResource StringToVisibilityConverter}}">
                                                <TextBlock Text="{Binding BadgeText}"
                                                           FontFamily="{StaticResource UiFontMono}"
                                                           FontSize="10"
                                                           FontWeight="Bold"
                                                           Foreground="{StaticResource N700}"/>
                                            </Border>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <!-- SYSTEM group -->
                            <TextBlock Text="TIZIM" Style="{StaticResource SidebarGroupLabel}" Margin="12,16,12,4"/>
                            <ListBox Style="{StaticResource SidebarListBox}"
                                     ItemsSource="{Binding NavSystemGroup}"
                                     SelectedItem="{Binding SelectedItem, Mode=TwoWay}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="18"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding Glyph}" Style="{StaticResource FluentIconText}" FontSize="14"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Title}" Margin="10,0,0,0" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="2" Text="{Binding Shortcut}"
                                                       FontFamily="{StaticResource UiFontMono}"
                                                       FontSize="10"
                                                       Foreground="{StaticResource N400}"
                                                       VerticalAlignment="Center"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Sidebar footer: shift / version -->
                    <Border Grid.Row="1"
                            Background="{StaticResource Surface1}"
                            BorderBrush="{StaticResource BorderSubtle}"
                            BorderThickness="0,1,0,0"
                            Padding="12">
                        <StackPanel>
                            <Border Background="{StaticResource SurfaceSunken}"
                                    BorderBrush="{StaticResource BorderSubtle}"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="12,10">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse Width="7" Height="7"
                                                 Fill="{StaticResource Success500}"
                                                 Margin="0,0,6,0"/>
                                        <TextBlock Text="Smena ochiq"
                                                   FontWeight="SemiBold"
                                                   FontSize="12"
                                                   Foreground="{StaticResource N900}"/>
                                    </StackPanel>
                                    <Grid Margin="0,6,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Tushum" FontSize="11" Foreground="{StaticResource N600}"/>
                                        <TextBlock Grid.Column="1" Text="8 240 000 so'm"
                                                   FontFamily="{StaticResource UiFontMono}"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource N900}"/>
                                    </Grid>
                                    <Grid Margin="0,2,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Cheklar" FontSize="11" Foreground="{StaticResource N600}"/>
                                        <TextBlock Grid.Column="1" Text="184 ta"
                                                   FontFamily="{StaticResource UiFontMono}"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource N900}"/>
                                    </Grid>
                                </StackPanel>
                            </Border>
                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="ShefPos v2.4.1"
                                           FontFamily="{StaticResource UiFontMono}"
                                           FontSize="10"
                                           Foreground="{StaticResource N400}"/>
                                <TextBlock Grid.Column="1" Text="DB ✓"
                                           FontFamily="{StaticResource UiFontMono}"
                                           FontSize="10"
                                           Foreground="{StaticResource Success600}"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- ─── WORKSPACE ─── -->
            <ContentControl Grid.Column="1"
                            Content="{Binding CurrentPage}"
                            HorizontalContentAlignment="Stretch"
                            VerticalContentAlignment="Stretch"/>
        </Grid>
    </Grid>
</UserControl>
