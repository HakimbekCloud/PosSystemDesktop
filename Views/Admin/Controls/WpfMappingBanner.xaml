<UserControl x:Class="PosSystem.Views.Admin.Controls.WpfMappingBanner"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root">
    <!-- v1-unique educational strip: shows WPF developers which XAML
         controls the current screen maps to. Hidden if Hint is empty. -->
    <Border Background="{StaticResource Brand50}"
            BorderBrush="{StaticResource Brand100}"
            BorderThickness="1"
            CornerRadius="8"
            Padding="14,10"
            Margin="0,0,0,16"
            Visibility="{Binding Hint, ElementName=Root, Converter={StaticResource StringToVisibilityConverter}}">
        <StackPanel Orientation="Horizontal">
            <Border Background="{StaticResource Brand700}"
                    CornerRadius="4"
                    Padding="6,2"
                    VerticalAlignment="Center">
                <TextBlock Text="XAML"
                           FontFamily="{StaticResource UiFontMono}"
                           FontSize="10"
                           FontWeight="Bold"
                           Foreground="White"/>
            </Border>
            <TextBlock Margin="10,0,0,0"
                       FontFamily="{StaticResource UiFont}"
                       FontSize="12"
                       Foreground="{StaticResource Brand900}"
                       VerticalAlignment="Center"
                       TextWrapping="Wrap">
                <Run Text="WPF dizayni · " FontWeight="SemiBold"/>
                <Run Text="{Binding Hint, ElementName=Root, Mode=OneWay}"/>
            </TextBlock>
        </StackPanel>
    </Border>
</UserControl>
