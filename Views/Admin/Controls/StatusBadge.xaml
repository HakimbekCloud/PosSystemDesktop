<UserControl x:Class="PosSystem.Views.Admin.Controls.StatusBadge"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root">
    <Border CornerRadius="4"
            BorderThickness="1"
            Padding="8,3"
            VerticalAlignment="Center"
            HorizontalAlignment="Left"
            Background="{Binding Bg, ElementName=Root}"
            BorderBrush="{Binding BorderColor, ElementName=Root}">
        <TextBlock Text="{Binding Text, ElementName=Root}"
                   FontFamily="{StaticResource UiFont}"
                   FontSize="11"
                   FontWeight="SemiBold"
                   Foreground="{Binding Fg, ElementName=Root}"/>
    </Border>
</UserControl>
