<UserControl x:Class="PosSystem.Views.Admin.Controls.StatusBadge"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root">
    <Border CornerRadius="3"
            BorderThickness="1"
            Padding="7,2"
            VerticalAlignment="Center"
            HorizontalAlignment="Left"
            Background="{Binding BackgroundBrush, ElementName=Root}"
            BorderBrush="{Binding BorderBrushColor, ElementName=Root}">
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
            <Ellipse Width="6" Height="6" Margin="0,0,4,0"
                     Fill="{Binding DotBrush, ElementName=Root}"
                     Visibility="{Binding ShowDot, ElementName=Root, Converter={StaticResource BoolToVisibilityConverter}}"/>
            <TextBlock Text="{Binding Text, ElementName=Root}"
                       FontFamily="{StaticResource UiFont}"
                       FontSize="11"
                       FontWeight="SemiBold"
                       Foreground="{Binding ForegroundBrush, ElementName=Root}"/>
        </StackPanel>
    </Border>
</UserControl>
