<UserControl x:Class="PosSystem.Views.Admin.Controls.EmptyState"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root">
    <StackPanel HorizontalAlignment="Center"
                VerticalAlignment="Center"
                MaxWidth="320">
        <Border Width="48" Height="48"
                CornerRadius="10"
                Background="{StaticResource N100}"
                HorizontalAlignment="Center"
                Margin="0,0,0,12">
            <TextBlock Style="{StaticResource FluentIconText}"
                       Text="{Binding Glyph, ElementName=Root}"
                       FontSize="20"
                       Foreground="{StaticResource N500}"/>
        </Border>
        <TextBlock Text="{Binding Title, ElementName=Root}"
                   FontFamily="{StaticResource UiFontDisplay}"
                   FontSize="14"
                   FontWeight="SemiBold"
                   Foreground="{StaticResource N800}"
                   HorizontalAlignment="Center"/>
        <TextBlock Text="{Binding Description, ElementName=Root}"
                   Style="{StaticResource HintText}"
                   HorizontalAlignment="Center"
                   TextAlignment="Center"
                   TextWrapping="Wrap"
                   Margin="0,6,0,0"/>
    </StackPanel>
</UserControl>
