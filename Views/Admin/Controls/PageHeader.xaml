<UserControl x:Class="PosSystem.Views.Admin.Controls.PageHeader"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root">
    <Border Style="{StaticResource PageHeadBorder}">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                <TextBlock Text="{Binding Crumb, ElementName=Root}"
                           Style="{StaticResource CrumbText}"
                           Visibility="{Binding Crumb, ElementName=Root, Converter={StaticResource StringToVisibilityConverter}}"
                           Margin="0,0,0,4"/>
                <TextBlock Text="{Binding Title, ElementName=Root}"
                           Style="{StaticResource PageTitleText}"/>
                <TextBlock Text="{Binding Subtitle, ElementName=Root}"
                           Style="{StaticResource PageSubtitleText}"
                           Margin="0,3,0,0"
                           Visibility="{Binding Subtitle, ElementName=Root, Converter={StaticResource StringToVisibilityConverter}}"/>
            </StackPanel>

            <ContentPresenter Grid.Column="1"
                              Content="{Binding Actions, ElementName=Root}"
                              VerticalAlignment="Center"
                              HorizontalAlignment="Right"/>
        </Grid>
    </Border>
</UserControl>
