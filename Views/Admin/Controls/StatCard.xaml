<UserControl x:Class="PosSystem.Views.Admin.Controls.StatCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root">
    <Border Background="{StaticResource Surface1}"
            BorderBrush="{StaticResource BorderSubtle}"
            BorderThickness="1"
            CornerRadius="{StaticResource CardRadius}"
            Padding="14,12"
            MinHeight="88">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Icon top-right -->
            <Border Width="28" Height="28"
                    Background="{Binding IconBackground, ElementName=Root}"
                    CornerRadius="6"
                    HorizontalAlignment="Right" VerticalAlignment="Top"
                    Grid.RowSpan="2">
                <TextBlock Style="{StaticResource FluentIconText}"
                           Text="{Binding Glyph, ElementName=Root}"
                           Foreground="{Binding IconForeground, ElementName=Root}"
                           FontSize="14"/>
            </Border>

            <!-- Label -->
            <TextBlock Grid.Row="0"
                       Text="{Binding Label, ElementName=Root}"
                       Style="{StaticResource StatLabelText}"
                       Margin="0,0,36,0"/>

            <!-- Value + unit -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,4,36,0">
                <TextBlock Text="{Binding Value, ElementName=Root}"
                           Style="{StaticResource StatValueText}"/>
                <TextBlock Text="{Binding Unit, ElementName=Root}"
                           Style="{StaticResource StatUnitText}"
                           Margin="5,0,0,3"
                           VerticalAlignment="Bottom"
                           Visibility="{Binding Unit, ElementName=Root, Converter={StaticResource StringToVisibilityConverter}}"/>
            </StackPanel>

            <!-- Foot: delta + sub -->
            <Grid Grid.Row="3" Margin="0,8,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Background="{Binding DeltaBackground, ElementName=Root}"
                        CornerRadius="3"
                        Padding="5,1"
                        VerticalAlignment="Center"
                        Visibility="{Binding Delta, ElementName=Root, Converter={StaticResource StringToVisibilityConverter}}">
                    <TextBlock Text="{Binding Delta, ElementName=Root}"
                               Foreground="{Binding DeltaForeground, ElementName=Root}"
                               FontFamily="{StaticResource UiFont}"
                               FontSize="11"
                               FontWeight="SemiBold"/>
                </Border>

                <TextBlock Grid.Column="1"
                           Text="{Binding Sub, ElementName=Root}"
                           Style="{StaticResource HintText}"
                           VerticalAlignment="Center"
                           TextAlignment="Right"
                           TextTrimming="CharacterEllipsis"
                           Margin="8,0,0,0"/>
            </Grid>
        </Grid>
    </Border>
</UserControl>
