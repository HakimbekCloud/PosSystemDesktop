<UserControl x:Class="PosSystem.Views.Admin.Controls.StatCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root">
    <Border Background="{StaticResource Surface1}"
            BorderBrush="{StaticResource BorderSubtle}"
            BorderThickness="1"
            CornerRadius="8"
            Padding="16"
            MinHeight="96">
        <Grid>
            <!-- Icon top-right -->
            <Border Width="32" Height="32"
                    HorizontalAlignment="Right" VerticalAlignment="Top"
                    CornerRadius="6"
                    Background="{Binding IconBg, ElementName=Root}">
                <TextBlock Style="{StaticResource FluentIconText}"
                           Text="{Binding Glyph, ElementName=Root}"
                           Foreground="{Binding IconFg, ElementName=Root}"
                           FontSize="15"/>
            </Border>

            <StackPanel Margin="0,0,40,0">
                <TextBlock Text="{Binding Label, ElementName=Root}" Style="{StaticResource StatLabelText}"/>
                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                    <TextBlock Text="{Binding Value, ElementName=Root}" Style="{StaticResource StatValueText}"/>
                    <TextBlock Text="{Binding Unit, ElementName=Root}"
                               Style="{StaticResource StatUnitText}"
                               Margin="6,0,0,3" VerticalAlignment="Bottom"
                               Visibility="{Binding Unit, ElementName=Root, Converter={StaticResource StringToVisibilityConverter}}"/>
                </StackPanel>
                <TextBlock Text="{Binding Delta, ElementName=Root}"
                           Style="{StaticResource StatDeltaText}"
                           Foreground="{Binding DeltaFg, ElementName=Root}"
                           Margin="0,6,0,0"
                           Visibility="{Binding Delta, ElementName=Root, Converter={StaticResource StringToVisibilityConverter}}"/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
