<UserControl x:Class="PosSystem.Views.Admin.Modules.EmployeesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:PosSystem.ViewModels.Admin.Modules"
             xmlns:c="clr-namespace:PosSystem.Views.Admin.Controls"
             d:DataContext="{d:DesignInstance Type=vm:EmployeesViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="{StaticResource SurfaceApp}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <c:PageHeader Grid.Row="0"
                      Crumb="ShefPos / Xodimlar"
                      Title="Xodimlar"
                      Subtitle="Kassirlar, menejerlar, omborchilar va ruxsatlar boshqaruvi">
            <c:PageHeader.Actions>
                <StackPanel Orientation="Horizontal">
                    <Button Style="{StaticResource AdminSecondaryButtonSm}" Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE74E;" FontFamily="{StaticResource FluentIcons}" FontSize="12" Margin="0,0,6,0"/>
                            <TextBlock Text="Hisobot"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource AdminSecondaryButtonSm}" Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE787;" FontFamily="{StaticResource FluentIcons}" FontSize="12" Margin="0,0,6,0"/>
                            <TextBlock Text="Smena jadvali"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource AdminPrimaryButtonSm}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE710;" FontFamily="{StaticResource FluentIcons}" FontSize="12" Margin="0,0,6,0"/>
                            <TextBlock Text="Yangi xodim"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </c:PageHeader.Actions>
        </c:PageHeader>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="20,16,20,24">

                <UniformGrid Columns="4" Rows="1">
                    <c:StatCard Margin="0,0,8,0" Label="JAMI XODIMLAR" Value="{Binding KpiTotal}"   Unit="{Binding KpiTotalUnit}"   Sub="{Binding KpiTotalSub}"   Glyph="&#xE716;" Tone="Brand"/>
                    <c:StatCard Margin="4,0,4,0" Label="SMENADA"       Value="{Binding KpiOnShift}" Unit="{Binding KpiOnShiftUnit}" Sub="{Binding KpiOnShiftSub}" Glyph="&#xE823;" Tone="Success"/>
                    <c:StatCard Margin="4,0,4,0" Label="OYLIK FONDI"   Value="{Binding KpiPayroll}" Sub="{Binding KpiPayrollSub}"   Glyph="&#xEAFD;" Tone="Info"/>
                    <c:StatCard Margin="8,0,0,0" Label="DAVOMAT"       Value="{Binding KpiAverage}" Sub="{Binding KpiAverageSub}"   Glyph="&#xE9D9;" Tone="Warning"/>
                </UniformGrid>

                <!-- Toolbar -->
                <Border Background="{StaticResource Surface1}"
                        BorderBrush="{StaticResource BorderSubtle}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="12,10"
                        Margin="0,16,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                            <Grid Width="280" Margin="0,0,8,0">
                                <TextBox x:Name="EmployeesSearch" Style="{StaticResource AdminTextBoxSm}" Padding="30,0,8,0"/>
                                <TextBlock Text="&#xE721;" FontFamily="{StaticResource FluentIcons}" FontSize="12"
                                           Foreground="{StaticResource N400}" VerticalAlignment="Center"
                                           Margin="10,0,0,0" IsHitTestVisible="False"/>
                                <TextBlock Text="Ism, telefon yoki rol bo'yicha…"
                                           Style="{StaticResource HintText}" VerticalAlignment="Center"
                                           Margin="32,0,0,0" IsHitTestVisible="False"
                                           Visibility="{Binding ElementName=EmployeesSearch, Path=Text, Converter={StaticResource EmptyStringToVisibilityConverter}}"/>
                            </Grid>
                            <ComboBox Style="{StaticResource AdminComboBoxSm}" Width="160" Margin="0,0,8,0">
                                <ComboBoxItem IsSelected="True">Rol: Barchasi</ComboBoxItem>
                                <ComboBoxItem>Administrator</ComboBoxItem>
                                <ComboBoxItem>Menejer</ComboBoxItem>
                                <ComboBoxItem>Kassir</ComboBoxItem>
                                <ComboBoxItem>Omborchi</ComboBoxItem>
                            </ComboBox>
                            <ComboBox Style="{StaticResource AdminComboBoxSm}" Width="160">
                                <ComboBoxItem IsSelected="True">Filial: Barchasi</ComboBoxItem>
                                <ComboBoxItem>Chilonzor</ComboBoxItem>
                                <ComboBoxItem>Mirobod</ComboBoxItem>
                                <ComboBoxItem>Yunusobod</ComboBoxItem>
                                <ComboBoxItem>Sergeli</ComboBoxItem>
                            </ComboBox>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Employee cards -->
                <ItemsControl ItemsSource="{Binding Employees}" Margin="0,12,0,0">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="3"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{StaticResource Surface1}"
                                    BorderBrush="{StaticResource BorderSubtle}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="16"
                                    Margin="0,0,12,12">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Head: avatar + name + status -->
                                    <Grid Grid.Row="0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Column="0" Width="44" Height="44" CornerRadius="999"
                                                VerticalAlignment="Center">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="{StaticResource Avatar0Bg}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Accent}" Value="1"><Setter Property="Background" Value="{StaticResource Avatar1Bg}"/></DataTrigger>
                                                        <DataTrigger Binding="{Binding Accent}" Value="2"><Setter Property="Background" Value="{StaticResource Avatar2Bg}"/></DataTrigger>
                                                        <DataTrigger Binding="{Binding Accent}" Value="3"><Setter Property="Background" Value="{StaticResource Avatar3Bg}"/></DataTrigger>
                                                        <DataTrigger Binding="{Binding Accent}" Value="4"><Setter Property="Background" Value="{StaticResource Avatar4Bg}"/></DataTrigger>
                                                        <DataTrigger Binding="{Binding Accent}" Value="5"><Setter Property="Background" Value="{StaticResource Avatar5Bg}"/></DataTrigger>
                                                        <DataTrigger Binding="{Binding Accent}" Value="6"><Setter Property="Background" Value="{StaticResource Avatar6Bg}"/></DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding Initials}"
                                                       FontWeight="Bold" FontSize="14"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{StaticResource Avatar0Fg}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Accent}" Value="1"><Setter Property="Foreground" Value="{StaticResource Avatar1Fg}"/></DataTrigger>
                                                            <DataTrigger Binding="{Binding Accent}" Value="2"><Setter Property="Foreground" Value="{StaticResource Avatar2Fg}"/></DataTrigger>
                                                            <DataTrigger Binding="{Binding Accent}" Value="3"><Setter Property="Foreground" Value="{StaticResource Avatar3Fg}"/></DataTrigger>
                                                            <DataTrigger Binding="{Binding Accent}" Value="4"><Setter Property="Foreground" Value="{StaticResource Avatar4Fg}"/></DataTrigger>
                                                            <DataTrigger Binding="{Binding Accent}" Value="5"><Setter Property="Foreground" Value="{StaticResource Avatar5Fg}"/></DataTrigger>
                                                            <DataTrigger Binding="{Binding Accent}" Value="6"><Setter Property="Foreground" Value="{StaticResource Avatar6Fg}"/></DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>

                                        <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="14" Foreground="{StaticResource N900}"/>
                                            <TextBlock Text="{Binding Role}" Style="{StaticResource HintText}" Margin="0,2,0,0"/>
                                        </StackPanel>

                                        <c:StatusBadge Grid.Column="2" VerticalAlignment="Top">
                                            <c:StatusBadge.Style>
                                                <Style TargetType="c:StatusBadge">
                                                    <Setter Property="Tone" Value="Success"/>
                                                    <Setter Property="Text" Value="Faol"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="leave">
                                                            <Setter Property="Tone" Value="Warning"/>
                                                            <Setter Property="Text" Value="Ta'tilda"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="probation">
                                                            <Setter Property="Tone" Value="Info"/>
                                                            <Setter Property="Text" Value="Sinov muddati"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </c:StatusBadge.Style>
                                        </c:StatusBadge>
                                    </Grid>

                                    <!-- Meta grid -->
                                    <Border Grid.Row="1" Background="{StaticResource SurfaceSunken}" CornerRadius="6" Padding="12" Margin="0,12,0,0">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition/>
                                                <RowDefinition/>
                                                <RowDefinition/>
                                            </Grid.RowDefinitions>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Filial"  Style="{StaticResource HintText}"/>
                                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Branch}" Style="{StaticResource BodyText}" FontWeight="Medium"/>

                                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Smena"   Style="{StaticResource HintText}" Margin="0,4,0,0"/>
                                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Shift}" Style="{StaticResource BodyText}" FontWeight="Medium" Margin="0,4,0,0"/>

                                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Telefon" Style="{StaticResource HintText}" Margin="0,4,0,0"/>
                                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Phone}"
                                                       FontFamily="{StaticResource UiFontMono}" FontSize="12"
                                                       Foreground="{StaticResource N700}" Margin="0,4,0,0"/>
                                        </Grid>
                                    </Border>

                                    <!-- Foot: sales + actions -->
                                    <Grid Grid.Row="2" Margin="0,12,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="Bu oygi sotuv" Style="{StaticResource HintText}"/>
                                            <TextBlock Text="{Binding SalesFormatted}"
                                                       FontFamily="{StaticResource UiFontMono}" FontWeight="SemiBold"
                                                       FontSize="14" Foreground="{StaticResource N900}" Margin="0,2,0,0"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                            <Button Style="{StaticResource RowActionButton}" Content="&#xE890;" ToolTip="Profil"/>
                                            <Button Style="{StaticResource RowActionButton}" Content="&#xE70F;" ToolTip="Tahrirlash"/>
                                            <Button Style="{StaticResource RowActionButton}" Content="&#xE712;" ToolTip="Boshqalar"/>
                                        </StackPanel>
                                    </Grid>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
