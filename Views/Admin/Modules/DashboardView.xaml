<UserControl x:Class="PosSystem.Views.Admin.Modules.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:PosSystem.ViewModels.Admin.Modules"
             xmlns:c="clr-namespace:PosSystem.Views.Admin.Controls"
             d:DataContext="{d:DesignInstance Type=vm:DashboardViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="{StaticResource SurfaceApp}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Page header -->
        <c:PageHeader Grid.Row="0"
                      Crumb="ShefPos / Boshqaruv paneli"
                      Title="Boshqaruv paneli"
                      Subtitle="14 May 2026, Payshanba · joriy smena 08:00 dan boshlangan">
            <c:PageHeader.Actions>
                <StackPanel Orientation="Horizontal">
                    <Button Style="{StaticResource AdminSecondaryButtonSm}" Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE787;" FontFamily="{StaticResource FluentIcons}" FontSize="12" Margin="0,0,6,0"/>
                            <TextBlock Text="Bugun"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource AdminSecondaryButtonSm}" Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE895;" FontFamily="{StaticResource FluentIcons}" FontSize="12" Margin="0,0,6,0"/>
                            <TextBlock Text="Yangilash"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource AdminPrimaryButtonSm}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE710;" FontFamily="{StaticResource FluentIcons}" FontSize="12" Margin="0,0,6,0"/>
                            <TextBlock Text="Tezkor sotuv"/>
                            <Border Style="{StaticResource KbdHint}" Background="#FFFFFF" Margin="8,0,0,0">
                                <TextBlock Text="F2" Style="{StaticResource KbdHintText}"/>
                            </Border>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </c:PageHeader.Actions>
        </c:PageHeader>

        <!-- Body -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="20,16,20,24">

                <!-- KPI grid -->
                <UniformGrid Columns="4" Rows="1">
                    <c:StatCard Margin="0,0,8,0"
                                Label="BUGUNGI TUSHUM"
                                Value="{Binding KpiRevenue}"
                                Delta="{Binding KpiRevenueDelta}" DeltaTone="Up"
                                Sub="{Binding KpiRevenueSub}"
                                Glyph="&#xE825;" Tone="Brand"/>
                    <c:StatCard Margin="4,0,4,0"
                                Label="CHEKLAR SONI"
                                Value="{Binding KpiReceipts}" Unit="{Binding KpiReceiptsUnit}"
                                Delta="{Binding KpiReceiptsDelta}" DeltaTone="Up"
                                Sub="{Binding KpiReceiptsSub}"
                                Glyph="&#xE7C1;" Tone="Info"/>
                    <c:StatCard Margin="4,0,4,0"
                                Label="O'RTACHA CHEK"
                                Value="{Binding KpiAverage}"
                                Delta="{Binding KpiAverageDelta}" DeltaTone="Up"
                                Sub="{Binding KpiAverageSub}"
                                Glyph="&#xE9D9;" Tone="Success"/>
                    <c:StatCard Margin="8,0,0,0"
                                Label="FOYDA (KUNLIK)"
                                Value="{Binding KpiProfit}"
                                Delta="{Binding KpiProfitDelta}" DeltaTone="Down"
                                Sub="{Binding KpiProfitSub}"
                                Glyph="&#xEAFD;" Tone="Warning"/>
                </UniformGrid>

                <!-- Charts + Attention row -->
                <Grid Margin="0,16,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.6*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Bar chart -->
                    <Border Grid.Column="0" Style="{StaticResource AdminCard}">
                        <DockPanel>
                            <Border DockPanel.Dock="Top"
                                    BorderBrush="{StaticResource BorderSubtle}"
                                    BorderThickness="0,0,0,1"
                                    Padding="16,12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Savdo dinamikasi" Style="{StaticResource CardTitleText}"/>
                                        <TextBlock Text="Soatlik · bugun 08:00 dan" Style="{StaticResource CardSubText}" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <Border Grid.Column="1" Style="{StaticResource SegmentedGroupBorder}">
                                        <StackPanel Orientation="Horizontal">
                                            <RadioButton Style="{StaticResource SegmentedItem}" GroupName="DashRange" IsChecked="True" Content="Soat"/>
                                            <RadioButton Style="{StaticResource SegmentedItem}" GroupName="DashRange" Content="Kun"/>
                                            <RadioButton Style="{StaticResource SegmentedItem}" GroupName="DashRange" Content="Hafta"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Border>

                            <!-- The "bar chart": gridlines + ItemsControl with vertical bars -->
                            <Grid Margin="16,16,16,16" Height="220">
                                <!-- Gridlines (4 horizontal) -->
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition/>
                                        <RowDefinition/>
                                        <RowDefinition/>
                                        <RowDefinition/>
                                    </Grid.RowDefinitions>
                                    <Border Grid.Row="0" BorderBrush="{StaticResource N100}" BorderThickness="0,0,0,1" VerticalAlignment="Top"/>
                                    <Border Grid.Row="1" BorderBrush="{StaticResource N100}" BorderThickness="0,0,0,1" VerticalAlignment="Top"/>
                                    <Border Grid.Row="2" BorderBrush="{StaticResource N100}" BorderThickness="0,0,0,1" VerticalAlignment="Top"/>
                                    <Border Grid.Row="3" BorderBrush="{StaticResource N100}" BorderThickness="0,0,0,1" VerticalAlignment="Bottom"/>
                                </Grid>

                                <!-- Bars -->
                                <ItemsControl ItemsSource="{Binding HourlyBars}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <UniformGrid Rows="1"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="6,0,6,0">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="*"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>
                                                <Border Grid.Row="0"
                                                        VerticalAlignment="Bottom"
                                                        CornerRadius="3,3,0,0"
                                                        Background="{StaticResource Brand500}"
                                                        HorizontalAlignment="Stretch"
                                                        MinHeight="6"
                                                        Height="{Binding BarHeight}"/>
                                                <TextBlock Grid.Row="1"
                                                           Text="{Binding Hour}"
                                                           Style="{StaticResource MonoText}"
                                                           Foreground="{StaticResource N500}"
                                                           HorizontalAlignment="Center"
                                                           Margin="0,6,0,0"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>
                        </DockPanel>
                    </Border>

                    <!-- Attention list -->
                    <Border Grid.Column="2" Style="{StaticResource AdminCard}">
                        <DockPanel>
                            <Border DockPanel.Dock="Top"
                                    BorderBrush="{StaticResource BorderSubtle}"
                                    BorderThickness="0,0,0,1"
                                    Padding="16,12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Diqqat talab" Style="{StaticResource CardTitleText}"/>
                                        <TextBlock Style="{StaticResource CardSubText}" Margin="0,2,0,0">
                                            <Run Text="{Binding Attention.Count, Mode=OneWay}"/>
                                            <Run Text=" ta ogohlantirish"/>
                                        </TextBlock>
                                    </StackPanel>
                                    <Button Grid.Column="1" Style="{StaticResource AdminGhostButtonSm}">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="Hammasi"/>
                                            <TextBlock Text="&#xE76C;" FontFamily="{StaticResource FluentIcons}" FontSize="10" Margin="6,0,0,0"/>
                                        </StackPanel>
                                    </Button>
                                </Grid>
                            </Border>

                            <ItemsControl ItemsSource="{Binding Attention}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="{StaticResource N100}" BorderThickness="0,0,0,1" Padding="14,10">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="28"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <Border Grid.Column="0" Width="26" Height="26" CornerRadius="5"
                                                        VerticalAlignment="Center"
                                                        Background="{StaticResource Warning50}">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="{StaticResource Warning50}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Severity}" Value="danger">
                                                                    <Setter Property="Background" Value="{StaticResource Danger50}"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Severity}" Value="info">
                                                                    <Setter Property="Background" Value="{StaticResource Info50}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock Text="{Binding Glyph}" FontFamily="{StaticResource FluentIcons}" FontSize="13"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Foreground" Value="{StaticResource Warning600}"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Severity}" Value="danger">
                                                                        <Setter Property="Foreground" Value="{StaticResource Danger600}"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding Severity}" Value="info">
                                                                        <Setter Property="Foreground" Value="{StaticResource Info600}"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Border>

                                                <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Text}"
                                                               FontFamily="{StaticResource UiFont}"
                                                               FontSize="13"
                                                               FontWeight="SemiBold"
                                                               Foreground="{StaticResource N900}"
                                                               TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Text="{Binding When}" Style="{StaticResource HintText}" Margin="0,2,0,0"/>
                                                </StackPanel>

                                                <Button Grid.Column="2" Style="{StaticResource RowActionButton}" Content="&#xE76C;" VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </DockPanel>
                    </Border>
                </Grid>

                <!-- Recent sales -->
                <Border Style="{StaticResource AdminCard}" Margin="0,16,0,0">
                    <DockPanel>
                        <Border DockPanel.Dock="Top"
                                BorderBrush="{StaticResource BorderSubtle}"
                                BorderThickness="0,0,0,1"
                                Padding="16,12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="So'nggi cheklar" Style="{StaticResource CardTitleText}"/>
                                    <TextBlock Text="Bugun soat 13:50 dan keyin yopilgan cheklar" Style="{StaticResource CardSubText}" Margin="0,2,0,0"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                    <Button Style="{StaticResource AdminGhostButtonSm}" Margin="0,0,6,0">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE74E;" FontFamily="{StaticResource FluentIcons}" FontSize="12" Margin="0,0,6,0"/>
                                            <TextBlock Text="Eksport"/>
                                        </StackPanel>
                                    </Button>
                                    <Button Style="{StaticResource AdminSecondaryButtonSm}">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="Barchasi"/>
                                            <TextBlock Text="&#xE76C;" FontFamily="{StaticResource FluentIcons}" FontSize="10" Margin="6,0,0,0"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <DataGrid Style="{StaticResource AdminDataGrid}"
                                  ItemsSource="{Binding RecentSales}"
                                  RowHeight="36">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="CHEK"    Binding="{Binding Receipt}" Width="80"  FontFamily="{StaticResource UiFontMono}"/>
                                <DataGridTextColumn Header="VAQT"    Binding="{Binding Time}"    Width="80"  FontFamily="{StaticResource UiFontMono}"/>
                                <DataGridTextColumn Header="KASSIR"  Binding="{Binding Cashier}" Width="*"/>
                                <DataGridTextColumn Header="TOVAR"   Binding="{Binding Items}"   Width="80"/>
                                <DataGridTemplateColumn Header="TO'LOV" Width="110">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <c:StatusBadge Text="{Binding Payment}" ShowDot="True">
                                                <c:StatusBadge.Style>
                                                    <Style TargetType="c:StatusBadge">
                                                        <Setter Property="Tone" Value="Neutral"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Payment}" Value="Karta"><Setter Property="Tone" Value="Info"/></DataTrigger>
                                                            <DataTrigger Binding="{Binding Payment}" Value="Naqd"><Setter Property="Tone" Value="Success"/></DataTrigger>
                                                            <DataTrigger Binding="{Binding Payment}" Value="Click"><Setter Property="Tone" Value="Brand"/></DataTrigger>
                                                            <DataTrigger Binding="{Binding Payment}" Value="Payme"><Setter Property="Tone" Value="Brand"/></DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </c:StatusBadge.Style>
                                            </c:StatusBadge>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="SUMMA" Binding="{Binding TotalFormatted}" Width="140">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="HorizontalAlignment" Value="Right"/>
                                            <Setter Property="FontFamily" Value="{StaticResource UiFontMono}"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTemplateColumn Header="" Width="80">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                                <Button Style="{StaticResource RowActionButton}" Content="&#xE890;" ToolTip="Ko'rish"/>
                                                <Button Style="{StaticResource RowActionButton}" Content="&#xE749;" ToolTip="Chop etish"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
