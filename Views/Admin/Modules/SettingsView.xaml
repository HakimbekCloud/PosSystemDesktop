<UserControl x:Class="PosSystem.Views.Admin.Modules.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:PosSystem.ViewModels.Admin.Modules"
             xmlns:c="clr-namespace:PosSystem.Views.Admin.Controls"
             d:DataContext="{d:DesignInstance Type=vm:SettingsViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="{StaticResource SurfaceApp}">

    <UserControl.Resources>
        <!-- Tab-list nav item — uses the same active/hover idiom as the sidebar -->
        <Style x:Key="SettingsTab" TargetType="ListBoxItem">
            <Setter Property="FontFamily"        Value="{StaticResource UiFont}"/>
            <Setter Property="FontSize"          Value="13"/>
            <Setter Property="FontWeight"        Value="Medium"/>
            <Setter Property="Foreground"        Value="{StaticResource N700}"/>
            <Setter Property="Cursor"            Value="Hand"/>
            <Setter Property="Padding"           Value="0"/>
            <Setter Property="Margin"            Value="0,1,0,1"/>
            <Setter Property="FocusVisualStyle"  Value="{x:Null}"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Root" CornerRadius="5" Background="Transparent" Padding="10,0" Height="32">
                            <ContentPresenter VerticalAlignment="Center"
                                              TextBlock.Foreground="{TemplateBinding Foreground}"
                                              TextBlock.FontWeight="{TemplateBinding FontWeight}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource N100}"/>
                                <Setter Property="Foreground" Value="{StaticResource N900}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource Brand50}"/>
                                <Setter Property="Foreground" Value="{StaticResource Brand700}"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <c:PageHeader Grid.Row="0"
                      Crumb="ShefPos / Sozlamalar"
                      Title="Sozlamalar"
                      Subtitle="Tizim, qurilmalar, integratsiyalar va xavfsizlik">
            <c:PageHeader.Actions>
                <StackPanel Orientation="Horizontal">
                    <Button Style="{StaticResource AdminGhostButtonSm}" Margin="0,0,8,0" Content="Bekor qilish"/>
                    <Button Style="{StaticResource AdminPrimaryButtonSm}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE74E;" FontFamily="{StaticResource FluentIcons}" FontSize="12" Margin="0,0,6,0"/>
                            <TextBlock Text="O'zgarishlarni saqlash"/>
                            <Border Style="{StaticResource KbdHint}" Background="#FFFFFF" Margin="8,0,0,0">
                                <TextBlock Text="Ctrl+S" Style="{StaticResource KbdHintText}"/>
                            </Border>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </c:PageHeader.Actions>
        </c:PageHeader>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Grid Margin="20,16,20,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- ─── Left: tab list ─── -->
                <Border Grid.Column="0"
                        Background="{StaticResource Surface1}"
                        BorderBrush="{StaticResource BorderSubtle}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="6"
                        VerticalAlignment="Top">
                    <ListBox Background="Transparent"
                             BorderThickness="0"
                             ItemsSource="{Binding Tabs}"
                             SelectedItem="{Binding SelectedTab}">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem" BasedOn="{StaticResource SettingsTab}"/>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Style="{StaticResource FluentIconText}" Text="{Binding Glyph}" FontSize="14"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Title}" Margin="10,0,0,0" VerticalAlignment="Center"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Border>

                <!-- ─── Right: sections (always-on for "general" + receipt preview pattern) ─── -->
                <StackPanel Grid.Column="2">

                    <!-- Unsaved changes bar -->
                    <Border Background="{StaticResource Warning50}"
                            BorderBrush="{StaticResource Warning100}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="14,10"
                            Margin="0,0,0,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="&#xE7BA;" FontFamily="{StaticResource FluentIcons}" FontSize="14" Foreground="{StaticResource Warning600}" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="Saqlanmagan o'zgarishlar mavjud — saqlash uchun Ctrl+S yoki yuqoridagi tugmani bosing"
                                       Style="{StaticResource BodyText}" Foreground="{StaticResource Warning700}" Margin="10,0,0,0" VerticalAlignment="Center"/>
                            <Button Grid.Column="2" Style="{StaticResource AdminGhostButtonSm}" Foreground="{StaticResource Warning700}" Content="Bekor qilish"/>
                        </Grid>
                    </Border>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="260"/>
                        </Grid.ColumnDefinitions>

                        <!-- Sections column -->
                        <StackPanel Grid.Column="0">

                            <!-- ── Section: company ── -->
                            <Border Style="{StaticResource AdminCard}" Margin="0,0,0,12">
                                <StackPanel>
                                    <Border BorderBrush="{StaticResource BorderSubtle}" BorderThickness="0,0,0,1" Padding="16,12">
                                        <StackPanel>
                                            <TextBlock Text="Tashkilot ma'lumotlari" Style="{StaticResource CardTitleText}"/>
                                            <TextBlock Text="Chek va hisobotlarda ko'rinadigan rekvizitlar" Style="{StaticResource CardSubText}" Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </Border>

                                    <StackPanel Margin="16,12,16,12">
                                        <Grid Margin="0,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="220"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="Tashkilot nomi" Style="{StaticResource LabelText}"/>
                                                <TextBlock Text="Yuridik nom — chekka chiqariladi" Style="{StaticResource HintText}" Margin="0,2,0,0"/>
                                            </StackPanel>
                                            <TextBox Grid.Column="1" Style="{StaticResource AdminTextBox}" Text="{Binding BusinessName, UpdateSourceTrigger=PropertyChanged}"/>
                                        </Grid>
                                        <Border Style="{StaticResource HDivider}" Margin="0,12"/>
                                        <Grid Margin="0,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="220"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="Yuridik manzil" Style="{StaticResource LabelText}" VerticalAlignment="Top" Margin="0,8,0,0"/>
                                            <TextBox Grid.Column="1" Style="{StaticResource AdminTextBox}" Height="60" AcceptsReturn="True" VerticalContentAlignment="Top" Padding="10,8"
                                                     Text="{Binding LegalAddress, UpdateSourceTrigger=PropertyChanged}"/>
                                        </Grid>
                                        <Border Style="{StaticResource HDivider}" Margin="0,12"/>
                                        <Grid Margin="0,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="220"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="16"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="INN / Telefon" Style="{StaticResource LabelText}"/>
                                            <TextBox  Grid.Column="1" Style="{StaticResource AdminTextBox}" Text="{Binding Inn, UpdateSourceTrigger=PropertyChanged}"/>
                                            <TextBox  Grid.Column="3" Style="{StaticResource AdminTextBox}" Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}"/>
                                        </Grid>
                                        <Border Style="{StaticResource HDivider}" Margin="0,12"/>
                                        <Grid Margin="0,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="220"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="E-pochta" Style="{StaticResource LabelText}"/>
                                            <TextBox  Grid.Column="1" Style="{StaticResource AdminTextBox}" Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"/>
                                        </Grid>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- ── Section: locale ── -->
                            <Border Style="{StaticResource AdminCard}" Margin="0,0,0,12">
                                <StackPanel>
                                    <Border BorderBrush="{StaticResource BorderSubtle}" BorderThickness="0,0,0,1" Padding="16,12">
                                        <StackPanel>
                                            <TextBlock Text="Mahalliylashtirish" Style="{StaticResource CardTitleText}"/>
                                            <TextBlock Text="Til, valyuta va vaqt zonasi" Style="{StaticResource CardSubText}" Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </Border>
                                    <StackPanel Margin="16,12,16,12">
                                        <Grid Margin="0,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="220"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="Til" Style="{StaticResource LabelText}"/>
                                            <ComboBox Grid.Column="1" Style="{StaticResource AdminComboBox}">
                                                <ComboBoxItem IsSelected="True">O'zbek (lotin)</ComboBoxItem>
                                                <ComboBoxItem>O'zbek (kirill)</ComboBoxItem>
                                                <ComboBoxItem>Русский</ComboBoxItem>
                                                <ComboBoxItem>English</ComboBoxItem>
                                            </ComboBox>
                                        </Grid>
                                        <Border Style="{StaticResource HDivider}" Margin="0,12"/>
                                        <Grid Margin="0,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="220"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="Valyuta" Style="{StaticResource LabelText}"/>
                                            <ComboBox Grid.Column="1" Style="{StaticResource AdminComboBox}">
                                                <ComboBoxItem IsSelected="True">So'm (UZS)</ComboBoxItem>
                                                <ComboBoxItem>USD</ComboBoxItem>
                                                <ComboBoxItem>EUR</ComboBoxItem>
                                            </ComboBox>
                                        </Grid>
                                        <Border Style="{StaticResource HDivider}" Margin="0,12"/>
                                        <Grid Margin="0,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="220"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="Sodiqlik tizimi" Style="{StaticResource LabelText}"/>
                                                <TextBlock Text="Mijozlarga ball va chegirma berish" Style="{StaticResource HintText}" Margin="0,2,0,0"/>
                                            </StackPanel>
                                            <CheckBox Grid.Column="2" Style="{StaticResource AdminToggle}" IsChecked="{Binding EnableLoyalty}"/>
                                        </Grid>
                                        <Border Style="{StaticResource HDivider}" Margin="0,12"/>
                                        <Grid Margin="0,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="220"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="Onlayn to'lovlar" Style="{StaticResource LabelText}"/>
                                                <TextBlock Text="Click, Payme, karta bilan to'lash" Style="{StaticResource HintText}" Margin="0,2,0,0"/>
                                            </StackPanel>
                                            <CheckBox Grid.Column="2" Style="{StaticResource AdminToggle}" IsChecked="{Binding EnableOnlinePayments}"/>
                                        </Grid>
                                        <Border Style="{StaticResource HDivider}" Margin="0,12"/>
                                        <Grid Margin="0,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="220"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="Avtomatik chek bosib chiqarish" Style="{StaticResource LabelText}"/>
                                                <TextBlock Text="Sotuv yakunida fiskal chek avtomatik chiqadi" Style="{StaticResource HintText}" Margin="0,2,0,0"/>
                                            </StackPanel>
                                            <CheckBox Grid.Column="2" Style="{StaticResource AdminToggle}" IsChecked="{Binding AutoPrintReceipt}"/>
                                        </Grid>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- ── Integrations ── -->
                            <Border Style="{StaticResource AdminCard}" Margin="0,0,0,12">
                                <StackPanel>
                                    <Border BorderBrush="{StaticResource BorderSubtle}" BorderThickness="0,0,0,1" Padding="16,12">
                                        <StackPanel>
                                            <TextBlock Text="Integratsiyalar" Style="{StaticResource CardTitleText}"/>
                                            <TextBlock Text="To'lov tizimlari, fiskal modul va tashqi xizmatlar" Style="{StaticResource CardSubText}" Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </Border>
                                    <ItemsControl ItemsSource="{Binding Integrations}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border BorderBrush="{StaticResource N100}" BorderThickness="0,0,0,1" Padding="16,12">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel Grid.Column="0">
                                                            <TextBlock Text="{Binding Name}" Style="{StaticResource LabelText}"/>
                                                            <TextBlock Text="{Binding Description}" Style="{StaticResource HintText}" Margin="0,2,0,0"/>
                                                        </StackPanel>
                                                        <TextBlock Grid.Column="1" Style="{StaticResource HintText}" VerticalAlignment="Center" Margin="0,0,16,0">
                                                            <Run Text="Oxirgi yangilanish:"/>
                                                            <Run Text="{Binding Updated, Mode=OneWay}"/>
                                                        </TextBlock>
                                                        <c:StatusBadge Grid.Column="2" VerticalAlignment="Center" Margin="0,0,12,0">
                                                            <c:StatusBadge.Style>
                                                                <Style TargetType="c:StatusBadge">
                                                                    <Setter Property="Tone" Value="Neutral"/>
                                                                    <Setter Property="Text" Value="Ulanmagan"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding Status}" Value="connected">
                                                                            <Setter Property="Tone" Value="Success"/>
                                                                            <Setter Property="Text" Value="Ulangan"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding Status}" Value="error">
                                                                            <Setter Property="Tone" Value="Danger"/>
                                                                            <Setter Property="Text" Value="Xatolik"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </c:StatusBadge.Style>
                                                        </c:StatusBadge>
                                                        <Button Grid.Column="3" Style="{StaticResource AdminSecondaryButtonSm}" Content="Sozlash"/>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                            <!-- ── Audit ── -->
                            <Border Style="{StaticResource AdminCard}">
                                <StackPanel>
                                    <Border BorderBrush="{StaticResource BorderSubtle}" BorderThickness="0,0,0,1" Padding="16,12">
                                        <StackPanel>
                                            <TextBlock Text="Audit jurnali" Style="{StaticResource CardTitleText}"/>
                                            <TextBlock Text="So'nggi 7 ta tizim hodisasi" Style="{StaticResource CardSubText}" Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </Border>
                                    <DataGrid Style="{StaticResource AdminDataGrid}"
                                              ItemsSource="{Binding Audit}"
                                              RowHeight="36">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="VAQT"      Binding="{Binding When}"   Width="170" FontFamily="{StaticResource UiFontMono}"/>
                                            <DataGridTextColumn Header="FOYDALANUVCHI" Binding="{Binding User}" Width="170"/>
                                            <DataGridTextColumn Header="HARAKAT"   Binding="{Binding Action}" Width="200"/>
                                            <DataGridTextColumn Header="TAFSILOT"  Binding="{Binding Detail}" Width="*"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </StackPanel>
                            </Border>

                        </StackPanel>

                        <!-- Receipt preview -->
                        <StackPanel Grid.Column="2" VerticalAlignment="Top">
                            <TextBlock Text="JONLI CHEK KO'RINISHI" Style="{StaticResource UppercaseLabelText}" Margin="0,4,0,8"/>
                            <Border Background="White"
                                    BorderBrush="{StaticResource BorderSubtle}"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    Padding="14,16">
                                <StackPanel>
                                    <TextBlock Text="{Binding ReceiptHeader}"
                                               FontFamily="{StaticResource UiFontMono}"
                                               FontSize="11"
                                               Foreground="{StaticResource N800}"
                                               TextAlignment="Center"
                                               TextWrapping="Wrap"/>
                                    <Border Height="1" Background="{StaticResource N200}" Margin="0,10" SnapsToDevicePixels="True"/>
                                    <TextBlock Text="14.05.2026  13:42" FontFamily="{StaticResource UiFontMono}" FontSize="11" Foreground="{StaticResource N700}" Margin="0,0,0,4"/>
                                    <TextBlock Text="Kassir: M. Rashidova"   FontFamily="{StaticResource UiFontMono}" FontSize="11" Foreground="{StaticResource N700}" Margin="0,0,0,4"/>
                                    <TextBlock Text="Chek #04812"             FontFamily="{StaticResource UiFontMono}" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource N900}"/>
                                    <Border Height="1" Background="{StaticResource N200}" Margin="0,10"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Coca-Cola 0.5L × 2" FontFamily="{StaticResource UiFontMono}" FontSize="11"/>
                                        <TextBlock Grid.Column="1" Text="16 000" FontFamily="{StaticResource UiFontMono}" FontSize="11"/>
                                    </Grid>
                                    <Grid Margin="0,4,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Non (katta) × 1"  FontFamily="{StaticResource UiFontMono}" FontSize="11"/>
                                        <TextBlock Grid.Column="1" Text="4 000"  FontFamily="{StaticResource UiFontMono}" FontSize="11"/>
                                    </Grid>
                                    <Border Height="1" Background="{StaticResource N200}" Margin="0,10"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="JAMI" FontFamily="{StaticResource UiFontMono}" FontWeight="Bold" FontSize="12" Foreground="{StaticResource N900}"/>
                                        <TextBlock Grid.Column="1" Text="20 000 so'm" FontFamily="{StaticResource UiFontMono}" FontWeight="Bold" FontSize="12" Foreground="{StaticResource N900}"/>
                                    </Grid>
                                    <Border Height="1" Background="{StaticResource N200}" Margin="0,10"/>
                                    <TextBlock Text="{Binding ReceiptFooter}"
                                               FontFamily="{StaticResource UiFontMono}"
                                               FontSize="11"
                                               Foreground="{StaticResource N700}"
                                               TextAlignment="Center"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                            <TextBlock Text="Bu maydondagi o'zgarishlar real vaqtda chekka aks etadi."
                                       Style="{StaticResource HintText}"
                                       TextWrapping="Wrap"
                                       Margin="0,8,0,0"/>
                        </StackPanel>
                    </Grid>

                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
