<UserControl x:Class="PosSystem.Views.Admin.Modules.HisobotlarView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:PosSystem.ViewModels.Admin.Modules"
             xmlns:c="clr-namespace:PosSystem.Views.Admin.Controls"
             d:DataContext="{d:DesignInstance Type=vm:HisobotlarViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="{StaticResource AppSurface}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <c:PageHeader Grid.Row="0"
                      Title="Hisobotlar"
                      Sub="Savdo dinamikasi, mahsulotlar va kassir samaradorligi"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24,16,24,24">
                <c:WpfMappingBanner Hint="{Binding WpfHint}"/>

                <UniformGrid Columns="4" Rows="1">
                    <c:StatCard Margin="0,0,6,0" Label="TUSHUM"      Value="{Binding KpiRevenue}" Glyph="&#xE825;" Tone="Brand"   Delta="+18.4% o'tgan haftadan" DeltaTone="Up"/>
                    <c:StatCard Margin="3,0,3,0" Label="FOYDA"       Value="{Binding KpiProfit}"  Glyph="&#xE9D9;" Tone="Success" Delta="+12.1%" DeltaTone="Up"/>
                    <c:StatCard Margin="3,0,3,0" Label="CHEKLAR"     Value="{Binding KpiOrders}" Unit="ta" Glyph="&#xE7C1;" Tone="Info" Delta="+96 chek" DeltaTone="Up"/>
                    <c:StatCard Margin="6,0,0,0" Label="O'RTACHA CHEK" Value="{Binding KpiAverage}" Glyph="&#xE9A6;" Tone="Warning" Delta="+5.2%" DeltaTone="Up"/>
                </UniformGrid>

                <!-- Daily bar chart + Payments donut row -->
                <Grid Margin="0,16,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.6*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Daily bars -->
                    <Border Grid.Column="0" Style="{StaticResource AdminCard}" Padding="0">
                        <DockPanel>
                            <Border DockPanel.Dock="Top" BorderBrush="{StaticResource BorderSubtle}" BorderThickness="0,0,0,1" Padding="16,14">
                                <StackPanel>
                                    <TextBlock Text="Savdo dinamikasi" Style="{StaticResource CardTitleText}"/>
                                    <TextBlock Text="So'nggi 7 kun · so'mda" Style="{StaticResource CardSubText}" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Border>
                            <Grid Margin="16,18,16,16" Height="220">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/>
                                    </Grid.RowDefinitions>
                                    <Border Grid.Row="0" BorderBrush="{StaticResource N100}" BorderThickness="0,0,0,1" VerticalAlignment="Top"/>
                                    <Border Grid.Row="1" BorderBrush="{StaticResource N100}" BorderThickness="0,0,0,1" VerticalAlignment="Top"/>
                                    <Border Grid.Row="2" BorderBrush="{StaticResource N100}" BorderThickness="0,0,0,1" VerticalAlignment="Top"/>
                                    <Border Grid.Row="3" BorderBrush="{StaticResource N100}" BorderThickness="0,0,0,1" VerticalAlignment="Bottom"/>
                                </Grid>
                                <ItemsControl ItemsSource="{Binding Days}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate><UniformGrid Rows="1"/></ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="10,0,10,0">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="*"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>
                                                <Border Grid.Row="0" VerticalAlignment="Bottom" CornerRadius="4,4,0,0"
                                                        Background="{StaticResource Brand500}" MinHeight="6"
                                                        Height="{Binding BarHeight}"/>
                                                <TextBlock Grid.Row="1" Text="{Binding Label}"
                                                           Style="{StaticResource MonoText}"
                                                           Foreground="{StaticResource N500}"
                                                           HorizontalAlignment="Center"
                                                           Margin="0,8,0,0"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>
                        </DockPanel>
                    </Border>

                    <!-- Payments breakdown -->
                    <Border Grid.Column="2" Style="{StaticResource AdminCard}" Padding="0">
                        <DockPanel>
                            <Border DockPanel.Dock="Top" BorderBrush="{StaticResource BorderSubtle}" BorderThickness="0,0,0,1" Padding="16,14">
                                <StackPanel>
                                    <TextBlock Text="To'lov turlari" Style="{StaticResource CardTitleText}"/>
                                    <TextBlock Text="Hafta bo'yicha taqsimot" Style="{StaticResource CardSubText}" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Border>
                            <ItemsControl ItemsSource="{Binding Payments}" Padding="16,14">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,0,0,12">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <Grid Grid.Row="0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <Border Grid.Column="0" Width="10" Height="10" CornerRadius="2"
                                                        Background="{Binding Color}" VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="1" Text="{Binding Label}" Style="{StaticResource BodyText}" Margin="8,0,0,0"/>
                                                <TextBlock Grid.Column="2" Text="{Binding AmountFmt}"
                                                           FontFamily="{StaticResource UiFontMono}"
                                                           FontSize="12" FontWeight="SemiBold"
                                                           Foreground="{StaticResource N900}"/>
                                            </Grid>
                                            <ProgressBar Grid.Row="1" Style="{StaticResource AdminProgressBar}"
                                                         Maximum="100" Value="{Binding Share}"
                                                         Foreground="{Binding Color}" Margin="0,6,0,0"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </DockPanel>
                    </Border>
                </Grid>

                <!-- Hourly bars + Cashiers row -->
                <Grid Margin="0,16,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.5*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource AdminCard}" Padding="0">
                        <DockPanel>
                            <Border DockPanel.Dock="Top" BorderBrush="{StaticResource BorderSubtle}" BorderThickness="0,0,0,1" Padding="16,14">
                                <StackPanel>
                                    <TextBlock Text="Soatlik tushum" Style="{StaticResource CardTitleText}"/>
                                    <TextBlock Text="O'rtacha kun · 08:00 – 22:00" Style="{StaticResource CardSubText}" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Border>
                            <Grid Margin="16,18,16,16" Height="180">
                                <ItemsControl ItemsSource="{Binding Hours}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate><UniformGrid Rows="1"/></ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="8,0,8,0">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="*"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>
                                                <Border Grid.Row="0" VerticalAlignment="Bottom" CornerRadius="4,4,0,0"
                                                        Background="{StaticResource Brand400}" MinHeight="6"
                                                        Height="{Binding BarHeight}"/>
                                                <TextBlock Grid.Row="1" Text="{Binding Label}"
                                                           Style="{StaticResource MonoText}"
                                                           Foreground="{StaticResource N500}"
                                                           HorizontalAlignment="Center"
                                                           Margin="0,8,0,0"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>
                        </DockPanel>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource AdminCard}" Padding="0">
                        <DockPanel>
                            <Border DockPanel.Dock="Top" BorderBrush="{StaticResource BorderSubtle}" BorderThickness="0,0,0,1" Padding="16,14">
                                <StackPanel>
                                    <TextBlock Text="Kassirlar samaradorligi" Style="{StaticResource CardTitleText}"/>
                                    <TextBlock Text="Bu hafta" Style="{StaticResource CardSubText}" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Border>
                            <ItemsControl ItemsSource="{Binding Cashiers}" Padding="16,14">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,0,0,14">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <Grid Grid.Row="0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <Border Grid.Column="0" Width="28" Height="28" CornerRadius="999" VerticalAlignment="Center">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="{StaticResource Avatar0Bg}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Accent}" Value="1"><Setter Property="Background" Value="{StaticResource Avatar1Bg}"/></DataTrigger>
                                                                <DataTrigger Binding="{Binding Accent}" Value="4"><Setter Property="Background" Value="{StaticResource Avatar4Bg}"/></DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock Text="{Binding Initials}" FontWeight="Bold" FontSize="11"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Foreground" Value="{StaticResource Avatar0Fg}"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Accent}" Value="1"><Setter Property="Foreground" Value="{StaticResource Avatar1Fg}"/></DataTrigger>
                                                                    <DataTrigger Binding="{Binding Accent}" Value="4"><Setter Property="Foreground" Value="{StaticResource Avatar4Fg}"/></DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Border>
                                                <TextBlock Grid.Column="1" Text="{Binding Name}"
                                                           Margin="8,0,0,0" VerticalAlignment="Center"
                                                           FontWeight="SemiBold" FontSize="13" Foreground="{StaticResource N900}"/>
                                                <TextBlock Grid.Column="2" Text="{Binding SalesFmt}"
                                                           FontFamily="{StaticResource UiFontMono}"
                                                           FontSize="12" FontWeight="Bold"
                                                           Foreground="{StaticResource N900}"
                                                           VerticalAlignment="Center"/>
                                            </Grid>
                                            <ProgressBar Grid.Row="1" Style="{StaticResource AdminProgressBar}"
                                                         Maximum="100" Value="{Binding Share}" Margin="0,6,0,0"/>
                                            <Grid Grid.Row="2" Margin="0,4,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Style="{StaticResource HintText}">
                                                    <Run Text="{Binding Checks, Mode=OneWay}"/>
                                                    <Run Text="chek"/>
                                                </TextBlock>
                                                <TextBlock Grid.Column="1" Style="{StaticResource HintText}">
                                                    <Run Text="O'rt:"/>
                                                    <Run Text="{Binding AverageFmt, Mode=OneWay}" FontFamily="{StaticResource UiFontMono}"/>
                                                </TextBlock>
                                            </Grid>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </DockPanel>
                    </Border>
                </Grid>

                <!-- Top products table -->
                <Border Style="{StaticResource AdminCard}" Margin="0,16,0,0" Padding="0">
                    <DockPanel>
                        <Border DockPanel.Dock="Top" BorderBrush="{StaticResource BorderSubtle}" BorderThickness="0,0,0,1" Padding="16,14">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Top sotilgan mahsulotlar" Style="{StaticResource CardTitleText}"/>
                                    <TextBlock Text="Bu hafta · soni va tushumi bo'yicha" Style="{StaticResource CardSubText}" Margin="0,2,0,0"/>
                                </StackPanel>
                                <Button Grid.Column="1" Style="{StaticResource AdminGhostButtonSm}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Barchasi"/>
                                        <TextBlock Text="&#xE76C;" FontFamily="{StaticResource FluentIcons}" FontSize="10" Margin="6,0,0,0"/>
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </Border>
                        <DataGrid Style="{StaticResource AdminDataGrid}" ItemsSource="{Binding TopProducts}" RowHeight="40">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="#" Binding="{Binding Rank}" Width="40">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="FontWeight" Value="Bold"/>
                                            <Setter Property="Foreground" Value="{StaticResource Brand600}"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="MAHSULOT" Binding="{Binding Name}" Width="*">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="SOTILDI" Binding="{Binding Sold}" Width="100">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="FontFamily" Value="{StaticResource UiFontMono}"/>
                                            <Setter Property="HorizontalAlignment" Value="Right"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTemplateColumn Header="HAJM" Width="240">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border Background="{StaticResource Brand500}"
                                                    Height="6" CornerRadius="999"
                                                    HorizontalAlignment="Left"
                                                    VerticalAlignment="Center"
                                                    Width="{Binding BarWidth}"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="TUSHUM" Binding="{Binding RevenueFmt}" Width="160">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="FontFamily" Value="{StaticResource UiFontMono}"/>
                                            <Setter Property="FontWeight" Value="Bold"/>
                                            <Setter Property="HorizontalAlignment" Value="Right"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
