<UserControl x:Class="PosSystem.Views.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="420"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ═══════ LEFT PANEL — Branding ═══════ -->
        <Border Grid.Column="0">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0.4,1">
                    <GradientStop Color="#0A1628" Offset="0"/>
                    <GradientStop Color="#0D2B5E" Offset="0.4"/>
                    <GradientStop Color="#1044A3" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>

            <Grid>
                <!-- Decorative circles -->
                <Ellipse Width="380" Height="380" HorizontalAlignment="Left"
                         VerticalAlignment="Top" Margin="-160,-140,0,0"
                         Opacity="0.06">
                    <Ellipse.Fill>
                        <SolidColorBrush Color="White"/>
                    </Ellipse.Fill>
                </Ellipse>
                <Ellipse Width="300" Height="300" HorizontalAlignment="Right"
                         VerticalAlignment="Bottom" Margin="0,0,-100,-80"
                         Opacity="0.06">
                    <Ellipse.Fill>
                        <SolidColorBrush Color="White"/>
                    </Ellipse.Fill>
                </Ellipse>

                <!-- Content -->
                <StackPanel VerticalAlignment="Center" Margin="52,0,44,0">

                    <!-- Logo -->
                    <Border Width="76" Height="76" CornerRadius="22"
                            HorizontalAlignment="Left" Margin="0,0,0,32">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#1976D2" Offset="0"/>
                                <GradientStop Color="#42A5F5" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <TextBlock Text="🛒" FontSize="36"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>

                    <!-- Title -->
                    <TextBlock Text="POS Tizimi" FontSize="32" FontWeight="Bold"
                               Foreground="White" Margin="0,0,0,10"/>
                    <TextBlock TextWrapping="Wrap" FontSize="15" LineHeight="24"
                               Foreground="#90B4E8" Margin="0,0,0,48">
                        Do'koningizni boshqarishning&#x0a;eng qulay usuli
                    </TextBlock>

                    <!-- Divider -->
                    <Border Height="1" Background="#1E3D7A" Margin="0,0,0,36"/>

                    <!-- Feature list -->
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,18">
                            <Border Width="32" Height="32" CornerRadius="8"
                                    Background="#163A7C" Margin="0,0,14,0">
                                <TextBlock Text="⚡" FontSize="15"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Tezkor sotuv" FontSize="13"
                                           FontWeight="SemiBold" Foreground="White"/>
                                <TextBlock Text="Bir necha soniyada sotuv" FontSize="11"
                                           Foreground="#6A92CC"/>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,18">
                            <Border Width="32" Height="32" CornerRadius="8"
                                    Background="#163A7C" Margin="0,0,14,0">
                                <TextBlock Text="🔄" FontSize="15"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Offline / Online" FontSize="13"
                                           FontWeight="SemiBold" Foreground="White"/>
                                <TextBlock Text="Internet bo'lmasa ham ishlaydi" FontSize="11"
                                           Foreground="#6A92CC"/>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,18">
                            <Border Width="32" Height="32" CornerRadius="8"
                                    Background="#163A7C" Margin="0,0,14,0">
                                <TextBlock Text="📊" FontSize="15"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Real vaqt sinxronizatsiya" FontSize="13"
                                           FontWeight="SemiBold" Foreground="White"/>
                                <TextBlock Text="Ma'lumotlar doim yangilanib turadi" FontSize="11"
                                           Foreground="#6A92CC"/>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal">
                            <Border Width="32" Height="32" CornerRadius="8"
                                    Background="#163A7C" Margin="0,0,14,0">
                                <TextBlock Text="👥" FontSize="15"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Mijozlar bazasi" FontSize="13"
                                           FontWeight="SemiBold" Foreground="White"/>
                                <TextBlock Text="Mijozlar bilan ishlash imkoni" FontSize="11"
                                           Foreground="#6A92CC"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>

                    <!-- Version -->
                    <TextBlock Text="v1.0.0" FontSize="11" Foreground="#334E82"
                               Margin="0,60,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══════ RIGHT PANEL — Form ═══════ -->
        <Border Grid.Column="1" Background="#F8FAFD">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <Grid VerticalAlignment="Center" MinHeight="600">

                    <StackPanel Width="400" HorizontalAlignment="Center"
                                VerticalAlignment="Center" Margin="0,40">

                        <!-- Form header -->
                        <TextBlock Text="Tizimga kirish" FontSize="28" FontWeight="Bold"
                                   Foreground="#0D1B3E" Margin="0,0,0,8"/>
                        <TextBlock Text="Davom etish uchun hisobingizga kiring"
                                   FontSize="14" Foreground="#7A8DAB" Margin="0,0,0,40"/>

                        <!-- ── Tenant subdomain ── -->
                        <TextBlock Text="Tashkilot kodi" FontSize="13" FontWeight="Medium"
                                   Foreground="#374151" Margin="0,0,0,8"/>
                        <Border BorderThickness="1.5" CornerRadius="10"
                                Background="White" Margin="0,0,0,20"
                                BorderBrush="#D1D9E6">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Style.Triggers>
                                        <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                            <Setter Property="BorderBrush" Value="#1565C0"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="48"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" BorderBrush="#EEF2F8"
                                        BorderThickness="0,0,1,0" CornerRadius="10,0,0,10">
                                    <TextBlock Text="🏢" FontSize="18"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                                <TextBox Grid.Column="1"
                                         Text="{Binding TenantSubdomain, UpdateSourceTrigger=PropertyChanged}"
                                         FontSize="14" Padding="12,13"
                                         BorderThickness="0" Background="Transparent"
                                         Foreground="#1A2540"
                                         Style="{StaticResource FlatTextBoxStyle}"/>
                                <TextBlock Grid.Column="1"
                                           Text="tenant-nomi"
                                           Foreground="#C0CCDE" FontSize="14"
                                           Margin="14,0,0,0" VerticalAlignment="Center"
                                           IsHitTestVisible="False">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding TenantSubdomain}" Value="">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </Border>

                        <!-- ── Username ── -->
                        <TextBlock Text="Login" FontSize="13" FontWeight="Medium"
                                   Foreground="#374151" Margin="0,0,0,8"/>
                        <Border BorderThickness="1.5" CornerRadius="10"
                                Background="White" Margin="0,0,0,20"
                                BorderBrush="#D1D9E6">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Style.Triggers>
                                        <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                            <Setter Property="BorderBrush" Value="#1565C0"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="48"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" BorderBrush="#EEF2F8"
                                        BorderThickness="0,0,1,0" CornerRadius="10,0,0,10">
                                    <TextBlock Text="👤" FontSize="18"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                                <TextBox Grid.Column="1" x:Name="UsernameBox"
                                         Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                                         FontSize="14" Padding="12,13"
                                         BorderThickness="0" Background="Transparent"
                                         Foreground="#1A2540"
                                         Style="{StaticResource FlatTextBoxStyle}"/>
                                <TextBlock Grid.Column="1"
                                           Text="Foydalanuvchi nomi"
                                           Foreground="#C0CCDE" FontSize="14"
                                           Margin="14,0,0,0" VerticalAlignment="Center"
                                           IsHitTestVisible="False">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Username}" Value="">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </Border>

                        <!-- ── Password ── -->
                        <TextBlock Text="Parol" FontSize="13" FontWeight="Medium"
                                   Foreground="#374151" Margin="0,0,0,8"/>
                        <Border BorderThickness="1.5" CornerRadius="10"
                                Background="White" Margin="0,0,0,8"
                                BorderBrush="#D1D9E6">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Style.Triggers>
                                        <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                            <Setter Property="BorderBrush" Value="#1565C0"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="48"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="44"/>
                                </Grid.ColumnDefinitions>

                                <!-- Lock icon -->
                                <Border Grid.Column="0" BorderBrush="#EEF2F8"
                                        BorderThickness="0,0,1,0" CornerRadius="10,0,0,10">
                                    <TextBlock Text="🔒" FontSize="18"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>

                                <!-- Password input (hidden chars) -->
                                <PasswordBox Grid.Column="1" x:Name="PasswordBox"
                                             FontSize="14" Padding="12,13"
                                             BorderThickness="0" Background="Transparent"
                                             Foreground="#1A2540"/>

                                <!-- Password input (visible chars) -->
                                <TextBox Grid.Column="1" x:Name="PasswordText"
                                         FontSize="14" Padding="12,13"
                                         BorderThickness="0" Background="Transparent"
                                         Foreground="#1A2540"
                                         Visibility="Collapsed"
                                         Style="{StaticResource FlatTextBoxStyle}"/>

                                <!-- Placeholder -->
                                <TextBlock Grid.Column="1"
                                           Text="••••••••"
                                           Foreground="#C0CCDE" FontSize="18"
                                           Margin="14,0,0,0" VerticalAlignment="Center"
                                           IsHitTestVisible="False">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Password}" Value="">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>

                                <!-- Toggle visibility button -->
                                <Button Grid.Column="2" x:Name="TogglePasswordBtn"
                                        Content="👁" FontSize="16"
                                        VerticalAlignment="Center" HorizontalAlignment="Center"
                                        Click="OnTogglePassword"
                                        Style="{StaticResource IconButtonStyle}"
                                        ToolTip="Parolni ko'rsatish"/>
                            </Grid>
                        </Border>

                        <!-- ── Error message ── -->
                        <Border x:Name="ErrorPanel" CornerRadius="8"
                                Background="#FEF2F2" Padding="14,10"
                                Margin="0,12,0,0"
                                Visibility="{Binding ErrorMessage,
                                             Converter={StaticResource StringToVisibilityConverter}}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⚠  " Foreground="#DC2626" FontSize="13"/>
                                <TextBlock Text="{Binding ErrorMessage}" Foreground="#DC2626"
                                           FontSize="13" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <!-- ── Login button ── -->
                        <Button x:Name="LoginBtn"
                                Command="{Binding LoginCommand}"
                                Height="50" FontSize="16" FontWeight="SemiBold"
                                Margin="0,20,0,0"
                                Style="{StaticResource PrimaryButtonStyle}">
                            <Grid Width="360">
                                <!-- Normal state -->
                                <TextBlock Text="Kirish" HorizontalAlignment="Center"
                                           Visibility="{Binding IsBusy,
                                           Converter={StaticResource InverseBoolToVisibilityConverter}}"/>
                                <!-- Loading state -->
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                                            Visibility="{Binding IsBusy,
                                            Converter={StaticResource BoolToVisibilityConverter}}">
                                    <TextBlock Text="Tekshirilmoqda..." Foreground="White"/>
                                </StackPanel>
                            </Grid>
                        </Button>

                        <!-- ── Help text ── -->
                        <TextBlock FontSize="12" Foreground="#9AADCA"
                                   HorizontalAlignment="Center" Margin="0,24,0,0"
                                   TextWrapping="Wrap" TextAlignment="Center">
                            Muammo bo'lsa tizim administratoriga murojaat qiling
                        </TextBlock>

                    </StackPanel>
                </Grid>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
