<UserControl x:Class="PosSystem.Views.Pos.PosView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:PosSystem.ViewModels.Pos"
             xmlns:game="clr-namespace:PosSystem.Views.Game"
             xmlns:helpers="clr-namespace:PosSystem.Helpers">

    <UserControl.Resources>
        <!-- Quantity +/- button -->
        <Style x:Key="QtyBtnStyle" TargetType="Button">
            <Setter Property="Background" Value="#F1F5F9"/>
            <Setter Property="Foreground" Value="#475569"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="24"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="QtyRoot"
                                RenderTransformOrigin="0.5,0.5"
                                Background="{TemplateBinding Background}" CornerRadius="6"
                                Padding="0,1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#E2E8F0"/>
                                <Setter Property="Foreground" Value="#0F172A"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="QtyRoot" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.94" ScaleY="0.94"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#CBD5E1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Product type toggle button (used in Add Product panel) -->
        <Style x:Key="TypeToggleBtnStyle" TargetType="Button">
            <Setter Property="Background"    Value="#F5F7FA"/>
            <Setter Property="Foreground"    Value="#546E7A"/>
            <Setter Property="BorderBrush"   Value="#D1D9E6"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Cursor"        Value="Hand"/>
            <Setter Property="FontSize"      Value="13"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="TypeToggleRoot"
                                RenderTransformOrigin="0.5,0.5"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#E8EFF8"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="TypeToggleRoot" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.98" ScaleY="0.98"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#40516B"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Padding" Value="12,11"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="NavRoot"
                                RenderTransformOrigin="0.5,0.5"
                                Background="{TemplateBinding Background}"
                                CornerRadius="12" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F2F7FF"/>
                                <Setter Property="Foreground" Value="#155EEF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="NavRoot" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.98" ScaleY="0.98"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SelectedNavButtonStyle" TargetType="Button" BasedOn="{StaticResource NavButtonStyle}">
            <Setter Property="Background" Value="#EAF2FF"/>
            <Setter Property="Foreground" Value="#155EEF"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="NavIconTextStyle" TargetType="TextBlock">
            <Setter Property="Width" Value="26"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextAlignment" Value="Center"/>
        </Style>

        <Style x:Key="InlineIconTextStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextAlignment" Value="Center"/>
        </Style>

        <!-- Payment type button: highlights when its CommandParameter matches PaymentType -->
        <Style x:Key="PayTypeBtn" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#344054"/>
            <Setter Property="BorderBrush" Value="#D8E1EE"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="PayTypeRoot"
                                RenderTransformOrigin="0.5,0.5"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="13" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#EEF2FF"/>
                                <Setter Property="BorderBrush" Value="#93C5FD"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="PayTypeRoot" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.98" ScaleY="0.98"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Value="True">
                    <DataTrigger.Binding>
                        <MultiBinding Converter="{StaticResource EqualityConverter}">
                            <Binding Path="PaymentType"/>
                            <Binding RelativeSource="{RelativeSource Self}" Path="CommandParameter"/>
                        </MultiBinding>
                    </DataTrigger.Binding>
                    <Setter Property="Background"   Value="#EAF2FF"/>
                    <Setter Property="Foreground"   Value="#155EEF"/>
                    <Setter Property="BorderBrush"  Value="#155EEF"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.LayoutTransform>
            <ScaleTransform ScaleX="{Binding Scale}" ScaleY="{Binding Scale}"/>
        </Grid.LayoutTransform>
        <Grid.RowDefinitions>
            <RowDefinition Height="68"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ HEADER в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ -->
        <Border Grid.Row="0" Background="#0D47A1">
            <Border.Effect>
                <DropShadowEffect BlurRadius="18" ShadowDepth="2" Opacity="0.18" Color="#0B1F3A"/>
            </Border.Effect>
            <DockPanel Margin="20,0" LastChildFill="False">

                <!-- Left: Brand -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="40" Height="40" Background="#1565C0" CornerRadius="12"
                            VerticalAlignment="Center" Margin="0,0,10,0">
                        <TextBlock Text="&#x1F6D2;" FontSize="18" FontFamily="Segoe UI Emoji"
                                   VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </Border>
                    <StackPanel>
                        <TextBlock Text="ShefPos" Foreground="White" FontSize="17"
                                   FontWeight="Bold"/>
                        <TextBlock Text="Enterprise POS" Foreground="#B3E5FC" FontSize="10"/>
                    </StackPanel>
                </StackPanel>

                <!-- Right: Status, settings, user, time, sync, logout -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">

                    <!-- Sync status -->
                    <Border CornerRadius="18" Padding="13,7" Margin="0,0,10,0" Background="#1565C0"
                            BorderBrush="#1565C0" BorderThickness="1">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="8" Height="8" VerticalAlignment="Center" Margin="0,0,6,0">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Fill" Value="#69F0AE"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsOnline}" Value="False">
                                                <Setter Property="Fill" Value="#FF8A65"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                            <TextBlock Text="{Binding SyncStatusText}" Foreground="White"
                                       FontSize="12" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Pending sales badge -->
                    <Border CornerRadius="15" Padding="10,5" Margin="0,0,10,0"
                            Background="#FF8F00"
                            Visibility="{Binding PendingSyncCount, Converter={StaticResource IntToVisibilityConverter}}">
                        <TextBlock Foreground="White" FontSize="12" FontWeight="SemiBold">
                            <Run Text="&#x23F3; "/>
                            <Run Text="{Binding PendingSyncCount}"/>
                            <Run Text=" sotuv"/>
                        </TextBlock>
                    </Border>

                    <!-- Sync error indicator -->
                    <Button x:Name="SyncErrorBtn"
                            Command="{Binding ToggleSyncErrorPanelCommand}"
                            Margin="0,0,10,0" Cursor="Hand"
                            FocusVisualStyle="{x:Null}"
                            Visibility="{Binding SyncErrors.Count,
                                         Converter={StaticResource IntToVisibilityConverter}}">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="#C62828" CornerRadius="12" Padding="10,4">
                                    <ContentPresenter/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#B71C1C"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="8" Height="8" Fill="White"
                                     VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Foreground="White" FontSize="12" VerticalAlignment="Center">
                                <Run Text="{Binding SyncErrors.Count, Mode=OneWay}"/>
                                <Run Text=" xato"/>
                            </TextBlock>
                        </StackPanel>
                    </Button>
                    <Popup IsOpen="{Binding IsSyncErrorPanelOpen, Mode=TwoWay}"
                           PlacementTarget="{Binding ElementName=SyncErrorBtn}"
                           Placement="Bottom" StaysOpen="False" AllowsTransparency="True"
                           HorizontalOffset="-180">
                        <Border Background="White" CornerRadius="10"
                                BorderBrush="#FFCDD2" BorderThickness="1"
                                Padding="16,14" MinWidth="340" MaxWidth="500">
                            <Border.Effect>
                                <DropShadowEffect ShadowDepth="8" BlurRadius="18"
                                                  Opacity="0.18" Color="#000"/>
                            </Border.Effect>
                            <StackPanel>
                                <DockPanel LastChildFill="True" Margin="0,0,0,10">
                                    <Button DockPanel.Dock="Right"
                                            Command="{Binding ClearAllSyncErrorsCommand}"
                                            Style="{StaticResource OutlineDangerButtonStyle}"
                                            Content="Hammasini tozalash"
                                            Padding="10,4" FontSize="12"/>
                                    <TextBlock Text="&#x26A0;  Sinxronlash xatolari"
                                               FontSize="13" FontWeight="Bold"
                                               Foreground="#C62828"
                                               VerticalAlignment="Center"/>
                                </DockPanel>
                                <Separator Background="#FFCDD2" Margin="0,0,0,10"/>
                                <ItemsControl ItemsSource="{Binding SyncErrors}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#FFF8F8" CornerRadius="8"
                                                    BorderBrush="#FFCDD2" BorderThickness="1"
                                                    Padding="10,8" Margin="0,0,0,6">
                                                <DockPanel>
                                                    <Button DockPanel.Dock="Right"
                                                            Command="{Binding DataContext.ClearSyncErrorCommand,
                                                                      RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                            CommandParameter="{Binding}"
                                                            Style="{StaticResource IconButtonStyle}"
                                                            Content="&#x2715;" FontSize="11"
                                                            Margin="10,0,0,0"
                                                            VerticalAlignment="Top"/>
                                                    <TextBlock Text="{Binding}"
                                                               Foreground="#B71C1C" FontSize="12"
                                                               TextWrapping="Wrap"
                                                               VerticalAlignment="Center"/>
                                                </DockPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </Popup>

                    <!-- Manual sync -->
                    <Button Command="{Binding TriggerSyncCommand}"
                            Style="{StaticResource HeaderIconButtonStyle}"
                            ToolTip="Sinxronlash" Content="&#x1F504;" FontFamily="Segoe UI Emoji" Margin="0,0,8,0"/>

                    <!-- Settings button + popup -->
                    <Button x:Name="SettingsBtn"
                            Command="{Binding ToggleSettingsCommand}"
                            Style="{StaticResource HeaderIconButtonStyle}"
                            ToolTip="Sozlamalar" Content="&#x2699;" FontFamily="Segoe UI Emoji" Margin="0,0,8,0"/>
                    <Popup IsOpen="{Binding IsSettingsOpen, Mode=TwoWay}"
                           PlacementTarget="{Binding ElementName=SettingsBtn}"
                           Placement="Bottom" StaysOpen="False" AllowsTransparency="True"
                           HorizontalOffset="-120">
                        <Border Background="White" CornerRadius="10"
                                BorderBrush="#E0E6F0" BorderThickness="1"
                                Padding="18,16" MinWidth="260">
                            <Border.Effect>
                                <DropShadowEffect ShadowDepth="6" BlurRadius="18" Opacity="0.15" Color="#000"/>
                            </Border.Effect>
                            <StackPanel>
                                <TextBlock Text="Sozlamalar" FontSize="14" FontWeight="Bold"
                                           Foreground="#1A2540" Margin="0,0,0,16"/>
                                <Separator Background="#EEF2F8" Margin="0,0,0,14"/>

                                <!-- Tablet mode toggle -->
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <CheckBox IsChecked="{Binding IsTabletMode}"
                                              Style="{StaticResource ToggleSwitchStyle}">
                                        <TextBlock Text="Planshet rejimi" FontSize="13"
                                                   Foreground="#374151" FontFamily="Segoe UI"/>
                                    </CheckBox>
                                </StackPanel>
                                <TextBlock Text="Klaviatura to'lov uchun chiqadi"
                                           FontSize="11" Foreground="#9AADCA" Margin="54,4,0,0"/>

                                <Separator Background="#EEF2F8" Margin="0,14,0,14"/>

                                <!-- Scale control -->
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="Masshtab" FontSize="13" Foreground="#374151"
                                                   FontFamily="Segoe UI" VerticalAlignment="Center"
                                                   Width="120"/>
                                        <Button Content="&#x2212;"
                                                Command="{Binding DecreaseScaleCommand}"
                                                Width="30" Height="30" FontSize="18" FontWeight="Bold"
                                                Style="{StaticResource IconButtonStyle}"/>
                                        <TextBlock Width="50" TextAlignment="Center"
                                                   VerticalAlignment="Center" FontSize="13"
                                                   FontWeight="SemiBold" Foreground="#1A2540">
                                            <Run Text="{Binding Scale, Mode=OneWay,
                                                         StringFormat='{}{0:P0}'}"/>
                                        </TextBlock>
                                        <Button Content="+"
                                                Command="{Binding IncreaseScaleCommand}"
                                                Width="30" Height="30" FontSize="18" FontWeight="Bold"
                                                Style="{StaticResource IconButtonStyle}"/>
                                    </StackPanel>
                                    <TextBlock Text="Ekran masshtabini o'zgartiradi"
                                               FontSize="11" Foreground="#9AADCA" Margin="0,4,0,0"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </Popup>

                    <!-- Username -->
                    <Border CornerRadius="16" Background="#1565C0" Padding="11,6" Margin="0,0,10,0"
                            BorderBrush="#1565C0" BorderThickness="1">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#x1F464;" FontSize="12" Margin="0,0,6,0"
                                       FontFamily="Segoe UI Emoji" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding UserName}" Foreground="#B3E5FC"
                                       FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Clock -->
                    <Border CornerRadius="16" Background="#1565C0" Padding="12,6" Margin="0,0,12,0"
                            BorderBrush="#1565C0" BorderThickness="1">
                        <TextBlock Text="{Binding CurrentTime}" Foreground="#FFFFFF"
                                   FontSize="12" VerticalAlignment="Center"
                                   FontFamily="Segoe UI"/>
                    </Border>

                    <!-- Order history -->
                    <Button Click="OnHistoryClick"
                            Style="{StaticResource HeaderIconButtonStyle}"
                            ToolTip="Zakaz tarixi" Content="&#x1F4CB;" FontFamily="Segoe UI Emoji" Margin="0,0,8,0"/>

                    <!-- Network monitor -->
                    <Button Click="OnNetworkMonitorClick"
                            Style="{StaticResource HeaderIconButtonStyle}"
                            ToolTip="Network Monitor" Content="&#x1F4E1;" FontFamily="Segoe UI Emoji" Margin="0,0,8,0"/>

                    <!-- Game toggle -->
                    <Button Command="{Binding ToggleGameCommand}"
                            Style="{StaticResource HeaderIconButtonStyle}"
                            ToolTip="ShefPuzzle" Content="&#x1F3AE;" FontFamily="Segoe UI Emoji" Margin="0,0,8,0"/>

                    <!-- Logout -->
                    <Button Command="{Binding LogoutCommand}"
                            Style="{StaticResource DangerButtonStyle}"
                            Background="#C62828"
                            Content="Chiqish" Padding="14,6" FontSize="13"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ GAME VIEW в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ -->
        <game:GameView Grid.Row="1"
                       DataContext="{Binding Game}"
                       Visibility="{Binding IsGameOpen, Converter={StaticResource BoolToVisibilityConverter}}"/>

        <!-- в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ MAIN CONTENT в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ -->
        <Grid Grid.Row="1"
              Visibility="{Binding IsGameOpen, Converter={StaticResource InverseBoolToVisibilityConverter}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="184"/>  <!-- Navigation -->
                <ColumnDefinition Width="*"/>    <!-- Products -->
                <ColumnDefinition Width="235"/>  <!-- Cart -->
                <ColumnDefinition Width="180"/>  <!-- Payment -->
            </Grid.ColumnDefinitions>

            <!-- в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ COLUMN 0: PRODUCTS в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ -->
            <Border Grid.Column="0" Background="#FBFCFE"
                    BorderBrush="#E5ECF6" BorderThickness="0,0,1,0">
                <Grid Margin="14,18,14,14">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0">
                        <Button Margin="0,0,0,7" Command="{Binding ShowSalesPageCommand}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource NavButtonStyle}">
                                    <Style.Triggers>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding IsProductsPageOpen}" Value="False"/>
                                                <Condition Binding="{Binding IsOmborPageOpen}"    Value="False"/>
                                                <Condition Binding="{Binding IsSettingsPageOpen}" Value="False"/>
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="Background"  Value="#EAF2FF"/>
                                            <Setter Property="Foreground"  Value="#155EEF"/>
                                            <Setter Property="FontWeight"  Value="SemiBold"/>
                                        </MultiDataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE7BF;" Style="{StaticResource NavIconTextStyle}"/>
                                <TextBlock Text="Sotuv" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Margin="0,0,0,7" Command="{Binding ShowProductsPageCommand}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource NavButtonStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsProductsPageOpen}" Value="True">
                                            <Setter Property="Background" Value="#EAF2FF"/>
                                            <Setter Property="Foreground" Value="#155EEF"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE7B8;" Style="{StaticResource NavIconTextStyle}"/>
                                <TextBlock Text="Mahsulotlar" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Margin="0,0,0,7" Command="{Binding ShowOmborPageCommand}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource NavButtonStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsOmborPageOpen}" Value="True">
                                            <Setter Property="Background" Value="#EAF2FF"/>
                                            <Setter Property="Foreground" Value="#155EEF"/>
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE821;" Style="{StaticResource NavIconTextStyle}"/>
                                <TextBlock Text="Ombor" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource NavButtonStyle}" Margin="0,0,0,7">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE9D2;" Style="{StaticResource NavIconTextStyle}"/>
                                <TextBlock Text="Hisobotlar" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource NavButtonStyle}" Margin="0,0,0,7">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE716;" Style="{StaticResource NavIconTextStyle}"/>
                                <TextBlock Text="Mijozlar" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource NavButtonStyle}" Margin="0,0,0,7">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE7C0;" Style="{StaticResource NavIconTextStyle}"/>
                                <TextBlock Text="Yetkazib beruvchilar" TextWrapping="Wrap" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource NavButtonStyle}" Margin="0,0,0,7">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE77B;" Style="{StaticResource NavIconTextStyle}"/>
                                <TextBlock Text="Xodimlar" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource NavButtonStyle}"
                                Command="{Binding ShowSettingsPageCommand}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE713;" Style="{StaticResource NavIconTextStyle}"/>
                                <TextBlock Text="Sozlamalar" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <Border Grid.Row="2" Background="#F1F7FF" CornerRadius="14"
                            BorderBrush="#DCEBFF" BorderThickness="1" Padding="14,12">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <Ellipse Width="9" Height="9" Fill="#22C55E" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="Onlayn" FontWeight="SemiBold" FontSize="12" Foreground="#1F2937"/>
                            </StackPanel>
                            <TextBlock Text="Tizim holati" FontSize="11" Foreground="#667085" Margin="0,0,0,8"/>
                            <TextBlock Text="v1.0.0" FontSize="11" Foreground="#667085"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <Grid Grid.Column="1" Background="#F5F8FC">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Search bar -->
                <Border Grid.Row="0" Background="White" Padding="20,14"
                        BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
                    <DockPanel LastChildFill="True">
                        <Button DockPanel.Dock="Right" Margin="10,0,0,0"
                                Command="{Binding ToggleAddProductCommand}"
                                Width="46" Height="46"
                                Style="{StaticResource PrimaryButtonStyle}"
                                ToolTip="Mahsulot qo'shish"
                                FontSize="20" FontWeight="Bold" Content="+"/>
                        <Border BorderBrush="#D8E1EE" BorderThickness="1" CornerRadius="14" Background="#FBFCFE">
                            <Grid>
                                <TextBlock Text="&#xE721;" Margin="12,0,0,0"
                                           Style="{StaticResource InlineIconTextStyle}"
                                           Foreground="#94A3B8" FontSize="14"/>
                                <TextBox Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                                         Padding="40,13,14,13" FontSize="14" BorderThickness="0"
                                         Background="Transparent" Style="{StaticResource FlatTextBoxStyle}"/>
                                <TextBlock Text="Mahsulot qidirish (nomi, kodi, barkod)..."
                                           Foreground="#94A3B8" FontSize="14"
                                           Margin="40,0,0,0" VerticalAlignment="Center"
                                           IsHitTestVisible="False">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SearchQuery}" Value="">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </Border>
                    </DockPanel>
                </Border>

                <!-- Category tabs -->
                <Border Grid.Row="1" Background="White"
                        BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
                    <ScrollViewer HorizontalScrollBarVisibility="Hidden"
                                  VerticalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding Categories}" Margin="18,10">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:CategoryViewModel}">
                                    <Button Content="{Binding Name}"
                                            Command="{Binding DataContext.SelectCategoryCommand,
                                                      RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}"
                                            Padding="18,9" Margin="4,0" Cursor="Hand" FontSize="13">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="Foreground" Value="#475467"/>
                                                <Setter Property="BorderThickness" Value="1"/>
                                                <Setter Property="BorderBrush" Value="#E5ECF6"/>
                                                <Setter Property="FontWeight" Value="Normal"/>
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border Background="{TemplateBinding Background}"
                                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                                    CornerRadius="18" Padding="{TemplateBinding Padding}">
                                                                <ContentPresenter HorizontalAlignment="Center"
                                                                                  VerticalAlignment="Center"/>
                                                            </Border>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                                <Style.Triggers>
                                                    <DataTrigger Value="True">
                                                        <DataTrigger.Binding>
                                                            <MultiBinding Converter="{StaticResource EqualityConverter}">
                                                                <Binding Path="DataContext.SelectedCategory"
                                                                         RelativeSource="{RelativeSource AncestorType=ItemsControl}"/>
                                                                <Binding Path="."/>
                                                            </MultiBinding>
                                                        </DataTrigger.Binding>
                                                        <Setter Property="BorderBrush" Value="#155EEF"/>
                                                        <Setter Property="Background" Value="#155EEF"/>
                                                        <Setter Property="Foreground" Value="White"/>
                                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                                    </DataTrigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#F2F7FF"/>
                                                        <Setter Property="BorderBrush" Value="#BFDBFE"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>

                <!-- Product grid -->
                <ScrollViewer Grid.Row="2" Padding="20,18">
                    <Grid>
                        <TextBlock Text="Mahsulotlar topilmadi"
                                   FontSize="15" Foreground="#94A3B8"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Margin="0,60,0,0">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding FilteredProducts.Count}" Value="0">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <ItemsControl ItemsSource="{Binding FilteredProducts}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel ItemWidth="174" ItemHeight="182"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Width="166" Height="174" Margin="4"
                                            Command="{Binding DataContext.AddToCartCommand,
                                                      RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}"
                                            Style="{StaticResource ProductCardStyle}">
                                        <Grid Width="166" Height="174">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="84"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>

                                            <!-- Image / placeholder -->
                                            <Border Grid.Row="0" CornerRadius="16,16,0,0" ClipToBounds="True">
                                                <Grid>
                                                    <Border Background="#F1F5F9"
                                                            Visibility="{Binding ImageUrl,
                                                                         Converter={StaticResource EmptyStringToVisibilityConverter}}">
                                                        <TextBlock Text="&#xE7B8;" FontSize="26"
                                                                   FontFamily="Segoe MDL2 Assets"
                                                                   Foreground="#64748B"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"/>
                                                    </Border>
                                                    <Image Stretch="UniformToFill"
                                                           Visibility="{Binding ImageUrl,
                                                                        Converter={StaticResource StringToVisibilityConverter}}"
                                                           Source="{Binding ImageUrl,
                                                                    Converter={StaticResource UrlToBitmapImageConverter}}"/>
                                                </Grid>
                                            </Border>

                                            <!-- Product info -->
                                            <StackPanel Grid.Row="1" Margin="12,9,12,8">
                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold"
                                                           FontSize="12.5" TextWrapping="Wrap"
                                                           MaxHeight="32" TextTrimming="CharacterEllipsis"
                                                           Margin="0,0,0,4" Foreground="#0F172A"/>
                                                <TextBlock FontSize="14" FontWeight="Bold"
                                                           Foreground="#0B5BD3">
                                                    <Run Text="{Binding Price, StringFormat='{}{0:N0}'}"/>
                                                    <Run Text=" so'm" Foreground="#3B82F6" FontSize="10"/>
                                                </TextBlock>
                                                <TextBlock FontSize="11" Foreground="#667085" Margin="0,4,0,0">
                                                    <Run Text="Stok: "/>
                                                    <Run Text="{Binding Stock, StringFormat='{}{0:N1}'}"/>
                                                    <Run Text=" "/>
                                                    <Run Text="{Binding Unit}"/>
                                                </TextBlock>
                                            </StackPanel>
                                        </Grid>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </ScrollViewer>

                <!-- в”Ђв”Ђ Add Product overlay в”Ђв”Ђ -->
                <Border Grid.Row="0" Grid.RowSpan="3" Panel.ZIndex="20" Background="White"
                        Visibility="{Binding IsAddProductOpen, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Header -->
                        <Border Grid.Row="0" Background="#0D47A1" Padding="16,14">
                            <DockPanel>
                                <Button DockPanel.Dock="Right"
                                        Command="{Binding ToggleAddProductCommand}"
                                        Style="{StaticResource HeaderIconButtonStyle}"
                                        Content="&#x2715;" Width="32" Height="32" FontSize="14"
                                        ToolTip="Yopish"/>
                                <TextBlock Text="Yangi mahsulot qo'shish"
                                           Foreground="White" FontSize="15" FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>
                            </DockPanel>
                        </Border>

                        <!-- Form body -->
                        <ScrollViewer Grid.Row="1" Padding="16,14,16,4"
                                      VerticalScrollBarVisibility="Auto">
                            <StackPanel>

                                <!-- Name (required) -->
                                <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="#607D8B"
                                           Margin="0,0,0,6">
                                    <Run Text="Nomi"/><Run Text=" *" Foreground="#E53935"/>
                                </TextBlock>
                                <Border BorderBrush="#CFD8DC" BorderThickness="1" CornerRadius="8"
                                        Background="#FAFAFA" Margin="0,0,0,16">
                                    <TextBox Text="{Binding AddProductVm.NameInput, UpdateSourceTrigger=PropertyChanged}"
                                             Padding="12,10" FontSize="14" BorderThickness="0"
                                             Background="Transparent"
                                             Style="{StaticResource FlatTextBoxStyle}"/>
                                </Border>

                                <!-- Measurement (required) - compact inline -->
                                <Grid Margin="0,0,0,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" VerticalAlignment="Center"
                                               FontSize="12" FontWeight="SemiBold" Foreground="#607D8B"
                                               Margin="0,0,10,0">
                                        <Run Text="O'lchov"/><Run Text=" *" Foreground="#E53935"/>
                                    </TextBlock>
                                    <ComboBox Grid.Column="1"
                                              ItemsSource="{Binding AddProductVm.Measurements}"
                                              SelectedItem="{Binding AddProductVm.SelectedMeasurement}"
                                              DisplayMemberPath="Name"
                                              Padding="10,7" FontSize="13"/>
                                </Grid>

                                <!-- Barcode (required) + Generate -->
                                <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="#607D8B"
                                           Margin="0,0,0,6">
                                    <Run Text="Barkod"/><Run Text=" *" Foreground="#E53935"/>
                                </TextBlock>
                                <Grid Margin="0,0,0,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" BorderBrush="#CFD8DC" BorderThickness="1"
                                            CornerRadius="8" Background="#FAFAFA">
                                        <TextBox Text="{Binding AddProductVm.BarcodeInput, UpdateSourceTrigger=PropertyChanged}"
                                                 Padding="12,10" FontSize="14" BorderThickness="0"
                                                 Background="Transparent" MaxLength="13"
                                                 helpers:NumericTextBox.IsNumeric="True"
                                                 Style="{StaticResource FlatTextBoxStyle}"/>
                                    </Border>
                                    <Button Grid.Column="2"
                                            Command="{Binding AddProductVm.GenerateBarcodeCommand}"
                                            Content="Yaratish" Padding="12,10"
                                            FontSize="13"
                                            Style="{StaticResource PrimaryButtonStyle}"/>
                                </Grid>

                                <!-- Tannarx (Cost) -->
                                <TextBlock Text="Tannarx (so'm)" FontSize="12" FontWeight="SemiBold"
                                           Foreground="#607D8B" Margin="0,0,0,6"/>
                                <Border BorderBrush="#CFD8DC" BorderThickness="1" CornerRadius="8"
                                        Background="#FAFAFA" Margin="0,0,0,16">
                                    <TextBox Text="{Binding AddProductVm.CostInput, UpdateSourceTrigger=PropertyChanged}"
                                             Padding="12,10" FontSize="14" BorderThickness="0"
                                             Background="Transparent"
                                             helpers:NumericTextBox.IsNumeric="True"
                                             Style="{StaticResource FlatTextBoxStyle}"/>
                                </Border>

                                <!-- Qoldiq (Stock) -->
                                <TextBlock Text="Boshlang'ich qoldiq" FontSize="12" FontWeight="SemiBold"
                                           Foreground="#607D8B" Margin="0,0,0,6"/>
                                <Border BorderBrush="#CFD8DC" BorderThickness="1" CornerRadius="8"
                                        Background="#FAFAFA" Margin="0,0,0,16">
                                    <TextBox Text="{Binding AddProductVm.StockInput, UpdateSourceTrigger=PropertyChanged}"
                                             Padding="12,10" FontSize="14" BorderThickness="0"
                                             Background="Transparent"
                                             helpers:NumericTextBox.IsNumeric="True"
                                             Style="{StaticResource FlatTextBoxStyle}"/>
                                </Border>

                                <!-- Narx (Price) -->
                                <TextBlock Text="Narx (so'm)" FontSize="12" FontWeight="SemiBold"
                                           Foreground="#607D8B" Margin="0,0,0,6"/>
                                <Border BorderBrush="#CFD8DC" BorderThickness="1" CornerRadius="8"
                                        Background="#FAFAFA" Margin="0,0,0,16">
                                    <TextBox Text="{Binding AddProductVm.PriceInput, UpdateSourceTrigger=PropertyChanged}"
                                             Padding="12,10" FontSize="14" BorderThickness="0"
                                             Background="Transparent"
                                             helpers:NumericTextBox.IsNumeric="True"
                                             Style="{StaticResource FlatTextBoxStyle}"/>
                                </Border>

                                <!-- Narx ro'yxati (Price list) -->
                                <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="#607D8B"
                                           Margin="0,0,0,6" Text="Narx ro'yxati"/>
                                <ComboBox ItemsSource="{Binding AddProductVm.PriceLists}"
                                          SelectedItem="{Binding AddProductVm.SelectedPriceList}"
                                          Padding="12,8" FontSize="13"
                                          Margin="0,0,0,4">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold"
                                                           Margin="0,0,8,0"/>
                                                <TextBlock Text="{Binding Currency}" Foreground="#78909C"
                                                           FontSize="11" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                                <TextBlock FontSize="11" Foreground="#9E9E9E" Margin="0,0,0,16">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding AddProductVm.PriceLists.Count}" Value="0">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                    <Run Text="&#x26A0; Narx ro'yxatlari topilmadi. Avval sinxronlashni bajaring."/>
                                </TextBlock>

                                <!-- Mahsulot turi (Product type) - moved to bottom -->
                                <TextBlock Text="MAHSULOT TURI" FontSize="10" FontWeight="Bold"
                                           Foreground="#9E9E9E" Margin="0,0,0,6"/>
                                <ComboBox ItemsSource="{Binding AddProductVm.ProductTypes}"
                                          SelectedItem="{Binding AddProductVm.SelectedProductType}"
                                          DisplayMemberPath="Name"
                                          Padding="12,8" FontSize="13"
                                          Margin="0,0,0,4"/>
                                <TextBlock FontSize="11" Foreground="#9E9E9E" Margin="0,0,0,16">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding AddProductVm.ProductTypes.Count}" Value="0">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                    <Run Text="&#x26A0; Mahsulot turlari topilmadi. Avval sinxronlashni bajaring."/>
                                </TextBlock>

                                <!-- Error -->
                                <Border CornerRadius="8" Background="#FFEBEE" Padding="12,10"
                                        Visibility="{Binding AddProductVm.ErrorText,
                                                     Converter={StaticResource StringToVisibilityConverter}}">
                                    <TextBlock Text="{Binding AddProductVm.ErrorText}"
                                               Foreground="#C62828" FontSize="13" TextWrapping="Wrap"/>
                                </Border>

                                <!-- Saving indicator -->
                                <TextBlock Text="Saqlanmoqda..."
                                           FontSize="13" Foreground="#1565C0" TextAlignment="Center"
                                           Margin="0,10,0,0"
                                           Visibility="{Binding AddProductVm.IsBusy,
                                                        Converter={StaticResource BoolToVisibilityConverter}}"/>

                            </StackPanel>
                        </ScrollViewer>

                        <!-- Footer buttons -->
                        <Border Grid.Row="2" Background="White" Padding="16,12"
                                BorderBrush="#E0E6F0" BorderThickness="0,1,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0"
                                        Command="{Binding ToggleAddProductCommand}"
                                        Content="Bekor qilish" Padding="0,12"
                                        Style="{StaticResource OutlineDangerButtonStyle}"
                                        FontSize="14"/>
                                <Button Grid.Column="2"
                                        Command="{Binding AddProductVm.SaveCommand}"
                                        Content="&#x2713;  Saqlash" Padding="0,12"
                                        Style="{StaticResource SuccessButtonStyle}"
                                        FontSize="14" FontWeight="SemiBold"/>
                            </Grid>
                        </Border>

                    </Grid>
                </Border>

            </Grid>

            <!-- в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ COLUMN 1: CART в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ -->
            <Border Grid.Column="2" Grid.ColumnSpan="2" Background="White"
                    BorderBrush="#E2E8F0" BorderThickness="1,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>  <!-- Customer -->
                        <RowDefinition Height="*"/>     <!-- Items -->
                        <RowDefinition Height="Auto"/>  <!-- Totals + Payment -->
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Customer selector -->
                    <Border Grid.Row="0" Padding="12,10,10,8"
                            BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="MIJOZ" FontSize="10" FontWeight="Bold"
                                           Foreground="#667085" Margin="0,0,0,6"/>
                                <TextBlock Text="{Binding SelectedCustomerDisplay}"
                                           FontSize="14" FontWeight="SemiBold" Foreground="#0F172A"
                                           Margin="0,0,0,8">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedCustomerDisplay}"
                                                             Value="Mijoz tanlanmagan">
                                                    <Setter Property="Foreground" Value="#BDBDBD"/>
                                                    <Setter Property="FontStyle" Value="Italic"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>

                                <Grid>
                                    <Border BorderBrush="#D8E1EE" BorderThickness="1" CornerRadius="12"
                                            Background="#FBFCFE">
                                        <TextBox x:Name="CustomerSearchBox"
                                                 Text="{Binding CustomerSearchText, UpdateSourceTrigger=PropertyChanged}"
                                                 Padding="12,10" FontSize="13" BorderThickness="0"
                                                 Background="Transparent"
                                                 Style="{StaticResource FlatTextBoxStyle}"/>
                                    </Border>
                                    <TextBlock Text="Qidirish..." Foreground="#94A3B8"
                                               FontSize="13" Margin="10,0,0,0"
                                               VerticalAlignment="Center" IsHitTestVisible="False">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding CustomerSearchText}" Value="">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>

                                    <Button HorizontalAlignment="Right"
                                            Command="{Binding ClearCustomerCommand}"
                                            Style="{StaticResource IconButtonStyle}"
                                            Width="34" Height="28" Margin="0,4,5,4"
                                            ToolTip="Mijozni o'chirish"
                                            Visibility="Collapsed">
                                        <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets"
                                                   FontSize="13" VerticalAlignment="Center"
                                                   HorizontalAlignment="Center"/>
                                    </Button>

                                    <Popup IsOpen="{Binding IsCustomerPopupOpen}"
                                           PlacementTarget="{Binding ElementName=CustomerSearchBox}"
                                           Placement="Bottom" AllowsTransparency="True" StaysOpen="False">
                                        <Border Background="White" BorderBrush="#E2E8F0" BorderThickness="1"
                                                CornerRadius="0,0,10,10" MinWidth="260">
                                            <Border.Effect>
                                                <DropShadowEffect ShadowDepth="6" BlurRadius="16"
                                                                  Opacity="0.16" Color="#0F172A"/>
                                            </Border.Effect>
                                            <ListBox ItemsSource="{Binding CustomerSuggestions}"
                                                     BorderThickness="0" MaxHeight="220"
                                                     Background="Transparent"
                                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                                <ListBox.ItemContainerStyle>
                                                    <Style TargetType="ListBoxItem">
                                                        <Setter Property="Padding" Value="12,10"/>
                                                        <Setter Property="Cursor" Value="Hand"/>
                                                        <EventSetter Event="MouseLeftButtonUp"
                                                                     Handler="OnCustomerItemClick"/>
                                                    </Style>
                                                </ListBox.ItemContainerStyle>
                                                <ListBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <StackPanel>
                                                            <TextBlock Text="{Binding Name}"
                                                                       FontWeight="SemiBold" FontSize="13" Foreground="#0F172A"/>
                                                            <TextBlock Text="{Binding Phone}"
                                                                       FontSize="11" Foreground="#64748B"/>
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </ListBox.ItemTemplate>
                                            </ListBox>
                                        </Border>
                                    </Popup>
                                </Grid>
                            </StackPanel>

                            <Button Grid.Column="1" Content="&#x2715;" VerticalAlignment="Bottom"
                                    Command="{Binding ClearCustomerCommand}"
                                    Style="{StaticResource IconButtonStyle}"
                                    Width="38" Height="38" Margin="10,0,0,0"
                                    FontSize="11" ToolTip="Mijozni o'chirish"/>
                        </Grid>
                    </Border>

                    <!-- Cart items list -->
                    <Grid Grid.Row="1">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                    Visibility="{Binding CartItems.Count,
                                                 Converter={StaticResource IntToVisibilityInverseConverter}}">
                            <Border Width="78" Height="78" CornerRadius="39" Background="#F4F7FB"
                                    BorderBrush="#E5ECF6" BorderThickness="1">
                                <TextBlock Text="&#xE7BF;" FontSize="34" FontFamily="Segoe MDL2 Assets"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Savat bo'sh" FontSize="15" FontWeight="SemiBold" Foreground="#667085"
                                       HorizontalAlignment="Center" Margin="0,10,0,0"/>
                            <TextBlock Text="Mahsulot qo'shish uchun skanerlang yoki qidiring"
                                       FontSize="11" Foreground="#98A2B3"
                                       HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        </StackPanel>

                        <ListView ItemsSource="{Binding CartItems}"
                                  BorderThickness="0" Background="Transparent"
                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                  VirtualizingPanel.ScrollUnit="Pixel"
                                  PreviewKeyDown="OnCartKeyDown">
                            <ListView.Resources>
                                <Style TargetType="GridViewColumnHeader">
                                    <Setter Property="Background" Value="#F8FAFC"/>
                                    <Setter Property="Foreground" Value="#667085"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="FontSize" Value="12"/>
                                    <Setter Property="Padding" Value="10,9"/>
                                </Style>
                            </ListView.Resources>
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="Padding" Value="8,7"/>
                                    <Setter Property="BorderBrush" Value="#EEF2F7"/>
                                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                </Style>
                            </ListView.ItemContainerStyle>
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="Mahsulot" Width="150">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel>
                                                    <TextBlock Text="{Binding ProductName}"
                                                               FontWeight="SemiBold" FontSize="13"
                                                               TextTrimming="CharacterEllipsis" MaxWidth="140" Foreground="#0F172A"/>
                                                    <TextBlock FontSize="11" Foreground="#94A3B8">
                                                        <Run Text="{Binding UnitPrice, Mode=OneWay, StringFormat='{}{0:N0}'}"/>
                                                        <Run Text=" so'm"/>
                                                    </TextBlock>
                                                </StackPanel>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>

                                    <GridViewColumn Header="Soni" Width="120">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <Grid Width="112">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="24"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="24"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Button Grid.Column="0" Content="&#x2212;"
                                                            Command="{Binding DecreaseQuantityCommand}"
                                                            Style="{StaticResource QtyBtnStyle}"/>
                                                    <TextBox Grid.Column="1"
                                                             Text="{Binding Quantity,
                                                             UpdateSourceTrigger=PropertyChanged,
                                                             StringFormat='{}{0:N2}'}"
                                                             TextAlignment="Center"
                                                             FontSize="13" FontWeight="SemiBold"
                                                             Padding="2,4" BorderThickness="0"
                                                             Background="Transparent"
                                                             helpers:NumericTextBox.IsNumeric="True"
                                                             Style="{StaticResource FlatTextBoxStyle}"/>
                                                    <Button Grid.Column="2" Content="+"
                                                            Command="{Binding IncreaseQuantityCommand}"
                                                            Style="{StaticResource QtyBtnStyle}"/>
                                                </Grid>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>

                                    <GridViewColumn Header="Jami" Width="96">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock FontWeight="Bold" FontSize="13"
                                                           Foreground="#1D4ED8" TextAlignment="Right">
                                                    <Run Text="{Binding LineTotal, Mode=OneWay, StringFormat='{}{0:N0}'}"/>
                                                </TextBlock>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>

                                    <GridViewColumn Width="30">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button Content="&#x2715;" FontSize="11"
                                                        Command="{Binding DataContext.RemoveFromCartCommand,
                                                                  RelativeSource={RelativeSource AncestorType=ListView}}"
                                                        CommandParameter="{Binding}"
                                                        Style="{StaticResource DeleteRowButtonStyle}"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </Grid>

                    <!-- Totals — eski JAMI bloki. Yangi mixed-payment bloki o'z
                         JAMI + Savatni tozalash sarlavhasiga ega, shuning uchun bu yashirildi. -->
                    <Border Grid.Row="2" Background="#FBFCFE"
                            BorderBrush="#E2E8F0" BorderThickness="0,1,0,1" Padding="18,12"
                            Visibility="Collapsed">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="JAMI" FontSize="16" FontWeight="Bold" Foreground="#0A3A8C"/>
                                <TextBlock FontSize="22" FontWeight="Bold" Foreground="#0B5BD3">
                                    <Run Text="{Binding Total, Mode=OneWay, StringFormat='{}{0:N0}'}"/>
                                    <Run Text=" so'm" FontSize="13" Foreground="#3B82F6"/>
                                </TextBlock>
                            </StackPanel>

                            <Button Grid.Column="1" Content="Savatni tozalash"
                                    Command="{Binding ClearCartCommand}"
                                    Style="{StaticResource OutlineDangerButtonStyle}"
                                    Height="36" Padding="10,0" FontSize="12"
                                    VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <!-- Clear cart -->
                    <Border Grid.Row="3" Padding="18,12" Visibility="Collapsed">
                        <Button Content="Savatni tozalash"
                                Command="{Binding ClearCartCommand}"
                                Style="{StaticResource OutlineDangerButtonStyle}"
                                Height="42" FontSize="13"/>
                    </Border>

                    <Border Grid.Row="4" Background="#F9FBFE"
                            BorderBrush="#E2E8F0" BorderThickness="0,1,0,0"
                            Padding="12,10" Visibility="Visible">
                        <StackPanel>
                            <!-- ════════════════════════════════════════════════════════
                                 MIXED PAYMENT BLOCK
                                 Three payment rows (Naqt / Karta / Qarz) + quick-fill
                                 chips + summary strip + SOTISH. Active row is driven
                                 by ActivePaymentRow on the VM (F1/F2/F3 shortcuts wired
                                 in PosView.xaml.cs).
                                 ════════════════════════════════════════════════════════ -->
                            <Grid x:Name="MixedPaymentBlock">
                                <Grid.Resources>
                                    <!-- Horseshoe magnet icon used on the "tortib olish" buttons.
                                         Open side faces LEFT (toward the amount input), with
                                         red north / brand-blue south pole caps so it reads
                                         immediately as a magnet. Rendered via DrawingImage so
                                         the three sub-shapes share a single coordinate system
                                         under Stretch=Uniform. -->
                                    <DrawingImage x:Key="MagnetIcon">
                                        <DrawingImage.Drawing>
                                            <DrawingGroup>
                                                <!-- 1) Horseshoe body (slate gray) -->
                                                <GeometryDrawing Brush="#475569">
                                                    <GeometryDrawing.Geometry>
                                                        <PathGeometry Figures="M 3 3 L 10 3 A 5 5 0 0 1 10 13 L 3 13 L 3 9 L 8 9 A 1.5 1.5 0 0 1 8 7 L 3 7 Z"/>
                                                    </GeometryDrawing.Geometry>
                                                </GeometryDrawing>
                                                <!-- 2) North pole cap on the upper prong (red) -->
                                                <GeometryDrawing Brush="#DC2626">
                                                    <GeometryDrawing.Geometry>
                                                        <RectangleGeometry Rect="3,3,2.2,4"/>
                                                    </GeometryDrawing.Geometry>
                                                </GeometryDrawing>
                                                <!-- 3) South pole cap on the lower prong (brand blue) -->
                                                <GeometryDrawing Brush="#155EEF">
                                                    <GeometryDrawing.Geometry>
                                                        <RectangleGeometry Rect="3,9,2.2,4"/>
                                                    </GeometryDrawing.Geometry>
                                                </GeometryDrawing>
                                            </DrawingGroup>
                                        </DrawingImage.Drawing>
                                    </DrawingImage>
                                </Grid.Resources>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/> <!-- 0: JAMI + clear -->
                                    <RowDefinition Height="10"/>
                                    <RowDefinition Height="Auto"/> <!-- 2: Naqt -->
                                    <RowDefinition Height="6"/>
                                    <RowDefinition Height="Auto"/> <!-- 4: Karta -->
                                    <RowDefinition Height="6"/>
                                    <RowDefinition Height="Auto"/> <!-- 6: Qarz + warning -->
                                    <RowDefinition Height="10"/>
                                    <RowDefinition Height="Auto"/> <!-- 8: quick chips -->
                                    <RowDefinition Height="10"/>
                                    <RowDefinition Height="Auto"/> <!-- 10: summary strip -->
                                    <RowDefinition Height="12"/>
                                    <RowDefinition Height="Auto"/> <!-- 12: SOTISH -->
                                </Grid.RowDefinitions>

                                <!-- ── Row 0: JAMI + "Savatni tozalash" pill ── -->
                                <Grid Grid.Row="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="JAMI" FontSize="10" FontWeight="Bold"
                                                   Foreground="#94A3B8"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                            <TextBlock FontSize="24" FontWeight="Bold"
                                                       Foreground="#0F172A"
                                                       Text="{Binding Total, StringFormat='{}{0:N0}'}"/>
                                            <TextBlock Text=" so'm" FontSize="12"
                                                       Foreground="#94A3B8"
                                                       VerticalAlignment="Bottom"
                                                       Margin="4,0,0,4"/>
                                        </StackPanel>
                                    </StackPanel>
                                    <Button Grid.Column="1"
                                            Content="Savatni tozalash"
                                            Command="{Binding ClearCartCommand}"
                                            Style="{StaticResource OutlineDangerButtonStyle}"
                                            Height="32" Padding="14,0" FontSize="12"/>
                                </Grid>

                                <!-- ── Row 2: Naqt ── -->
                                <Grid Grid.Row="2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="118"/>
                                        <ColumnDefinition Width="6"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="6"/>
                                        <ColumnDefinition Width="68"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Row label button -->
                                    <Button Grid.Column="0" Height="42"
                                            Command="{Binding SetActivePaymentRowCommand}"
                                            CommandParameter="cash"
                                            HorizontalContentAlignment="Stretch"
                                            FocusVisualStyle="{x:Null}"
                                            Cursor="Hand"
                                            BorderThickness="0">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="RowLabel"
                                                        Background="White"
                                                        BorderBrush="#D8E1EE"
                                                        BorderThickness="1"
                                                        CornerRadius="8"
                                                        Padding="10,0">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0" Text="&#x1F4B5;" FontFamily="Segoe UI Emoji"
                                                                   FontSize="14" VerticalAlignment="Center"
                                                                   Margin="0,0,8,0"/>
                                                        <TextBlock Grid.Column="1" Text="Naqt"
                                                                   x:Name="LabelText"
                                                                   FontSize="13" FontWeight="SemiBold"
                                                                   VerticalAlignment="Center"
                                                                   Foreground="#475569"/>
                                                        <Border Grid.Column="2"
                                                                x:Name="KbdBadge"
                                                                BorderBrush="#D8E1EE"
                                                                BorderThickness="1"
                                                                CornerRadius="3"
                                                                Padding="5,1"
                                                                VerticalAlignment="Center">
                                                            <TextBlock Text="F1" FontSize="10"
                                                                       FontWeight="Bold"
                                                                       Foreground="#94A3B8"
                                                                       FontFamily="Consolas"/>
                                                        </Border>
                                                    </Grid>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <DataTrigger Binding="{Binding ActivePaymentRow}" Value="cash">
                                                        <Setter TargetName="RowLabel"  Property="Background"  Value="#EAF2FF"/>
                                                        <Setter TargetName="RowLabel"  Property="BorderBrush" Value="#155EEF"/>
                                                        <Setter TargetName="LabelText" Property="Foreground"  Value="#0B5BD3"/>
                                                        <Setter TargetName="KbdBadge"  Property="BorderBrush" Value="#155EEF"/>
                                                    </DataTrigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>

                                    <!-- Amount input -->
                                    <Border Grid.Column="2"
                                            x:Name="CashInputBorder"
                                            Background="White"
                                            BorderBrush="#D8E1EE"
                                            BorderThickness="1"
                                            CornerRadius="8">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="BorderBrush" Value="#D8E1EE"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ActivePaymentRow}" Value="cash">
                                                        <Setter Property="BorderBrush" Value="#155EEF"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBox Grid.Column="0"
                                                     Tag="cash"
                                                     GotFocus="OnPaymentInputGotFocus"
                                                     Text="{Binding CashAmount,
                                                            UpdateSourceTrigger=PropertyChanged,
                                                            StringFormat='{}{0:N0}'}"
                                                     TextAlignment="Right"
                                                     FontSize="16" FontWeight="Bold"
                                                     Padding="12,0,6,0"
                                                     Height="42"
                                                     VerticalContentAlignment="Center"
                                                     BorderThickness="0"
                                                     Background="Transparent"
                                                     helpers:NumericTextBox.IsNumeric="True"
                                                     Style="{StaticResource FlatTextBoxStyle}"/>
                                            <TextBlock Grid.Column="1" Text="so'm"
                                                       FontSize="11" FontWeight="SemiBold"
                                                       Foreground="#94A3B8"
                                                       VerticalAlignment="Center"
                                                       Margin="2,0,12,0"/>
                                        </Grid>
                                    </Border>

                                    <!-- Fill remaining (magnit ikoni = qolgan summani "tortib olish") -->
                                    <Button Grid.Column="4" Height="42"
                                            Command="{Binding FillRemainingCommand}"
                                            CommandParameter="cash"
                                            ToolTip="Qolgan summani Naqt qatoriga tortib olish"
                                            Background="White"
                                            BorderBrush="#D8E1EE"
                                            BorderThickness="1"
                                            FocusVisualStyle="{x:Null}"
                                            Cursor="Hand">
                                        <Image Source="{StaticResource MagnetIcon}"
                                               Width="20" Height="20" Stretch="Uniform"/>
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        CornerRadius="8">
                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#F8FAFC"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </Grid>

                                <!-- ── Row 4: Karta ── -->
                                <Grid Grid.Row="4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="118"/>
                                        <ColumnDefinition Width="6"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="6"/>
                                        <ColumnDefinition Width="68"/>
                                    </Grid.ColumnDefinitions>

                                    <Button Grid.Column="0" Height="42"
                                            Command="{Binding SetActivePaymentRowCommand}"
                                            CommandParameter="card"
                                            HorizontalContentAlignment="Stretch"
                                            FocusVisualStyle="{x:Null}"
                                            Cursor="Hand"
                                            BorderThickness="0">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="RowLabel"
                                                        Background="White"
                                                        BorderBrush="#D8E1EE"
                                                        BorderThickness="1"
                                                        CornerRadius="8"
                                                        Padding="10,0">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0" Text="&#x1F4B3;" FontFamily="Segoe UI Emoji"
                                                                   FontSize="14" VerticalAlignment="Center"
                                                                   Margin="0,0,8,0"/>
                                                        <TextBlock Grid.Column="1" Text="Karta"
                                                                   x:Name="LabelText"
                                                                   FontSize="13" FontWeight="SemiBold"
                                                                   VerticalAlignment="Center"
                                                                   Foreground="#475569"/>
                                                        <Border Grid.Column="2"
                                                                x:Name="KbdBadge"
                                                                BorderBrush="#D8E1EE"
                                                                BorderThickness="1"
                                                                CornerRadius="3"
                                                                Padding="5,1"
                                                                VerticalAlignment="Center">
                                                            <TextBlock Text="F2" FontSize="10"
                                                                       FontWeight="Bold"
                                                                       Foreground="#94A3B8"
                                                                       FontFamily="Consolas"/>
                                                        </Border>
                                                    </Grid>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <DataTrigger Binding="{Binding ActivePaymentRow}" Value="card">
                                                        <Setter TargetName="RowLabel"  Property="Background"  Value="#EAF2FF"/>
                                                        <Setter TargetName="RowLabel"  Property="BorderBrush" Value="#155EEF"/>
                                                        <Setter TargetName="LabelText" Property="Foreground"  Value="#0B5BD3"/>
                                                        <Setter TargetName="KbdBadge"  Property="BorderBrush" Value="#155EEF"/>
                                                    </DataTrigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>

                                    <Border Grid.Column="2"
                                            Background="White"
                                            BorderThickness="1"
                                            CornerRadius="8">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="BorderBrush" Value="#D8E1EE"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ActivePaymentRow}" Value="card">
                                                        <Setter Property="BorderBrush" Value="#155EEF"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBox Grid.Column="0"
                                                     Tag="card"
                                                     GotFocus="OnPaymentInputGotFocus"
                                                     Text="{Binding CardAmount,
                                                            UpdateSourceTrigger=PropertyChanged,
                                                            StringFormat='{}{0:N0}'}"
                                                     TextAlignment="Right"
                                                     FontSize="16" FontWeight="Bold"
                                                     Padding="12,0,6,0"
                                                     Height="42"
                                                     VerticalContentAlignment="Center"
                                                     BorderThickness="0"
                                                     Background="Transparent"
                                                     helpers:NumericTextBox.IsNumeric="True"
                                                     Style="{StaticResource FlatTextBoxStyle}"/>
                                            <TextBlock Grid.Column="1" Text="so'm"
                                                       FontSize="11" FontWeight="SemiBold"
                                                       Foreground="#94A3B8"
                                                       VerticalAlignment="Center"
                                                       Margin="2,0,12,0"/>
                                        </Grid>
                                    </Border>

                                    <Button Grid.Column="4" Height="42"
                                            Command="{Binding FillRemainingCommand}"
                                            CommandParameter="card"
                                            ToolTip="Qolgan summani Karta qatoriga tortib olish"
                                            Background="White"
                                            BorderBrush="#D8E1EE"
                                            BorderThickness="1"
                                            FocusVisualStyle="{x:Null}"
                                            Cursor="Hand">
                                        <Image Source="{StaticResource MagnetIcon}"
                                               Width="20" Height="20" Stretch="Uniform"/>
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        CornerRadius="8">
                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#F8FAFC"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </Grid>

                                <!-- ── Row 6: Qarz (+ inline customer warning) ── -->
                                <Grid Grid.Row="6">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid Grid.Row="0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="118"/>
                                            <ColumnDefinition Width="6"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="6"/>
                                            <ColumnDefinition Width="68"/>
                                        </Grid.ColumnDefinitions>

                                        <Button Grid.Column="0" Height="42"
                                                Command="{Binding SetActivePaymentRowCommand}"
                                                CommandParameter="debt"
                                                HorizontalContentAlignment="Stretch"
                                                FocusVisualStyle="{x:Null}"
                                                Cursor="Hand"
                                                BorderThickness="0">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="RowLabel"
                                                            Background="White"
                                                            BorderBrush="#D8E1EE"
                                                            BorderThickness="1"
                                                            CornerRadius="8"
                                                            Padding="10,0">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Grid.Column="0" Text="&#xE7BF;"
                                                                       FontFamily="Segoe MDL2 Assets"
                                                                       FontSize="14" VerticalAlignment="Center"
                                                                       Margin="0,0,8,0"
                                                                       Foreground="#94A3B8"/>
                                                            <TextBlock Grid.Column="1" Text="Qarz"
                                                                       x:Name="LabelText"
                                                                       FontSize="13" FontWeight="SemiBold"
                                                                       VerticalAlignment="Center"
                                                                       Foreground="#475569"/>
                                                            <Border Grid.Column="2"
                                                                    x:Name="KbdBadge"
                                                                    BorderBrush="#D8E1EE"
                                                                    BorderThickness="1"
                                                                    CornerRadius="3"
                                                                    Padding="5,1"
                                                                    VerticalAlignment="Center">
                                                                <TextBlock Text="F3" FontSize="10"
                                                                           FontWeight="Bold"
                                                                           Foreground="#94A3B8"
                                                                           FontFamily="Consolas"/>
                                                            </Border>
                                                        </Grid>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <DataTrigger Binding="{Binding ActivePaymentRow}" Value="debt">
                                                            <Setter TargetName="RowLabel"  Property="Background"  Value="#EAF2FF"/>
                                                            <Setter TargetName="RowLabel"  Property="BorderBrush" Value="#155EEF"/>
                                                            <Setter TargetName="LabelText" Property="Foreground"  Value="#0B5BD3"/>
                                                            <Setter TargetName="KbdBadge"  Property="BorderBrush" Value="#155EEF"/>
                                                        </DataTrigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>

                                        <Border Grid.Column="2"
                                                Background="White"
                                                BorderThickness="1"
                                                CornerRadius="8">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="BorderBrush" Value="#D8E1EE"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding ActivePaymentRow}" Value="debt">
                                                            <Setter Property="BorderBrush" Value="#155EEF"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsDebtBlocked}" Value="True">
                                                            <Setter Property="BorderBrush" Value="#F59E0B"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBox Grid.Column="0"
                                                         Tag="debt"
                                                         GotFocus="OnPaymentInputGotFocus"
                                                         Text="{Binding DebtAmount,
                                                                UpdateSourceTrigger=PropertyChanged,
                                                                StringFormat='{}{0:N0}'}"
                                                         TextAlignment="Right"
                                                         FontSize="16" FontWeight="Bold"
                                                         Padding="12,0,6,0"
                                                         Height="42"
                                                         VerticalContentAlignment="Center"
                                                         BorderThickness="0"
                                                         Background="Transparent"
                                                         helpers:NumericTextBox.IsNumeric="True"
                                                         Style="{StaticResource FlatTextBoxStyle}"/>
                                                <TextBlock Grid.Column="1" Text="so'm"
                                                           FontSize="11" FontWeight="SemiBold"
                                                           Foreground="#94A3B8"
                                                           VerticalAlignment="Center"
                                                           Margin="2,0,12,0"/>
                                            </Grid>
                                        </Border>

                                        <Button Grid.Column="4" Height="42"
                                                Command="{Binding FillRemainingCommand}"
                                                CommandParameter="debt"
                                                ToolTip="Qolgan summani Qarz qatoriga tortib olish"
                                                Background="White"
                                                BorderBrush="#D8E1EE"
                                                BorderThickness="1"
                                                FocusVisualStyle="{x:Null}"
                                                Cursor="Hand">
                                            <Image Source="{StaticResource MagnetIcon}"
                                                   Width="20" Height="20" Stretch="Uniform"/>
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}"
                                                            BorderBrush="{TemplateBinding BorderBrush}"
                                                            BorderThickness="{TemplateBinding BorderThickness}"
                                                            CornerRadius="8">
                                                        <ContentPresenter HorizontalAlignment="Center"
                                                                          VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="#F8FAFC"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </Grid>

                                    <!-- Qarz: customer-required warning -->
                                    <StackPanel Grid.Row="1" Orientation="Horizontal"
                                                Margin="124,4,0,0"
                                                Visibility="{Binding IsDebtBlocked,
                                                             Converter={StaticResource BoolToVisibilityConverter}}">
                                        <TextBlock Text="&#xE7BA;" FontFamily="Segoe MDL2 Assets"
                                                   FontSize="11" Foreground="#B45309"
                                                   VerticalAlignment="Center" Margin="0,0,4,0"/>
                                        <TextBlock Text="Qarz uchun mijoz tanlanishi shart"
                                                   FontSize="11" FontWeight="SemiBold"
                                                   Foreground="#B45309"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Grid>

                                <!-- ── Row 8: Quick-fill chips ── -->
                                <Grid Grid.Row="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="TEZKOR"
                                               FontSize="10" FontWeight="Bold"
                                               Foreground="#94A3B8"
                                               VerticalAlignment="Center"
                                               Margin="0,0,10,0"/>
                                    <WrapPanel Grid.Column="1" Orientation="Horizontal">
                                        <WrapPanel.Resources>
                                            <Style x:Key="QuickChip" TargetType="Button">
                                                <Setter Property="Height"            Value="28"/>
                                                <Setter Property="Padding"           Value="12,0"/>
                                                <Setter Property="Margin"            Value="0,0,6,6"/>
                                                <Setter Property="Background"        Value="White"/>
                                                <Setter Property="Foreground"        Value="#475569"/>
                                                <Setter Property="BorderBrush"       Value="#D8E1EE"/>
                                                <Setter Property="BorderThickness"   Value="1"/>
                                                <Setter Property="FontSize"          Value="12"/>
                                                <Setter Property="FontWeight"        Value="Bold"/>
                                                <Setter Property="Cursor"            Value="Hand"/>
                                                <Setter Property="FocusVisualStyle"  Value="{x:Null}"/>
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border Background="{TemplateBinding Background}"
                                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                                    CornerRadius="6"
                                                                    Padding="{TemplateBinding Padding}">
                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter Property="Background" Value="#F8FAFC"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                            <Style x:Key="QuickChipAccent" TargetType="Button" BasedOn="{StaticResource QuickChip}">
                                                <Setter Property="BorderBrush" Value="#155EEF"/>
                                                <Setter Property="Foreground"  Value="#0B5BD3"/>
                                            </Style>
                                            <Style x:Key="QuickChipMuted" TargetType="Button" BasedOn="{StaticResource QuickChip}">
                                                <Setter Property="Foreground"  Value="#94A3B8"/>
                                            </Style>
                                        </WrapPanel.Resources>
                                        <Button Style="{StaticResource QuickChip}" Content="+10K"
                                                Command="{Binding AddQuickAmountCommand}" CommandParameter="10000"/>
                                        <Button Style="{StaticResource QuickChip}" Content="+20K"
                                                Command="{Binding AddQuickAmountCommand}" CommandParameter="20000"/>
                                        <Button Style="{StaticResource QuickChip}" Content="+50K"
                                                Command="{Binding AddQuickAmountCommand}" CommandParameter="50000"/>
                                        <Button Style="{StaticResource QuickChip}" Content="+100K"
                                                Command="{Binding AddQuickAmountCommand}" CommandParameter="100000"/>
                                        <Button Style="{StaticResource QuickChipAccent}" Content="= JAMI"
                                                Command="{Binding FillRemainingCommand}"
                                                CommandParameter="{Binding ActivePaymentRow}"/>
                                    </WrapPanel>
                                    <Button Grid.Column="2"
                                            Command="{Binding ClearPaymentsCommand}"
                                            Content="Tozalash"
                                            Height="28" Padding="12,0"
                                            Background="White"
                                            Foreground="#94A3B8"
                                            BorderBrush="#D8E1EE"
                                            BorderThickness="1"
                                            FontSize="12" FontWeight="Bold"
                                            Cursor="Hand"
                                            FocusVisualStyle="{x:Null}">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        CornerRadius="6"
                                                        Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#F8FAFC"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </Grid>

                                <!-- ── Row 10: Summary strip (QABUL QILINDI + QOLDIQ/QAYTIM) ── -->
                                <Grid Grid.Row="10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- QABUL QILINDI (always shown, green) -->
                                    <Border Grid.Column="0"
                                            Background="#ECFDF3"
                                            BorderBrush="#DCFCE7"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            Padding="12,8"
                                            MinHeight="56">
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="QABUL QILINDI"
                                                       FontSize="10" FontWeight="Bold"
                                                       Foreground="#15803D"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                                <TextBlock FontSize="20" FontWeight="Bold"
                                                           Foreground="#15803D"
                                                           Text="{Binding TotalTendered, StringFormat='{}{0:N0}'}"/>
                                                <TextBlock Text=" so'm"
                                                           FontSize="11" FontWeight="SemiBold"
                                                           Foreground="#15803D" Opacity="0.85"
                                                           VerticalAlignment="Bottom"
                                                           Margin="3,0,0,3"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>

                                    <!-- QOLDIQ (amber) — visible until fully paid -->
                                    <Border Grid.Column="2"
                                            Background="#FFFBEB"
                                            BorderBrush="#FDE68A"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            Padding="12,8"
                                            MinHeight="56"
                                            Visibility="{Binding IsFullyPaid,
                                                         Converter={StaticResource InverseBoolToVisibilityConverter}}">
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="QOLDIQ"
                                                       FontSize="10" FontWeight="Bold"
                                                       Foreground="#B45309"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                                <TextBlock FontSize="20" FontWeight="Bold"
                                                           Foreground="#B45309"
                                                           Text="{Binding Remaining, StringFormat='{}{0:N0}'}"/>
                                                <TextBlock Text=" so'm"
                                                           FontSize="11" FontWeight="SemiBold"
                                                           Foreground="#B45309" Opacity="0.85"
                                                           VerticalAlignment="Bottom"
                                                           Margin="3,0,0,3"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>

                                    <!-- QAYTIM (rose) — visible once fully paid -->
                                    <Border Grid.Column="2"
                                            Background="#FEF2F2"
                                            BorderBrush="#FECACA"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            Padding="12,8"
                                            MinHeight="56"
                                            Visibility="{Binding IsFullyPaid,
                                                         Converter={StaticResource BoolToVisibilityConverter}}">
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="QAYTIM"
                                                       FontSize="10" FontWeight="Bold"
                                                       Foreground="#DC2626"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                                <TextBlock FontSize="20" FontWeight="Bold"
                                                           Foreground="#DC2626"
                                                           Text="{Binding MixedChange, StringFormat='{}{0:N0}'}"/>
                                                <TextBlock Text=" so'm"
                                                           FontSize="11" FontWeight="SemiBold"
                                                           Foreground="#DC2626" Opacity="0.85"
                                                           VerticalAlignment="Bottom"
                                                           Margin="3,0,0,3"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <!-- ── Row 12: SOTISH ── -->
                                <Button Grid.Row="12"
                                        Command="{Binding CheckoutCommand}"
                                        Style="{StaticResource SuccessButtonStyle}"
                                        Height="58" FontSize="18" FontWeight="Bold">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets"
                                                   Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="SOTISH" VerticalAlignment="Center"/>
                                        <Border BorderBrush="#FFFFFF" BorderThickness="1"
                                                CornerRadius="3" Padding="6,1"
                                                Margin="10,0,0,0"
                                                Opacity="0.7"
                                                VerticalAlignment="Center">
                                            <TextBlock Text="F12" FontSize="10"
                                                       FontWeight="Bold"
                                                       FontFamily="Consolas"
                                                       Foreground="White"/>
                                        </Border>
                                    </StackPanel>
                                </Button>
                            </Grid>

                            <Border Visibility="{Binding IsTabletMode,
                                         Converter={StaticResource BoolToVisibilityConverter}}"
                                    Margin="0,8,0,0">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="34"/>
                                        <RowDefinition Height="3"/>
                                        <RowDefinition Height="34"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="4"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="4"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="4"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="4"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="4"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="4"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <Button Grid.Row="0" Grid.Column="0" Content="7"
                                            Command="{Binding KeypadInputCommand}" CommandParameter="7"
                                            Style="{StaticResource KeypadButtonStyle}"/>
                                    <Button Grid.Row="0" Grid.Column="2" Content="8"
                                            Command="{Binding KeypadInputCommand}" CommandParameter="8"
                                            Style="{StaticResource KeypadButtonStyle}"/>
                                    <Button Grid.Row="0" Grid.Column="4" Content="9"
                                            Command="{Binding KeypadInputCommand}" CommandParameter="9"
                                            Style="{StaticResource KeypadButtonStyle}"/>
                                    <Button Grid.Row="0" Grid.Column="6" Content="00"
                                            Command="{Binding KeypadInputCommand}" CommandParameter="00"
                                            Style="{StaticResource KeypadButtonStyle}"/>
                                    <Button Grid.Row="0" Grid.Column="8" Content="0"
                                            Command="{Binding KeypadInputCommand}" CommandParameter="0"
                                            Style="{StaticResource KeypadButtonStyle}"/>
                                    <Button Grid.Row="0" Grid.Column="10" Content="&#xE750;" FontFamily="Segoe MDL2 Assets"
                                            Command="{Binding KeypadInputCommand}" CommandParameter="&#x232B;"
                                            Style="{StaticResource KeypadButtonStyle}"/>

                                    <Button Grid.Row="2" Grid.Column="0" Content="4"
                                            Command="{Binding KeypadInputCommand}" CommandParameter="4"
                                            Style="{StaticResource KeypadButtonStyle}"/>
                                    <Button Grid.Row="2" Grid.Column="2" Content="5"
                                            Command="{Binding KeypadInputCommand}" CommandParameter="5"
                                            Style="{StaticResource KeypadButtonStyle}"/>
                                    <Button Grid.Row="2" Grid.Column="4" Content="6"
                                            Command="{Binding KeypadInputCommand}" CommandParameter="6"
                                            Style="{StaticResource KeypadButtonStyle}"/>
                                    <Button Grid.Row="2" Grid.Column="6" Content="1"
                                            Command="{Binding KeypadInputCommand}" CommandParameter="1"
                                            Style="{StaticResource KeypadButtonStyle}"/>
                                    <Button Grid.Row="2" Grid.Column="8" Content="2"
                                            Command="{Binding KeypadInputCommand}" CommandParameter="2"
                                            Style="{StaticResource KeypadButtonStyle}"/>
                                    <Button Grid.Row="2" Grid.Column="10" Content="3"
                                            Command="{Binding KeypadInputCommand}" CommandParameter="3"
                                            Style="{StaticResource KeypadButtonStyle}"/>
                                    <Button Grid.Row="2" Grid.Column="12" Content="C"
                                            Command="{Binding KeypadInputCommand}" CommandParameter="C"
                                            Style="{StaticResource OutlineDangerButtonStyle}"/>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ COLUMN 2: PAYMENT в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ -->
            <Border Grid.Column="3" Background="#F9FBFE"
                    BorderBrush="#E2E8F0" BorderThickness="1,0,0,0"
                    Visibility="Collapsed">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="18,18,18,20">

                        <!-- Payment type label -->
                        <TextBlock Text="TO'LOV USULI" FontSize="10" FontWeight="Bold"
                                   Foreground="#667085" Margin="0,0,0,10"/>

                        <!-- Naqt / Karta buttons -->
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Height="48"
                                    Command="{Binding SelectPaymentTypeCommand}" CommandParameter="cash"
                                    Style="{StaticResource PayTypeBtn}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#x1F4B5;" FontSize="18" Margin="0,0,6,0"
                                               FontFamily="Segoe UI Emoji" VerticalAlignment="Center"/>
                                    <TextBlock Text="Naqt" FontSize="14" FontWeight="SemiBold"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Grid.Column="2" Height="48"
                                    Command="{Binding SelectPaymentTypeCommand}" CommandParameter="card"
                                    Style="{StaticResource PayTypeBtn}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#x1F4B3;" FontSize="18" Margin="0,0,6,0"
                                               FontFamily="Segoe UI Emoji" VerticalAlignment="Center"/>
                                    <TextBlock Text="Karta" FontSize="14" FontWeight="SemiBold"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </Grid>

                        <!-- Paid amount -->
                        <TextBlock Text="To'lov summasi" FontSize="11" FontWeight="Bold"
                                   Foreground="#667085" Margin="0,0,0,7"/>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" BorderBrush="#D8E1EE" BorderThickness="1"
                                    CornerRadius="13" Background="White">
                                <TextBox Text="{Binding PaidAmount,
                                         UpdateSourceTrigger=PropertyChanged,
                                         StringFormat='{}{0:N0}'}"
                                         TextAlignment="Right"
                                         FontSize="22" FontWeight="Bold" Padding="12,10"
                                         BorderThickness="0" Background="Transparent"
                                         helpers:NumericTextBox.IsNumeric="True"
                                         Style="{StaticResource FlatTextBoxStyle}"/>
                            </Border>
                            <TextBlock Grid.Column="1" Text=" so'm" Foreground="#667085"
                                       FontSize="13" VerticalAlignment="Center"/>
                        </Grid>

                        <!-- Change -->
                        <Grid Margin="0,0,0,14">
                            <TextBlock Text="Qaytim" FontSize="13" Foreground="#667085"
                                       VerticalAlignment="Center"/>
                            <TextBlock HorizontalAlignment="Right" FontSize="15"
                                       FontWeight="SemiBold" VerticalAlignment="Center">
                                <Run Text="{Binding Change, Mode=OneWay, StringFormat='{}{0:N0}'}"/>
                                <Run Text=" so'm"/>
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#16A34A"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Change,
                                                         Converter={StaticResource IsNegativeConverter}}"
                                                         Value="True">
                                                <Setter Property="Foreground" Value="#DC2626"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>

                        <!-- Numeric keypad (tablet mode) -->
                        <Border Visibility="{Binding IsTabletMode,
                                             Converter={StaticResource BoolToVisibilityConverter}}"
                                Margin="0,0,0,12">
                            <StackPanel>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="46"/>
                                        <RowDefinition Height="4"/>
                                        <RowDefinition Height="46"/>
                                        <RowDefinition Height="4"/>
                                        <RowDefinition Height="46"/>
                                        <RowDefinition Height="4"/>
                                        <RowDefinition Height="46"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="4"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="4"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <Button Grid.Row="0" Grid.Column="0" Content="7"
                                            Command="{Binding KeypadInputCommand}" CommandParameter="7"
                                            Style="{StaticResource KeypadButtonStyle}"/>
                                    <Button Grid.Row="0" Grid.Column="2" Content="8"
                                            Command="{Binding KeypadInputCommand}" CommandParameter="8"
                                            Style="{StaticResource KeypadButtonStyle}"/>
                                    <Button Grid.Row="0" Grid.Column="4" Content="9"
                                            Command="{Binding KeypadInputCommand}" CommandParameter="9"
                                            Style="{StaticResource KeypadButtonStyle}"/>

                                    <Button Grid.Row="2" Grid.Column="0" Content="4"
                                            Command="{Binding KeypadInputCommand}" CommandParameter="4"
                                            Style="{StaticResource KeypadButtonStyle}"/>
                                    <Button Grid.Row="2" Grid.Column="2" Content="5"
                                            Command="{Binding KeypadInputCommand}" CommandParameter="5"
                                            Style="{StaticResource KeypadButtonStyle}"/>
                                    <Button Grid.Row="2" Grid.Column="4" Content="6"
                                            Command="{Binding KeypadInputCommand}" CommandParameter="6"
                                            Style="{StaticResource KeypadButtonStyle}"/>

                                    <Button Grid.Row="4" Grid.Column="0" Content="1"
                                            Command="{Binding KeypadInputCommand}" CommandParameter="1"
                                            Style="{StaticResource KeypadButtonStyle}"/>
                                    <Button Grid.Row="4" Grid.Column="2" Content="2"
                                            Command="{Binding KeypadInputCommand}" CommandParameter="2"
                                            Style="{StaticResource KeypadButtonStyle}"/>
                                    <Button Grid.Row="4" Grid.Column="4" Content="3"
                                            Command="{Binding KeypadInputCommand}" CommandParameter="3"
                                            Style="{StaticResource KeypadButtonStyle}"/>

                                    <Button Grid.Row="6" Grid.Column="0" Content="00"
                                            Command="{Binding KeypadInputCommand}" CommandParameter="00"
                                            Style="{StaticResource KeypadButtonStyle}"/>
                                    <Button Grid.Row="6" Grid.Column="2" Content="0"
                                            Command="{Binding KeypadInputCommand}" CommandParameter="0"
                                            Style="{StaticResource KeypadButtonStyle}"/>
                                    <Button Grid.Row="6" Grid.Column="4" Content="&#xE750;" FontFamily="Segoe MDL2 Assets"
                                            Command="{Binding KeypadInputCommand}" CommandParameter="&#x232B;"
                                            Style="{StaticResource KeypadButtonStyle}"/>
                                </Grid>

                                <Button Content="C  -  Tozalash" Margin="0,4,0,0" Height="38"
                                        Command="{Binding KeypadInputCommand}" CommandParameter="C"
                                        Style="{StaticResource OutlineDangerButtonStyle}"
                                        FontSize="13" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Border>

                        <!-- SOTISH button -->
                        <Button Command="{Binding CheckoutCommand}"
                                Style="{StaticResource SuccessButtonStyle}"
                                Height="60" FontSize="18" FontWeight="Bold">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#x2714;  " FontSize="16"/>
                                <TextBlock Text="SOTISH"/>
                            </StackPanel>
                        </Button>

                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>

            <Border Grid.Column="1" Grid.ColumnSpan="3"
                    Background="#FFFFFF"
                    BorderBrush="#CBD5E1" BorderThickness="1,0,0,0"
                    Panel.ZIndex="40"
                    Visibility="{Binding IsSettingsPageOpen, Converter={StaticResource BoolToVisibilityConverter}}">
                <Grid Margin="20">
                    <Border Background="#FFFFFF" CornerRadius="0"
                            BorderBrush="#CBD5E1" BorderThickness="1"
                            Padding="0">
                        <Grid>
                            <Grid.Visibility>
                                <Binding Path="IsPrinterSettingsPageOpen" Converter="{StaticResource InverseBoolToVisibilityConverter}"/>
                            </Grid.Visibility>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="1"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Border Background="#F8FAFC" BorderBrush="#CBD5E1" BorderThickness="0,0,0,1" Padding="16,12">
                                <StackPanel>
                                    <TextBlock Text="Sozlamalar" FontSize="20" FontWeight="Bold" Foreground="#0F172A"/>
                                    <TextBlock Text="Tizim sozlamalari" FontSize="12" Foreground="#475569" Margin="0,3,0,0"/>
                                </StackPanel>
                            </Border>

                            <Button Grid.Row="2"
                                    Command="{Binding ShowPrinterSettingsPageCommand}"
                                    Style="{StaticResource NavButtonStyle}"
                                    HorizontalAlignment="Left"
                                    Width="310" Margin="16" Padding="12,10">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE749;" FontFamily="Segoe MDL2 Assets"
                                               FontSize="18" Width="30" VerticalAlignment="Center"/>
                                    <StackPanel>
                                        <TextBlock Text="Printerlar" FontSize="14" FontWeight="SemiBold"/>
                                        <TextBlock Text="Chek va sennik printerlarini tanlash" FontSize="12" Foreground="#475569"/>
                                    </StackPanel>
                                </StackPanel>
                            </Button>
                        </Grid>
                    </Border>

                    <Border Background="#FFFFFF" CornerRadius="0"
                            BorderBrush="#CBD5E1" BorderThickness="1"
                            Padding="0"
                            Visibility="{Binding IsPrinterSettingsPageOpen, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="1"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="1"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <DockPanel Grid.Row="0" LastChildFill="True"
                                       Background="#F8FAFC"
                                       Margin="0">
                                <DockPanel.Resources>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DockPanel.Resources>
                                <Button DockPanel.Dock="Left"
                                        Command="{Binding ShowSettingsPageCommand}"
                                        Style="{StaticResource IconButtonStyle}"
                                        Width="36" Height="32" Margin="12,10,10,10">
                                    <TextBlock Text="&#xE72B;" FontFamily="Segoe MDL2 Assets" FontSize="15"/>
                                </Button>
                                <StackPanel Margin="0,10,0,10">
                                    <TextBlock Text="Printerlar" FontSize="20" FontWeight="Bold" Foreground="#0F172A"/>
                                    <TextBlock Text="Zakaz cheki va sennik printerlarini tanlang" FontSize="12" Foreground="#475569" Margin="0,2,0,0"/>
                                </StackPanel>
                                <Button DockPanel.Dock="Right"
                                        Command="{Binding RefreshPrintersCommand}"
                                        Margin="0,10,12,10"
                                        Padding="10,6"
                                        MinWidth="0"
                                        Background="#1565C0"
                                        Foreground="White"
                                        BorderBrush="#0D47A1"
                                        BorderThickness="1"
                                        Cursor="Hand"
                                        FocusVisualStyle="{x:Null}">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="RefreshRoot"
                                                    RenderTransformOrigin="0.5,0.5"
                                                    Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#0D47A1"/>
                                                    <Setter Property="BorderBrush" Value="#083B87"/>
                                                </Trigger>
                                                <Trigger Property="IsPressed" Value="True">
                                                    <Setter Property="Background" Value="#083B87"/>
                                                    <Setter TargetName="RefreshRoot" Property="RenderTransform">
                                                        <Setter.Value>
                                                            <ScaleTransform ScaleX="0.96" ScaleY="0.96"/>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE895;" FontFamily="Segoe MDL2 Assets"
                                                   Foreground="White"
                                                   FontSize="13" Margin="0,0,7,0"/>
                                        <TextBlock Text="Yangilash" Foreground="White"
                                                   FontSize="13" FontWeight="SemiBold"/>
                                    </StackPanel>
                                </Button>
                            </DockPanel>

                            <Grid Grid.Row="2" MaxWidth="640" HorizontalAlignment="Left" Margin="18,18,18,18">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="12"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="170"/>
                                    <ColumnDefinition Width="320"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Chek printeri"
                                           VerticalAlignment="Center" FontSize="13" FontWeight="SemiBold" Foreground="#334155"/>
                                <ComboBox Grid.Row="0" Grid.Column="1"
                                          ItemsSource="{Binding AvailablePrinters}"
                                          SelectedItem="{Binding SelectedReceiptPrinter, Mode=TwoWay}"
                                          Height="30" FontSize="13" Padding="6,2"/>

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Sennik printeri"
                                           VerticalAlignment="Center" FontSize="13" FontWeight="SemiBold" Foreground="#334155"/>
                                <ComboBox Grid.Row="2" Grid.Column="1"
                                          ItemsSource="{Binding AvailablePrinters}"
                                          SelectedItem="{Binding SelectedLabelPrinter, Mode=TwoWay}"
                                          Height="30" FontSize="13" Padding="6,2"/>
                            </Grid>

                            <Border Grid.Row="4" Background="#F8FAFC" CornerRadius="0"
                                    BorderBrush="#CBD5E1" BorderThickness="1"
                                    Padding="12" MaxWidth="640" HorizontalAlignment="Left"
                                    Margin="18,0,18,18">
                                <TextBlock Text="Chek printeri tanlangan bo'lsa, sotuv yakunlanganda zakaz avtomatik printerga yuboriladi."
                                           TextWrapping="Wrap" FontSize="12" Foreground="#334155"/>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <!-- ════════════════ OMBOR PAGE OVERLAY ════════════════ -->
            <Border Grid.Column="1" Grid.ColumnSpan="3"
                    Background="#F8FAFC"
                    BorderBrush="#E2E8F0" BorderThickness="1,0,0,0"
                    Panel.ZIndex="46"
                    Visibility="{Binding IsOmborPageOpen, Converter={StaticResource BoolToVisibilityConverter}}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/> <!-- header     -->
                        <RowDefinition Height="Auto"/> <!-- stats      -->
                        <RowDefinition Height="Auto"/> <!-- tab bar    -->
                        <RowDefinition Height="*"/>    <!-- tab content -->
                    </Grid.RowDefinitions>

                    <!-- ── Header ─────────────────────────────────────────────── -->
                    <Border Grid.Row="0" Background="White" Padding="28,16"
                            BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                                <!-- Inventar -->
                                <Button Padding="14,8" Margin="0,0,8,0"
                                        Foreground="#344054" FontSize="13"
                                        Cursor="Hand" FocusVisualStyle="{x:Null}"
                                        BorderBrush="#D0D5DD" BorderThickness="1" Background="White">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    CornerRadius="10" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#F9FAFB"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xEA3A;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                                   Margin="0,0,7,0" VerticalAlignment="Center" Foreground="#667085"/>
                                        <TextBlock Text="Inventar" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <!-- Transfer -->
                                <Button Padding="14,8" Margin="0,0,10,0"
                                        Foreground="#344054" FontSize="13"
                                        Cursor="Hand" FocusVisualStyle="{x:Null}"
                                        BorderBrush="#D0D5DD" BorderThickness="1" Background="White">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    CornerRadius="10" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#F9FAFB"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE8AB;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                                   Margin="0,0,7,0" VerticalAlignment="Center" Foreground="#667085"/>
                                        <TextBlock Text="Transfer" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <!-- Yangi kirim -->
                                <Button Padding="18,8" Style="{StaticResource PrimaryButtonStyle}" FontSize="13">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="+" FontWeight="Bold" FontSize="16" Margin="0,0,6,0"/>
                                        <TextBlock Text="Yangi kirim" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Ombor" FontSize="22" FontWeight="Bold" Foreground="#0F172A"/>
                                <TextBlock Text="Kirim, chiqim, transfer va inventarizatsiya"
                                           Foreground="#667085" FontSize="12" Margin="0,3,0,0"/>
                            </StackPanel>
                        </DockPanel>
                    </Border>

                    <!-- ── Stat cards ──────────────────────────────────────────── -->
                    <Border Grid.Row="1" Background="White" Padding="24,14"
                            BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
                        <UniformGrid Columns="4">
                            <!-- Ombor qiymati -->
                            <Border Margin="0,0,12,0" Background="White" CornerRadius="12"
                                    BorderBrush="#E2E8F0" BorderThickness="1" Padding="16,14">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.06" Color="#0F172A"/>
                                </Border.Effect>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="OMBOR QIYMATI" FontSize="10" FontWeight="SemiBold"
                                                   Foreground="#667085" Margin="0,0,0,6"/>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding OmborVm.TotalValue, StringFormat='{}{0:N0}', Mode=OneWay}"
                                                       FontSize="22" FontWeight="Bold" Foreground="#155EEF"/>
                                            <TextBlock Text=" so'm" FontSize="13" Foreground="#64748B" Margin="4,6,0,0"/>
                                        </StackPanel>
                                    </StackPanel>
                                    <Border Grid.Column="1" Width="40" Height="40" CornerRadius="10"
                                            Background="#EEF2FF" VerticalAlignment="Center">
                                        <TextBlock Text="&#xE83F;" FontFamily="Segoe MDL2 Assets" FontSize="20"
                                                   Foreground="#155EEF" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </Grid>
                            </Border>
                            <!-- Bugungi kirim -->
                            <Border Margin="0,0,12,0" Background="White" CornerRadius="12"
                                    BorderBrush="#E2E8F0" BorderThickness="1" Padding="16,14">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.06" Color="#0F172A"/>
                                </Border.Effect>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="BUGUNGI KIRIM" FontSize="10" FontWeight="SemiBold"
                                                   Foreground="#667085" Margin="0,0,0,6"/>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding OmborVm.TodayIncoming, StringFormat='{}{0:N0}', Mode=OneWay}"
                                                       FontSize="22" FontWeight="Bold" Foreground="#16A34A"/>
                                            <TextBlock Text=" so'm" FontSize="13" Foreground="#64748B" Margin="4,6,0,0"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                            <TextBlock Text="&#xE74B;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                                       Foreground="#16A34A" VerticalAlignment="Center" Margin="0,0,3,0"/>
                                            <TextBlock Text="+12.4%" FontSize="11" FontWeight="SemiBold" Foreground="#16A34A"/>
                                        </StackPanel>
                                    </StackPanel>
                                    <Border Grid.Column="1" Width="40" Height="40" CornerRadius="10"
                                            Background="#DCFCE7" VerticalAlignment="Center">
                                        <TextBlock Text="&#xE74B;" FontFamily="Segoe MDL2 Assets" FontSize="20"
                                                   Foreground="#16A34A" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </Grid>
                            </Border>
                            <!-- Bugungi chiqim -->
                            <Border Margin="0,0,12,0" Background="White" CornerRadius="12"
                                    BorderBrush="#E2E8F0" BorderThickness="1" Padding="16,14">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.06" Color="#0F172A"/>
                                </Border.Effect>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="BUGUNGI CHIQIM" FontSize="10" FontWeight="SemiBold"
                                                   Foreground="#667085" Margin="0,0,0,6"/>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding OmborVm.TodayOutgoing, StringFormat='{}{0:N0}', Mode=OneWay}"
                                                       FontSize="22" FontWeight="Bold" Foreground="#0369A1"/>
                                            <TextBlock Text=" so'm" FontSize="13" Foreground="#64748B" Margin="4,6,0,0"/>
                                        </StackPanel>
                                    </StackPanel>
                                    <Border Grid.Column="1" Width="40" Height="40" CornerRadius="10"
                                            Background="#E0F2FE" VerticalAlignment="Center">
                                        <TextBlock Text="&#xE74C;" FontFamily="Segoe MDL2 Assets" FontSize="20"
                                                   Foreground="#0369A1" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </Grid>
                            </Border>
                            <!-- Diqqat talab -->
                            <Border Background="White" CornerRadius="12"
                                    BorderBrush="#E2E8F0" BorderThickness="1" Padding="16,14">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.06" Color="#0F172A"/>
                                </Border.Effect>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="DIQQAT TALAB" FontSize="10" FontWeight="SemiBold"
                                                   Foreground="#667085" Margin="0,0,0,6"/>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding OmborVm.AlertCount, Mode=OneWay}"
                                                       FontSize="26" FontWeight="Bold" Foreground="#D97706"/>
                                            <TextBlock Text=" ta" FontSize="14" Foreground="#64748B" Margin="4,8,0,0"/>
                                        </StackPanel>
                                    </StackPanel>
                                    <Border Grid.Column="1" Width="40" Height="40" CornerRadius="10"
                                            Background="#FEF3C7" VerticalAlignment="Center">
                                        <TextBlock Text="&#xE7BA;" FontFamily="Segoe MDL2 Assets" FontSize="20"
                                                   Foreground="#D97706" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </Grid>
                            </Border>
                        </UniformGrid>
                    </Border>

                    <!-- ── Tab bar ─────────────────────────────────────────────── -->
                    <Border Grid.Row="2" Background="White"
                            BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
                        <StackPanel Orientation="Horizontal" Margin="24,0">
                            <!-- Operatsiyalar tab -->
                            <Button Command="{Binding OmborVm.ShowMovementsTabCommand}"
                                    Padding="0,0,0,0" Margin="0,0,4,0"
                                    BorderThickness="0" Background="Transparent"
                                    Cursor="Hand" FocusVisualStyle="{x:Null}">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="TabBorder1" Padding="16,12,16,10"
                                                BorderThickness="0,0,0,2" BorderBrush="Transparent">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock x:Name="TabLbl1" Text="Operatsiyalar"
                                                           FontSize="14" FontWeight="SemiBold" Foreground="#667085"/>
                                                <Border x:Name="TabBadge1" Margin="8,0,0,0"
                                                        Background="#F1F5F9" CornerRadius="10" Padding="8,2">
                                                    <TextBlock Text="{Binding DataContext.OmborVm.MovementsCount,
                                                               RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                               FontSize="11" FontWeight="SemiBold" Foreground="#667085"/>
                                                </Border>
                                            </StackPanel>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <DataTrigger Binding="{Binding DataContext.OmborVm.ActiveTab,
                                                         RelativeSource={RelativeSource AncestorType=UserControl}}" Value="movements">
                                                <Setter TargetName="TabBorder1" Property="BorderBrush" Value="#155EEF"/>
                                                <Setter TargetName="TabLbl1"    Property="Foreground"  Value="#155EEF"/>
                                                <Setter TargetName="TabBadge1"  Property="Background"  Value="#EEF2FF"/>
                                            </DataTrigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            <!-- Joriy qoldiq tab -->
                            <Button Command="{Binding OmborVm.ShowStockTabCommand}"
                                    Padding="0,0,0,0" Margin="0,0,4,0"
                                    BorderThickness="0" Background="Transparent"
                                    Cursor="Hand" FocusVisualStyle="{x:Null}">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="TabBorder2" Padding="16,12,16,10"
                                                BorderThickness="0,0,0,2" BorderBrush="Transparent">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock x:Name="TabLbl2" Text="Joriy qoldiq"
                                                           FontSize="14" FontWeight="SemiBold" Foreground="#667085"/>
                                                <Border x:Name="TabBadge2" Margin="8,0,0,0"
                                                        Background="#F1F5F9" CornerRadius="10" Padding="8,2">
                                                    <TextBlock Text="{Binding DataContext.OmborVm.StockCount,
                                                               RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                               FontSize="11" FontWeight="SemiBold" Foreground="#667085"/>
                                                </Border>
                                            </StackPanel>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <DataTrigger Binding="{Binding DataContext.OmborVm.ActiveTab,
                                                         RelativeSource={RelativeSource AncestorType=UserControl}}" Value="stock">
                                                <Setter TargetName="TabBorder2" Property="BorderBrush" Value="#155EEF"/>
                                                <Setter TargetName="TabLbl2"    Property="Foreground"  Value="#155EEF"/>
                                                <Setter TargetName="TabBadge2"  Property="Background"  Value="#EEF2FF"/>
                                            </DataTrigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            <!-- Ogohlantirishlar tab -->
                            <Button Command="{Binding OmborVm.ShowAlertsTabCommand}"
                                    Padding="0,0,0,0"
                                    BorderThickness="0" Background="Transparent"
                                    Cursor="Hand" FocusVisualStyle="{x:Null}">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="TabBorder3" Padding="16,12,16,10"
                                                BorderThickness="0,0,0,2" BorderBrush="Transparent">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock x:Name="TabLbl3" Text="Ogohlantirishlar"
                                                           FontSize="14" FontWeight="SemiBold" Foreground="#667085"/>
                                                <Border x:Name="TabBadge3" Margin="8,0,0,0"
                                                        Background="#FEF3C7" CornerRadius="10" Padding="8,2">
                                                    <TextBlock Text="{Binding DataContext.OmborVm.AlertCount,
                                                               RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                               FontSize="11" FontWeight="SemiBold" Foreground="#D97706"/>
                                                </Border>
                                            </StackPanel>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <DataTrigger Binding="{Binding DataContext.OmborVm.ActiveTab,
                                                         RelativeSource={RelativeSource AncestorType=UserControl}}" Value="alerts">
                                                <Setter TargetName="TabBorder3" Property="BorderBrush" Value="#155EEF"/>
                                                <Setter TargetName="TabLbl3"    Property="Foreground"  Value="#155EEF"/>
                                                <Setter TargetName="TabBadge3"  Property="Background"  Value="#EEF2FF"/>
                                            </DataTrigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </StackPanel>
                    </Border>

                    <!-- ── Tab content ─────────────────────────────────────────── -->
                    <Grid Grid.Row="3">

                        <!-- ── TAB: Operatsiyalar ── -->
                        <Grid>
                            <Grid.Style>
                                <Style TargetType="Grid">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding OmborVm.ActiveTab}" Value="movements">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </Style>
                            </Grid.Style>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <!-- Table header -->
                            <Border Grid.Row="0" Background="#F8FAFC"
                                    BorderBrush="#E2E8F0" BorderThickness="0,0,0,1" Padding="0,10">
                                <Grid Margin="24,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="110"/>
                                        <ColumnDefinition Width="105"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="70"/>
                                        <ColumnDefinition Width="130"/>
                                        <ColumnDefinition Width="110"/>
                                        <ColumnDefinition Width="110"/>
                                        <ColumnDefinition Width="40"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="SANA"           FontSize="11" FontWeight="SemiBold" Foreground="#667085" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="HUJJAT"         FontSize="11" FontWeight="SemiBold" Foreground="#667085" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" Text="TURI"           FontSize="11" FontWeight="SemiBold" Foreground="#667085" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="3" Text="KONTRAGENT"     FontSize="11" FontWeight="SemiBold" Foreground="#667085" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="4" Text="POS." TextAlignment="Right" FontSize="11" FontWeight="SemiBold" Foreground="#667085" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="5" Text="SUMMA" TextAlignment="Right" FontSize="11" FontWeight="SemiBold" Foreground="#667085" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="6" Text="MAS'UL"         FontSize="11" FontWeight="SemiBold" Foreground="#667085" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="7" Text="HOLATI"         FontSize="11" FontWeight="SemiBold" Foreground="#667085" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                            <!-- Table body -->
                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                <ItemsControl ItemsSource="{Binding OmborVm.Movements}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="#F2F4F7" BorderThickness="0,0,0,1"
                                                    Background="White" Padding="0,11">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Style.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="#F8FAFC"/>
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <Grid Margin="24,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="120"/>
                                                        <ColumnDefinition Width="110"/>
                                                        <ColumnDefinition Width="105"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="70"/>
                                                        <ColumnDefinition Width="130"/>
                                                        <ColumnDefinition Width="110"/>
                                                        <ColumnDefinition Width="110"/>
                                                        <ColumnDefinition Width="40"/>
                                                    </Grid.ColumnDefinitions>
                                                    <!-- Sana -->
                                                    <TextBlock Grid.Column="0" Text="{Binding Date}"
                                                               FontSize="12" Foreground="#667085" VerticalAlignment="Center"/>
                                                    <!-- Hujjat -->
                                                    <TextBlock Grid.Column="1" Text="{Binding DocNumber}"
                                                               FontSize="13" FontWeight="SemiBold" Foreground="#0F172A"
                                                               VerticalAlignment="Center"
                                                               FontFamily="Consolas, Courier New"/>
                                                    <!-- Turi badge -->
                                                    <Border Grid.Column="2" CornerRadius="6" Padding="9,3"
                                                            HorizontalAlignment="Left" VerticalAlignment="Center"
                                                            Background="{Binding TypeBg, Converter={StaticResource HexToBrushConverter}}">
                                                        <TextBlock Text="{Binding TypeLabel}" FontSize="12" FontWeight="SemiBold"
                                                                   Foreground="{Binding TypeColor, Converter={StaticResource HexToBrushConverter}}"/>
                                                    </Border>
                                                    <!-- Kontragent -->
                                                    <TextBlock Grid.Column="3" Text="{Binding Supplier}"
                                                               FontSize="13" Foreground="#344054" VerticalAlignment="Center"
                                                               TextTrimming="CharacterEllipsis"/>
                                                    <!-- Pozitsiyalar -->
                                                    <TextBlock Grid.Column="4" Text="{Binding Items}"
                                                               FontSize="13" FontWeight="SemiBold" Foreground="#0F172A"
                                                               TextAlignment="Right" VerticalAlignment="Center"/>
                                                    <!-- Summa -->
                                                    <TextBlock Grid.Column="5" Text="{Binding SumDisplay}"
                                                               FontSize="13" FontWeight="Bold" Foreground="#0F172A"
                                                               TextAlignment="Right" VerticalAlignment="Center"/>
                                                    <!-- Mas'ul -->
                                                    <TextBlock Grid.Column="6" Text="{Binding By}"
                                                               FontSize="12" Foreground="#667085" VerticalAlignment="Center"/>
                                                    <!-- Holati badge -->
                                                    <Border Grid.Column="7" CornerRadius="6" Padding="9,3"
                                                            HorizontalAlignment="Left" VerticalAlignment="Center"
                                                            Background="{Binding StatusBg, Converter={StaticResource HexToBrushConverter}}">
                                                        <StackPanel Orientation="Horizontal">
                                                            <Ellipse Width="6" Height="6" VerticalAlignment="Center" Margin="0,0,5,0"
                                                                     Fill="{Binding StatusColor, Converter={StaticResource HexToBrushConverter}}"/>
                                                            <TextBlock Text="{Binding StatusLabel}" FontSize="12" FontWeight="SemiBold"
                                                                       Foreground="{Binding StatusColor, Converter={StaticResource HexToBrushConverter}}"/>
                                                        </StackPanel>
                                                    </Border>
                                                    <!-- Action -->
                                                    <Button Grid.Column="8" Width="28" Height="28"
                                                            Style="{StaticResource IconButtonStyle}" ToolTip="Ko'rish">
                                                        <TextBlock Text="&#xE890;" FontFamily="Segoe MDL2 Assets" FontSize="13"/>
                                                    </Button>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>

                            <!-- Movements pagination -->
                            <Border Grid.Row="2" Background="White"
                                    BorderBrush="#E2E8F0" BorderThickness="0,1,0,0" Padding="24,10">
                                <DockPanel LastChildFill="False">
                                    <TextBlock DockPanel.Dock="Left" VerticalAlignment="Center"
                                               FontSize="13" Foreground="#667085">
                                        <Run Text="Jami "/>
                                        <Run Text="{Binding OmborVm.MovTotalCount, Mode=OneWay}"/>
                                        <Run Text=" ta operatsiya · "/>
                                        <Run Text="{Binding OmborVm.MovPage, Mode=OneWay}"/>
                                        <Run Text="-sahifa, "/>
                                        <Run Text="{Binding OmborVm.MovTotalPages, Mode=OneWay}"/>
                                        <Run Text=" dan"/>
                                    </TextBlock>
                                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                        <Button Width="32" Height="32" Margin="0,0,4,0"
                                                Command="{Binding OmborVm.MovPrevPageCommand}"
                                                Cursor="Hand" FocusVisualStyle="{x:Null}">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="MP1" Background="White" BorderBrush="#D0D5DD" BorderThickness="1" CornerRadius="6">
                                                        <TextBlock x:Name="MP1T" Text="&#x276E;" FontSize="14" Foreground="#344054" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="MP1" Property="Background" Value="#F3F4F6"/>
                                                        </Trigger>
                                                        <Trigger Property="IsEnabled" Value="False">
                                                            <Setter TargetName="MP1"  Property="Background"  Value="#F9FAFB"/>
                                                            <Setter TargetName="MP1T" Property="Foreground"  Value="#D0D5DD"/>
                                                            <Setter TargetName="MP1"  Property="BorderBrush" Value="#E2E8F0"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                        <Border Width="32" Height="32" Margin="0,0,4,0" Background="#155EEF" CornerRadius="6">
                                            <TextBlock Text="{Binding OmborVm.MovPage, Mode=OneWay}"
                                                       FontSize="13" FontWeight="SemiBold" Foreground="White"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <Button Width="32" Height="32"
                                                Command="{Binding OmborVm.MovNextPageCommand}"
                                                Cursor="Hand" FocusVisualStyle="{x:Null}">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="MN1" Background="White" BorderBrush="#D0D5DD" BorderThickness="1" CornerRadius="6">
                                                        <TextBlock x:Name="MN1T" Text="&#x276F;" FontSize="14" Foreground="#344054" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="MN1" Property="Background" Value="#F3F4F6"/>
                                                        </Trigger>
                                                        <Trigger Property="IsEnabled" Value="False">
                                                            <Setter TargetName="MN1"  Property="Background"  Value="#F9FAFB"/>
                                                            <Setter TargetName="MN1T" Property="Foreground"  Value="#D0D5DD"/>
                                                            <Setter TargetName="MN1"  Property="BorderBrush" Value="#E2E8F0"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </StackPanel>
                                </DockPanel>
                            </Border>
                        </Grid>

                        <!-- ── TAB: Joriy qoldiq ── -->
                        <Grid>
                            <Grid.Style>
                                <Style TargetType="Grid">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding OmborVm.ActiveTab}" Value="stock">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </Style>
                            </Grid.Style>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <!-- Table header -->
                            <Border Grid.Row="0" Background="#F8FAFC"
                                    BorderBrush="#E2E8F0" BorderThickness="0,0,0,1" Padding="0,10">
                                <Grid Margin="24,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="60"/>
                                        <ColumnDefinition Width="160"/>
                                        <ColumnDefinition Width="130"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="MAHSULOT"          FontSize="11" FontWeight="SemiBold" Foreground="#667085" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="KATEGORIYA"        FontSize="11" FontWeight="SemiBold" Foreground="#667085" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" Text="QOLDIQ" TextAlignment="Right" FontSize="11" FontWeight="SemiBold" Foreground="#667085" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="3" Text="MIN"    TextAlignment="Right" FontSize="11" FontWeight="SemiBold" Foreground="#667085" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="4" Text="HOLATI"             FontSize="11" FontWeight="SemiBold" Foreground="#667085" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="5" Text="TANNARX (JAMI)" TextAlignment="Right" FontSize="11" FontWeight="SemiBold" Foreground="#667085" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                            <!-- Table body -->
                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                <ItemsControl ItemsSource="{Binding OmborVm.StockItems}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="#F2F4F7" BorderThickness="0,0,0,1"
                                                    Background="White" Padding="0,10">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Style.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="#F8FAFC"/>
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <Grid Margin="24,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="120"/>
                                                        <ColumnDefinition Width="100"/>
                                                        <ColumnDefinition Width="60"/>
                                                        <ColumnDefinition Width="160"/>
                                                        <ColumnDefinition Width="130"/>
                                                    </Grid.ColumnDefinitions>
                                                    <!-- Mahsulot -->
                                                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                                        <Border Width="34" Height="34" CornerRadius="8"
                                                                Background="#EEF2FF" Margin="0,0,10,0">
                                                            <TextBlock Text="&#xE7B8;" FontFamily="Segoe MDL2 Assets"
                                                                       FontSize="16" Foreground="#155EEF"
                                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <StackPanel VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold"
                                                                       FontSize="13" Foreground="#0F172A"/>
                                                            <TextBlock Text="{Binding Code}" FontSize="11"
                                                                       Foreground="#94A3B8"/>
                                                        </StackPanel>
                                                    </StackPanel>
                                                    <!-- Kategoriya -->
                                                    <TextBlock Grid.Column="1" Text="{Binding Category}"
                                                               FontSize="13" Foreground="#64748B" VerticalAlignment="Center"
                                                               TextTrimming="CharacterEllipsis"/>
                                                    <!-- Qoldiq -->
                                                    <StackPanel Grid.Column="2" Orientation="Horizontal"
                                                                HorizontalAlignment="Right" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Stock, StringFormat='{}{0:N0}'}"
                                                                   FontSize="13" FontWeight="Bold"
                                                                   Foreground="{Binding BarColor, Converter={StaticResource HexToBrushConverter}}"/>
                                                        <TextBlock Text="{Binding Unit}" FontSize="11"
                                                                   Foreground="#64748B" Margin="4,2,0,0"/>
                                                    </StackPanel>
                                                    <!-- Min -->
                                                    <TextBlock Grid.Column="3" Text="{Binding MinStock, StringFormat='{}{0:N0}'}"
                                                               FontSize="12" Foreground="#94A3B8"
                                                               TextAlignment="Right" VerticalAlignment="Center"/>
                                                    <!-- Progress bar + label -->
                                                    <StackPanel Grid.Column="4" VerticalAlignment="Center" Margin="8,0,0,0">
                                                        <Grid Height="6" Width="120" HorizontalAlignment="Left">
                                                            <Border Background="#E2E8F0" CornerRadius="3"/>
                                                            <Border HorizontalAlignment="Left" CornerRadius="3"
                                                                    Width="{Binding FillWidth}"
                                                                    Background="{Binding BarColor, Converter={StaticResource HexToBrushConverter}}"/>
                                                        </Grid>
                                                        <TextBlock Text="{Binding StatusLabel}" FontSize="11"
                                                                   Foreground="{Binding BarColor, Converter={StaticResource HexToBrushConverter}}"
                                                                   Margin="0,4,0,0" FontWeight="SemiBold"/>
                                                    </StackPanel>
                                                    <!-- Tannarx jami -->
                                                    <StackPanel Grid.Column="5" Orientation="Horizontal"
                                                                HorizontalAlignment="Right" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding CostTotal, StringFormat='{}{0:N0}'}"
                                                                   FontSize="13" Foreground="#344054" FontWeight="SemiBold"/>
                                                        <TextBlock Text=" so'm" FontSize="11" Foreground="#94A3B8" Margin="2,2,0,0"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>

                            <!-- Stock pagination -->
                            <Border Grid.Row="2" Background="White"
                                    BorderBrush="#E2E8F0" BorderThickness="0,1,0,0" Padding="24,10">
                                <DockPanel LastChildFill="False">
                                    <TextBlock DockPanel.Dock="Left" VerticalAlignment="Center"
                                               FontSize="13" Foreground="#667085">
                                        <Run Text="Jami "/>
                                        <Run Text="{Binding OmborVm.StockTotalCount, Mode=OneWay}"/>
                                        <Run Text=" ta mahsulot · "/>
                                        <Run Text="{Binding OmborVm.StockPage, Mode=OneWay}"/>
                                        <Run Text="-sahifa, "/>
                                        <Run Text="{Binding OmborVm.StockTotalPages, Mode=OneWay}"/>
                                        <Run Text=" dan"/>
                                    </TextBlock>
                                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                        <Button Width="32" Height="32" Margin="0,0,4,0"
                                                Command="{Binding OmborVm.StockPrevPageCommand}"
                                                Cursor="Hand" FocusVisualStyle="{x:Null}">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="SP1" Background="White" BorderBrush="#D0D5DD" BorderThickness="1" CornerRadius="6">
                                                        <TextBlock x:Name="SP1T" Text="&#x276E;" FontSize="14" Foreground="#344054" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="SP1" Property="Background" Value="#F3F4F6"/>
                                                        </Trigger>
                                                        <Trigger Property="IsEnabled" Value="False">
                                                            <Setter TargetName="SP1"  Property="Background"  Value="#F9FAFB"/>
                                                            <Setter TargetName="SP1T" Property="Foreground"  Value="#D0D5DD"/>
                                                            <Setter TargetName="SP1"  Property="BorderBrush" Value="#E2E8F0"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                        <Border Width="32" Height="32" Margin="0,0,4,0" Background="#155EEF" CornerRadius="6">
                                            <TextBlock Text="{Binding OmborVm.StockPage, Mode=OneWay}"
                                                       FontSize="13" FontWeight="SemiBold" Foreground="White"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <Button Width="32" Height="32"
                                                Command="{Binding OmborVm.StockNextPageCommand}"
                                                Cursor="Hand" FocusVisualStyle="{x:Null}">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="SN1" Background="White" BorderBrush="#D0D5DD" BorderThickness="1" CornerRadius="6">
                                                        <TextBlock x:Name="SN1T" Text="&#x276F;" FontSize="14" Foreground="#344054" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="SN1" Property="Background" Value="#F3F4F6"/>
                                                        </Trigger>
                                                        <Trigger Property="IsEnabled" Value="False">
                                                            <Setter TargetName="SN1"  Property="Background"  Value="#F9FAFB"/>
                                                            <Setter TargetName="SN1T" Property="Foreground"  Value="#D0D5DD"/>
                                                            <Setter TargetName="SN1"  Property="BorderBrush" Value="#E2E8F0"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </StackPanel>
                                </DockPanel>
                            </Border>
                        </Grid>

                        <!-- ── TAB: Ogohlantirishlar ── -->
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24,16">
                            <ScrollViewer.Style>
                                <Style TargetType="ScrollViewer">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding OmborVm.ActiveTab}" Value="alerts">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </Style>
                            </ScrollViewer.Style>
                            <StackPanel>
                                <!-- Empty state -->
                                <Border Background="White" CornerRadius="12" Padding="32"
                                        BorderBrush="#E2E8F0" BorderThickness="1">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding DataContext.OmborVm.AlertCount,
                                                             RelativeSource={RelativeSource AncestorType=UserControl}}" Value="0">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel HorizontalAlignment="Center">
                                        <Border Width="64" Height="64" CornerRadius="16"
                                                Background="#DCFCE7" HorizontalAlignment="Center" Margin="0,0,0,16">
                                            <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets"
                                                       FontSize="28" Foreground="#16A34A"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBlock Text="Barcha mahsulotlar yetarli" FontSize="16" FontWeight="Bold"
                                                   Foreground="#0F172A" HorizontalAlignment="Center"/>
                                        <TextBlock Text="Hozircha ogohlantirish yo'q." FontSize="13"
                                                   Foreground="#667085" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                                    </StackPanel>
                                </Border>
                                <!-- Alert cards -->
                                <ItemsControl ItemsSource="{Binding DataContext.OmborVm.Alerts,
                                              RelativeSource={RelativeSource AncestorType=UserControl}}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="White" CornerRadius="12"
                                                    BorderBrush="#E2E8F0" BorderThickness="1"
                                                    Padding="20,16" Margin="0,0,0,10">
                                                <Border.Effect>
                                                    <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.05" Color="#0F172A"/>
                                                </Border.Effect>
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Style.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="BorderBrush" Value="#CBD5E1"/>
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <DockPanel>
                                                    <!-- Icon -->
                                                    <Border DockPanel.Dock="Left" Width="48" Height="48"
                                                            CornerRadius="12" Margin="0,0,16,0"
                                                            Background="{Binding AlertBg, Converter={StaticResource HexToBrushConverter}}">
                                                        <TextBlock Text="&#xE7BA;" FontFamily="Segoe MDL2 Assets"
                                                                   FontSize="22" VerticalAlignment="Center"
                                                                   HorizontalAlignment="Center"
                                                                   Foreground="{Binding AlertFg, Converter={StaticResource HexToBrushConverter}}"/>
                                                    </Border>
                                                    <!-- Order button -->
                                                    <Button DockPanel.Dock="Right" Padding="14,7"
                                                            VerticalAlignment="Center"
                                                            Foreground="#344054" FontSize="12"
                                                            Cursor="Hand" FocusVisualStyle="{x:Null}"
                                                            BorderBrush="#D0D5DD" BorderThickness="1" Background="White">
                                                        <Button.Template>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border Background="{TemplateBinding Background}"
                                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                                        CornerRadius="8" Padding="{TemplateBinding Padding}">
                                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                </Border>
                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter Property="Background" Value="#F9FAFB"/>
                                                                    </Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Button.Template>
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="+" FontWeight="Bold" FontSize="14" Margin="0,0,5,0"/>
                                                            <TextBlock Text="Buyurtma" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                    </Button>
                                                    <!-- Badge -->
                                                    <Border DockPanel.Dock="Right" CornerRadius="6" Padding="10,4"
                                                            HorizontalAlignment="Left" VerticalAlignment="Center"
                                                            Margin="0,0,12,0"
                                                            Background="{Binding AlertBg, Converter={StaticResource HexToBrushConverter}}">
                                                        <StackPanel Orientation="Horizontal">
                                                            <Ellipse Width="6" Height="6" VerticalAlignment="Center" Margin="0,0,5,0"
                                                                     Fill="{Binding AlertFg, Converter={StaticResource HexToBrushConverter}}"/>
                                                            <TextBlock Text="{Binding BadgeText}" FontSize="12" FontWeight="SemiBold"
                                                                       Foreground="{Binding AlertFg, Converter={StaticResource HexToBrushConverter}}"/>
                                                        </StackPanel>
                                                    </Border>
                                                    <!-- Name + message -->
                                                    <StackPanel VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Name}" FontWeight="Bold"
                                                                   FontSize="14" Foreground="#0F172A"/>
                                                        <TextBlock Text="{Binding Message}" FontSize="12"
                                                                   Foreground="#667085" Margin="0,4,0,0"
                                                                   TextWrapping="Wrap"/>
                                                    </StackPanel>
                                                </DockPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </ScrollViewer>

                    </Grid>
                </Grid>
            </Border>

            <!-- ════════════════ MAHSULOTLAR PAGE OVERLAY ════════════════ -->
            <Border Grid.Column="1" Grid.ColumnSpan="3"
                    Background="#F8FAFC"
                    BorderBrush="#E2E8F0" BorderThickness="1,0,0,0"
                    Panel.ZIndex="45"
                    Visibility="{Binding IsProductsPageOpen, Converter={StaticResource BoolToVisibilityConverter}}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/> <!-- header -->
                        <RowDefinition Height="Auto"/> <!-- stats -->
                        <RowDefinition Height="Auto"/> <!-- search -->
                        <RowDefinition Height="Auto"/> <!-- category pills -->
                        <RowDefinition Height="Auto"/> <!-- table header -->
                        <RowDefinition Height="*"/>    <!-- table body -->
                        <RowDefinition Height="Auto"/> <!-- pagination -->
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <Border Grid.Row="0" Background="White" Padding="28,16"
                            BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                                <Button Padding="16,9" Margin="0,0,8,0"
                                        Foreground="#344054" FontSize="13"
                                        Cursor="Hand" FocusVisualStyle="{x:Null}"
                                        BorderBrush="#D0D5DD" BorderThickness="1" Background="White">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="Btn1" Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    CornerRadius="10" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#F9FAFB"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#x2191;" Margin="0,0,6,0" FontSize="14"/>
                                        <TextBlock Text="Import"/>
                                    </StackPanel>
                                </Button>
                                <Button Padding="16,9" Margin="0,0,10,0"
                                        Foreground="#344054" FontSize="13"
                                        Cursor="Hand" FocusVisualStyle="{x:Null}"
                                        BorderBrush="#D0D5DD" BorderThickness="1" Background="White">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="Btn2" Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    CornerRadius="10" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#F9FAFB"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#x2193;" Margin="0,0,6,0" FontSize="14"/>
                                        <TextBlock Text="Eksport"/>
                                    </StackPanel>
                                </Button>
                                <Button Padding="18,9"
                                        Command="{Binding ToggleAddProductCommand}"
                                        Style="{StaticResource PrimaryButtonStyle}"
                                        FontSize="13">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="+" FontWeight="Bold" FontSize="16" Margin="0,0,6,0"/>
                                        <TextBlock Text="Yangi mahsulot" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Mahsulotlar" FontSize="22" FontWeight="Bold" Foreground="#0F172A"/>
                                <TextBlock Foreground="#667085" FontSize="12" Margin="0,3,0,0">
                                    <Run Text="Katalogda "/>
                                    <Run Text="{Binding ProductsVm.TotalCount, Mode=OneWay}"/>
                                    <Run Text=" ta nomenklatura · "/>
                                    <Run Text="{Binding ProductsVm.CategoryCount, Mode=OneWay}"/>
                                    <Run Text=" ta kategoriya"/>
                                </TextBlock>
                            </StackPanel>
                        </DockPanel>
                    </Border>

                    <!-- Stat cards -->
                    <Border Grid.Row="1" Background="White" Padding="24,14"
                            BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
                        <UniformGrid Columns="4">
                            <!-- Jami mahsulotlar -->
                            <Border Margin="0,0,12,0" Background="White" CornerRadius="12"
                                    BorderBrush="#E2E8F0" BorderThickness="1" Padding="16,14">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.06" Color="#0F172A"/>
                                </Border.Effect>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="JAMI MAHSULOTLAR" FontSize="10" FontWeight="SemiBold"
                                                   Foreground="#667085" Margin="0,0,0,6"/>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding ProductsVm.TotalCount, Mode=OneWay}"
                                                       FontSize="26" FontWeight="Bold" Foreground="#0F172A"/>
                                            <TextBlock Text=" ta" FontSize="14" Foreground="#64748B" Margin="4,8,0,0"/>
                                        </StackPanel>
                                    </StackPanel>
                                    <Border Grid.Column="1" Width="40" Height="40" CornerRadius="10"
                                            Background="#EEF2FF" VerticalAlignment="Center">
                                        <TextBlock Text="&#xF158;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                                                   Foreground="#155EEF" HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                </Grid>
                            </Border>
                            <!-- Ombor qiymati -->
                            <Border Margin="0,0,12,0" Background="White" CornerRadius="12"
                                    BorderBrush="#E2E8F0" BorderThickness="1" Padding="16,14">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.06" Color="#0F172A"/>
                                </Border.Effect>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="OMBOR QIYMATI" FontSize="10" FontWeight="SemiBold"
                                                   Foreground="#667085" Margin="0,0,0,6"/>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding ProductsVm.TotalStockValue, Mode=OneWay, StringFormat='{}{0:N0}'}"
                                                       FontSize="20" FontWeight="Bold" Foreground="#0F172A"/>
                                            <TextBlock Text=" so'm" FontSize="12" Foreground="#64748B" Margin="4,5,0,0"/>
                                        </StackPanel>
                                    </StackPanel>
                                    <Border Grid.Column="1" Width="40" Height="40" CornerRadius="10"
                                            Background="#FFF7ED" VerticalAlignment="Center">
                                        <TextBlock Text="&#xE9F9;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                                                   Foreground="#EA580C" HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                </Grid>
                            </Border>
                            <!-- Kam qoldiq -->
                            <Border Margin="0,0,12,0" Background="White" CornerRadius="12"
                                    BorderBrush="#E2E8F0" BorderThickness="1" Padding="16,14">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.06" Color="#0F172A"/>
                                </Border.Effect>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="KAM QOLDIQ" FontSize="10" FontWeight="SemiBold"
                                                   Foreground="#667085" Margin="0,0,0,6"/>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding ProductsVm.LowStockCount, Mode=OneWay}"
                                                       FontSize="26" FontWeight="Bold" Foreground="#F59E0B"/>
                                            <TextBlock Text=" ta" FontSize="14" Foreground="#64748B" Margin="4,8,0,0"/>
                                        </StackPanel>
                                    </StackPanel>
                                    <Border Grid.Column="1" Width="40" Height="40" CornerRadius="10"
                                            Background="#FFFBEB" VerticalAlignment="Center">
                                        <TextBlock Text="&#xE783;" FontFamily="Segoe MDL2 Assets" FontSize="20"
                                                   Foreground="#F59E0B" HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                </Grid>
                            </Border>
                            <!-- Tugagan -->
                            <Border Background="White" CornerRadius="12"
                                    BorderBrush="#E2E8F0" BorderThickness="1" Padding="16,14">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.06" Color="#0F172A"/>
                                </Border.Effect>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="TUGAGAN" FontSize="10" FontWeight="SemiBold"
                                                   Foreground="#667085" Margin="0,0,0,6"/>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding ProductsVm.OutOfStockCount, Mode=OneWay}"
                                                       FontSize="26" FontWeight="Bold" Foreground="#EF4444"/>
                                            <TextBlock Text=" ta" FontSize="14" Foreground="#64748B" Margin="4,8,0,0"/>
                                        </StackPanel>
                                    </StackPanel>
                                    <Border Grid.Column="1" Width="40" Height="40" CornerRadius="10"
                                            Background="#FEF2F2" VerticalAlignment="Center">
                                        <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="20"
                                                   Foreground="#EF4444" HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                </Grid>
                            </Border>
                        </UniformGrid>
                    </Border>

                    <!-- Search + filter toolbar -->
                    <Border Grid.Row="2" Background="White" Padding="24,10"
                            BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
                        <DockPanel LastChildFill="False">
                            <!-- Search box -->
                            <Border DockPanel.Dock="Left" BorderBrush="#D8E1EE" BorderThickness="1"
                                    CornerRadius="10" Background="#FBFCFE" Width="300">
                                <Grid>
                                    <TextBlock Text="&#xE721;" Margin="12,0,0,0"
                                               FontFamily="Segoe MDL2 Assets"
                                               Foreground="#94A3B8" FontSize="14"
                                               VerticalAlignment="Center"/>
                                    <TextBox Text="{Binding ProductsVm.SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                                             Padding="38,10,12,10" FontSize="13" BorderThickness="0"
                                             Background="Transparent" Style="{StaticResource FlatTextBoxStyle}"/>
                                    <TextBlock Text="Nomi, kodi yoki barkod bo'yicha..."
                                               Foreground="#94A3B8" FontSize="13"
                                               Margin="38,0,0,0" VerticalAlignment="Center"
                                               IsHitTestVisible="False">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ProductsVm.SearchQuery}" Value="">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                            </Border>

                            <!-- Right: dropdowns + view toggles -->
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">

                                <!-- Barcha filiallar dropdown -->
                                <Grid Margin="0,0,8,0">
                                    <Button x:Name="BranchBtn"
                                            Cursor="Hand" FocusVisualStyle="{x:Null}"
                                            BorderBrush="#D0D5DD" BorderThickness="1"
                                            Background="White" Padding="12,7"
                                            Click="OnBranchBtnClick">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        CornerRadius="8" Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#F9FAFB"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="Barcha filiallar" FontSize="13" Foreground="#344054" VerticalAlignment="Center"/>
                                            <TextBlock Text="&#xE70D;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                                       Foreground="#667085" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                        </StackPanel>
                                    </Button>
                                    <Popup x:Name="BranchPopup"
                                           PlacementTarget="{Binding ElementName=BranchBtn}"
                                           IsOpen="{Binding ProductsVm.IsBranchOpen, Mode=TwoWay}"
                                           Placement="Bottom" StaysOpen="False"
                                           AllowsTransparency="True" PopupAnimation="Fade">
                                        <Border Background="White" BorderBrush="#E2E8F0" BorderThickness="1"
                                                CornerRadius="8" Padding="4" MinWidth="180"
                                                DataContext="{Binding DataContext, ElementName=BranchBtn}">
                                            <Border.Effect>
                                                <DropShadowEffect BlurRadius="16" ShadowDepth="4" Opacity="0.12" Color="#0F172A"/>
                                            </Border.Effect>
                                            <StackPanel>
                                                <Border CornerRadius="6" Background="#EEF2FF" Padding="12,8">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets"
                                                                   FontSize="11" Foreground="#155EEF" Margin="0,0,8,0"
                                                                   VerticalAlignment="Center"/>
                                                        <TextBlock Text="Barcha filiallar" FontSize="13"
                                                                   FontWeight="SemiBold" Foreground="#155EEF"/>
                                                    </StackPanel>
                                                </Border>
                                            </StackPanel>
                                        </Border>
                                    </Popup>
                                </Grid>

                                <!-- Statusi dropdown -->
                                <Grid Margin="0,0,12,0">
                                    <Button x:Name="StatusBtn"
                                            Cursor="Hand" FocusVisualStyle="{x:Null}"
                                            BorderBrush="#D0D5DD" BorderThickness="1"
                                            Background="White" Padding="12,7"
                                            Click="OnStatusBtnClick">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        CornerRadius="8" Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#F9FAFB"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="Statusi: " FontSize="13" Foreground="#667085" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding ProductsVm.SelectedStatus}"
                                                       FontSize="13" FontWeight="SemiBold" Foreground="#344054" VerticalAlignment="Center"/>
                                            <TextBlock Text="&#xE70D;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                                                       Foreground="#667085" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                        </StackPanel>
                                    </Button>
                                    <Popup x:Name="StatusPopup"
                                           PlacementTarget="{Binding ElementName=StatusBtn}"
                                           IsOpen="{Binding ProductsVm.IsStatusOpen, Mode=TwoWay}"
                                           Placement="Bottom" StaysOpen="False"
                                           AllowsTransparency="True" PopupAnimation="Fade">
                                        <Border Background="White" BorderBrush="#E2E8F0" BorderThickness="1"
                                                CornerRadius="8" Padding="4" MinWidth="190"
                                                DataContext="{Binding DataContext, ElementName=StatusBtn}">
                                            <Border.Effect>
                                                <DropShadowEffect BlurRadius="16" ShadowDepth="4" Opacity="0.12" Color="#0F172A"/>
                                            </Border.Effect>
                                            <StackPanel>
                                                <Button Command="{Binding ProductsVm.PickStatusCommand}" CommandParameter="Barchasi"
                                                        Padding="12,9" HorizontalContentAlignment="Left"
                                                        Background="Transparent" BorderThickness="0"
                                                        Cursor="Hand" FocusVisualStyle="{x:Null}" FontSize="13">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border x:Name="Si0" Background="{TemplateBinding Background}" CornerRadius="6"
                                                                    Padding="{TemplateBinding Padding}">
                                                                <DockPanel>
                                                                    <TextBlock DockPanel.Dock="Left" Text="Barchasi" FontSize="13" Foreground="#0F172A" VerticalAlignment="Center"/>
                                                                    <TextBlock DockPanel.Dock="Right" Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                                                               Foreground="#155EEF" HorizontalAlignment="Right" VerticalAlignment="Center">
                                                                        <TextBlock.Style>
                                                                            <Style TargetType="TextBlock">
                                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding ProductsVm.SelectedStatus}" Value="Barchasi">
                                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </TextBlock.Style>
                                                                    </TextBlock>
                                                                </DockPanel>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter Property="Background" Value="#F5F8FF"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>
                                                <Button Command="{Binding ProductsVm.PickStatusCommand}" CommandParameter="Faol"
                                                        Padding="12,9" HorizontalContentAlignment="Left"
                                                        Background="Transparent" BorderThickness="0"
                                                        Cursor="Hand" FocusVisualStyle="{x:Null}" FontSize="13">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border x:Name="Si1" Background="{TemplateBinding Background}" CornerRadius="6"
                                                                    Padding="{TemplateBinding Padding}">
                                                                <DockPanel>
                                                                    <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                                                                        <Ellipse Width="8" Height="8" Fill="#22C55E" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                                        <TextBlock Text="Faol" FontSize="13" Foreground="#0F172A"/>
                                                                    </StackPanel>
                                                                    <TextBlock DockPanel.Dock="Right" Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                                                               Foreground="#155EEF" HorizontalAlignment="Right" VerticalAlignment="Center">
                                                                        <TextBlock.Style>
                                                                            <Style TargetType="TextBlock">
                                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding ProductsVm.SelectedStatus}" Value="Faol">
                                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </TextBlock.Style>
                                                                    </TextBlock>
                                                                </DockPanel>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter Property="Background" Value="#F5F8FF"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>
                                                <Button Command="{Binding ProductsVm.PickStatusCommand}" CommandParameter="Kam qoldiq"
                                                        Padding="12,9" HorizontalContentAlignment="Left"
                                                        Background="Transparent" BorderThickness="0"
                                                        Cursor="Hand" FocusVisualStyle="{x:Null}" FontSize="13">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border x:Name="Si2" Background="{TemplateBinding Background}" CornerRadius="6"
                                                                    Padding="{TemplateBinding Padding}">
                                                                <DockPanel>
                                                                    <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                                                                        <Ellipse Width="8" Height="8" Fill="#F59E0B" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                                        <TextBlock Text="Kam qoldiq" FontSize="13" Foreground="#0F172A"/>
                                                                    </StackPanel>
                                                                    <TextBlock DockPanel.Dock="Right" Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                                                               Foreground="#155EEF" HorizontalAlignment="Right" VerticalAlignment="Center">
                                                                        <TextBlock.Style>
                                                                            <Style TargetType="TextBlock">
                                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding ProductsVm.SelectedStatus}" Value="Kam qoldiq">
                                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </TextBlock.Style>
                                                                    </TextBlock>
                                                                </DockPanel>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter Property="Background" Value="#F5F8FF"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>
                                                <Button Command="{Binding ProductsVm.PickStatusCommand}" CommandParameter="Tugagan"
                                                        Padding="12,9" HorizontalContentAlignment="Left"
                                                        Background="Transparent" BorderThickness="0"
                                                        Cursor="Hand" FocusVisualStyle="{x:Null}" FontSize="13">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border x:Name="Si3" Background="{TemplateBinding Background}" CornerRadius="6"
                                                                    Padding="{TemplateBinding Padding}">
                                                                <DockPanel>
                                                                    <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                                                                        <Ellipse Width="8" Height="8" Fill="#EF4444" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                                        <TextBlock Text="Tugagan" FontSize="13" Foreground="#0F172A"/>
                                                                    </StackPanel>
                                                                    <TextBlock DockPanel.Dock="Right" Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                                                               Foreground="#155EEF" HorizontalAlignment="Right" VerticalAlignment="Center">
                                                                        <TextBlock.Style>
                                                                            <Style TargetType="TextBlock">
                                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding ProductsVm.SelectedStatus}" Value="Tugagan">
                                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </TextBlock.Style>
                                                                    </TextBlock>
                                                                </DockPanel>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter Property="Background" Value="#F5F8FF"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>
                                            </StackPanel>
                                        </Border>
                                    </Popup>
                                </Grid>

                                <!-- View toggle: filter reset | list | grid -->
                                <Border BorderBrush="#D0D5DD" BorderThickness="1" CornerRadius="8" Background="White">
                                    <StackPanel Orientation="Horizontal">
                                        <!-- Reset filters -->
                                        <Button Width="32" Height="32" BorderThickness="0"
                                                Command="{Binding ProductsVm.ResetFiltersCommand}"
                                                Cursor="Hand" FocusVisualStyle="{x:Null}" ToolTip="Filtrlarni tozalash">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="VtA" Background="{TemplateBinding Background}" CornerRadius="7,0,0,7">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="#F3F4F6"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                            <TextBlock Text="&#xEA23;" FontFamily="Segoe MDL2 Assets" FontSize="13" Foreground="#667085"/>
                                        </Button>
                                        <Border Width="1" Background="#D0D5DD"/>
                                        <!-- List view -->
                                        <Button Width="32" Height="32" BorderThickness="0"
                                                Command="{Binding ProductsVm.SetListViewCommand}"
                                                Cursor="Hand" FocusVisualStyle="{x:Null}" ToolTip="Jadval ko'rinishi">
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Background" Value="Transparent"/>
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border x:Name="VtB" Background="{TemplateBinding Background}" CornerRadius="0">
                                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                </Border>
                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter Property="Background" Value="#F3F4F6"/>
                                                                    </Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding ProductsVm.IsGridView}" Value="False">
                                                            <Setter Property="Background" Value="#EEF2FF"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                            <TextBlock Text="&#xE8FD;" FontFamily="Segoe MDL2 Assets" FontSize="13">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="#667085"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding ProductsVm.IsGridView}" Value="False">
                                                                <Setter Property="Foreground" Value="#155EEF"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Button>
                                        <Border Width="1" Background="#D0D5DD"/>
                                        <!-- Grid view -->
                                        <Button Width="32" Height="32" BorderThickness="0"
                                                Command="{Binding ProductsVm.SetGridViewCommand}"
                                                Cursor="Hand" FocusVisualStyle="{x:Null}" ToolTip="Grid ko'rinishi">
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Background" Value="Transparent"/>
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border x:Name="VtC" Background="{TemplateBinding Background}" CornerRadius="0,7,7,0">
                                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                </Border>
                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter Property="Background" Value="#F3F4F6"/>
                                                                    </Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding ProductsVm.IsGridView}" Value="True">
                                                            <Setter Property="Background" Value="#EEF2FF"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                            <TextBlock Text="&#xF0E2;" FontFamily="Segoe MDL2 Assets" FontSize="13">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="#667085"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding ProductsVm.IsGridView}" Value="True">
                                                                <Setter Property="Foreground" Value="#155EEF"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Button>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </DockPanel>
                    </Border>

                    <!-- Category filter pills -->
                    <Border Grid.Row="3" Background="White" Padding="24,10"
                            BorderBrush="#E2E8F0" BorderThickness="0,0,0,1">
                        <ScrollViewer HorizontalScrollBarVisibility="Hidden"
                                      VerticalScrollBarVisibility="Disabled">
                            <ItemsControl ItemsSource="{Binding ProductsVm.CategoryFilters}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Content="{Binding Display}"
                                                Command="{Binding DataContext.ProductsVm.SelectFilterCommand,
                                                          RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Margin="0,0,6,0" Padding="16,7"
                                                Cursor="Hand" FocusVisualStyle="{x:Null}">
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Background"       Value="White"/>
                                                    <Setter Property="Foreground"       Value="#344054"/>
                                                    <Setter Property="BorderBrush"      Value="#D0D5DD"/>
                                                    <Setter Property="BorderThickness"  Value="1.5"/>
                                                    <Setter Property="FontSize"         Value="13"/>
                                                    <Setter Property="FontWeight"       Value="Normal"/>
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border x:Name="PillRoot"
                                                                        RenderTransformOrigin="0.5,0.5"
                                                                        Background="{TemplateBinding Background}"
                                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                                        CornerRadius="20" Padding="{TemplateBinding Padding}">
                                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                                      VerticalAlignment="Center"/>
                                                                </Border>
                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter Property="Background" Value="#F5F8FF"/>
                                                                    </Trigger>
                                                                    <Trigger Property="IsPressed" Value="True">
                                                                        <Setter TargetName="PillRoot" Property="RenderTransform">
                                                                            <Setter.Value>
                                                                                <ScaleTransform ScaleX="0.97" ScaleY="0.97"/>
                                                                            </Setter.Value>
                                                                        </Setter>
                                                                    </Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                            <Setter Property="Background"      Value="#155EEF"/>
                                                            <Setter Property="Foreground"      Value="White"/>
                                                            <Setter Property="BorderBrush"     Value="#155EEF"/>
                                                            <Setter Property="FontWeight"      Value="SemiBold"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>

                    <!-- Table header -->
                    <Border Grid.Row="4" Background="#F8FAFC"
                            BorderBrush="#E2E8F0" BorderThickness="0,0,0,1" Padding="0,10">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ProductsVm.IsGridView}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Grid Margin="24,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="28"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="110"/>
                            </Grid.ColumnDefinitions>
                            <CheckBox Grid.Column="0" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="MAHSULOT"    FontSize="11" FontWeight="SemiBold" Foreground="#667085" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" Text="KATEGORIYA"  FontSize="11" FontWeight="SemiBold" Foreground="#667085" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="3" Text="SOTISH NARXI" FontSize="11" FontWeight="SemiBold" Foreground="#667085" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="4" Text="TANNARX"     FontSize="11" FontWeight="SemiBold" Foreground="#667085" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="5" Text="QOLDIQ"      FontSize="11" FontWeight="SemiBold" Foreground="#667085" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="6" Text="HOLATI"      FontSize="11" FontWeight="SemiBold" Foreground="#667085" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <!-- Table body (list view) -->
                    <ScrollViewer Grid.Row="5"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <ScrollViewer.Style>
                            <Style TargetType="ScrollViewer">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ProductsVm.IsGridView}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ScrollViewer.Style>
                        <ItemsControl ItemsSource="{Binding ProductsVm.FilteredProducts}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#F2F4F7" BorderThickness="0,0,0,1"
                                            Background="White" Padding="0,10">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#F8FAFC"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Grid Margin="24,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="28"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="130"/>
                                                <ColumnDefinition Width="130"/>
                                                <ColumnDefinition Width="110"/>
                                                <ColumnDefinition Width="100"/>
                                                <ColumnDefinition Width="110"/>
                                                <ColumnDefinition Width="110"/>
                                            </Grid.ColumnDefinitions>

                                            <CheckBox Grid.Column="0" VerticalAlignment="Center"/>

                                            <!-- Mahsulot nomi + kodi -->
                                            <StackPanel Grid.Column="1" Orientation="Horizontal"
                                                        VerticalAlignment="Center">
                                                <Border Width="34" Height="34" CornerRadius="8"
                                                        Background="#EEF2FF" Margin="0,0,10,0">
                                                    <TextBlock Text="&#xE7B8;" FontFamily="Segoe MDL2 Assets"
                                                               FontSize="16" Foreground="#155EEF"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"/>
                                                </Border>
                                                <StackPanel VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold"
                                                               FontSize="13" Foreground="#0F172A"/>
                                                    <TextBlock Text="{Binding Code}" FontSize="11"
                                                               Foreground="#94A3B8"/>
                                                </StackPanel>
                                            </StackPanel>

                                            <!-- Kategoriya -->
                                            <TextBlock Grid.Column="2" Text="{Binding CategoryName}"
                                                       Foreground="#155EEF" FontSize="13"
                                                       VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis"/>

                                            <!-- Sotish narxi -->
                                            <StackPanel Grid.Column="3" Orientation="Horizontal"
                                                        VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Price, StringFormat='{}{0:N0}'}"
                                                           FontSize="13" FontWeight="SemiBold" Foreground="#0F172A"/>
                                                <TextBlock Text=" so'm" FontSize="11" Foreground="#64748B"
                                                           Margin="3,2,0,0"/>
                                            </StackPanel>

                                            <!-- Tannarx -->
                                            <StackPanel Grid.Column="4" Orientation="Horizontal"
                                                        VerticalAlignment="Center">
                                                <TextBlock Text="{Binding CostPrice, StringFormat='{}{0:N0}'}"
                                                           FontSize="13" Foreground="#64748B"/>
                                                <TextBlock Text=" so'm" FontSize="11" Foreground="#94A3B8"
                                                           Margin="3,2,0,0"/>
                                            </StackPanel>

                                            <!-- Qoldiq -->
                                            <StackPanel Grid.Column="5" Orientation="Horizontal"
                                                        VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Stock, StringFormat='{}{0:N0}'}"
                                                           FontSize="13" FontWeight="Bold"
                                                           Foreground="{Binding StatusColor,
                                                                        Converter={StaticResource HexToBrushConverter}}"/>
                                                <TextBlock Text="{Binding Unit}" FontSize="11"
                                                           Foreground="#64748B" Margin="4,2,0,0"/>
                                            </StackPanel>

                                            <!-- Holati badge -->
                                            <Border Grid.Column="6"
                                                    CornerRadius="6" Padding="10,4"
                                                    HorizontalAlignment="Left" VerticalAlignment="Center"
                                                    Background="{Binding StatusBg,
                                                                 Converter={StaticResource HexToBrushConverter}}">
                                                <StackPanel Orientation="Horizontal">
                                                    <Ellipse Width="7" Height="7" VerticalAlignment="Center"
                                                             Margin="0,0,5,0"
                                                             Fill="{Binding StatusColor,
                                                                    Converter={StaticResource HexToBrushConverter}}"/>
                                                    <TextBlock Text="{Binding Status}" FontSize="12"
                                                               FontWeight="SemiBold"
                                                               Foreground="{Binding StatusColor,
                                                                            Converter={StaticResource HexToBrushConverter}}"/>
                                                </StackPanel>
                                            </Border>

                                            <!-- Amallar -->
                                            <StackPanel Grid.Column="7" Orientation="Horizontal"
                                                        VerticalAlignment="Center" HorizontalAlignment="Right">
                                                <Button Width="28" Height="28" Margin="0,0,4,0"
                                                        Style="{StaticResource IconButtonStyle}"
                                                        ToolTip="Ko'rish">
                                                    <TextBlock Text="&#xE890;" FontFamily="Segoe MDL2 Assets" FontSize="13"/>
                                                </Button>
                                                <Button Width="28" Height="28" Margin="0,0,4,0"
                                                        Style="{StaticResource IconButtonStyle}"
                                                        ToolTip="Tahrirlash">
                                                    <TextBlock Text="&#xE70F;" FontFamily="Segoe MDL2 Assets" FontSize="13"/>
                                                </Button>
                                                <Button Width="28" Height="28" Margin="0,0,4,0"
                                                        Style="{StaticResource IconButtonStyle}"
                                                        ToolTip="Chop etish">
                                                    <TextBlock Text="&#xE749;" FontFamily="Segoe MDL2 Assets" FontSize="13"/>
                                                </Button>
                                                <Button Width="28" Height="28"
                                                        Style="{StaticResource DeleteRowButtonStyle}"
                                                        ToolTip="O'chirish">
                                                    <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="13"/>
                                                </Button>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- Grid view (card layout) -->
                    <ScrollViewer Grid.Row="5"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Padding="24,16,24,16">
                        <ScrollViewer.Style>
                            <Style TargetType="ScrollViewer">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ProductsVm.IsGridView}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ScrollViewer.Style>
                        <ItemsControl ItemsSource="{Binding ProductsVm.FilteredProducts}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Width="220" Margin="0,0,16,16" CornerRadius="12"
                                            Background="White" BorderBrush="#E2E8F0" BorderThickness="1">
                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.06" Color="#0F172A"/>
                                        </Border.Effect>
                                        <Grid Margin="16">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <!-- Icon + status badge -->
                                            <Grid Grid.Row="0" Margin="0,0,0,12">
                                                <Border Width="44" Height="44" CornerRadius="10"
                                                        Background="#EEF2FF" HorizontalAlignment="Left">
                                                    <TextBlock Text="&#xE7B8;" FontFamily="Segoe MDL2 Assets"
                                                               FontSize="20" Foreground="#155EEF"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <Border HorizontalAlignment="Right" VerticalAlignment="Top"
                                                        CornerRadius="6" Padding="8,3"
                                                        Background="{Binding StatusBg, Converter={StaticResource HexToBrushConverter}}">
                                                    <TextBlock Text="{Binding Status}" FontSize="11" FontWeight="SemiBold"
                                                               Foreground="{Binding StatusColor, Converter={StaticResource HexToBrushConverter}}"/>
                                                </Border>
                                            </Grid>

                                            <!-- Name + category -->
                                            <StackPanel Grid.Row="1" Margin="0,0,0,10">
                                                <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="SemiBold"
                                                           Foreground="#0F172A" TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding CategoryName}" FontSize="12"
                                                           Foreground="#155EEF" Margin="0,2,0,0"
                                                           TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>

                                            <!-- Price + stock -->
                                            <Grid Grid.Row="2" Margin="0,0,0,12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="Narx" FontSize="11" Foreground="#94A3B8"/>
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="{Binding Price, StringFormat='{}{0:N0}'}"
                                                                   FontSize="13" FontWeight="Bold" Foreground="#0F172A"/>
                                                        <TextBlock Text=" so'm" FontSize="10" Foreground="#64748B" Margin="2,2,0,0"/>
                                                    </StackPanel>
                                                </StackPanel>
                                                <StackPanel Grid.Column="1">
                                                    <TextBlock Text="Qoldiq" FontSize="11" Foreground="#94A3B8"/>
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="{Binding Stock, StringFormat='{}{0:N0}'}"
                                                                   FontSize="13" FontWeight="Bold"
                                                                   Foreground="{Binding StatusColor, Converter={StaticResource HexToBrushConverter}}"/>
                                                        <TextBlock Text="{Binding Unit}" FontSize="10" Foreground="#64748B" Margin="3,2,0,0"/>
                                                    </StackPanel>
                                                </StackPanel>
                                            </Grid>

                                            <!-- Actions -->
                                            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
                                                <Button Width="28" Height="28" Margin="0,0,4,0"
                                                        Style="{StaticResource IconButtonStyle}" ToolTip="Ko'rish">
                                                    <TextBlock Text="&#xE890;" FontFamily="Segoe MDL2 Assets" FontSize="13"/>
                                                </Button>
                                                <Button Width="28" Height="28" Margin="0,0,4,0"
                                                        Style="{StaticResource IconButtonStyle}" ToolTip="Tahrirlash">
                                                    <TextBlock Text="&#xE70F;" FontFamily="Segoe MDL2 Assets" FontSize="13"/>
                                                </Button>
                                                <Button Width="28" Height="28"
                                                        Style="{StaticResource DeleteRowButtonStyle}" ToolTip="O'chirish">
                                                    <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="13"/>
                                                </Button>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- Pagination bar -->
                    <Border Grid.Row="6" Background="White"
                            BorderBrush="#E2E8F0" BorderThickness="0,1,0,0"
                            Padding="24,10">
                        <DockPanel LastChildFill="False">
                            <!-- Info text -->
                            <TextBlock DockPanel.Dock="Left" VerticalAlignment="Center"
                                       FontSize="13" Foreground="#667085">
                                <Run Text="Jami "/>
                                <Run Text="{Binding ProductsVm.TotalFiltered, Mode=OneWay}"/>
                                <Run Text=" ta yozuv · "/>
                                <Run Text="{Binding ProductsVm.CurrentPage, Mode=OneWay}"/>
                                <Run Text="-sahifa, "/>
                                <Run Text="{Binding ProductsVm.TotalPages, Mode=OneWay}"/>
                                <Run Text=" dan"/>
                            </TextBlock>
                            <!-- Page buttons -->
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                <!-- Prev -->
                                <Button Width="32" Height="32" Margin="0,0,4,0"
                                        Command="{Binding ProductsVm.PrevPageCommand}"
                                        Cursor="Hand" FocusVisualStyle="{x:Null}">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="PgPrev" Background="White"
                                                    BorderBrush="#D0D5DD" BorderThickness="1"
                                                    CornerRadius="6">
                                                <TextBlock x:Name="PgPrevTxt"
                                                           Text="&#x276E;" FontSize="14"
                                                           Foreground="#344054"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="PgPrev" Property="Background" Value="#F3F4F6"/>
                                                </Trigger>
                                                <Trigger Property="IsEnabled" Value="False">
                                                    <Setter TargetName="PgPrev"    Property="Background"    Value="#F9FAFB"/>
                                                    <Setter TargetName="PgPrevTxt" Property="Foreground"   Value="#D0D5DD"/>
                                                    <Setter TargetName="PgPrev"    Property="BorderBrush"  Value="#E2E8F0"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                                <!-- Current page -->
                                <Border Width="32" Height="32" Margin="0,0,4,0"
                                        Background="#155EEF" CornerRadius="6">
                                    <TextBlock Text="{Binding ProductsVm.CurrentPage, Mode=OneWay}"
                                               FontSize="13" FontWeight="SemiBold"
                                               Foreground="White"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                                <!-- Next -->
                                <Button Width="32" Height="32"
                                        Command="{Binding ProductsVm.NextPageCommand}"
                                        Cursor="Hand" FocusVisualStyle="{x:Null}">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="PgNext" Background="White"
                                                    BorderBrush="#D0D5DD" BorderThickness="1"
                                                    CornerRadius="6">
                                                <TextBlock x:Name="PgNextTxt"
                                                           Text="&#x276F;" FontSize="14"
                                                           Foreground="#344054"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="PgNext" Property="Background" Value="#F3F4F6"/>
                                                </Trigger>
                                                <Trigger Property="IsEnabled" Value="False">
                                                    <Setter TargetName="PgNext"    Property="Background"   Value="#F9FAFB"/>
                                                    <Setter TargetName="PgNextTxt" Property="Foreground"  Value="#D0D5DD"/>
                                                    <Setter TargetName="PgNext"    Property="BorderBrush" Value="#E2E8F0"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </StackPanel>
                        </DockPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
