<UserControl x:Class="PosSystem.Views.Pos.PosView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:PosSystem.ViewModels.Pos"
             xmlns:game="clr-namespace:PosSystem.Views.Game">

    <UserControl.Resources>
        <!-- Quantity +/- button -->
        <Style x:Key="QtyBtnStyle" TargetType="Button">
            <Setter Property="Background" Value="#EEF2F7"/>
            <Setter Property="Foreground" Value="#546E7A"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="24"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4"
                                Padding="0,1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#CFD8DC"/>
                                <Setter Property="Foreground" Value="#263238"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#B0BEC5"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#CFD8DC"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Payment type button: highlights when its CommandParameter matches PaymentType -->
        <Style x:Key="PayTypeBtn" TargetType="Button">
            <Setter Property="Background" Value="#F5F7FA"/>
            <Setter Property="Foreground" Value="#546E7A"/>
            <Setter Property="BorderBrush" Value="#D1D9E6"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#E8EFF8"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#D4E2F4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Value="True">
                    <DataTrigger.Binding>
                        <MultiBinding Converter="{StaticResource EqualityConverter}">
                            <Binding Path="PaymentType"/>
                            <Binding RelativeSource="{RelativeSource Self}" Path="CommandParameter"/>
                        </MultiBinding>
                    </DataTrigger.Binding>
                    <Setter Property="Background"   Value="#1565C0"/>
                    <Setter Property="Foreground"   Value="White"/>
                    <Setter Property="BorderBrush"  Value="#0D47A1"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.LayoutTransform>
            <ScaleTransform ScaleX="{Binding Scale}" ScaleY="{Binding Scale}"/>
        </Grid.LayoutTransform>
        <Grid.RowDefinitions>
            <RowDefinition Height="56"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ═══════════════════ HEADER ═══════════════════ -->
        <Border Grid.Row="0" Background="#0D47A1">
            <DockPanel Margin="16,0" LastChildFill="False">

                <!-- Left: Brand -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="🛒" FontSize="20" Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <TextBlock Text="ShefPos" Foreground="White" FontSize="18"
                               FontWeight="Bold" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Right: Status, settings, user, time, sync, logout -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">

                    <!-- Sync status -->
                    <Border CornerRadius="12" Padding="10,4" Margin="0,0,12,0" Background="#1565C0">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="8" Height="8" VerticalAlignment="Center" Margin="0,0,6,0">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Fill" Value="#69F0AE"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsOnline}" Value="False">
                                                <Setter Property="Fill" Value="#FF8A65"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                            <TextBlock Text="{Binding SyncStatusText}" Foreground="White"
                                       FontSize="12" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Pending sales badge -->
                    <Border CornerRadius="12" Padding="10,4" Margin="0,0,12,0"
                            Background="#FF8F00"
                            Visibility="{Binding PendingSyncCount, Converter={StaticResource IntToVisibilityConverter}}">
                        <TextBlock Foreground="White" FontSize="12">
                            <Run Text="⏳ "/>
                            <Run Text="{Binding PendingSyncCount}"/>
                            <Run Text=" sotuv"/>
                        </TextBlock>
                    </Border>

                    <!-- Manual sync -->
                    <Button Command="{Binding TriggerSyncCommand}"
                            Style="{StaticResource HeaderIconButtonStyle}"
                            ToolTip="Sinxronlash" Content="🔄" Margin="0,0,8,0"/>

                    <!-- Settings button + popup -->
                    <Button x:Name="SettingsBtn"
                            Command="{Binding ToggleSettingsCommand}"
                            Style="{StaticResource HeaderIconButtonStyle}"
                            ToolTip="Sozlamalar" Content="⚙" Margin="0,0,8,0"/>
                    <Popup IsOpen="{Binding IsSettingsOpen, Mode=TwoWay}"
                           PlacementTarget="{Binding ElementName=SettingsBtn}"
                           Placement="Bottom" StaysOpen="False" AllowsTransparency="True"
                           HorizontalOffset="-120">
                        <Border Background="White" CornerRadius="10"
                                BorderBrush="#E0E6F0" BorderThickness="1"
                                Padding="18,16" MinWidth="260">
                            <Border.Effect>
                                <DropShadowEffect ShadowDepth="6" BlurRadius="18" Opacity="0.15" Color="#000"/>
                            </Border.Effect>
                            <StackPanel>
                                <TextBlock Text="Sozlamalar" FontSize="14" FontWeight="Bold"
                                           Foreground="#1A2540" Margin="0,0,0,16"/>
                                <Separator Background="#EEF2F8" Margin="0,0,0,14"/>

                                <!-- Tablet mode toggle -->
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <CheckBox IsChecked="{Binding IsTabletMode}"
                                              Style="{StaticResource ToggleSwitchStyle}">
                                        <TextBlock Text="Planshet rejimi" FontSize="13"
                                                   Foreground="#374151" FontFamily="Segoe UI"/>
                                    </CheckBox>
                                </StackPanel>
                                <TextBlock Text="Klaviatura to'lov uchun chiqadi"
                                           FontSize="11" Foreground="#9AADCA" Margin="54,4,0,0"/>

                                <Separator Background="#EEF2F8" Margin="0,14,0,14"/>

                                <!-- Scale control -->
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="Masshtab" FontSize="13" Foreground="#374151"
                                                   FontFamily="Segoe UI" VerticalAlignment="Center"
                                                   Width="120"/>
                                        <Button Content="−"
                                                Command="{Binding DecreaseScaleCommand}"
                                                Width="30" Height="30" FontSize="18" FontWeight="Bold"
                                                Style="{StaticResource IconButtonStyle}"/>
                                        <TextBlock Width="50" TextAlignment="Center"
                                                   VerticalAlignment="Center" FontSize="13"
                                                   FontWeight="SemiBold" Foreground="#1A2540">
                                            <Run Text="{Binding Scale, Mode=OneWay,
                                                         StringFormat='{}{0:P0}'}"/>
                                        </TextBlock>
                                        <Button Content="+"
                                                Command="{Binding IncreaseScaleCommand}"
                                                Width="30" Height="30" FontSize="18" FontWeight="Bold"
                                                Style="{StaticResource IconButtonStyle}"/>
                                    </StackPanel>
                                    <TextBlock Text="Ekran masshtabini o'zgartiradi"
                                               FontSize="11" Foreground="#9AADCA" Margin="0,4,0,0"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </Popup>

                    <!-- Username -->
                    <TextBlock Foreground="#B3E5FC" FontSize="13" VerticalAlignment="Center"
                               Margin="0,0,16,0">
                        <Run Text="👤 "/>
                        <Run Text="{Binding UserName}"/>
                    </TextBlock>

                    <!-- Clock -->
                    <TextBlock Text="{Binding CurrentTime}" Foreground="White"
                               FontSize="13" VerticalAlignment="Center" Margin="0,0,16,0"
                               FontFamily="Consolas"/>

                    <!-- Game toggle -->
                    <Button Command="{Binding ToggleGameCommand}"
                            Style="{StaticResource HeaderIconButtonStyle}"
                            ToolTip="ShefPuzzle" Content="🎮" Margin="0,0,8,0"/>

                    <!-- Logout -->
                    <Button Command="{Binding LogoutCommand}"
                            Style="{StaticResource DangerButtonStyle}"
                            Content="Chiqish" Padding="14,6" FontSize="13"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ═══════════════════ GAME VIEW ═══════════════════ -->
        <game:GameView Grid.Row="1"
                       DataContext="{Binding Game}"
                       Visibility="{Binding IsGameOpen, Converter={StaticResource BoolToVisibilityConverter}}"/>

        <!-- ═══════════════════ MAIN CONTENT ═══════════════════ -->
        <Grid Grid.Row="1"
              Visibility="{Binding IsGameOpen, Converter={StaticResource InverseBoolToVisibilityConverter}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>    <!-- Products -->
                <ColumnDefinition Width="370"/>  <!-- Cart -->
                <ColumnDefinition Width="270"/>  <!-- Payment -->
            </Grid.ColumnDefinitions>

            <!-- ══════════ COLUMN 0: PRODUCTS ══════════ -->
            <Grid Grid.Column="0" Background="#F0F4F8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Search bar -->
                <Border Grid.Row="0" Background="White" Padding="12,10"
                        BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
                    <Border BorderBrush="#CFD8DC" BorderThickness="1" CornerRadius="8" Background="#FAFAFA">
                        <Grid>
                            <TextBlock Text="🔍" Margin="10,0,0,0" VerticalAlignment="Center"
                                       Foreground="#9E9E9E" FontSize="14"/>
                            <TextBox Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                                     Padding="32,9,10,9" FontSize="14" BorderThickness="0"
                                     Background="Transparent" Style="{StaticResource FlatTextBoxStyle}">
                                <TextBox.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="8"/>
                                    </Style>
                                </TextBox.Resources>
                            </TextBox>
                            <TextBlock Text="Mahsulot qidirish (nomi, kodi, barkod)..."
                                       Foreground="#BDBDBD" FontSize="14"
                                       Margin="36,0,0,0" VerticalAlignment="Center"
                                       IsHitTestVisible="False">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SearchQuery}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </Border>
                </Border>

                <!-- Category tabs -->
                <Border Grid.Row="1" Background="White"
                        BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
                    <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding Categories}" Margin="8,6">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:CategoryViewModel}">
                                    <Button Content="{Binding Name}"
                                            Command="{Binding DataContext.SelectCategoryCommand,
                                                      RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}"
                                            Padding="16,7" Margin="3,0" Cursor="Hand" FontSize="13">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="Foreground" Value="#546E7A"/>
                                                <Setter Property="BorderThickness" Value="0,0,0,3"/>
                                                <Setter Property="BorderBrush" Value="Transparent"/>
                                                <Setter Property="FontWeight" Value="Normal"/>
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border Background="{TemplateBinding Background}"
                                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                                    Padding="{TemplateBinding Padding}">
                                                                <ContentPresenter HorizontalAlignment="Center"
                                                                                  VerticalAlignment="Center"/>
                                                            </Border>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                                <Style.Triggers>
                                                    <DataTrigger Value="True">
                                                        <DataTrigger.Binding>
                                                            <MultiBinding Converter="{StaticResource EqualityConverter}">
                                                                <Binding Path="DataContext.SelectedCategory"
                                                                         RelativeSource="{RelativeSource AncestorType=ItemsControl}"/>
                                                                <Binding Path="."/>
                                                            </MultiBinding>
                                                        </DataTrigger.Binding>
                                                        <Setter Property="BorderBrush" Value="#1565C0"/>
                                                        <Setter Property="Foreground" Value="#1565C0"/>
                                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                                    </DataTrigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#E3F2FD"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>

                <!-- Product grid -->
                <ScrollViewer Grid.Row="2" Padding="12">
                    <Grid>
                        <TextBlock Text="Mahsulotlar topilmadi"
                                   FontSize="15" Foreground="#90A4AE"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Margin="0,60,0,0">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding FilteredProducts.Count}" Value="0">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <ItemsControl ItemsSource="{Binding FilteredProducts}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Width="160" Height="158" Margin="5"
                                            Command="{Binding DataContext.AddToCartCommand,
                                                      RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}"
                                            Style="{StaticResource ProductCardStyle}">
                                        <Grid Width="160" Height="158">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="80"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>

                                            <!-- Image / placeholder -->
                                            <Border Grid.Row="0" CornerRadius="10,10,0,0" ClipToBounds="True">
                                                <Grid>
                                                    <Border Background="#EEF5FF"
                                                            Visibility="{Binding ImageUrl,
                                                                         Converter={StaticResource EmptyStringToVisibilityConverter}}">
                                                        <TextBlock Text="📦" FontSize="30"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"/>
                                                    </Border>
                                                    <Image Stretch="UniformToFill"
                                                           Visibility="{Binding ImageUrl,
                                                                        Converter={StaticResource StringToVisibilityConverter}}"
                                                           Source="{Binding ImageUrl,
                                                                    Converter={StaticResource UrlToBitmapImageConverter}}"/>
                                                </Grid>
                                            </Border>

                                            <!-- Product info -->
                                            <StackPanel Grid.Row="1" Margin="10,6,10,4">
                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold"
                                                           FontSize="12" TextWrapping="Wrap"
                                                           MaxHeight="30" TextTrimming="CharacterEllipsis"
                                                           Margin="0,0,0,2"/>
                                                <TextBlock FontSize="13" FontWeight="Bold"
                                                           Foreground="#1565C0">
                                                    <Run Text="{Binding Price, StringFormat='{}{0:N0}'}"/>
                                                    <Run Text=" so'm" Foreground="#1976D2" FontSize="10"/>
                                                </TextBlock>
                                                <TextBlock FontSize="10" Foreground="#78909C">
                                                    <Run Text="Stok: "/>
                                                    <Run Text="{Binding Stock, StringFormat='{}{0:N1}'}"/>
                                                    <Run Text=" "/>
                                                    <Run Text="{Binding Unit}"/>
                                                </TextBlock>
                                            </StackPanel>
                                        </Grid>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </ScrollViewer>
            </Grid>

            <!-- ══════════ COLUMN 1: CART ══════════ -->
            <Border Grid.Column="1" Background="White"
                    BorderBrush="#E0E0E0" BorderThickness="1,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>  <!-- Customer -->
                        <RowDefinition Height="*"/>     <!-- Items -->
                        <RowDefinition Height="Auto"/>  <!-- Totals -->
                        <RowDefinition Height="Auto"/>  <!-- Clear button -->
                    </Grid.RowDefinitions>

                    <!-- Customer selector -->
                    <Border Grid.Row="0" Padding="12,10"
                            BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="MIJOZ" FontSize="10" FontWeight="Bold"
                                           Foreground="#9E9E9E" Margin="0,0,0,4"/>
                                <TextBlock Text="{Binding SelectedCustomerDisplay}"
                                           FontSize="13" FontWeight="Medium" Foreground="#37474F"
                                           Margin="0,0,0,6">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedCustomerDisplay}"
                                                             Value="Mijoz tanlanmagan">
                                                    <Setter Property="Foreground" Value="#BDBDBD"/>
                                                    <Setter Property="FontStyle" Value="Italic"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>

                                <Grid>
                                    <Border BorderBrush="#CFD8DC" BorderThickness="1" CornerRadius="6"
                                            Background="#FAFAFA">
                                        <TextBox x:Name="CustomerSearchBox"
                                                 Text="{Binding CustomerSearchText, UpdateSourceTrigger=PropertyChanged}"
                                                 Padding="8,6" FontSize="13" BorderThickness="0"
                                                 Background="Transparent"
                                                 Style="{StaticResource FlatTextBoxStyle}"/>
                                    </Border>
                                    <TextBlock Text="Qidirish..." Foreground="#BDBDBD"
                                               FontSize="13" Margin="10,0,0,0"
                                               VerticalAlignment="Center" IsHitTestVisible="False">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding CustomerSearchText}" Value="">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>

                                    <Popup IsOpen="{Binding IsCustomerPopupOpen}"
                                           PlacementTarget="{Binding ElementName=CustomerSearchBox}"
                                           Placement="Bottom" AllowsTransparency="True" StaysOpen="False">
                                        <Border Background="White" BorderBrush="#CFD8DC" BorderThickness="1"
                                                CornerRadius="0,0,8,8" MinWidth="260">
                                            <Border.Effect>
                                                <DropShadowEffect ShadowDepth="4" BlurRadius="10"
                                                                  Opacity="0.15" Color="#000"/>
                                            </Border.Effect>
                                            <ListBox ItemsSource="{Binding CustomerSuggestions}"
                                                     BorderThickness="0" MaxHeight="220"
                                                     Background="Transparent"
                                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                                <ListBox.ItemContainerStyle>
                                                    <Style TargetType="ListBoxItem">
                                                        <Setter Property="Padding" Value="12,8"/>
                                                        <Setter Property="Cursor" Value="Hand"/>
                                                        <EventSetter Event="MouseLeftButtonUp"
                                                                     Handler="OnCustomerItemClick"/>
                                                    </Style>
                                                </ListBox.ItemContainerStyle>
                                                <ListBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <StackPanel>
                                                            <TextBlock Text="{Binding Name}"
                                                                       FontWeight="SemiBold" FontSize="13"/>
                                                            <TextBlock Text="{Binding Phone}"
                                                                       FontSize="11" Foreground="#78909C"/>
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </ListBox.ItemTemplate>
                                            </ListBox>
                                        </Border>
                                    </Popup>
                                </Grid>
                            </StackPanel>

                            <Button Grid.Column="1" Content="✕" VerticalAlignment="Bottom"
                                    Command="{Binding ClearCustomerCommand}"
                                    Style="{StaticResource IconButtonStyle}"
                                    Margin="8,0,0,0" ToolTip="Mijozni o'chirish"/>
                        </Grid>
                    </Border>

                    <!-- Cart items list -->
                    <Grid Grid.Row="1">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                    Visibility="{Binding CartItems.Count,
                                                 Converter={StaticResource IntToVisibilityInverseConverter}}">
                            <TextBlock Text="🛒" FontSize="42" HorizontalAlignment="Center" Opacity="0.3"/>
                            <TextBlock Text="Savat bo'sh" FontSize="14" Foreground="#BDBDBD"
                                       HorizontalAlignment="Center" Margin="0,8,0,0"/>
                        </StackPanel>

                        <ListView ItemsSource="{Binding CartItems}"
                                  BorderThickness="0" Background="Transparent"
                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                  VirtualizingPanel.ScrollUnit="Pixel"
                                  PreviewKeyDown="OnCartKeyDown">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="Mahsulot" Width="130">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel>
                                                    <TextBlock Text="{Binding ProductName}"
                                                               FontWeight="Medium" FontSize="13"
                                                               TextTrimming="CharacterEllipsis" MaxWidth="120"/>
                                                    <TextBlock FontSize="11" Foreground="#9E9E9E">
                                                        <Run Text="{Binding UnitPrice, Mode=OneWay, StringFormat='{}{0:N0}'}"/>
                                                        <Run Text=" so'm"/>
                                                    </TextBlock>
                                                </StackPanel>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>

                                    <GridViewColumn Header="Soni" Width="114">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <Grid Width="106">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="24"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="24"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Button Grid.Column="0" Content="−"
                                                            Command="{Binding DecreaseQuantityCommand}"
                                                            Style="{StaticResource QtyBtnStyle}"/>
                                                    <TextBox Grid.Column="1"
                                                             Text="{Binding Quantity,
                                                             UpdateSourceTrigger=PropertyChanged,
                                                             StringFormat='{}{0:N2}'}"
                                                             TextAlignment="Center"
                                                             FontSize="13" FontWeight="SemiBold"
                                                             Padding="2,3" BorderThickness="0"
                                                             Background="Transparent"
                                                             Style="{StaticResource FlatTextBoxStyle}"/>
                                                    <Button Grid.Column="2" Content="+"
                                                            Command="{Binding IncreaseQuantityCommand}"
                                                            Style="{StaticResource QtyBtnStyle}"/>
                                                </Grid>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>

                                    <GridViewColumn Header="Jami" Width="88">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock FontWeight="Bold" FontSize="13"
                                                           Foreground="#1565C0" TextAlignment="Right">
                                                    <Run Text="{Binding LineTotal, Mode=OneWay, StringFormat='{}{0:N0}'}"/>
                                                </TextBlock>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>

                                    <GridViewColumn Width="30">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button Content="✕" FontSize="11"
                                                        Command="{Binding DataContext.RemoveFromCartCommand,
                                                                  RelativeSource={RelativeSource AncestorType=ListView}}"
                                                        CommandParameter="{Binding}"
                                                        Style="{StaticResource DeleteRowButtonStyle}"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                </GridView>
                            </ListView.View>
                        </ListView>
                    </Grid>

                    <!-- Totals -->
                    <Border Grid.Row="2" Background="#F8FAFC"
                            BorderBrush="#E0E0E0" BorderThickness="0,1,0,1" Padding="14,12">
                        <StackPanel>
                            <Grid Margin="0,0,0,6">
                                <TextBlock Text="Subtotal" Foreground="#78909C" FontSize="13"/>
                                <TextBlock HorizontalAlignment="Right" FontSize="13">
                                    <Run Text="{Binding Subtotal, Mode=OneWay, StringFormat='{}{0:N0}'}"/>
                                    <Run Text=" so'm" Foreground="#9E9E9E"/>
                                </TextBlock>
                            </Grid>

                            <Grid Margin="0,0,0,6">
                                <TextBlock Text="Chegirma" Foreground="#78909C" FontSize="13"
                                           VerticalAlignment="Center"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <TextBox Text="{Binding CartDiscount,
                                             UpdateSourceTrigger=PropertyChanged,
                                             StringFormat='{}{0:N0}'}"
                                             Width="90" TextAlignment="Right"
                                             FontSize="13" Padding="6,3"
                                             Style="{StaticResource FlatTextBoxStyle}"/>
                                    <TextBlock Text=" so'm" Foreground="#9E9E9E"
                                               FontSize="13" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Grid>

                            <Separator Background="#E0E0E0" Margin="0,4"/>

                            <Grid>
                                <TextBlock Text="JAMI" FontSize="16" FontWeight="Bold" Foreground="#1A237E"/>
                                <TextBlock HorizontalAlignment="Right"
                                           FontSize="20" FontWeight="Bold" Foreground="#0D47A1">
                                    <Run Text="{Binding Total, Mode=OneWay, StringFormat='{}{0:N0}'}"/>
                                    <Run Text=" so'm" FontSize="13" Foreground="#1565C0"/>
                                </TextBlock>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Clear cart -->
                    <Border Grid.Row="3" Padding="12,8">
                        <Button Content="🗑  Savatni tozalash"
                                Command="{Binding ClearCartCommand}"
                                Style="{StaticResource OutlineDangerButtonStyle}"
                                Height="34" FontSize="13"/>
                    </Border>
                </Grid>
            </Border>

            <!-- ══════════ COLUMN 2: PAYMENT ══════════ -->
            <Border Grid.Column="2" Background="#FAFBFD"
                    BorderBrush="#E0E0E0" BorderThickness="1,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="14,14,14,14">

                        <!-- Payment type label -->
                        <TextBlock Text="TO'LOV USULI" FontSize="10" FontWeight="Bold"
                                   Foreground="#9E9E9E" Margin="0,0,0,8"/>

                        <!-- Naqt / Karta buttons -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Height="46"
                                    Command="{Binding SelectPaymentTypeCommand}" CommandParameter="cash"
                                    Style="{StaticResource PayTypeBtn}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="💵" FontSize="18" Margin="0,0,6,0"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Text="Naqt" FontSize="14" FontWeight="SemiBold"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Grid.Column="2" Height="46"
                                    Command="{Binding SelectPaymentTypeCommand}" CommandParameter="card"
                                    Style="{StaticResource PayTypeBtn}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="💳" FontSize="18" Margin="0,0,6,0"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Text="Karta" FontSize="14" FontWeight="SemiBold"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </Grid>

                        <!-- Paid amount -->
                        <TextBlock Text="To'lov summasi" FontSize="11" FontWeight="Bold"
                                   Foreground="#9E9E9E" Margin="0,0,0,6"/>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" BorderBrush="#CFD8DC" BorderThickness="1"
                                    CornerRadius="8" Background="White">
                                <TextBox Text="{Binding PaidAmount,
                                         UpdateSourceTrigger=PropertyChanged,
                                         StringFormat='{}{0:N0}'}"
                                         TextAlignment="Right"
                                         FontSize="20" FontWeight="Bold" Padding="10,8"
                                         BorderThickness="0" Background="Transparent"
                                         Style="{StaticResource FlatTextBoxStyle}"/>
                            </Border>
                            <TextBlock Grid.Column="1" Text=" so'm" Foreground="#78909C"
                                       FontSize="13" VerticalAlignment="Center"/>
                        </Grid>

                        <!-- Change -->
                        <Grid Margin="0,0,0,12">
                            <TextBlock Text="Qaytim" FontSize="13" Foreground="#546E7A"
                                       VerticalAlignment="Center"/>
                            <TextBlock HorizontalAlignment="Right" FontSize="15"
                                       FontWeight="SemiBold" VerticalAlignment="Center">
                                <Run Text="{Binding Change, Mode=OneWay, StringFormat='{}{0:N0}'}"/>
                                <Run Text=" so'm"/>
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#2E7D32"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Change,
                                                         Converter={StaticResource IsNegativeConverter}}"
                                                         Value="True">
                                                <Setter Property="Foreground" Value="#C62828"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>

                        <!-- Numeric keypad (tablet mode) -->
                        <Border Visibility="{Binding IsTabletMode,
                                             Converter={StaticResource BoolToVisibilityConverter}}"
                                Margin="0,0,0,12">
                            <StackPanel>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="44"/>
                                        <RowDefinition Height="4"/>
                                        <RowDefinition Height="44"/>
                                        <RowDefinition Height="4"/>
                                        <RowDefinition Height="44"/>
                                        <RowDefinition Height="4"/>
                                        <RowDefinition Height="44"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="4"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="4"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <Button Grid.Row="0" Grid.Column="0" Content="7"
                                            Command="{Binding KeypadInputCommand}" CommandParameter="7"
                                            Style="{StaticResource KeypadButtonStyle}"/>
                                    <Button Grid.Row="0" Grid.Column="2" Content="8"
                                            Command="{Binding KeypadInputCommand}" CommandParameter="8"
                                            Style="{StaticResource KeypadButtonStyle}"/>
                                    <Button Grid.Row="0" Grid.Column="4" Content="9"
                                            Command="{Binding KeypadInputCommand}" CommandParameter="9"
                                            Style="{StaticResource KeypadButtonStyle}"/>

                                    <Button Grid.Row="2" Grid.Column="0" Content="4"
                                            Command="{Binding KeypadInputCommand}" CommandParameter="4"
                                            Style="{StaticResource KeypadButtonStyle}"/>
                                    <Button Grid.Row="2" Grid.Column="2" Content="5"
                                            Command="{Binding KeypadInputCommand}" CommandParameter="5"
                                            Style="{StaticResource KeypadButtonStyle}"/>
                                    <Button Grid.Row="2" Grid.Column="4" Content="6"
                                            Command="{Binding KeypadInputCommand}" CommandParameter="6"
                                            Style="{StaticResource KeypadButtonStyle}"/>

                                    <Button Grid.Row="4" Grid.Column="0" Content="1"
                                            Command="{Binding KeypadInputCommand}" CommandParameter="1"
                                            Style="{StaticResource KeypadButtonStyle}"/>
                                    <Button Grid.Row="4" Grid.Column="2" Content="2"
                                            Command="{Binding KeypadInputCommand}" CommandParameter="2"
                                            Style="{StaticResource KeypadButtonStyle}"/>
                                    <Button Grid.Row="4" Grid.Column="4" Content="3"
                                            Command="{Binding KeypadInputCommand}" CommandParameter="3"
                                            Style="{StaticResource KeypadButtonStyle}"/>

                                    <Button Grid.Row="6" Grid.Column="0" Content="00"
                                            Command="{Binding KeypadInputCommand}" CommandParameter="00"
                                            Style="{StaticResource KeypadButtonStyle}"/>
                                    <Button Grid.Row="6" Grid.Column="2" Content="0"
                                            Command="{Binding KeypadInputCommand}" CommandParameter="0"
                                            Style="{StaticResource KeypadButtonStyle}"/>
                                    <Button Grid.Row="6" Grid.Column="4" Content="⌫"
                                            Command="{Binding KeypadInputCommand}" CommandParameter="⌫"
                                            Style="{StaticResource KeypadButtonStyle}"/>
                                </Grid>

                                <Button Content="C  —  Tozalash" Margin="0,4,0,0" Height="38"
                                        Command="{Binding KeypadInputCommand}" CommandParameter="C"
                                        Style="{StaticResource OutlineDangerButtonStyle}"
                                        FontSize="13" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Border>

                        <!-- SOTISH button -->
                        <Button Command="{Binding CheckoutCommand}"
                                Style="{StaticResource SuccessButtonStyle}"
                                Height="54" FontSize="18" FontWeight="Bold">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="✔  " FontSize="16"/>
                                <TextBlock Text="SOTISH"/>
                            </StackPanel>
                        </Button>

                    </StackPanel>
                </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
