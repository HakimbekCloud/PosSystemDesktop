<Window x:Class="PosSystem.Views.Pos.ShiftReportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:PosSystem.Converters"
        Title="Smena Z-Hisoboti"
        Width="560" Height="680"
        MinWidth="480" MinHeight="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResizeWithGrip"
        Background="#0D47A1"
        FontFamily="Segoe UI Variable Display, Segoe UI">

    <Window.Resources>
        <conv:BoolToVisibilityConverter         x:Key="BoolVis"/>
        <conv:InverseBoolToVisibilityConverter  x:Key="InvBoolVis"/>
        <conv:InverseBoolConverter              x:Key="InvBool"/>
        <conv:StringToVisibilityConverter       x:Key="StrVis"/>

        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="Foreground" Value="#90CAF9"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin"     Value="0,0,0,2"/>
        </Style>

        <Style x:Key="ValueText" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="13"/>
            <Setter Property="Foreground" Value="#E3F2FD"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="BigValue" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="15"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

        <Style x:Key="BoxBorder" TargetType="Border">
            <Setter Property="Background"   Value="#1565C0"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding"      Value="14,10"/>
            <Setter Property="Margin"       Value="0,0,0,10"/>
        </Style>

        <Style x:Key="RowSep" TargetType="Separator">
            <Setter Property="Background" Value="#1E88E5"/>
            <Setter Property="Margin"     Value="0,6"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── Header ─────────────────────────────────────────────────────── -->
        <Border Grid.Row="0" Background="#0A3880" Padding="20,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Smena Z-Hisoboti"
                               FontSize="20" FontWeight="Bold" Foreground="White"/>
                    <TextBlock FontSize="12" Foreground="#90CAF9" Margin="0,3,0,0">
                        <Run Text="Holati: "/>
                        <Run Text="{Binding StatusDisplay}" FontWeight="SemiBold"/>
                    </TextBlock>
                </StackPanel>

                <Border Grid.Column="1" CornerRadius="8" Padding="12,6" VerticalAlignment="Center">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="#FF8F00"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding StatusDisplay}" Value="YOPILGAN">
                                    <Setter Property="Background" Value="#2E7D32"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding StatusDisplay}" Value="OCHIQ">
                                    <Setter Property="Background" Value="#1B5E20"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBlock Text="{Binding StatusDisplay}"
                               Foreground="White" FontWeight="Bold" FontSize="12"/>
                </Border>
            </Grid>
        </Border>

        <!-- ── Body ───────────────────────────────────────────────────────── -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                      Padding="16,12,16,4">
            <StackPanel>

                <!-- Loading indicator -->
                <TextBlock Text="Yuklanmoqda..." Foreground="#90CAF9"
                           FontSize="14" HorizontalAlignment="Center" Margin="0,30"
                           Visibility="{Binding IsLoading, Converter={StaticResource BoolVis}}"/>

                <!-- Error message -->
                <Border Background="#B71C1C" CornerRadius="8" Padding="12,10" Margin="0,0,0,10"
                        Visibility="{Binding ErrorMessage, Converter={StaticResource StrVis}}">
                    <TextBlock Text="{Binding ErrorMessage}" Foreground="White"
                               TextWrapping="Wrap" FontSize="12"/>
                </Border>

                <!-- Report content (hidden while loading) -->
                <StackPanel Visibility="{Binding IsLoading, Converter={StaticResource InvBoolVis}}">

                    <!-- Shift times -->
                    <Border Style="{StaticResource BoxBorder}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                <TextBlock Text="Ochildi" Style="{StaticResource SectionLabel}"/>
                                <TextBlock Text="{Binding OpenedAtDisplay}"
                                           Style="{StaticResource ValueText}" TextWrapping="Wrap"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Yopildi" Style="{StaticResource SectionLabel}"/>
                                <TextBlock Text="{Binding ClosedAtDisplay}"
                                           Style="{StaticResource ValueText}" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Sales summary -->
                    <Border Style="{StaticResource BoxBorder}">
                        <StackPanel>
                            <TextBlock Text="SAVDO" FontSize="12" FontWeight="Bold"
                                       Foreground="#90CAF9" Margin="0,0,0,8"/>

                            <DockPanel Margin="0,2">
                                <TextBlock Text="{Binding OrderCount}"
                                           DockPanel.Dock="Right" Style="{StaticResource BigValue}"/>
                                <TextBlock Text="Zakazlar soni" Style="{StaticResource SectionLabel}"
                                           VerticalAlignment="Center"/>
                            </DockPanel>
                            <Separator Style="{StaticResource RowSep}"/>

                            <DockPanel Margin="0,2">
                                <TextBlock Text="{Binding FormattedCashSales}"
                                           DockPanel.Dock="Right" Style="{StaticResource BigValue}"/>
                                <TextBlock Text="Naqd savdo" Style="{StaticResource SectionLabel}"
                                           VerticalAlignment="Center"/>
                            </DockPanel>

                            <DockPanel Margin="0,2">
                                <TextBlock Text="{Binding FormattedCashback}"
                                           DockPanel.Dock="Right" Style="{StaticResource ValueText}"/>
                                <TextBlock Text="Cashback (-)" Style="{StaticResource SectionLabel}"
                                           VerticalAlignment="Center"/>
                            </DockPanel>

                            <DockPanel Margin="0,2">
                                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                    <TextBlock Text="{Binding FormattedRefund}"
                                               Style="{StaticResource ValueText}" Margin="0,0,6,0"/>
                                    <TextBlock Foreground="#90CAF9" FontSize="11" VerticalAlignment="Center">
                                        <Run Text="x"/><Run Text="{Binding RefundCount}"/>
                                    </TextBlock>
                                </StackPanel>
                                <TextBlock Text="Qaytarish (-)" Style="{StaticResource SectionLabel}"
                                           VerticalAlignment="Center"/>
                            </DockPanel>

                            <DockPanel Margin="0,2">
                                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                    <TextBlock Text="{Binding FormattedDebtPayment}"
                                               Style="{StaticResource ValueText}" Margin="0,0,6,0"/>
                                    <TextBlock Foreground="#90CAF9" FontSize="11" VerticalAlignment="Center">
                                        <Run Text="x"/><Run Text="{Binding DebtPaymentCount}"/>
                                    </TextBlock>
                                </StackPanel>
                                <TextBlock Text="Qarz to'lov (+)" Style="{StaticResource SectionLabel}"
                                           VerticalAlignment="Center"/>
                            </DockPanel>
                        </StackPanel>
                    </Border>

                    <!-- Cash movements -->
                    <Border Style="{StaticResource BoxBorder}">
                        <StackPanel>
                            <TextBlock Text="NAQD HARAKATLAR" FontSize="12" FontWeight="Bold"
                                       Foreground="#90CAF9" Margin="0,0,0,8"/>

                            <DockPanel Margin="0,2">
                                <TextBlock Text="{Binding FormattedOpening}"
                                           DockPanel.Dock="Right" Style="{StaticResource ValueText}"/>
                                <TextBlock Text="Boshlang'ich qoldiq" Style="{StaticResource SectionLabel}"
                                           VerticalAlignment="Center"/>
                            </DockPanel>
                            <Separator Style="{StaticResource RowSep}"/>

                            <DockPanel Margin="0,2">
                                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                    <TextBlock Text="{Binding FormattedCashIn}"
                                               Style="{StaticResource ValueText}" Margin="0,0,6,0"/>
                                    <TextBlock Foreground="#90CAF9" FontSize="11" VerticalAlignment="Center">
                                        <Run Text="x"/><Run Text="{Binding CashInCount}"/>
                                    </TextBlock>
                                </StackPanel>
                                <TextBlock Text="Kirim (+)" Style="{StaticResource SectionLabel}"
                                           VerticalAlignment="Center"/>
                            </DockPanel>

                            <DockPanel Margin="0,2">
                                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                    <TextBlock Text="{Binding FormattedCashOut}"
                                               Style="{StaticResource ValueText}" Margin="0,0,6,0"/>
                                    <TextBlock Foreground="#90CAF9" FontSize="11" VerticalAlignment="Center">
                                        <Run Text="x"/><Run Text="{Binding CashOutCount}"/>
                                    </TextBlock>
                                </StackPanel>
                                <TextBlock Text="Chiqim (-)" Style="{StaticResource SectionLabel}"
                                           VerticalAlignment="Center"/>
                            </DockPanel>
                            <Separator Style="{StaticResource RowSep}"/>

                            <DockPanel Margin="0,2">
                                <TextBlock Text="{Binding FormattedExpected}"
                                           DockPanel.Dock="Right"
                                           Style="{StaticResource BigValue}" Foreground="#69F0AE"/>
                                <TextBlock Text="Kutilayotgan naqd" Style="{StaticResource SectionLabel}"
                                           VerticalAlignment="Center" Foreground="#A5D6A7"/>
                            </DockPanel>
                        </StackPanel>
                    </Border>

                    <!-- Footer / signature block -->
                    <Border Style="{StaticResource BoxBorder}">
                        <StackPanel>
                            <TextBlock Foreground="#90CAF9" FontSize="11" Margin="0,0,0,10">
                                <Run Text="Hisobot vaqti: "/>
                                <Run Text="{Binding GeneratedAt}"/>
                            </TextBlock>
                            <TextBlock Text="Kassir:   ___________________________"
                                       Foreground="#E3F2FD" FontSize="12" Margin="0,0,0,6"/>
                            <TextBlock Text="Menejer:  ___________________________"
                                       Foreground="#E3F2FD" FontSize="12"/>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <!-- ── Footer buttons ─────────────────────────────────────────────── -->
        <Border Grid.Row="2" Background="#0A3880" Padding="16,12">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">

                <Button Command="{Binding PrintReportCommand}"
                        IsEnabled="{Binding IsLoading, Converter={StaticResource InvBool}}"
                        Padding="20,10" Margin="0,0,10,0"
                        FontSize="13" FontWeight="SemiBold" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="PrintRoot" CornerRadius="10"
                                    Padding="{TemplateBinding Padding}"
                                    Background="#1565C0" BorderBrush="#42A5F5" BorderThickness="1">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="PrintRoot" Property="Background" Value="#0D47A1"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="PrintRoot" Property="Opacity" Value="0.5"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#x1F5A8;" FontFamily="Segoe UI Emoji"
                                   FontSize="14" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Chop etish" Foreground="White" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button Click="OnCloseClick" Padding="20,10"
                        FontSize="13" FontWeight="SemiBold" Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="CloseRoot" CornerRadius="10"
                                    Padding="{TemplateBinding Padding}"
                                    Background="#37474F" BorderBrush="#546E7A" BorderThickness="1">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="CloseRoot" Property="Background" Value="#263238"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                    <TextBlock Text="Yopish" Foreground="White" VerticalAlignment="Center"/>
                </Button>

            </StackPanel>
        </Border>
    </Grid>
</Window>
