<UserControl x:Class="PosSystem.Views.Game.GameView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:gvm="clr-namespace:PosSystem.ViewModels.Game">

    <Grid x:Name="RootGrid" Background="#F0F4F8"
          PreviewMouseMove="OnRootMouseMove"
          PreviewMouseUp="OnRootMouseUp">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="300"/>
        </Grid.ColumnDefinitions>

        <!-- ══════════ BOARD AREA ══════════ -->
        <Border Grid.Column="0" Background="#F0F4F8">
            <Grid HorizontalAlignment="Center" VerticalAlignment="Center">

                <!-- Board card -->
                <Border Background="White" CornerRadius="14"
                        BorderBrush="#E0E6F0" BorderThickness="1" Padding="10">
                    <Border.Effect>
                        <DropShadowEffect ShadowDepth="4" BlurRadius="20" Opacity="0.10" Color="#000"/>
                    </Border.Effect>

                    <Grid>
                        <!-- Cells -->
                        <ItemsControl x:Name="BoardPanel" ItemsSource="{Binding Cells}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="9" Rows="9"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type gvm:CellViewModel}">
                                    <Border Width="46" Height="46" Margin="1"
                                            CornerRadius="6"
                                            BorderBrush="#E4EAF2" BorderThickness="1"
                                            Background="{Binding DisplayColor, Converter={StaticResource HexToBrushConverter}}"
                                            Opacity="{Binding DisplayOpacity}">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <!-- Slightly thicker margin on sector edges -->
                                                <Setter Property="Margin" Value="1"/>
                                            </Style>
                                        </Border.Style>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Game-over overlay -->
                        <Border CornerRadius="10" Background="#DDFFFFFF"
                                Visibility="{Binding IsGameOver, Converter={StaticResource BoolToVisibilityConverter}}">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="O'YIN TUGADI" FontSize="22" FontWeight="Bold"
                                           Foreground="#1A2540" HorizontalAlignment="Center"
                                           Margin="0,0,0,12"/>
                                <TextBlock HorizontalAlignment="Center" FontSize="32"
                                           FontWeight="Bold" Foreground="#0D47A1" Margin="0,0,0,6">
                                    <Run Text="{Binding Score, StringFormat='{}{0:N0}'}"/>
                                </TextBlock>
                                <TextBlock HorizontalAlignment="Center" FontSize="13"
                                           Foreground="#78909C" Margin="0,0,0,24">
                                    <Run Text="Rekord: "/>
                                    <Run Text="{Binding BestScore, StringFormat='{}{0:N0}'}"/>
                                </TextBlock>
                                <Button Content="  Qayta boshlash  "
                                        Command="{Binding NewGameCommand}"
                                        Style="{StaticResource PrimaryButtonStyle}"
                                        Height="42" FontSize="15" Padding="24,0"
                                        HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- ══════════ SIDE PANEL ══════════ -->
        <Border Grid.Column="1" Background="White"
                BorderBrush="#E0E0E0" BorderThickness="1,0,0,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="16,16,16,16">

                    <!-- ── Game title ── -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <TextBlock Text="🎮" FontSize="20" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <StackPanel>
                            <TextBlock Text="ShefPuzzle" FontSize="16" FontWeight="Bold"
                                       Foreground="#1A2540"/>
                            <TextBlock FontSize="11" Foreground="#9AADCA">
                                <Run Text="Daraja "/>
                                <Run Text="{Binding Level}"/>
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>

                    <!-- ── Score card ── -->
                    <Border Background="#F8FAFC" CornerRadius="10"
                            BorderBrush="#E0E6F0" BorderThickness="1"
                            Padding="14,12" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="NATIJA" FontSize="10" FontWeight="Bold"
                                       Foreground="#9E9E9E" Margin="0,0,0,4"/>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock FontSize="28" FontWeight="Bold" Foreground="#0D47A1">
                                    <Run Text="{Binding Score, StringFormat='{}{0:N0}'}"/>
                                </TextBlock>
                                <TextBlock Text="{Binding LastGain}" FontSize="12"
                                           Foreground="#2E7D32" FontWeight="SemiBold"
                                           VerticalAlignment="Center" Margin="8,4,0,0"
                                           Visibility="{Binding LastGain, Converter={StaticResource StringToVisibilityConverter}}"/>
                            </StackPanel>

                            <Separator Background="#E8ECF4" Margin="0,8"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                    <TextBlock Text="REKORD" FontSize="9" FontWeight="Bold"
                                               Foreground="#9E9E9E" HorizontalAlignment="Center"/>
                                    <TextBlock FontSize="14" FontWeight="Bold"
                                               Foreground="#546E7A" HorizontalAlignment="Center">
                                        <Run Text="{Binding BestScore, StringFormat='{}{0:N0}'}"/>
                                    </TextBlock>
                                </StackPanel>

                                <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                    <TextBlock Text="QATORLAR" FontSize="9" FontWeight="Bold"
                                               Foreground="#9E9E9E" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding LinesCleared}" FontSize="14"
                                               FontWeight="Bold" Foreground="#546E7A"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>

                                <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                    <TextBlock Text="FIGURALAR" FontSize="9" FontWeight="Bold"
                                               Foreground="#9E9E9E" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding PiecesPlaced}" FontSize="14"
                                               FontWeight="Bold" Foreground="#546E7A"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- ── Next pieces ── -->
                    <TextBlock Text="KEYINGI FIGURALAR" FontSize="10" FontWeight="Bold"
                               Foreground="#9E9E9E" Margin="0,0,0,10"/>

                    <ItemsControl ItemsSource="{Binding NextPieces}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type gvm:PieceViewModel}">
                                <Border Margin="0,0,0,8" CornerRadius="10"
                                        BorderBrush="#E0E6F0" BorderThickness="1"
                                        Padding="12,10" Cursor="Hand"
                                        PreviewMouseDown="OnPieceMouseDown">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#F8FAFC"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsUsed}" Value="True">
                                                    <Setter Property="Opacity" Value="0.3"/>
                                                    <Setter Property="Cursor" Value="Arrow"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsDragging}" Value="True">
                                                    <Setter Property="Opacity" Value="0.2"/>
                                                </DataTrigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#EEF5FF"/>
                                                    <Setter Property="BorderBrush" Value="#1565C0"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>

                                    <!-- Piece shape rendered row by row -->
                                    <ItemsControl ItemsSource="{Binding Rows}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Vertical"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <ItemsControl ItemsSource="{Binding}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <StackPanel Orientation="Horizontal"/>
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate DataType="{x:Type gvm:PreviewCell}">
                                                            <Border Width="22" Height="22" Margin="1" CornerRadius="4">
                                                                <Border.Style>
                                                                    <Style TargetType="Border">
                                                                        <Setter Property="Background" Value="Transparent"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsFilled}" Value="True">
                                                                                <Setter Property="Background"
                                                                                        Value="{Binding Color, Converter={StaticResource HexToBrushConverter}}"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Border.Style>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- ── Controls ── -->
                    <Separator Background="#EEF2F8" Margin="0,4,0,12"/>

                    <Button Content="🔄  Yangi o'yin"
                            Command="{Binding NewGameCommand}"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Height="40" FontSize="13" Margin="0,0,0,8"/>

                    <StackPanel Orientation="Horizontal">
                        <CheckBox IsChecked="{Binding IsSoundEnabled}"
                                  Style="{StaticResource ToggleSwitchStyle}">
                            <TextBlock Text="Tovush" FontSize="12" Foreground="#546E7A"
                                       FontFamily="Segoe UI"/>
                        </CheckBox>
                    </StackPanel>

                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- ══════════ DRAG FLOAT CANVAS ══════════ -->
        <Canvas x:Name="FloatCanvas" Grid.ColumnSpan="2"
                IsHitTestVisible="False"/>
    </Grid>
</UserControl>
