<!--
  ShefPos Admin v1 — Colors & Surfaces
  Mirrors the styles-wpf.css :root variables exactly (the v1 sheet,
  not v2). Topbar is the heavier #0849A8 brand-700 here.
-->
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ── Brand ── -->
    <SolidColorBrush x:Key="Brand25"  Color="#F6FAFF"/>
    <SolidColorBrush x:Key="Brand50"  Color="#EEF6FF"/>
    <SolidColorBrush x:Key="Brand100" Color="#D9EAFF"/>
    <SolidColorBrush x:Key="Brand200" Color="#B8D8FF"/>
    <SolidColorBrush x:Key="Brand300" Color="#86BEFF"/>
    <SolidColorBrush x:Key="Brand400" Color="#4D9BFF"/>
    <SolidColorBrush x:Key="Brand500" Color="#155EEF"/>
    <SolidColorBrush x:Key="Brand600" Color="#0B5BD3"/>
    <SolidColorBrush x:Key="Brand700" Color="#0849A8"/>
    <SolidColorBrush x:Key="Brand800" Color="#0A3A8C"/>
    <SolidColorBrush x:Key="Brand900" Color="#0B2B66"/>

    <!-- ── Neutral ── -->
    <SolidColorBrush x:Key="N0"   Color="#FFFFFF"/>
    <SolidColorBrush x:Key="N25"  Color="#FCFCFD"/>
    <SolidColorBrush x:Key="N50"  Color="#F8FAFC"/>
    <SolidColorBrush x:Key="N100" Color="#F1F5F9"/>
    <SolidColorBrush x:Key="N200" Color="#E2E8F0"/>
    <SolidColorBrush x:Key="N300" Color="#CBD5E1"/>
    <SolidColorBrush x:Key="N400" Color="#94A3B8"/>
    <SolidColorBrush x:Key="N500" Color="#64748B"/>
    <SolidColorBrush x:Key="N600" Color="#475569"/>
    <SolidColorBrush x:Key="N700" Color="#334155"/>
    <SolidColorBrush x:Key="N800" Color="#1E293B"/>
    <SolidColorBrush x:Key="N900" Color="#0F172A"/>

    <!-- ── Semantic ── -->
    <SolidColorBrush x:Key="Success50"  Color="#ECFDF3"/>
    <SolidColorBrush x:Key="Success100" Color="#DCFCE7"/>
    <SolidColorBrush x:Key="Success500" Color="#22C55E"/>
    <SolidColorBrush x:Key="Success600" Color="#16A34A"/>
    <SolidColorBrush x:Key="Success700" Color="#15803D"/>

    <SolidColorBrush x:Key="Warning50"  Color="#FFFAEB"/>
    <SolidColorBrush x:Key="Warning100" Color="#FEF3C7"/>
    <SolidColorBrush x:Key="Warning500" Color="#F59E0B"/>
    <SolidColorBrush x:Key="Warning600" Color="#D97706"/>

    <SolidColorBrush x:Key="Danger50"  Color="#FEF2F2"/>
    <SolidColorBrush x:Key="Danger100" Color="#FEE2E2"/>
    <SolidColorBrush x:Key="Danger500" Color="#EF4444"/>
    <SolidColorBrush x:Key="Danger600" Color="#DC2626"/>
    <SolidColorBrush x:Key="Danger700" Color="#B91C1C"/>

    <SolidColorBrush x:Key="Info50"  Color="#EFF6FF"/>
    <SolidColorBrush x:Key="Info100" Color="#DBEAFE"/>
    <SolidColorBrush x:Key="Info500" Color="#3B82F6"/>
    <SolidColorBrush x:Key="Info600" Color="#2563EB"/>

    <!-- ── Surfaces (semantic) ── -->
    <SolidColorBrush x:Key="AppSurface"     Color="#F3F3F3"/>
    <SolidColorBrush x:Key="Surface1"       Color="#FFFFFF"/>
    <SolidColorBrush x:Key="SurfaceMuted"   Color="#FAFAFA"/>
    <SolidColorBrush x:Key="BorderSubtle"   Color="#E5E5E5"/>
    <SolidColorBrush x:Key="BorderStrong"   Color="#D1D1D1"/>

    <!-- ── Topbar (solid brand-700, no gradient in v1) ── -->
    <SolidColorBrush x:Key="TopbarBg"            Color="#0849A8"/>
    <SolidColorBrush x:Key="TopbarBorderBottom"  Color="#0A3A8C"/>
    <SolidColorBrush x:Key="TopbarPillBg"        Color="#FFFFFF" Opacity="0.14"/>
    <SolidColorBrush x:Key="TopbarPillBorder"    Color="#FFFFFF" Opacity="0.18"/>
    <SolidColorBrush x:Key="TopbarPillHover"     Color="#FFFFFF" Opacity="0.20"/>
    <SolidColorBrush x:Key="TopbarTextMuted"     Color="#D9EAFF"/>

    <!-- ── Avatar tints ── -->
    <SolidColorBrush x:Key="Avatar0Bg" Color="#DCE9FF"/><SolidColorBrush x:Key="Avatar0Fg" Color="#0849A8"/>
    <SolidColorBrush x:Key="Avatar1Bg" Color="#FCE7E5"/><SolidColorBrush x:Key="Avatar1Fg" Color="#B91C1C"/>
    <SolidColorBrush x:Key="Avatar2Bg" Color="#DCFCE7"/><SolidColorBrush x:Key="Avatar2Fg" Color="#15803D"/>
    <SolidColorBrush x:Key="Avatar3Bg" Color="#FEF3C7"/><SolidColorBrush x:Key="Avatar3Fg" Color="#92400E"/>
    <SolidColorBrush x:Key="Avatar4Bg" Color="#E0E7FF"/><SolidColorBrush x:Key="Avatar4Fg" Color="#3730A3"/>
    <SolidColorBrush x:Key="Avatar5Bg" Color="#FCE7F3"/><SolidColorBrush x:Key="Avatar5Fg" Color="#9D174D"/>
    <SolidColorBrush x:Key="Avatar6Bg" Color="#CFFAFE"/><SolidColorBrush x:Key="Avatar6Fg" Color="#155E75"/>

</ResourceDictionary>
