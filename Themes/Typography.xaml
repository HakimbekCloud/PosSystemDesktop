<!--
  ShefPos design system — Typography & shared text styles.
  Segoe UI Variable is the Windows 11 native font; falls back gracefully.
-->
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Font families -->
    <FontFamily x:Key="UiFont">Segoe UI Variable Text, Segoe UI, system-ui</FontFamily>
    <FontFamily x:Key="UiFontDisplay">Segoe UI Variable Display, Segoe UI, system-ui</FontFamily>
    <FontFamily x:Key="UiFontMono">Cascadia Mono, Consolas, monospace</FontFamily>
    <FontFamily x:Key="FluentIcons">Segoe Fluent Icons, Segoe MDL2 Assets</FontFamily>

    <!-- ── Page title (page-head h1) ── -->
    <Style x:Key="PageTitleText" TargetType="TextBlock">
        <Setter Property="FontFamily"   Value="{StaticResource UiFontDisplay}"/>
        <Setter Property="FontSize"     Value="18"/>
        <Setter Property="FontWeight"   Value="SemiBold"/>
        <Setter Property="Foreground"   Value="{StaticResource N900}"/>
        <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
    </Style>

    <Style x:Key="PageSubtitleText" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource UiFont}"/>
        <Setter Property="FontSize"   Value="12"/>
        <Setter Property="Foreground" Value="{StaticResource N500}"/>
    </Style>

    <Style x:Key="CrumbText" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource UiFont}"/>
        <Setter Property="FontSize"   Value="11"/>
        <Setter Property="Foreground" Value="{StaticResource N500}"/>
    </Style>

    <Style x:Key="SectionHeaderText" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource UiFontDisplay}"/>
        <Setter Property="FontSize"   Value="13"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource N900}"/>
    </Style>

    <Style x:Key="CardTitleText" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource UiFont}"/>
        <Setter Property="FontSize"   Value="13"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource N900}"/>
    </Style>

    <Style x:Key="CardSubText" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource UiFont}"/>
        <Setter Property="FontSize"   Value="11"/>
        <Setter Property="Foreground" Value="{StaticResource N500}"/>
    </Style>

    <Style x:Key="LabelText" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource UiFont}"/>
        <Setter Property="FontSize"   Value="13"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource N800}"/>
    </Style>

    <Style x:Key="HintText" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource UiFont}"/>
        <Setter Property="FontSize"   Value="11"/>
        <Setter Property="Foreground" Value="{StaticResource N500}"/>
    </Style>

    <Style x:Key="BodyText" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource UiFont}"/>
        <Setter Property="FontSize"   Value="13"/>
        <Setter Property="Foreground" Value="{StaticResource N800}"/>
    </Style>

    <Style x:Key="MutedText" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource UiFont}"/>
        <Setter Property="FontSize"   Value="12"/>
        <Setter Property="Foreground" Value="{StaticResource N500}"/>
    </Style>

    <Style x:Key="MonoText" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource UiFontMono}"/>
        <Setter Property="FontSize"   Value="12"/>
        <Setter Property="Foreground" Value="{StaticResource N700}"/>
    </Style>

    <!-- KPI / stat block typography -->
    <Style x:Key="StatLabelText" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource UiFont}"/>
        <Setter Property="FontSize"   Value="11"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource N500}"/>
    </Style>
    <Style x:Key="StatValueText" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource UiFontDisplay}"/>
        <Setter Property="FontSize"   Value="22"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource N900}"/>
    </Style>
    <Style x:Key="StatUnitText" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource UiFont}"/>
        <Setter Property="FontSize"   Value="12"/>
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="Foreground" Value="{StaticResource N400}"/>
    </Style>

    <!-- Section labels (uppercase) -->
    <Style x:Key="UppercaseLabelText" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource UiFont}"/>
        <Setter Property="FontSize"   Value="10"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="{StaticResource N500}"/>
        <!-- Uppercase via Typography is not native in WPF; rely on consumers to write text in caps. -->
    </Style>

    <!-- Fluent icon glyph -->
    <Style x:Key="FluentIconText" TargetType="TextBlock">
        <Setter Property="FontFamily"        Value="{StaticResource FluentIcons}"/>
        <Setter Property="FontSize"          Value="14"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
    </Style>

</ResourceDictionary>
