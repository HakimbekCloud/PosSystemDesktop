<!--
  ShefPos Admin v1 — Typography
  Segoe UI Variable, slightly looser scale than v2 (14px body).
-->
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <FontFamily x:Key="UiFont">Segoe UI Variable Text, Segoe UI, system-ui</FontFamily>
    <FontFamily x:Key="UiFontDisplay">Segoe UI Variable Display, Segoe UI, system-ui</FontFamily>
    <FontFamily x:Key="UiFontMono">Cascadia Mono, Consolas, monospace</FontFamily>
    <!-- Use Segoe MDL2 Assets as the primary icon font: it ships with every
         Windows 10+ install and contains all codepoints used in this admin.
         Segoe Fluent Icons (Win11 only) is listed as a graceful upgrade. -->
    <FontFamily x:Key="FluentIcons">Segoe MDL2 Assets, Segoe Fluent Icons</FontFamily>

    <!-- Page-head title h1: 20px SemiBold -->
    <Style x:Key="PageTitleText" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource UiFontDisplay}"/>
        <Setter Property="FontSize"   Value="20"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource N900}"/>
    </Style>
    <Style x:Key="PageSubText" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource UiFont}"/>
        <Setter Property="FontSize"   Value="12"/>
        <Setter Property="Foreground" Value="{StaticResource N500}"/>
    </Style>

    <!-- Card / section titles -->
    <Style x:Key="CardTitleText" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource UiFont}"/>
        <Setter Property="FontSize"   Value="14"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource N900}"/>
    </Style>
    <Style x:Key="CardSubText" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource UiFont}"/>
        <Setter Property="FontSize"   Value="12"/>
        <Setter Property="Foreground" Value="{StaticResource N500}"/>
    </Style>

    <!-- Body / muted / mono -->
    <Style x:Key="BodyText" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource UiFont}"/>
        <Setter Property="FontSize"   Value="14"/>
        <Setter Property="Foreground" Value="{StaticResource N800}"/>
    </Style>
    <Style x:Key="MutedText" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource UiFont}"/>
        <Setter Property="FontSize"   Value="12"/>
        <Setter Property="Foreground" Value="{StaticResource N500}"/>
    </Style>
    <Style x:Key="HintText" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource UiFont}"/>
        <Setter Property="FontSize"   Value="11"/>
        <Setter Property="Foreground" Value="{StaticResource N500}"/>
    </Style>
    <Style x:Key="MonoText" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource UiFontMono}"/>
        <Setter Property="FontSize"   Value="12"/>
        <Setter Property="Foreground" Value="{StaticResource N700}"/>
    </Style>

    <!-- KPI stat block -->
    <Style x:Key="StatLabelText" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource UiFont}"/>
        <Setter Property="FontSize"   Value="11"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource N500}"/>
    </Style>
    <Style x:Key="StatValueText" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource UiFontDisplay}"/>
        <Setter Property="FontSize"   Value="22"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource N900}"/>
    </Style>
    <Style x:Key="StatUnitText" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource UiFont}"/>
        <Setter Property="FontSize"   Value="12"/>
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="Foreground" Value="{StaticResource N400}"/>
    </Style>
    <Style x:Key="StatDeltaText" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource UiFont}"/>
        <Setter Property="FontSize"   Value="11"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <!-- Fluent icon glyph host -->
    <Style x:Key="FluentIconText" TargetType="TextBlock">
        <Setter Property="FontFamily"          Value="{StaticResource FluentIcons}"/>
        <Setter Property="FontSize"            Value="16"/>
        <Setter Property="VerticalAlignment"   Value="Center"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
    </Style>

</ResourceDictionary>
